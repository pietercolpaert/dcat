_:b0__44024 <http://www.w3.org/ns/dcat#endDate> "2025-12-31"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#startDate> "2018-01-01"^^<http://www.w3.org/2001/XMLSchema#date>;

<feed> <https://w3id.org/tree#member> <#0c9151e3c9d8ea5497597c68cb632863>.
<#0c9151e3c9d8ea5497597c68cb632863> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <https://oppnadata.skane.se/store/34/resource/5>;
    <https://www.w3.org/ns/activitystreams#published> "2026-05-14T07:01:21.969Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#0c9151e3c9d8ea5497597c68cb632863> {
<https://oppnadata.skane.se/store/34/resource/5> <http://www.w3.org/ns/dcat#keyword> "Cykel"@sv, "Leder"@sv, "Natur"@sv, "Toalett"@sv, "Cykling"@sv, "Biking"@en, "vattenpost"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/IRREG>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2321000255>;
    <http://purl.org/dc/terms/description> "Datamängden omfattar ledsträckning och skyltar för rekreativa cykelleder för vilka Region Skåne är huvudman. Leder som omfattas är Cykelleden Skåne, Sydkustleden och Sydostleden.\n\nSkyltar är representerade som punktobjekt. Datamängden omfattar skyltar längs Cykelleden Skåne, Sydkustleden och Sydostleden, och är en bearbetning av material som skapades i samband med ledernas tillkomst. \n\nData för skyltar är ofullständig: data saknas för Malmö kommun. Datamängden uppdateras löpande, främst utifrån uppgifter från respektive kommun som har del av cykellederna. \n\nData för rekreativa cykelleder (ledsträckning) tillhandahålls även av Trafikverket genom dataprodukten Turismcykelled i Nationella vägdatabasen, NVDB. I den datamängden ingår rekreativa cykelleder, men datamängdernas detaljeringsgrad och informationsmodell skiljer sig något åt."@sv;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/3337385>;
    <http://schema.org/diagram> <https://oppnadata.skane.se/store/34/resource/83>;
    <http://www.w3.org/ns/dcat#contactPoint> <https://oppnadata.skane.se/store/34/resource/53>, <https://oppnadata.skane.se/store/34/resource/54>, <https://oppnadata.skane.se/store/34/resource/55>, <https://oppnadata.skane.se/store/34/resource/63>;
    <http://www.w3.org/ns/dcat#distribution> <https://oppnadata.skane.se/store/34/resource/6>, <https://oppnadata.skane.se/store/34/resource/7>, <https://oppnadata.skane.se/store/34/resource/65>, <https://oppnadata.skane.se/store/34/resource/80>, <https://oppnadata.skane.se/store/34/resource/81>, <https://oppnadata.skane.se/store/34/resource/82>;
    <http://purl.org/dc/terms/issued> "2025-08-13"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#landingPage> <https://utveckling.skane.se/regional-utveckling/verksamhetsomraden/natur-och-rekreation/cykelleder/>, <https://uteiskane.se/>;
    <http://purl.org/dc/terms/title> "Rekreativa cykelleder i Skåne"@sv, "Biking trails in Skåne"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/EDUC>, <http://publications.europa.eu/resource/authority/data-theme/TRAN>;
    a <http://www.w3.org/ns/dcat#Dataset>
}


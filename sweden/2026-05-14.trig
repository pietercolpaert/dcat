<#f8c0bdcb0afa7d2f44847d5eaf86f5ef> {
<https://opendata.umea.se/api/v2/catalog/datasets/moebler-som-foervaltas-av-gator-och-parker-umea-kommun> <http://www.w3.org/ns/dcat#keyword> "Umeå kommun", "Möbler"@sv, "Bänk"@sv, "Bord"@sv, "Soffa"@sv, "Parksoffa"@sv, "Hammock"@sv, "Picknickbord"@sv, "Stol"@sv;

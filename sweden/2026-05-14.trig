<#3741a2386a2e3b287eaea81a02e55468> {
<https://opendata-catalog.smhi.se/md/2ef48b70-7d1f-11ed-a51b-432755aaeed3> <http://www.w3.org/ns/dcat#keyword> "Öppna data"@sv, "Hydrologi"@sv, "Observation"@sv, "Vattenstånd"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/IRREG>;
    <http://purl.org/dc/terms/identifier> "_2ef48b70-7d1f-11ed-a51b-432755aaeed3";

<#d05ff34ea4ad3ac5cf421b9f62c982e2> {
<https://opendata-catalog.smhi.se/md/4a3b003b-f886-4225-b940-a6e498ac2187> <http://www.w3.org/ns/dcat#keyword> "Öppna data"@sv, "Hydrologi"@sv, "Observation"@sv, "Vattenföring"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/IRREG>;
    <http://purl.org/dc/terms/identifier> "_4a3b003b-f886-4225-b940-a6e498ac2187";

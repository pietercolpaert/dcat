<https://doi.org/10.5878/nsbw-2102> <http://www.w3.org/ns/dcat#keyword> "TAXATION"@en, "BESKATTNING"@sv, "FISCAL POLICY"@en, "SKATTEPOLITIK"@sv, "ECONOMIC HISTORY"@en, "EKONOMISK HISTORIA"@sv;

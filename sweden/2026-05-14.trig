<https://kungsbacka.entryscape.net/store/1/resource/57> <http://www.w3.org/ns/dcat#keyword> "grillplats"@sv, "grillplatser"@sv, "barbecue area"@en, "barbecue areas"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2120001256>;
    <http://purl.org/dc/terms/description> "Datamängden grillplatser (barbecue areas på engelska) omfattar grillplatser på allmän plats utomhus som är fria att användas för allmänheten, oftast året om och kostnadsfritt. Vid grillplatserna finns oftast bänkar, vindskydd och annan funktionalitet f��r en bra upplevelse. Datamängden innehåller information om t.ex. namn, plats, kontaktinformation med mera. Det kan även finnas kompletterande information om vilka egenskaper som finns vid grillplatsen. Exempelvis vatten för att släcka en eld."@sv, "The dataset includes barbecue areas in public places outdoors that are free to use for the public, usually all year round and free of charge. At the barbecue area there is often benches, wind guard and other equipment for a pleasant experience. The dataset contains information about e.g. name, location, contact information and more. There may also be additional information about which characteristics that are available at the barbecue area. Water for putting out the fire or something else."@en;
    <http://schema.org/diagram> <https://kungsbacka.entryscape.net/store/1/resource/77>;
    <http://www.w3.org/ns/dcat#contactPoint> <https://kungsbacka.entryscape.net/store/1/resource/27>, <https://kungsbacka.entryscape.net/store/1/resource/30>;
    <http://www.w3.org/ns/dcat#distribution> <https://kungsbacka.entryscape.net/store/1/resource/59>, <https://kungsbacka.entryscape.net/store/1/resource/197>;
    <http://purl.org/dc/terms/title> "Grillplatser i Kungsbacka kommun"@sv, "Barbecue areas in Kungsbacka municipality"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/SOCI>, <http://publications.europa.eu/resource/authority/data-theme/ENVI>;
    <http://entryscape.com/terms/basedOn> <https://assets.entryscape.com/store/13/resource/143>;
    <http://purl.org/dc/terms/conformsTo> <https://dataportal.se/specifications/grillplatser/1.0>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


    <http://purl.org/dc/terms/modified> "2026-05-13T17:35:41.574409"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Busshållplatser"@sv, "Bus stops"@en, "Busstoppesteder"@da;

<#e435f2b0bb714e9dcb8a636c0161d848> {
<http://api.kolada.se/v3/kpi/N00522> <http://www.w3.org/ns/dcat#keyword> "Kommun"@sv, "Region"@sv, "Rådet för främjande av kommunala analyser - Kolada";

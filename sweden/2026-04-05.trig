<feed> <https://w3id.org/tree#member> <#31e3d75c94d8a4e8cdfb73c3e48fe702>.
<#31e3d75c94d8a4e8cdfb73c3e48fe702> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <https://www.geodata.se/resources/ba11f37e-f69c-4a90-adf7-dfec1a924b02>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-05T06:27:23.927Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#31e3d75c94d8a4e8cdfb73c3e48fe702> {
<https://www.geodata.se/resources/ba11f37e-f69c-4a90-adf7-dfec1a924b02> <http://www.w3.org/ns/dcat#keyword> "Geodatasamverkan"@sv;
    <http://purl.org/dc/terms/identifier> "ba11f37e-f69c-4a90-adf7-dfec1a924b02";
    <http://www.w3.org/ns/dcat#endpointURL> <https://www.lantmateriet.se/sv/Kartor-och-geografisk-information/geodataprodukter/produktlista/fastighetsavisering/>;
    <http://purl.org/dc/terms/type> <http://www.wikidata.org/entity/Q749568>;
    <http://purl.org/dc/terms/title> "Fastighetsavisering"@sv;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021004888>;
    <http://purl.org/dc/terms/description> "Fastighetsavisering finns i två varianter, fullständig och förenklad.\n\nFastighetsavisering Fullständig bevakar och aviserar förändringar utifrån ett geografiskt omr��de (kommun, län, riket) och/eller en viss bestämd stock av fastigheter. Informationen levereras enligt överföringsformatet (ÖFF) som textfiler Genom aviseringen får du tillgång till de förändringar som sker i allmänna-, adress-, inskrivnings-, byggnadsdelen samt rättighets- och planinformation hos Lantmäteriet. I produkten ingår även taxeringsuppgiftsdelen som aviseras en gång varje år. Avisering av personnummer och personuppgifter om inteckningar kräver särskilda skäl. Fastighetsavisering Fullständig ger dig samtliga förändringar som skett på en fastighet för de tabeller du abonnerar på. Fastighetsavisering Fullständig kan beställas för de flesta tabellerna som ingår i registret och leverans sker dagligen (vardagar) eller veckovis.\n\nFastighetsavisering Förenklad ger dig endast den senaste förändringen om flera förändringar skett inom samma tabell och fastighet sedan du senast fick en leverans. Leverans sker en gång per månad, kvartal, halvår eller år. Fastighetsavisering Förenklad kan endast väljas för fastighet och/eller adress. Innan en avisering kan börja måste du göra ett startuttag. Om bevakning skall ske på en stock av fastigheter kan ett eller flera startuttag per år vara nödvändigt då stocken under året ändras."@sv;
    a <http://www.w3.org/ns/dcat#DataService>, <http://entryscape.com/terms/IndependentDataService>
}


<#f4f663fd03158fe882b343273d697c0b> {
<https://doi.org/10.5878/002024> <http://www.w3.org/ns/dcat#keyword> "äldre järnålder"@sv, "Early Iron Age"@en, "yngre bronsålder"@sv, "Late Bronze Age"@en, "folkvandringstid"@sv, "Migration Period"@en;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__46685.
_:b0__46685 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/author>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/4ffa2232927728321e1ee5ca4a299835>;

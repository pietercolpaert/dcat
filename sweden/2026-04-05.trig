<feed> <https://w3id.org/tree#member> <#a2e6e7509737e7812c3f209227d07b31>.
<#a2e6e7509737e7812c3f209227d07b31> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <http://api.kolada.se/v3/kpi/N00327>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-05T06:27:19.049Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#a2e6e7509737e7812c3f209227d07b31> {
<http://api.kolada.se/v3/kpi/N00327> <http://www.w3.org/ns/dcat#keyword> "Kommun"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "N00327";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Mäns Kommunindex för tema Arbete och löner baseras på indikatorerna Föräldrapenningdagar som tas ut av män, andel av antal dagar (%), Lämnat etableringsuppdraget och börjat arbeta (status efter 90 dagar), andel (%), Sysselsättningsgrad, utrikes födda 20-64 år, andel (%), Förvärvsarbetande skyddsbehövande och anhöriga (flyktingar) 20-64 år, vistelsetid 4-6 år, andel (%), Ginikoefficient - förvärvsinkomst, index, Kvinnors andel av männens lönesumma, dagbefolkning, andel (%), Sysselsättningsgrad 20-64 år, andel (%), Långtidsarbetslöshet 25-65 år, årsmedelvärde, andel (%) av bef., Invånare 16-84 år som är oroliga över att förlora sitt arbete, andel (%). Nyckeltalen normaliseras så att samtliga regioners värden placeras på en skala från 0 till 100 där 0 är sämst och 100 är bäst (för vissa indikatorer används inverterad skala). I nästa steg vägs de normaliserade indikatorvärdena samman till index på aspektnivå. Detta görs med medelvärden, samtliga indikatorer vägs samman med samma vikt inom respektive aspekt. Därefter vägs indexet på aspektnivå ihop till temanivå enligt samma princip och även dessa värden hamnar mellan 0 och 100. Viktningen är lika stor för samtliga aspekter inom temat. Index beräknas av Tillväxtverket inom ramen för BRP+. "@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/N00327_json>;
    <http://purl.org/dc/terms/provenance> _:b0__72043.
_:b0__72043 <http://purl.org/dc/terms/description> "Källa: Försäkringskassan, SCB, SCB - Befolkningens arbetsmarknadsstatus (BAS), STATIV från SCB, Arbetsförmedlingen, Folkhälsomyndigheten."@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/N00327> <http://purl.org/dc/terms/modified> "2025-05-05"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Arbete och löner – Kommunindex Män"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/SOCI>, <http://publications.europa.eu/resource/authority/data-theme/REGI>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


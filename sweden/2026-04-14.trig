<#2ab5c62b0120399fb0f44c1556ca82e8> {
<http://api.kolada.se/v3/kpi/U40462> <http://www.w3.org/ns/dcat#keyword> "Kommun"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "U40462";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Antal deltagare som svarat alternativen \"För det mesta\" eller \"Alltid\" på frågan \"Har stödet fått ta den tid du behövt?\" dividerat med samtliga deltagare som svarat på frågan. Samtliga svarsalternativ är \"Aldrig\", \"Sällan\", \"Ibland\", \"Ofta\", \"För det mesta\", \"Alltid\". Frågan ställs till deltagare som fått insatser med finansiering eller stöd av Finansiell samordning (Finsam) vid avslut. Syftet är att mäta om deltagarna upplever att rehabiliteringsprocessen får ta den tid som behövs utifrån deltagarnas egna förutsättningar. Finansiell samordning sker genom samordningsförbund där det kan ingå en eller flera kommuner och undersökningen sammanställs på samordningsförbundsnivå. Kommuner som ingår i samma samordningsförbund har därför samma värde. "@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/U40462_json>;
    <http://purl.org/dc/terms/provenance> _:b0__2830.
_:b0__2830 <http://purl.org/dc/terms/description> "Källa: Nationella nätverket för samordningsförbund (NNS)."@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/U40462> <http://purl.org/dc/terms/modified> "2026-02-02"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Deltagarbedömning Finsam - Stödet har fått den ta den tid som behövts för deltagaren, andel (%)"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/SOCI>, <http://publications.europa.eu/resource/authority/data-theme/REGI>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


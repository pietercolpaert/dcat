    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/MONTHLY>;
    <http://purl.org/dc/terms/identifier> "_bbe9d940-cd80-402e-bcc8-ac587d5be230", "bbe9d940-cd80-402e-bcc8-ac587d5be230";

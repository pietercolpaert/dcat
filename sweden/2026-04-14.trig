<#15e755c61357d200e09193c18b244e47> {
<https://opendata-catalog.smhi.se/md/7ef0a848-a7c0-4078-9604-da90978cfb87> <http://www.w3.org/ns/dcat#keyword> "Öppna data"@sv, "Inspire"@sv, "Observation"@sv, "Oceanografi"@sv, "Havstemperatur"@sv, "Geografiska oceanografiska förhållanden"@sv;

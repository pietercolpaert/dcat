    <https://www.w3.org/ns/activitystreams#published> "2026-04-14T06:37:41.355Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#46b4454e51344451a9279604b161855f> {
<https://opendata.umea.se/api/v2/catalog/datasets/energiforbrukning-i-geografiska-omradet-092115-tegsborg-kyrkan> <http://www.w3.org/ns/dcat#keyword> "Energi"@sv, "Consumption"@en, "Umeå Energi", "Förbrukning"@sv, "El"@sv, "Fjärrvärme"@sv, "Energy"@en, "Electricity"@en, "District heating"@en;
    <http://purl.org/dc/terms/identifier> "energiforbrukning-i-geografiska-omradet-092115-tegsborg-kyrkan@http://dataportal.se/organisation/SE2120002627";
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://admin.dataportal.se/store/43/resource/fd2584866d01e4eaee64e3ffcfe40e02>;
    <http://purl.org/dc/terms/description> "Anonymiserad förbrukningsdata från Umeå Energi per nyckelkodsområde i Umeå Kommun. Detta data bör inte ses som exakta och kompletta förbrukningsvärden utan mer som en kvalificerad uppskattning av förbrukningen i syfte att se trender och indikationer.Datafilerna kommer endast innehålla värden för fastigheter i Umeå kommun där Umeå Energi är nätägare och informationen inte anses vara olämplig för distribution. Uppdateras normalt en gång varje månad med nytillkomna värden.Frågor kring detta förbrukningsdata hänvisas till matdata.datalager@umeaenergi.se "@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://opendata.umea.se/explore/?refine.dcat.contact_name=Ume%C3%A5+Energi&refine.dcat.contact_email=matdata.datalager%2540umeaenergi.se>;
    <http://www.w3.org/ns/dcat#distribution> <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-092115-tegsborg-kyrkan-API>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-092115-tegsborg-kyrkan-csv>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-092115-tegsborg-kyrkan-json>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-092115-tegsborg-kyrkan-jsonl>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-092115-tegsborg-kyrkan-parquet>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-092115-tegsborg-kyrkan-rdfxml>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-092115-tegsborg-kyrkan-jsonld>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-092115-tegsborg-kyrkan-turtle>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-092115-tegsborg-kyrkan-n3>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-092115-tegsborg-kyrkan-xlsx>;
    <http://purl.org/dc/terms/issued> "2024-01-16T23:49:08.406000+00:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

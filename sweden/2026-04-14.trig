<https://doi.org/10.5878/gyf8-6823> <http://www.w3.org/ns/dcat#keyword> "Markanvändning"@sv, "granbarkborre"@sv, "Norway spruce"@en, "Land use"@en, "markanvändning"@sv, "land use"@en, "skogsbruk"@sv, "forest exploitation"@en, "picea abies"@en, "översikt över skogsskador"@sv, "inventory of forest damage"@en, "skogsskador"@sv, "NRS"@sv, "TFDI"@en, "forest damage"@en, "barrskog"@sv, "coniferous forest"@en, "Ips typographus"@en, "Dubbelögad bastborre"@sv, "Four-eyed spruce bark beetle"@en, "Inventering av skador på skog"@sv, "Forest damage inventory"@en, "Gran (art)"@sv, "polygraphus poligraphus"@en, "ips typographus"@en, "ips typographus (linnaeus, c., 1758)"@en, "picea abies (l.) h. karst."@en, "polygraphus poligraphus (linnaeus, c., 1758)"@en;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__9703.
_:b0__9703 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;

<#a583b1216557209939774c64ca32647a> {
<https://doi.org/10.57804/ckmq-a684> <http://www.w3.org/ns/dcat#keyword> "Sweden"@en, "Sweden"@sv, "Economic History"@en, "foreign trade"@sv, "foreign trade"@en, "export"@sv, "export"@en, "import"@sv, "import"@en, "prices"@sv, "prices"@en, "terms of trade"@sv, "terms of trade"@en, "Economic History"@sv;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__10219.
_:b0__10219 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/1ba29f35daf25f81409e20affbcf5b9f>;
    a <http://www.w3.org/ns/prov#Attribution>.
<https://doi.org/10.57804/ckmq-a684> <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021002932>;
    <http://purl.org/dc/terms/description> "Detta är ett dataset som innehåller serier om svensk utrikeshandel, från 1780 till 1830. Innehåller serier om 37 enskilda importvaror, 19 exportvaror och 12 återexportvaror, på aggregerad nivå och per vara. Innehåller även prisindex för import och export samt terms of trade.\n\nSerierna publicerades i doktorsavhandlingen On the Ocean of Protectionism: The Structure of Swedish Tariffs and Trade 1780-1830.\n\nDatasetet har ursprungligen publicerats i DiVA och flyttades över till SND 2024."@sv, "This is a data set containing series on Swedish foreign trade, from 1780 to 1830. Contains series on 37 individual import commodities, 19 export commodities, and 12 re-export commodities, on the aggregated level and by commodity. Also contains price indexes for imports and exports as well as terms of trade.\n\nThe series were published in PhD thesis On the Ocean of Protectionism: The Structure of Swedish Tariffs and Trade 1780-1830.\n\nThe dataset was originally published in DiVA and moved to SND in 2024."@en;
    <http://www.w3.org/ns/dcat#distribution> <https://doi.org/10.57804/ckmq-a684#distribution>;
    <http://purl.org/dc/terms/issued> "2017-12-19T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.57804/ckmq-a684>;
    <http://purl.org/dc/terms/modified> "2024-08-27T09:27:04.521306Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Series on Swedish Foreign Trade, 1780-1830"@sv, "Series on Swedish Foreign Trade, 1780-1830"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/SOCI>;
    a <http://www.w3.org/ns/dcat#Dataset>
}


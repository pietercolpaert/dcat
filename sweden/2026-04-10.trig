    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.5878/002935>;
    <http://purl.org/dc/terms/modified> "2020-01-17T10:40:55Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Befolkningsförändringar 1891-1900"@sv, "Population changes 1891-1900"@en;

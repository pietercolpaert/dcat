    <https://www.w3.org/ns/activitystreams#published> "2026-04-10T06:37:20.144Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#c99b0fd536067d12671f9b7e070d7ce0> {
<http://api.kolada.se/v3/kpi/N70642> <http://www.w3.org/ns/dcat#keyword> "Region"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "N70642";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Andelen vårdtillfällen där patienten fått en eller flera skador och där skadan bedömts som undvikbar (kategorierna \"undvikbar\" eller \"sannolikt undvikbar\" i journalgranskningen). Med vårdskada avsesen skada på patient som hade kunnat undvikas om lämpliga åtgärder hade vidtagits vid patientens kontakt med hälso- och sjukvården. Exempel på vårdskador är trycksår eller vårdrelaterade infektioner som förvärvats under sjukhusvistelsen. Granskningsteamet, bestående av läkare och sjuksköterska, gör ett slumpmässigt urval av ett antal journaler per månad. Därefter granskas journaler från dessa vårdtillfällen för att söka markörer, det vill säga journaluppgifter som innebär en ökad risk för att en skada har inträffat. Om patienten har drabbats av en skada under vårdtillfället gör granskningsteamet en bedömning av vilken typ av skada det rör sig om, hur allvarlig den är och om den hade kunnat undvikas. Data finns tillgängligt enligt könsuppdelning."@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/N70642_json>;
    <http://purl.org/dc/terms/provenance> _:b0__6408.
_:b0__6408 <http://purl.org/dc/terms/description> "Källa: SKR via Vården i siffror"@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/N70642> <http://purl.org/dc/terms/title> "Vårdtillfälle med vårdskada (undvikbar), andel (%) (-2023)"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/HEAL>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


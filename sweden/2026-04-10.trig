<https://admin.dataportal.se/store/818/resource/5ce02393cd91ea1ee7d898c5e4e13d63> <http://www.w3.org/ns/dcat#keyword> "health"@en, "children"@en, "cancer"@en, "genomics"@en, "FEGA Sweden", "biobank"@en, "tumour"@en;
    <http://purl.org/dc/terms/issued> "2024-02-22T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

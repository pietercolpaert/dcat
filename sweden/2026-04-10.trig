<#9dd39086d245858a34281441cfffa4fb> {
<https://opendata-catalog.smhi.se/md/81074210-7d22-11ed-a51b-432755aaeed3> <http://www.w3.org/ns/dcat#keyword> "Snö"@sv, "Öppna data"@sv, "Hydrologi"@sv, "Observation"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/IRREG>, <http://publications.europa.eu/resource/authority/frequency/OTHER>;
    <http://purl.org/dc/terms/identifier> "_81074210-7d22-11ed-a51b-432755aaeed3", "81074210-7d22-11ed-a51b-432755aaeed3";
    <http://www.w3.org/ns/dcat#byteSize> "24732"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>;

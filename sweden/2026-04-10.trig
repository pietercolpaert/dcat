<#b700534527ee79865b582b09cb5f9d5c> {
<https://metadata.havochvatten.se/store/1/resource/261> <http://www.w3.org/ns/dcat#keyword> "kartläggning"@sv, "fysisk planering"@sv, "byggnader"@sv, "grön infrastruktur"@sv, "kustmiljö"@sv, "vattendirektivet"@sv, "fysisk påverkan"@sv, "art- och habitatdirektivet"@sv, "havsmiljödirektivet"@sv, "hydromorfologisk status"@sv, "kustzonsplanering"@sv, "påverkansfaktorer"@sv, "exploatering"@sv, "uppföljning"@sv, "grundområden"@sv, "strandzon"@sv, "geografisk information (GIS)"@sv, "belastning"@sv, "bottenstörning"@sv, "etableringar"@sv, "invallade områden"@sv, "påverkanszoner"@sv, "morfologiskt tillstånd"@sv;
    <http://xmlns.com/foaf/0.1/page> <https://geodata.havochvatten.se/download/fysisk-paverkan-kust-paverkanszoner/Beskrivning%20av%207_Paverkanszoner.pdf>, <https://www.havochvatten.se/download/18.7d45de5c174e8f2dabe8afa3/1604908758378/rapport-2020-12-fysisk-storning-i-grunda-havsomraden.pdf>;
    <http://purl.org/dc/terms/identifier> "4e545c80-5196-400c-8102-50fe16ddb59d";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021006420>;
    <http://purl.org/dc/terms/description> "Underlag/skikt över byggnader och etableringar längs med kusten genom ortofoton. Innehåller även områden som invallats och torrlagts."@sv, "Underlag eller skikt för potentiella påverkanszoner för nutida period (tiden närmast 2016). Påverkanszonerna visar en klassad risk (1–5) för påverkan på morfologiskt tillstånd, hydrografiska förhållanden och konnektivitet. Påverkanszonerna har tagits fram med utgångspunkt från fysiska påverkanstryck och naturmiljöns känslighet. Metoden med vilken zonerna tagits fram tar hänsyn till egenskaper hos objekten och hos den omkringliggande miljön, det vill säga djup, vågexponering och geologi eller bottensubstrat.\nPåverkanszonerna är inte tänkta att användas vid uppföljning och planering i detalj för enskilda objekt, utan på en mer övergripande nivå eller skala."@sv;
    <http://purl.org/dc/terms/isPartOf> <https://metadata.havochvatten.se/store/34/resource/21>;
    <http://purl.org/dc/terms/spatial> <http://sws.geonames.org/3337386>, <http://sws.geonames.org/2721357>, <http://sws.geonames.org/3337385>, <http://sws.geonames.org/2666218>, <http://sws.geonames.org/2664415>, <http://sws.geonames.org/2711508>, <http://sws.geonames.org/2712411>, <http://sws.geonames.org/2708794>, <http://sws.geonames.org/2702259>, <http://sws.geonames.org/604010>, <http://sws.geonames.org/2673722>, <http://sws.geonames.org/2676207>, <http://sws.geonames.org/2685867>, <http://sws.geonames.org/2664292>, _:b0__71165.
_:b0__71165 <http://www.w3.org/ns/dcat#bbox> "POLYGON((10.59 66,24.2 66,24.2 55.13,10.59 55.13,10.59 66))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;

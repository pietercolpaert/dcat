    <http://www.w3.org/ns/dcat#bbox> "POLYGON((11 69,26 69,26 55,11 55,11 69))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    <http://www.w3.org/ns/dcat#endDate> "2026-04-10"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#startDate> "1970-01-01"^^<http://www.w3.org/2001/XMLSchema#date>;

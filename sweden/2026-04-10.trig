    <http://purl.org/dc/terms/issued> "2018-03-05"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Submitted public claims to the Swedish Enforcement Autorithy"@en, "Statliga fordringar som lämnats in till Kronofogden"@sv;

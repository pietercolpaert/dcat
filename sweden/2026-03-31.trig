<#ed892c0b2a41fea16181394754a89b13> {
<https://doi.org/10.5879/gp51-a110> <http://www.w3.org/ns/dcat#keyword> "ATMOSPHERIC TEMPERATURE"@en, "AIR TEMPERATURE"@en, "SURFACE TEMPERATURE"@en;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__78032.
_:b0__78032 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;

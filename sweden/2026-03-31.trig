<http://api.kolada.se/v3/kpi/N79504> <http://www.w3.org/ns/dcat#keyword> "Region"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;

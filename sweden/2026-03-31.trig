    <http://purl.org/dc/terms/modified> "2026-03-31T09:30:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Överklagandefrekvens hovrätt till Högsta domstolen"@sv, "Frequency of appeal from courts of appeal to the Supreme Court"@en;

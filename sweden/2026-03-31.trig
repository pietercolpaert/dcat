<feed> <https://w3id.org/tree#member> <#2afad212a2e9e7764f131a576d11213c>.
<#2afad212a2e9e7764f131a576d11213c> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <http://api.kolada.se/v3/kpi/N78118>;
    <https://www.w3.org/ns/activitystreams#published> "2026-03-31T06:29:53.797Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#2afad212a2e9e7764f131a576d11213c> {
<http://api.kolada.se/v3/kpi/N78118> <http://www.w3.org/ns/dcat#keyword> "Region"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "N78118";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Indexvärde avseende patientupplevd kvalitet på hälso- och vårdcentral. Indexering görs av de ingående dimensionerna Vård och behandling, Delaktighet, Bemötande, Kontuinitet, Information, samt Tillgänglighet, därefter tas ett indexerat medelvärde fram. Patientenkäten går ut till ett urval av patienter som träffat en läkare på en hälso- eller vårdcentral under september-oktober. Data finns tillgängligt enligt könsuppdelning."@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/N78118_json>;
    <http://purl.org/dc/terms/provenance> _:b0__707.
_:b0__707 <http://purl.org/dc/terms/description> "Källa: RKA baserat på uppgifter från Nationell patientenkät, SKR"@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/N78118> <http://purl.org/dc/terms/modified> "2025-03-14"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Patientupplevd kvalitet på hälso- och vårdcentral, index"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/HEAL>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}

<feed> <https://w3id.org/tree#member> <#f1665ef32b3a604d1402881606ea11fa>.
<#f1665ef32b3a604d1402881606ea11fa> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <http://api.kolada.se/v3/kpi/N00378>;
    <https://www.w3.org/ns/activitystreams#published> "2026-03-31T06:29:53.798Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#f1665ef32b3a604d1402881606ea11fa> {
<http://api.kolada.se/v3/kpi/N00378> <http://www.w3.org/ns/dcat#keyword> "Kommun"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "N00378";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Mäns Kommunindex för tema Social baseras på indikatorerna Anmälda sexualbrott, antal/100 000 inv, Anmälda våldsbrott, antal/100 000 inv, Anmälda brott mot frihet och frid, antal/100 000 inv, Anmälda ekobrott, antal/100 000 inv, Anmälda stöld- och tillgreppsbrott, antal/100 000 inv, Invånare 16-84 år som röker dagligen, andel (%), Invånare 16-84 år med riskabla alkoholvanor, andel (%), Invånare 16-84 år som äter frukt och grönt mer än 3 ggr/dag, andel (%), Invånare 16-84 år som är fysiskt aktiva minst 150 min/vecka, andel (%), Trafikolyckor med räddningsinsatser per 1000 inv, Arbetsolyckor, antal/1000 sysselsatta, Skadade vårdade i slutenvård, 3-årsm, antal/100 000 inv, Fallskador bland personer 65+, 3-årsm, antal slutenvårdstillfällen /100 000 inv, Barn 1-5 år inskrivna i förskola, andel (%), Elever i åk 9 som är behöriga till yrkesprogram, hemkommun, andel (%), Gymnasieelever med examen inom 4 år, hemkommun, andel (%). Nyckeltalen normaliseras så att samtliga regioners värden placeras på en skala från 0 till 100 där 0 är sämst och 100 är bäst (för vissa indikatorer används inverterad skala). I nästa steg vägs de normaliserade indikatorvärdena samman till index på aspektnivå. Detta görs med medelvärden, samtliga indikatorer vägs samman med samma vikt inom respektive aspekt. Därefter vägs indexet på aspektnivå ihop till temanivå enligt samma princip och även dessa värden hamnar mellan 0 och 100. Viktningen är lika stor för samtliga aspekter inom temat. Index beräknas av Tillväxtverket inom ramen för BRP+. "@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/N00378_json>;
    <http://purl.org/dc/terms/provenance> _:b0__4006.
_:b0__4006 <http://purl.org/dc/terms/description> "Källa: SCB, BRÅ, Folkhälsomyndigheten, Hälsa på lika villkor (HLV) samt Liv & Hälsa (LH), Myndigheten för samhällsskydd och beredskap (MSB), Arbetsmiljöverket, Socialstyrelsen, Patientregistret, Socialstyrelsen, Skolverket"@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/N00378> <http://purl.org/dc/terms/modified> "2025-05-05"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Social hållbarhet - Kommunindex Män"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/SOCI>, <http://publications.europa.eu/resource/authority/data-theme/REGI>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}

<feed> <https://w3id.org/tree#member> <#fdc763dce997e104ec456ed647a5f3f6>.

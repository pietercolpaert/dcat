    <http://purl.org/dc/terms/type> <http://inspire.ec.europa.eu/metadata-codelist/ResourceType/dataset>;
    <http://purl.org/dc/terms/modified> "2020-02-07"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Trafikflöde Motorfordon"@sv;

<#0cc45d92dc0a418f1efbec4011f84034> {
<http://pxweb.etjanst.domstol.se/dataset/09_Konkurser_TR.px> <http://www.w3.org/ns/dcat#keyword> "Officiell statistik"@sv, "Konkurs"@sv, "Domstolsverket"@sv, "Tingsrätt"@sv;
    <http://xmlns.com/foaf/0.1/page> <https://www.domstol.se/om-sveriges-domstolar/statistik-styrning-och-utveckling/statistik/officiell-domstolsstatistik/>;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>, <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021002742>;
    <http://purl.org/dc/terms/description> "Antal ärenden avseende konkurser för alla tingsrätter och per tingsrätt. Antal balanserade konkurser avser öppna (pågående) konkursärenden där beslut om försättande i konkurs meddelats. Balansen går inte att sätta i relation till inkomna konkursansökningar eftersom balansen endast avser konkurser som meddelats men ännu inte avslutats. Antal avslutade konkurser är konkurser som avslutats på grund av t.ex. avskrivningsbeslut, hävt konkursbeslut eller beslut varigenom utdelning fastställts."@sv, "Number of bankruptcy matters at district courts. Concluded bankruptcies refers to a dismissal or rescission of a bankruptcy judgment or a decision that results in a composition arrangement. Pending bankruptcies means that a decision to declare bankruptcy has been made but the bankruptcy is not concluded yet, therefore pending bankruptcies can not be compared to the number of filed bankruptcy applications."@en;
    <http://purl.org/dc/terms/spatial> <http://sws.geonames.org/2661886>;
    <http://www.w3.org/ns/dcat#contactPoint> <https://admin.dataportal.se/store/601/resource/450f76ab581c240995bffa3cac11448a>;
    <http://www.w3.org/ns/dcat#distribution> <http://pxweb.etjanst.domstol.se/distribution/sv/09_Konkurser_TR.px>, <http://pxweb.etjanst.domstol.se/distribution/en/09_Konkurser_TR.px>;
    <http://purl.org/dc/terms/creator> <http://dataportal.se/organisation/SE2021002742>;
    <http://purl.org/dc/terms/issued> "2025-06-02"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#landingPage> <https://pxweb.etjanst.domstol.se/PxWeb/pxweb/sv/DOMstat/DOMstat__AntalMal/09_Konkurser_TR.px>, <https://pxweb.etjanst.domstol.se/PxWeb/pxweb/en/DOMstat/DOMstat__AntalMal/09_Konkurser_TR.px>;
    <http://purl.org/dc/terms/modified> "2026-03-31T09:30:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Inkomna, balanserade och avslutade konkurser vid tingsrätt"@sv, "Filed (incoming), concluded and pending bankruptcy matters at district courts"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/JUST>;
    <http://purl.org/dc/terms/temporal> _:b0__5339.
_:b0__5339 <http://www.w3.org/ns/dcat#endDate> "2025-12-31"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#startDate> "2002-01-01"^^<http://www.w3.org/2001/XMLSchema#date>;
    a <http://purl.org/dc/terms/PeriodOfTime>.
<http://pxweb.etjanst.domstol.se/dataset/09_Konkurser_TR.px> a <http://www.w3.org/ns/dcat#Dataset>
}


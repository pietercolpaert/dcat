<#6ab4dec7b7162e885dfbf32b8def64db> {
<http://pxweb.etjanst.domstol.se/dataset/02_Ungdomsmal_HR.px> <http://www.w3.org/ns/dcat#keyword> "Officiell statistik"@sv, "Domstolsverket"@sv, "Hovrätt"@sv, "Brottmål"@sv, "Ungdomsmål"@sv, "Minderårig"@sv, "Underårig"@sv;
    <http://xmlns.com/foaf/0.1/page> <https://www.domstol.se/om-sveriges-domstolar/statistik-styrning-och-utveckling/statistik/officiell-domstolsstatistik/>;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>, <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021002742>;
    <http://purl.org/dc/terms/description> "Antal avgjorda ungdomsmål och målens handläggningstider i månader för hovrätter totalt och per hovrätt. Ungdomsmål är brottmål med förekomst av tilltalad aktör i åldern 15-20 år. Gruppen 15-17 år (U18) tillhör kategorin förtursmål. I statistiken för denna kategori förekommer såväl mål med lagstadgad frist (kriterium: fängelse i mer än sex månader) som mål som inte uppfyller kriteriet för lagstadgad frist. Gruppen 18-20 år (U21) tillhör inte kategorin förtursmål per definition, men omfattas av krav på skyndsam hantering enligt lag för mål med förekomst av underårig (under 21 år)."@sv, "Number of determined criminal cases and turnaround times in months involving juveniles at courts of appeal, that is criminal cases where at least one defendant is under 21 years of age. The group of 15-17 years old (U18) belongs to priority cases. These cases shall be handled promptly. The group of 18-20 years old (U21) does not belong to the priority cases by definition, but is subject to the requirement for prompt handling according to the law for cases involving minors (under 21 years old)."@en;
    <http://purl.org/dc/terms/spatial> <http://sws.geonames.org/2661886>;
    <http://www.w3.org/ns/dcat#contactPoint> <https://admin.dataportal.se/store/601/resource/450f76ab581c240995bffa3cac11448a>;
    <http://www.w3.org/ns/dcat#distribution> <http://pxweb.etjanst.domstol.se/distribution/sv/02_Ungdomsmal_HR.px>, <http://pxweb.etjanst.domstol.se/distribution/en/02_Ungdomsmal_HR.px>;
    <http://purl.org/dc/terms/creator> <http://dataportal.se/organisation/SE2021002742>;
    <http://purl.org/dc/terms/issued> "2025-06-02"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#landingPage> <https://pxweb.etjanst.domstol.se/PxWeb/pxweb/sv/DOMstat/DOMstat__Ungdomsmal/02_Ungdomsmal_HR.px>, <https://pxweb.etjanst.domstol.se/PxWeb/pxweb/en/DOMstat/DOMstat__Ungdomsmal/02_Ungdomsmal_HR.px>;
    <http://purl.org/dc/terms/modified> "2026-03-31T09:30:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Avgjorda ungdomsmål med handläggningstider vid hovrätt"@sv, "Determined criminal cases with turnaround times involving juveniles at courts of appeal"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/JUST>;
    <http://purl.org/dc/terms/temporal> _:b0__174.
_:b0__174 <http://www.w3.org/ns/dcat#endDate> "2025-12-31"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#startDate> "2005-01-01"^^<http://www.w3.org/2001/XMLSchema#date>;
    a <http://purl.org/dc/terms/PeriodOfTime>.
<http://pxweb.etjanst.domstol.se/dataset/02_Ungdomsmal_HR.px> a <http://www.w3.org/ns/dcat#Dataset>
}


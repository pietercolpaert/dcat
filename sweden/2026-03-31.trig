    <http://purl.org/dc/terms/creator> <http://dataportal.se/organisation/SE2021002742>;
    <http://purl.org/dc/terms/issued> "2025-06-02"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#landingPage> <https://pxweb.etjanst.domstol.se/PxWeb/pxweb/sv/DOMstat/DOMstat__Overklagande/05_Overklagande_andringsfrekvens_FR_till_KR.px>, <https://pxweb.etjanst.domstol.se/PxWeb/pxweb/en/DOMstat/DOMstat__Overklagande/05_Overklagande_andringsfrekvens_FR_till_KR.px>;
    <http://purl.org/dc/terms/modified> "2026-03-31T09:30:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Överklagande- och ändringsfrekvens förvaltningsrätt till kammarrätt"@sv, "Frequency of appeal from administrative courts to administrative courts of appeal"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/JUST>;

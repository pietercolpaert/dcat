    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}

<feed> <https://w3id.org/tree#member> <#7e3358ba08031185cc125a0013e4e740>.
<#7e3358ba08031185cc125a0013e4e740> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <http://api.kolada.se/v3/kpi/N71020>;
    <https://www.w3.org/ns/activitystreams#published> "2026-03-31T06:29:55.693Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#7e3358ba08031185cc125a0013e4e740> {
<http://api.kolada.se/v3/kpi/N71020> <http://www.w3.org/ns/dcat#keyword> "Region"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "N71020";

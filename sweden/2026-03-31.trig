    <http://www.w3.org/ns/dcat#landingPage> <https://pxweb.etjanst.domstol.se/PxWeb/pxweb/sv/DOMstat/DOMstat__AntalMal/02b_Malutveckling_per_malkategori_arenden_TR.px>, <https://pxweb.etjanst.domstol.se/PxWeb/pxweb/en/DOMstat/DOMstat__AntalMal/02b_Malutveckling_per_malkategori_arenden_TR.px>;
    <http://purl.org/dc/terms/modified> "2026-03-31T09:30:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Inkomna, avgjorda och balanserade ärenden per målkategori vid tingsrätt"@sv, "Filed (incoming), determined and pending matters by case category at district courts"@en;

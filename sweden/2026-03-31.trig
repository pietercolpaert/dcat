    <http://www.w3.org/ns/dcat#landingPage> <https://pxweb.etjanst.domstol.se/PxWeb/pxweb/sv/DOMstat/DOMstat__Snabbspar/01_Avgjorda_snabbsparsmal_TR.px>, <https://pxweb.etjanst.domstol.se/PxWeb/pxweb/en/DOMstat/DOMstat__Snabbspar/01_Avgjorda_snabbsparsmal_TR.px>;
    <http://purl.org/dc/terms/modified> "2026-03-31T09:30:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Antal avgjorda brottmål inom snabbare lagföring vid tingsrätt"@sv, "Determined criminal cases within faster legal proceedings at district courts"@en;

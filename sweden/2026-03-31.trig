    <http://purl.org/dc/terms/identifier> "_762376b4-1f11-4d40-a4c6-865c98ae3765", "762376b4-1f11-4d40-a4c6-865c98ae3765";
    <http://www.w3.org/ns/dcat#byteSize> "33485"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>;
    <http://data.europa.eu/r5r/hvdCategory> <http://data.europa.eu/bna/c_164e0bf5>;

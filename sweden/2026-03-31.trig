    <http://purl.org/dc/terms/creator> <http://dataportal.se/organisation/SE2021002742>;
    <http://purl.org/dc/terms/issued> "2025-06-02"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#landingPage> <https://pxweb.etjanst.domstol.se/PxWeb/pxweb/sv/DOMstat/DOMstat__Overklagande/06_Overklagandefrekvens_KR_till_HFD.px>, <https://pxweb.etjanst.domstol.se/PxWeb/pxweb/en/DOMstat/DOMstat__Overklagande/06_Overklagandefrekvens_KR_till_HFD.px>;
    <http://purl.org/dc/terms/modified> "2026-03-31T09:30:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

<https://resources.stockholm.se/data/a0f9b145-f0ba-49f6-9191-2995f3c8a32e> <http://www.w3.org/ns/dcat#keyword> "Stockholms stad", "Höjddata"@sv, "Verksamhetsdata"@sv, "Extern dataportal"@sv, "1.Publicerad på webb"@sv, "Laser"@sv, "Lidar"@sv, "Punktmoln"@sv, "Laserskanning"@sv, "Lasermoln"@sv;

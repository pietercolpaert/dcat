    <http://purl.org/dc/terms/publisher> <https://konsumentverket.entryscape.net/store/1/resource/5>;
    <http://purl.org/dc/terms/description> "Statistiken från undersökningen Konsumenterna och miljön fördelat efter kvinnor och män. Statistiken beskriver hur konsumtionen på olika marknader påverkar miljön och var konsumenter uppfattar det som enklast och svårast att göra val med miljöhänsyn. \n\nI 2019 års rapport har en fråga om klimatångest inkluderats. Alltså om konsumenter upplever oro eller skuld i samband med köp av produkter inom olika konsumtionsområden.\n\nVår förhoppning är att rapporten kan användas som inspiration till åtgärder som syftar till att begr��nsa konsumtionens miljöpåverkan, samt för prioritering och uppföljning av sådana åtgärder."@sv;
    <http://purl.org/dc/terms/spatial> <http://sws.geonames.org/2661886>;
    <http://www.w3.org/ns/dcat#contactPoint> <https://konsumentverket.entryscape.net/store/1/resource/6>;
    <http://www.w3.org/ns/dcat#distribution> <https://konsumentverket.entryscape.net/store/1/resource/37>, <https://konsumentverket.entryscape.net/store/1/resource/35>;
    <http://purl.org/dc/terms/issued> "2017"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2020-06-22"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Konsumenterna och miljön - fördelning kvinnor och män"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>;
    <http://purl.org/dc/terms/temporal> _:b0__60003.
_:b0__60003 <http://www.w3.org/ns/dcat#startDate> "2017"^^<http://www.w3.org/2001/XMLSchema#date>;
    a <http://purl.org/dc/terms/PeriodOfTime>.
<https://konsumentverket.entryscape.net/store/1/resource/32> a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}

<feed> <https://w3id.org/tree#member> <#a8aeae174e8f9297ee62e458a62473c7>.
<#a8aeae174e8f9297ee62e458a62473c7> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://catalog.molndal.se/store/1/resource/162>;
    <https://www.w3.org/ns/activitystreams#published> "2026-03-06T06:15:30.087Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#a8aeae174e8f9297ee62e458a62473c7> {
<https://catalog.molndal.se/store/1/resource/162> <http://purl.org/dc/terms/format> "application/vnd.ogc.wms_xml";
    <http://data.europa.eu/r5r/availability> <http://data.europa.eu/r5r/availability/available>;
    <http://www.w3.org/ns/dcat#accessURL> <https://wms.molndal.se/isms/oppnadata_skyfallskartering2023?request=GetCapabilities&service=WMS>;
    <http://purl.org/dc/terms/title> "Skyfallskartering Mölndal 2023"@sv;
    <http://purl.org/dc/terms/description> "Skyfallskartering för Mölndals tätorter framtagen av stadsledningsförvaltningen, Mölndals stad. Skyfallskarteringen visar vilka ytor som riskeras att översvämmas vid ett kraftigt regn (100-årsregn med klimatfaktor 1,25). Karteringen utförs med hjälp av en hydraulisk modellering där översvämningsutbredning och vattendjup beräknas för dimensionerande regn över ett studerat område. Metoden finns beskriven i rapport ”PM Modellteknisk dokumentation Mölndal Skyfallskartering 20230223”."@sv;
    a <http://www.w3.org/ns/dcat#Distribution>
}


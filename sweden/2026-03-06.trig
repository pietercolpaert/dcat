<#6ffa9868a4a25b502344d32c83756920> {
<https://catalog.molndal.se/store/1/resource/161> <http://www.w3.org/ns/dcat#contactPoint> <https://catalog.molndal.se/store/1/resource/163>;
    <http://www.w3.org/ns/dcat#keyword> "Översvämning"@sv, "Skyfallskartering"@sv, "Skyfall"@sv, "Samordning för hållbarhet, Ekonomi och hållbarhetsstyrning";
    <http://www.w3.org/ns/dcat#distribution> <https://catalog.molndal.se/store/1/resource/162>;
    <http://purl.org/dc/terms/title> "Skyfallskartering 2023, 100-årsregn, maxdjup(m)"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/publisher> <https://catalog.molndal.se/store/1/resource/160>;
    <http://purl.org/dc/terms/description> "Skyfallskartering för Mölndals tätorter framtagen av stadsledningsförvaltningen, Mölndals stad. Skyfallskarteringen visar vilka ytor som riskeras att översvämmas vid ett kraftigt regn (100-årsregn med klimatfaktor 1,25). Karteringen utförs med hjälp av en hydraulisk modellering där översvämningsutbredning och vattendjup beräknas för dimensionerande regn över ett studerat område. Metoden finns beskriven i rapport ”PM Modellteknisk dokumentation Mölndal Skyfallskartering 20230223”."@sv;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/2691457>, _:b0__484.
_:b0__484 <http://www.w3.org/ns/dcat#bbox> "POLYGON((11.94342659648963 57.68153555913676,12.164971983448133 57.68153555913676,12.164971983448133 57.542942280134014,11.94342659648963 57.542942280134014,11.94342659648963 57.68153555913676))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.
<https://catalog.molndal.se/store/1/resource/161> a <http://www.w3.org/ns/dcat#Dataset>
}

<feed> <https://w3id.org/tree#member> <#e0663be73587da14deadea197a26419f>.
<#e0663be73587da14deadea197a26419f> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://catalog.harryda.se/store/2/resource/272>;

<#d759622c293fc99296540d8d5414b3dc> {
<https://admin.dataportal.se/store/818/resource/4b6fd5adb589b42744d32da82a03f59f> <http://www.w3.org/ns/dcat#keyword> "CORS"@sv, "CORS"@en, "SHARE ERIC", "POPULATION DISTRIBUTION"@en, "BEFOLKNINGSFÖRDELNING"@sv, "AGEING"@en, "ÅLDRANDE"@sv, "DEMOGRAPHY"@en, "DEMOGRAFI"@sv, "VITAL STATISTICS"@en, "BEFOLKNINGSSTATISTIK"@sv, "AGEING POPULATION"@en, "ÅLDRANDE BEFOLKNING"@sv;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__6422.
_:b0__6422 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/author>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/dddfeb968e38fe20141d4c3916f7f76b>;

<https://konsumentverket.entryscape.net/store/1/resource/32> <http://www.w3.org/ns/dcat#keyword> "Konsumentverket", "Konsumtion"@sv, "Miljö"@sv, "Environment"@en, "Kvinnor"@sv, "Män"@sv, "Consumption"@en, "Female"@en, "Male"@en, "Gender"@en, "Kön"@sv;
    <http://xmlns.com/foaf/0.1/page> <https://www.konsumentverket.se/aktuella-konsumentproblem/forskning-och-rapporter/konsumenterna-och-miljon/>;

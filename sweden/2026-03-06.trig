<#65fa82bce22a001dc3939a72f31ee43b> {
<https://catalog.molndal.se/store/1/resource/155> <http://www.w3.org/ns/dcat#keyword> "Skyfallskartering"@sv, "Skyfall"@sv;
    <http://xmlns.com/foaf/0.1/page> <https://catalog.molndal.se/store/1/resource/164>;
    <http://www.w3.org/ns/dcat#endpointDescription> <http://wms.molndal.se/isms/oppnadata_skyfallskartering2023?request=GetCapabilities&service=WMS>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/publisher> <https://catalog.molndal.se/store/1/resource/160>;
    <http://purl.org/dc/terms/description> "Skyfallskartering för Mölndals tätorter framtagen av stadsledningsförvaltningen, Mölndals stad. Skyfallskarteringen visar vilka ytor som riskeras att översvämmas vid ett kraftigt regn (100-årsregn med klimatfaktor 1,25). Karteringen utförs med hjälp av en hydraulisk modellering där översvämningsutbredning och vattendjup beräknas för dimensionerande regn över ett studerat område. Metoden finns beskriven i rapport ”PM Modellteknisk dokumentation Mölndal Skyfallskartering 20230223”."@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://catalog.molndal.se/store/1/resource/163>;
    <http://www.w3.org/ns/dcat#landingPage> <https://www.molndal.se/bygga-bo-och-miljo/vatten-och-avlopp/dagvatten-och-skyfall/skyfall-i-ditt-omrade>;
    <http://www.w3.org/ns/dcat#endpointURL> <http://wms.molndal.se/isms/oppnadata_skyfallskartering2023?>;
    <http://purl.org/dc/terms/title> "Mölndal Skyfallskartering 2023, 100-årsregn, maxdjup(m)"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>;
    <http://purl.org/dc/terms/conformsTo> <http://www.opengis.net/def/serviceType/ogc/wms>;
    a <http://www.w3.org/ns/dcat#DataService>, <http://entryscape.com/terms/IndependentDataService>
}


<#d9ab832757a804f8121cd90f7ad10c07> {
<https://admin.dataportal.se/store/818/resource/0771d29f7ba53ce1b676e2e5aadea266> <http://www.w3.org/ns/dcat#keyword> "time instant, UTC"@en, "time instant, UTC"@sv, "quality flag"@en, "quality flag"@sv, "Integrated Carbon Observation System", "ICOS"@en, "Atmosphere Thematic Centre"@en, "number of points"@en, "number of points"@sv, "Δ14C"@en, "��14C"@sv, "14CO2"@en, "integration time"@en, "integration time"@sv, "weighted standard error of Δ¹⁴C"@en, "weighted standard error of Δ¹⁴C"@sv;
    <http://purl.org/dc/terms/issued> "2025-07-01T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2025-07-01T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "ICOS ATC 14C Release analysed by ICOS CRL from Hyltemossa (150.0 m)"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__12922.

<#18af0c942e6630d66c46dbffa498a2c1> {
<https://doi.org/10.5878/002402> <http://www.w3.org/ns/dcat#keyword> "CORS"@sv, "CORS"@en, "WOMEN'S ROLE"@en, "KVINNOROLL"@sv, "CHILD CARE"@en, "BARNOMSORG"@sv, "DOMESTIC RESPONSIBILITIES"@en, "HUSHÅLLSANSVAR"@sv, "JOB SATISFACTION"@en, "ARBETSTILLFREDSSTÄLLELSE"@sv, "FAMILIES"@en, "FAMILJER"@sv, "QUALITY OF LIFE"@en, "LIVSKVALITET"@sv, "CHILDREN"@en, "BARN"@sv, "HOUSEWORK"@en, "HUSHÅLLSARBETE"@sv, "MARRIAGE"@en, "ÄKTENSKAP"@sv, "PARENTAL ROLE"@en, "FÖRÄLDRAROLL"@sv, "DIVORCE"@en, "SKILSMÄSSA"@sv, "HAPPINESS"@en, "LYCKA"@sv;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__8785.
_:b0__8785 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/f89f583929eb9c309279d7d11127e877>;

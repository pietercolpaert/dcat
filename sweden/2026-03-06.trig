    <http://purl.org/dc/terms/modified> "2026-01-07T03:00:04.842000+00:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Lekplatser som förvaltas av Gator och parker"@sv, "Playgrounds managed by Gator och parker"@en;

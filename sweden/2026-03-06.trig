    <http://purl.org/dc/terms/identifier> "5fcde58b-ca30-4b41-b6c2-9dcca67dd016";
    <http://purl.org/dc/terms/modified> "2013-01-01"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Primärkarta över Malmö stad"@sv;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2120001124>;
    <http://purl.org/dc/terms/description> "Primärkartan täcker hela Malmö kommuns yta. Innehåller: Byggnader; Transportnät; Slänter; Markanvändning; Vegetation; Hydrografi; Fastighetsinformation; Ledningar ovan mark; samt ytterligare detaljer på allmän platsmark. Består av 2D-objekt med z-koordinater på vissa objektsklasser. Primärkartan används t.ex. som underlag vid projektering, till detaljplaner, till bygglovsansökan och bullerberäkning."@sv;
    <http://purl.org/dc/terms/spatial> _:b0__36284.
_:b0__36284 <http://www.w3.org/ns/locn#geometry> "POLYGON((12.82 55.64,13.15 55.64,13.15 55.50,12.82 55.50,12.82 55.64))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.

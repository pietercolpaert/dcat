of Daily Living"@en, "Äldre, 80 och över"@sv, "Aged, 80 and over"@en, "Demens"@sv, "Dementia"@en, "Minne"@sv, "Memory"@en, "Registries"@en, "Blodtryck"@sv, "Blood Pressure"@en, "Äldretandvård"@sv, "Dental Care for Aged"@en, "Hälsoundersökningar"@sv, "Health Surveys"@en, "Sköra äldre"@sv, "Frail Elderly"@en, "Äldrepsykiatri"@sv, "Geriatric Psychiatry"@en, "Intervjuer [Publikationstyp]"@sv, "Interview"@en, "Hjärtfunktionstester"@sv, "Heart Function Tests"@en, "Elektrokardiografi"@sv, "Electrocardiography"@en, "Uppföljningsstudier"@sv, "Follow-Up Studies"@en, "Populationsövervakning"@sv, "Population Surveillance"@en, "Syntester"@sv, "Vision Tests"@en, "Civilstånd"@sv, "Marital Status"@en, "Dödsorsaker"@sv, "Cause of Death"@en, "Kartläggning och enkäter"@sv, "Surveys and Questionnaires"@en, "Economics, Medical"@en, "Minnesförmåga (Psykologi)"@sv, "Retention, Psychology"@en, "Pensionering"@sv, "Retirement"@en, "Sjukhusvistelse"@sv, "Hospitalization"@en, "Sociala villkor"@sv, "Social Conditions"@en, "Syn"@sv, "Vision, Ocular"@en, "blodvärde"@sv, "blood count"@en, "balance"@en, "stödbehov"@sv, "assistance needs"@en, "koncentrationsförmåga"@sv, "concentrations capacity"@en, "lungfunktion"@sv, "respiratory function"@en, "gångtest"@sv, "walking test"@en, "near- national e-infrastructure for aging research"@sv, "near- national e-infrastructure for aging research"@en, "homecare"@en, "Stockholm Gerontology Research Center Foundation", "PENSIONS"@en, "PENSION"@sv, "LEISURE TIME ACTIVITIES"@en, "FRITIDSAKTIVITETER"@sv, "LIVING CONDITIONS"@en, "LEVNADSFÖRH��LLANDEN"@sv, "CARE OF THE ELDERLY"@en, "ÄLDREOMSORG"@sv, "HOUSING CONDITIONS"@en, "BOSTADSFÖRHÅLLANDE"@sv, "AGEING"@en, "ÅLDRANDE"@sv, "HEIGHT (PHYSIOLOGY)"@en, "LÄNGD"@sv, "WEIGHT (PHYSIOLOGY)"@en, "VIKT"@sv, "MENTAL HEALTH"@en, "PSYKISK HÄLSA"@sv;

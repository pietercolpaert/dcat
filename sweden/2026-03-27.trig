_:b0__69026 <http://www.w3.org/ns/dcat#endDate> "2018-12-31"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#startDate> "2008-01-01"^^<http://www.w3.org/2001/XMLSchema#date>;

<feed> <https://w3id.org/tree#member> <#0e438ecc994c66b07a92446e19d785fd>.
<#0e438ecc994c66b07a92446e19d785fd> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <https://resources.stockholm.se/data/c1aca559-4174-411e-b7d7-433fcfdae554>;
    <https://www.w3.org/ns/activitystreams#published> "2026-03-27T06:27:19.564Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#0e438ecc994c66b07a92446e19d785fd> {
<https://resources.stockholm.se/data/c1aca559-4174-411e-b7d7-433fcfdae554> <http://www.w3.org/ns/dcat#keyword> "Stockholms stad", "3.Öppet format"@sv, "Verksamhetsdata"@sv, "Extern dataportal"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/IRREG>;
    <http://purl.org/dc/terms/identifier> "c1aca559-4174-411e-b7d7-433fcfdae554";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/RESTRICTED>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://resources.stockholm.se/metadata#foaf/Stockholms+stad/>;
    <http://purl.org/dc/terms/description> "Ekområden och punktskiktet ekar från 2006 uppdaterats 2017 med hjälp av nya fältinventeringar och flygbildstolkning utifrån skötselaspekter, samt komplettering med nyfunna jätteekar. Shp-filen Kärnområden är dock densamma som skapades 2007 utifrån inventeringen 2006, eftersom inga nya värdeklassningar har gjorts inom projektet.  Polygonerna visar områden med kluster av ekområden och karterade ekar som bedömts som kärnområden för Stockholm stads Ekmiljöer. Buffertzoner på 250 m gjorda runt alla klass- 1 och 2-ekar från punktskiktet ”Ekar” har legat till grund för den geografiska avgränsningen. Övriga kriterier har varit förekomst minst en klass 1- ekområde i ett kärnområde samt totalt minst 30 grova ekar av klass 1-3, varav minst 10 värdefulla ekar av klass 1-2. Mer information; Data har framställts för projektet ”Stockholms Unika Ekmiljöer” på uppdrag av markkontoret, Stockholms Stad. Beskrivning av metoden finns i Rapporten ”Stockholms unika ekmiljöer – Metodutveckling och litteraturstudie 2006-10-01”. Analysresultat samt mer information finns i slutrapport ”Stockholms unika ekmiljöer – Förekomst, bevarande och utveckling” skriven av Ekologigruppen AB, maj 2007. "@sv;
    <http://purl.org/dc/terms/spatial> _:b0__48925.
_:b0__48925 <http://www.w3.org/ns/dcat#bbox> "POLYGON((17.7605 59.4407,18.2011 59.4407,18.2011 59.2272,17.7605 59.2272,17.7605 59.4407))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    <http://www.w3.org/ns/locn#geometry> "POLYGON((17.7605 59.4407,18.2011 59.4407,18.2011 59.2272,17.7605 59.2272,17.7605 59.4407))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.
<https://resources.stockholm.se/data/c1aca559-4174-411e-b7d7-433fcfdae554> <http://www.w3.org/ns/dcat#contactPoint> <https://resources.stockholm.se/metadata#vcard/Stockholms+stad+-+Milj%C3%B6f%C3%B6rvaltningen/>;
    <http://www.w3.org/ns/dcat#distribution> <https://resources.stockholm.se/data/c1aca559-4174-411e-b7d7-433fcfdae554#HTTP:ESRI+Portal-URL/3>, <https://resources.stockholm.se/data/c1aca559-4174-411e-b7d7-433fcfdae554#HTTP:ESRI+Portal-URL/2>;
    <http://www.w3.org/ns/dcat#landingPage> <https://dataportalen.stockholm.se/dataportalen/GetMetaDataById?id=42eeca58-5864-4c86-b7f2-2333f1614c3a>;
    <http://purl.org/dc/terms/type> <http://inspire.ec.europa.eu/metadata-codelist/ResourceType/dataset>;
    <http://purl.org/dc/terms/created> "2017-12-31"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Ekdatabasen 2017"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>;
    a <http://www.w3.org/ns/dcat#dataset>, <http://www.w3.org/ns/dcat#Dataset>
}


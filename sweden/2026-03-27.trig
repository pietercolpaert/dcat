    <http://www.w3.org/ns/dcat#endDate> "2026-03-27"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#startDate> "1995-01-01"^^<http://www.w3.org/2001/XMLSchema#date>;

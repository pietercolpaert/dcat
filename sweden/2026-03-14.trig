<#df55e9e745895782a72d08dbb32a717c> {
<https://www.geodata.se/resources/7d25f577-182e-4eff-8092-70b45fca8f8d> <http://www.w3.org/ns/dcat#keyword> "HVD"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/IRREG>;

<#1e0a4d18e618f9ff23e7ca69c5bbdecd> {
<http://api.kolada.se/v3/kpi/N79223> <http://www.w3.org/ns/dcat#keyword> "Region"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;

<https://doi.org/10.5878/001790> <http://www.w3.org/ns/dcat#keyword> "PARTICIPATION"@en, "DELTAGANDE"@sv, "PARTY IDENTIFICATION"@en, "PARTIIDENTIFIKATION"@sv, "WAGES"@en, "LÖNER"@sv, "LABOUR MOVEMENT"@en, "ARBETARRÖRELSE"@sv, "TRADE UNION MEMBERSHIP"@en, "MEDLEMSKAP I FACKFÖRENING"@sv, "WAGE DETERMINATION"@en, "LÖNESÄTTNING"@sv, "TRADE UNION OFFICIALS"@en, "FACKFÖRENINGSFUNKTIONÄRER"@sv, "LABOUR RELATIONS"@en, "ARBETSMARKNADSRELATIONER"@sv, "STRIKES"@en, "STREJKER"@sv, "LABOUR DISPUTES"@en, "ARBETSMARKNADSKONFLIKTER"@sv;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__24340.
_:b0__24340 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;

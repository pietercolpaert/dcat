<feed> <https://w3id.org/tree#member> <#729d16b253bb7514b834e13234d6ccbb>.
<#729d16b253bb7514b834e13234d6ccbb> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <http://api.kolada.se/v3/kpi/N70643>;
    <https://www.w3.org/ns/activitystreams#published> "2026-03-14T06:15:39.529Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#729d16b253bb7514b834e13234d6ccbb> {
<http://api.kolada.se/v3/kpi/N70643> <http://www.w3.org/ns/dcat#keyword> "Region"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "N70643";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Andel patienter som utreds inom ett standardiserat vårdförlopp av totalt antal personer som beräknas få en cancerdiagnos under året. Beräkningen baseras på underlag från Socialstyrelsen. Standardiserade vårdförlopp (SVF) är ett nationellt arbetssätt som ska minska onödig väntan och ovisshet för patienten. Alla SVF startar med en välgrundad misstanke om cancer. Vad som är välgrundad misstanke, hur det ska utredas och hur lång tid detta får ta, framgår av det nationella vårdprogrammet för varje cancerdiagnos. Tiden från välgrundad misstanke till start av behandling mäts likadant i hela landet. Inom ett SVF beskrivs vilka utredningar som ska göras vid misstanke om en viss cancersjukdom, samt inom vilka maximala tidsgränser som utredningarna ska eftersträvas att vara klara och den första behandlingen ska vara startad. Nämnaren består av totalt antal personer som beräknas få en cancerdiagnos under året. Beräkningen baseras på antal cancerfall de senaste tre åren med underlag från Cancerregistret vid Socialstyrelsen. "@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/N70643_json>;
    <http://purl.org/dc/terms/provenance> _:b0__823.
_:b0__823 <http://purl.org/dc/terms/description> "Källa: Vårdförloppsuppföljning vid cancer, SKR via Vården i siffror"@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/N70643> <http://purl.org/dc/terms/modified> "2025-08-18"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Standardiserat vårdförlopp för patienter med cancer, andel (%)"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/HEAL>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


_:b0__65961 <http://www.w3.org/ns/dcat#endDate> "2023-08-31"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#startDate> "2023-03-01"^^<http://www.w3.org/2001/XMLSchema#date>;

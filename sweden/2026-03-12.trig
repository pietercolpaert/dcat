<https://doi.org/10.5878/wzp5-pe66> <http://www.w3.org/ns/dcat#keyword> "POLITICS"@en, "POLITIK"@sv, "POLITICAL PARTIES"@en, "POLITISKA PARTIER"@sv, "PARTY POLITICS"@en, "PARTIPOLITIK"@sv, "MEMBERSHIP"@en, "MEDLEMSKAP"@sv, "DEMOCRACY"@en, "DEMOKRATI"@sv;

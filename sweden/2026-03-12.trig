<#e692ccef07b6b8e5a05302fda74368d0> {
<https://doi.org/10.23695/P5HW-DR52> <http://www.w3.org/ns/dcat#keyword> "Language Technology (Computational Linguistics)"@en, "corpus"@en;
    <http://www.w3.org/ns/dcat#distribution> <https://doi.org/10.23695/P5HW-DR52#distribution>;

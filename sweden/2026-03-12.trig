<https://opendata.upplandsvasby.se/dataset/3f326e95-5a45-4a78-b435-008465ec817a> <http://www.w3.org/ns/dcat#keyword> "Upplands Väsby kommun", "utegym", "ute";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;

    <http://purl.org/dc/terms/modified> "2025-06-16T09:32:31.831975Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Journalist 2011"@sv, "Swedish journalist 2011"@en;

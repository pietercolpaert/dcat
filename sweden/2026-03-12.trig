<#c39c13fca46ba4d77371e1b1f1aab0cc> {
<https://doi.org/10.5878/002388> <http://www.w3.org/ns/dcat#keyword> "CORS"@sv, "CORS"@en, "EMPLOYMENT"@en, "ANSTÄLLNING"@sv, "MIGRATION (HUMAN)"@en, "MIGRATION"@sv, "SOCIAL WELFARE"@en, "SOCIAL VÄLFÄRD"@sv, "ECONOMICS"@en, "EKONOMI"@sv;

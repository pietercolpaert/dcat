<feed> <https://w3id.org/tree#member> <#ee423bfb71881f72f2e9d9b20633a824>.
<#ee423bfb71881f72f2e9d9b20633a824> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <https://catalog.sodertalje.se/store/15/resource/11>;
    <https://www.w3.org/ns/activitystreams#published> "2026-03-12T06:18:41.425Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#ee423bfb71881f72f2e9d9b20633a824> {
<https://catalog.sodertalje.se/store/15/resource/11> <http://purl.org/dc/terms/license> <http://creativecommons.org/publicdomain/zero/1.0/>;
    <http://purl.org/dc/terms/format> "application/json";
    <http://xmlns.com/foaf/0.1/page> <https://catalog.sodertalje.se/store/15/resource/862>;
    <http://purl.org/dc/terms/issued> "2021-04-07"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://data.europa.eu/r5r/availability> <http://data.europa.eu/r5r/availability/stable>;
    <http://www.w3.org/ns/adms#status> <http://publications.europa.eu/resource/authority/distribution-status/COMPLETED>;
    <http://purl.org/dc/terms/modified> "2021-11-09"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#accessURL> <https://api.sodertalje.se/getwatertemp>;
    <http://purl.org/dc/terms/title> "Data temperatursensorer (IoT) badplatser - senast registrerat värde"@sv, "Data temperature sensors (IoT) public beaches - last recorded value"@en;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/description> "Datamängden Data temperatursensorer (IoT) badplatser visar temperaturmätningar i Södertälje kommuns badsjöar. Det sitter sensorer i badsjöarna som mäter vattentemperatur varje timme vilket sedan rapporteras vidare genom ett LoRaWAN-nät till en databas som det går att nå genom denna datamängd. Sensorerna sitter monterade på ca en meters djup.\n\nDistributionen visar senast registrerade värde.\n\n\nOm APIet ger tillbaka NO DATA så beror det på att alla sensorerna är antingen inplockade på säsongen eller tillfälligt ur funktion."@sv, "The dataset Data temperature sensors (IoT) bathing places shows temperature measurements in Södertälje municipality's bathing lakes. There are sensors in the bathing lakes that measure water temperature every hour, which is then reported further through a LoRaWAN network to a database that can be reached through this dataset. The sensors are mounted at a depth of about one meter.\n\nThe distribution shows the most recently recorded value.\n\nIf the API returns NO DATA it is because the sensors are either taken inside for the season or temporarily out of order."@en;
    a <http://www.w3.org/ns/dcat#Distribution>
}

<feed> <https://w3id.org/tree#member> <#152077fb6dbebc98b609b22791526b31>.
<#152077fb6dbebc98b609b22791526b31> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <https://catalog.sodertalje.se/store/15/resource/297>;
    <https://www.w3.org/ns/activitystreams#published> "2026-03-12T06:18:41.425Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#152077fb6dbebc98b609b22791526b31> {
<https://catalog.sodertalje.se/store/15/resource/297> <http://www.w3.org/ns/dcat#temporalResolution> "PT1H"^^<http://www.w3.org/2001/XMLSchema#duration>;
    <http://purl.org/dc/terms/license> <http://creativecommons.org/publicdomain/zero/1.0/>;
    <http://xmlns.com/foaf/0.1/page> <https://catalog.sodertalje.se/store/15/resource/862>;
    <http://data.europa.eu/r5r/availability> <http://data.europa.eu/r5r/availability/stable>;
    <http://www.w3.org/ns/adms#status> <http://publications.europa.eu/resource/authority/distribution-status/COMPLETED>;
    <http://www.w3.org/ns/dcat#accessURL> <https://api.sodertalje.se/GETALLwatertemp?start=2024-09-01&end=2024-09-15>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/description> "Datamängden Data temperatursensorer (IoT) badplatser visar temperaturmätningar i Södertälje kommuns badsjöar. Det sitter sensorer i badsjöarna som mäter vattentemperatur varje timme vilket sedan rapporteras vidare genom ett LoRaWAN-nät till en databas som det går att nå genom denna datamängd. Sensorerna sitter monterade på ca en meters djup.\n\nDistributionen visar historisk data och du väljer period i URL:en\n\nOm APIet ger tillbaka ett felmeddelande så beror det på att alla sensorerna är antingen inplockade på säsongen eller tillfälligt ur funktion under den valda perioden."@sv, "Historical data temperature sensors (IoT) public beaches, shows temperature measurements in Södertälje municipality's bathing lakes.\n\nThere are sensors in the bathing lakes that measure water temperature every day, which is then reported further through a LoRaWAN network to a database that can be accessed through this amount of data.\n\nThe sensors are mounted at a depth of about one meter.\n\nIf the API returns an error message it is because the sensors are either taken inside for the season or temporarily out of order during the selected period."@en;
    <http://purl.org/dc/terms/format> "application/json";
    <http://purl.org/dc/terms/issued> "2020-06-01"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2025-03-04"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Data temperatursensorer (IoT) badplatser - Historisk data"@sv, "Historical data temperature sensors (IoT) - Public beaches,"@en;
    a <http://www.w3.org/ns/dcat#Distribution>
}


    <http://purl.org/dc/terms/temporal> _:b0__570.
_:b0__570 <http://www.w3.org/ns/dcat#endDate> "2099-12-31"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#startDate> "2001-01-01"^^<http://www.w3.org/2001/XMLSchema#date>;
    a <http://purl.org/dc/terms/PeriodOfTime>.
<https://metadata.trafikverket.se/store/1/resource/977> <http://entryscape.org/terms/metadataIdentifier> "4adfd874-0a0c-43c3-9e1b-c61ee5463ffd";
    <http://www.w3.org/ns/dcat#keyword> "område: transport"@sv, "ämne: bytespunkt"@sv;
    <https://dataportal.se/concepts/geose/areaCoveredQuotient> "449964/449964";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/IRREG>;
    <http://www.w3.org/ns/prov#wasUsedBy> _:b0__8878.
_:b0__8878 <http://www.w3.org/ns/prov#generated> _:b0__204.

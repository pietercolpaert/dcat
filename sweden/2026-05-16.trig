    <http://purl.org/dc/terms/modified> "2022-03-28T11:02:21.328471Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Mikrofysikaliska egenskaper och fallhastighet av snöpartiklar från partikelbilder tagna med Dual Ice Crystal Imager (D-ICI) i Kiruna (Sverige) 2014–2018"@sv, "Snow ice particle microphysical properties and fall speed from particle images taken with the Dual Ice Crystal Imager (D-ICI) in Kiruna (Sweden) 2014–2018"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>;

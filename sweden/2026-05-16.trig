    <http://purl.org/dc/terms/issued> "2026-04-17"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2026-05-15T02:41:21.884236"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Träd"@sv, "Tree"@en, "Træ"@da;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>;

<http://api.kolada.se/v3/kpi/N07538> <http://purl.org/dc/terms/modified> "2025-03-31"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Anmälda ekobrott, antal/100 000 inv"@sv;

    <http://purl.org/dc/terms/issued> "2020-12-17"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2026-04-17T08:44:15.849278"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Förvärvsarbetande invånare 20-64 år, andel"@sv, "Employed residents aged 20-64, share"@en, "Beskæftigede beboere i alderen 20-64 år, andel"@da;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/SOCI>;
    a <http://www.w3.org/ns/dcat#Dataset>
}


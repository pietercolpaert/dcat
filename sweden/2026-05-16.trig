<https://opendata-catalog.smhi.se/md/9d8a1894-9f6c-4d74-9d2e-d481f8737ced> <http://www.w3.org/ns/dcat#keyword> "Öppna data"@sv, "Meteorologi"@sv, "Modelldata"@sv, "Lufttemperatur"@sv, "Nederbördsmängd"@sv, "Lufttryck"@sv, "Molnmängd"@sv, "Relativ luftfuktighet"@sv, "Vindhastighet"@sv, "Vindriktning"@sv, "HVD"@sv;

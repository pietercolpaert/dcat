    <https://www.w3.org/ns/activitystreams#published> "2026-03-17T06:23:37.135Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#58964f694b4a69b5a92a65049172b017> {
<https://www.geodata.se/resources/3542ba2c-db3e-409b-b357-723864763373> <http://www.w3.org/ns/dcat#keyword> "Inspire"@sv, "Landtäcke"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/OTHER>;
    <http://purl.org/dc/terms/identifier> "3542ba2c-db3e-409b-b357-723864763373";
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021004888>;
    <http://purl.org/dc/terms/description> "Data om marktäcke anpassat för skalområdet 1:10 000. Marktäcket inkluderar information om skog, åker, öppen mark och bebyggelseområde.\nDatamängden kan inte beställas separat utan ingår endast i befintliga tjänster: Marktäcke nedladdning Inspire och Basemap Visning Inspire\n\nDataset for Land cover in scale 1:10 000. The Land cover includes information about forest, arable land, open land and built-up areas.\nThe dataset can’t be ordered separately. It is only included in existing services: Land cover download Inspire and Basemap. Download Inspire"@sv;
    <http://purl.org/dc/terms/spatial> _:b0__97083.
_:b0__97083 <http://www.w3.org/ns/locn#geometry> "POLYGON((11.26 68.83,25.59 68.83,25.59 55.26,11.26 55.26,11.26 68.83))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.
<https://www.geodata.se/resources/3542ba2c-db3e-409b-b357-723864763373> <http://www.w3.org/ns/dcat#distribution> <urn:uuid:982e408f-6dd5-3109-a9a1-90dfb4ac032b>, <urn:uuid:529c5036-b1f1-38c8-f76d-de6b331c079d>, <urn:uuid:2085a5e3-19a1-ff0e-dd76-840daa0d187e>, <urn:uuid:fe5368a1-a64c-e757-c9ec-372bb92ce9b3>;
    <http://purl.org/dc/terms/provenance> _:b0__63805.
_:b0__63805 <http://www.w3.org/2000/01/rdf-schema#value> "The data began to be collected in the 1930s through the interpretation of aerial images in stereo and reconnaissance in the field. Nowadays photogrammetric techniques with aerial imagery are used for updating, for example stereo mapping and screen digitization of digital orthophoto.\n\nData började samlas in på 1930-talet genom tolkning av flygbilder i stereo och rekognosering i fält. Numera nyttjas helt fotogrammetriska metoder med flygbilder för ajourhållning t.ex. stereokartering och skärmbildsdigitalisering på digitalt ortofoto."@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<https://www.geodata.se/resources/3542ba2c-db3e-409b-b357-723864763373> <http://purl.org/dc/terms/modified> "2025-09-01"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Datamängd för marktäcke Inspire"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://inspire.ec.europa.eu/theme/lc>;
    a <http://www.w3.org/ns/dcat#Dataset>
}

<feed> <https://w3id.org/tree#member> <#a723c38e379ca5ff10607b7f0d3f09b6>.
<#a723c38e379ca5ff10607b7f0d3f09b6> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <https://www.geodata.se/resources/a72d6694-1169-47b3-aa53-8b7b264d9738>;

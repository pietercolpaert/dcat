    <http://purl.org/dc/terms/temporal> _:b0__61462.
_:b0__61462 <http://www.w3.org/ns/dcat#endDate> "2099-12-31"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#startDate> "2001-01-01"^^<http://www.w3.org/2001/XMLSchema#date>;
    a <http://purl.org/dc/terms/PeriodOfTime>.
<https://metadata.trafikverket.se/store/1/resource/1023> <http://entryscape.org/terms/metadataIdentifier> "639d91c3-4fae-4292-b8ec-a99d4b5c8ec1";
    <http://www.w3.org/ns/dcat#keyword> "område: transport"@sv, "trafikslag: järnväg"@sv;

<https://resources.stockholm.se/data/2b4ffea4-53a0-4782-9b12-961a36b9419a> <http://www.w3.org/ns/dcat#keyword> "Stockholms stad", "Verksamhetsdata"@sv, "Extern dataportal"@sv, "4.URI som identifierare"@sv, "infoMapAccessService"@sv, "NVDB"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/CONT>;
    <http://purl.org/dc/terms/identifier> "2b4ffea4-53a0-4782-9b12-961a36b9419a";

<https://resources.stockholm.se/data/ed5cb18b-ff08-469a-a5c8-91eeef9510dc> <http://www.w3.org/ns/dcat#keyword> "Stockholms stad", "Trafik"@sv, "Verksamhetsdata"@sv, "Extern dataportal"@sv, "Ingen eller försumbar"@sv, "Trafikplanering"@sv, "Trafikmätning"@sv, "Trafikflöde"@sv, "Traffic flow observed"@sv, "Fiware"@sv, "2.Maskinläsbar"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/CONT>;

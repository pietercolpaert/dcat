<http://api.kolada.se/v3/kpi/N17672> <http://www.w3.org/ns/dcat#keyword> "Kommun"@sv, "Enhetsnivå"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;

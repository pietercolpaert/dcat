<#a3adc024bba6c7cfacf0f73fab27d322> {
<https://doi.org/10.5878/d9ck-bd78> <http://www.w3.org/ns/dcat#keyword> "folkhälsa"@sv, "public health"@en, "husdjursskötsel (ekonomi)"@sv, "livestock industry"@en, "antibiotika"@sv, "antibiotikaresistens"@sv, "antibiotic resistance"@en, "antimikrobiella läkemedel"@sv, "antimicrobial drugs"@en, "folkhälsovetenskap"@sv, "public health medicine"@en, "fjäderfäskötsel (arbete)"@sv, "poultry farming"@en, "Vietnam"@sv, "Vietnam"@en, "låg- och medelinkomstländer"@sv, "low- and middle-income countries"@en, "antibiotics"@en, "husdjursproducenter"@sv, "livestock farmers"@en, "djurläkemedel"@sv, "veterinary drugs"@en, "veterinary medicine"@en, "veterinärmedicin"@sv, "escherichia coli"@en, "Southeast Asia"@en, "Sydostasien"@sv;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__40900.
_:b0__40900 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;

    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/SOCI>;
    <http://purl.org/dc/terms/temporal> _:b0__8664.
_:b0__8664 <http://www.w3.org/ns/dcat#startDate> "2008-01-01"^^<http://www.w3.org/2001/XMLSchema#date>;

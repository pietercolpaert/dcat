<#d67356ac334ed81e5ba7262619289970> {
<http://api.kolada.se/v3/kpi/U28628> <http://www.w3.org/ns/dcat#keyword> "Kommun"@sv, "Enhetsnivå"@sv, "Rådet för främjande av kommunala analyser - Kolada";

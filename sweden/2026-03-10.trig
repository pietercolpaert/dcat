_:b0__48966 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/author>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/22039c963ea2299d30d38116bde04643>;

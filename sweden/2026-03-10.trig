    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2120001371>;
    <http://purl.org/dc/terms/description> "Miljöstationen är ett komplement till Kungälvs kommuns övriga återvinningscentraler och här kan du lämna ditt farliga avfall.\n\nKungälvs kommun friskriver sig från varje form av ansvar för fel eller förändringar i öppna data som levererats från Kungälvs kommun till konsumenten. Kungälvs kommun friskriver sig från varje form av ansvar för skada eller annan olägenhet som kan uppkomma för konsumenten till följd av nyttjande av öppna data i följdproduktion eller tillsammans med annan information."@sv;
    <http://www.w3.org/ns/dcat#distribution> <https://catalog.kungalv.se/store/1/resource/55>, <https://catalog.kungalv.se/store/1/resource/57>;
    <http://purl.org/dc/terms/title> "Miljöstationer i Kungälv"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>;
    <http://entryscape.com/terms/basedOn> <https://assets.entryscape.com/store/13/resource/69>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


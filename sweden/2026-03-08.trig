<feed> <https://w3id.org/tree#member> <#c5a2fb6f10e75a410a446a21325ee6d0>.
<#c5a2fb6f10e75a410a446a21325ee6d0> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <https://jobstream.api.jobtechdev.se/#distributionJob_Stream>;
    <https://www.w3.org/ns/activitystreams#published> "2026-03-08T06:13:38.273Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#c5a2fb6f10e75a410a446a21325ee6d0> {
<https://jobstream.api.jobtechdev.se/#distributionJob_Stream> <http://purl.org/dc/terms/license> <http://creativecommons.org/publicdomain/zero/1.0/>;
    <http://purl.org/dc/terms/format> "application/json";
    <http://www.w3.org/ns/dcat#accessService> <https://jobstream.api.jobtechdev.se/#dataserviceJob_Stream>;
    <http://data.europa.eu/r5r/availability> <http://data.europa.eu/r5r/availability/stable>;
    <http://www.w3.org/ns/adms#status> <http://publications.europa.eu/resource/authority/distribution-status/COMPLETED>;
    <http://www.w3.org/ns/dcat#accessURL> <https://jobstream.api.jobtechdev.se>;
    <http://purl.org/dc/terms/title> "JobStream API"@en, "JobStream API"@sv;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>, <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/description> "JobStream provides access to all job advertisements, published on the Swedish Public Employment Service’s Job board (Platsbanken), including real-time information, related to changes, regarding these advertisements, e.g. publishing or deleting of job posts, or updates of job ads texts.By using this API, it gives the opportunity to make a copy of all the job advertisements, published on the Swedish Public Employment Service’s Job board (Platsbanken). It is also possible to filter by professions and/or themes of geography. Furthermore, it can be used to create an own search engine, or to conduct different types of analysis. The advertisements can be kept up-to-date via JobStream, while changes are saved in the own database, including expired and/or depublished job advertisements."@en, "JobStream ger tillgång till alla platsannonser som är publicerade i Platsbanken, inklusive realtidsinformation om förändringar som sker runt eller i dessa platsannonser, t.ex. publiceringar, avpubliceringar eller uppdateringar av annonstexter. Det ger möjlighet att ha en egen kopia av alla platsannonser som publiceras via Arbetsförmedlingen. Det går även att filtrera på yrkes- eller geografiska begrepp. Det kan användas för att skapa en egen sökmotor, eller för olika typer av analys. Platsannonserna kan hållas uppdaterade via JobStream så att ändringar sparas i den egna databasen, och så att avpublicerade platsannonser kan hanteras."@sv;
    <http://purl.org/dc/terms/conformsTo> <https://jobstream.api.jobtechdev.se/swagger.json>;
    a <http://www.w3.org/ns/dcat#Distribution>, <http://entryscape.com/terms/ServiceDistribution>
}


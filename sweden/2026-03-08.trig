    <http://purl.org/dc/terms/issued> "2025-02-03T14:33:44.644022Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.5878/gyf8-6823>;
    <http://purl.org/dc/terms/modified> "2025-02-03T14:33:44.644022Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Nationell Riktad Skogsskadeinventering (NRS) - Barkborreskador på gran i Västernorrland 2013"@sv, "Target Tailored Forest Damage Inventory (TFDI) - Damage by bark beetles on Norway spruce in the county of Västernorrland 2013"@en;
    <http://purl.org/dc/terms/temporal> _:b0__46967.
_:b0__46967 <http://www.w3.org/ns/dcat#endDate> "2013-10-04"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#startDate> "2013-09-02"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    a <http://purl.org/dc/terms/PeriodOfTime>
}

<feed> <https://w3id.org/tree#member> <#4da3c80a092ba31e5433beec58ec0b2b>.
<#4da3c80a092ba31e5433beec58ec0b2b> a <https://www.w3.org/ns/activitystreams#Update>;

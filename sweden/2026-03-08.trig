<#fd13f858bb9bf9a5b863fbee0e6a9b3d> {
<https://doi.org/10.5878/7fgz-e479> <http://www.w3.org/ns/dcat#keyword> "Antarktis"@sv, "Antarctica"@en, "Antarctic region"@en, "Första svenska Antarktisexpeditionen, 1901-1904"@sv, "Swedish Antarctic Expedition, 1901-1904"@en, "Nordenskjöld, Otto, 1869-1928"@sv, "Nordenskjöld, Otto, 1869-1928"@en, "arkeologiskt område"@sv, "archaeological site"@en, "polarexpeditioner"@sv, "polar expeditions"@en, "Ad��liepingvin (Pygoscelis adeliae)"@sv, "Adélie penguin (Pygoscelis adeliae)"@en, "Hakremspingvin (Pygoscelis antarcticus)"@sv, "Chinstrap penguin (Pygoscelis antarcticus)"@en, "Åsnepingvin (Pygoscelis papua)"@sv, "Gentoo penguin (Pygoscelis papua)"@en;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__51506.
_:b0__51506 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;

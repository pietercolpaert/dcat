    <http://purl.org/dc/terms/modified> "2024-05-03"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "SE.ACMF Meteorologiska observationer - Markytans tillstånd"@sv;

<#729418fa88261e5dc93c456f0a9a5239> {
<https://opendata-api.malmo.se/dataset/9e894366-4d3f-47bb-8b9d-fe49d68b0160> <http://www.w3.org/ns/dcat#keyword> "Malmö stad", "statistik";
    <http://www.w3.org/ns/dcat#distribution> <https://opendata-api.malmo.se/dataset/9e894366-4d3f-47bb-8b9d-fe49d68b0160/resource/8f3f8c7d-0dec-44a4-ad3f-f5c9ea805575>, <https://opendata-api.malmo.se/dataset/9e894366-4d3f-47bb-8b9d-fe49d68b0160/resource/040a16e4-eb33-46e2-bb03-dcb351389434>;

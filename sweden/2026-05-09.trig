<#a4733ac7cb6d13ac8fc83dcbbc61cf4c> {
<https://opendata.umea.se/api/v2/catalog/datasets/vaxthusgasutslapp_umea> <http://www.w3.org/ns/dcat#keyword> "Umeå kommun", "Koldioxidutsläpp"@sv, "Utsläpp"@sv, "CO2"@sv, "CO2e"@sv;
    <http://purl.org/dc/terms/identifier> "vaxthusgasutslapp_umea@http://dataportal.se/organisation/SE2120002627";
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://admin.dataportal.se/store/43/resource/7a00bd3796ed09a600646432cb321722>;
    <http://purl.org/dc/terms/description> "Data kommer från den nationella emissionsdatabasen som samlar Sveriges nationella utsläpp av klimatgaser och luftföroreningar som fördelade till läns- och kommunnivå. I detta data set finns Umeås utsläpp fördelade på olika sektorer i CO2e. Uppgifterna utgår från Sveriges officiella utsläppsstatistik. "@sv;

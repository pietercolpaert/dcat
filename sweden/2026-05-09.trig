<#35d2e572a2437cd4bf3dc1342e95529a> {
<https://opendata-api.malmo.se/dataset/c914ed8b-8ce2-42cd-a138-e501215ef8b2> <http://www.w3.org/ns/dcat#keyword> "Malmö stad", "laddning", "laddstationer", "laddstolpar", "elfordon", "charging", "elbil", "laddpunkter", "EV";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/IRREG>;
    <http://purl.org/dc/terms/identifier> "c914ed8b-8ce2-42cd-a138-e501215ef8b2";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://malmo.se/>;
    <http://purl.org/dc/terms/description> "Malmö stad tillhandahåller för närvarande inga kommunalt anordnade laddpunkter för allmänt bruk.\n\nFör laddning av elfordon i Malmö stad hänvisas till aktörer som erbjuder offentliga laddplatser, t.ex. parkeringsbolag, mackar, el-leverantörer och detaljhandel."@sv, "The city of Malmö currently does not provide any municipally arranged charging\npoints for public use.\n\nFor charging electric vehicles in the city of Malmö, please refer to actors\nwho offer public charging points, such as parking companies, gas stations,\nelectricity suppliers and retailers.\n\n"@en, "Malmø kommune stiller i øjeblikket ingen kommunalt arrangerede ladestandere\ntil rådighed til offentlig brug.\n\nFor opladning af elbiler i Malmø by henvises til aktører, der tilbyder\noffentlige ladepunkter, såsom parkeringsselskaber, tankstationer,\nelleverandører og detailhandlere.\n\n"@da;
    <http://purl.org/dc/terms/spatial> <http://www.geonames.org/2692965/malmoe.html>, _:b0__876.
_:b0__876 <http://www.w3.org/ns/dcat#bbox> "POLYGON((12.8850967451 55.6421476735,13.1517619812 55.6421476735,13.1517619812 55.5022773196,12.8850967451 55.5022773196,12.8850967451 55.6421476735))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.
<https://opendata-api.malmo.se/dataset/c914ed8b-8ce2-42cd-a138-e501215ef8b2> <http://www.w3.org/ns/dcat#contactPoint> <https://admin.dataportal.se/store/290/resource/155fe08a3c2cd31689f13de2b1fbdc76>;
    <http://purl.org/dc/terms/issued> "2022-12-01"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2026-03-25T14:58:10.530524"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Laddstationer för elfordon"@sv, "Charging stations for electric vehicles"@en, "Ladestationer til elbiler"@da;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TRAN>;
    a <http://www.w3.org/ns/dcat#Dataset>

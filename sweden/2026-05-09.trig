    <http://purl.org/dc/terms/modified> "2026-05-08T11:59:44.529011"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Pendling 2011-2021 - Statistikunderlag för Malmös områden"@sv, "Commuting 2011-2021 - Statistical data for Malmö's areas"@en, "Pendling 2011-2021 - Statistiske data for Malmøs områder"@da;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/SOCI>;

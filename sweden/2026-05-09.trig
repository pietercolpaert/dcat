<https://www.geodata.se/resources/f17cf1dd-ad0d-4c1b-8e9f-605319212edc> <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/CONT>;
    <http://purl.org/dc/terms/identifier> "f17cf1dd-ad0d-4c1b-8e9f-605319212edc";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021002361-LST>;
    <http://purl.org/dc/terms/description> "Samtliga Protokoll A för alla metoder som finns inlagda i Nationella Biotopkarteringsdatabasen. \nVarje Protokoll A representerar en biotopkarterad sträcka i ett vattendrag.\n\nSträckorna ligger inlagda som linjer. \nVarje protokoll A har en startpunkt och en slutpunkt. Ändarna på varje linje är den sträckans startpunkt och stoppunkt. Startpunkten är den ände av linjerna som ligger uppströms i vattendraget.\nMängden data för objekten är begränsat i skiktet, men varje linje har en länk till objektets protokoll i databasen.\nAlla sträckor har inte linjer inlagda i databasen. För att se dessa behöver du även ladda ner punktskiktet.\n\nKoordinater är i Sweref 99 TM."@sv;
    <http://purl.org/dc/terms/spatial> _:b0__1380.
_:b0__1380 <http://www.w3.org/ns/locn#geometry> "POLYGON((10.0301 69.0617,24.2195 69.0617,24.2195 54.9804,10.0301 54.9804,10.0301 69.0617))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.
<https://www.geodata.se/resources/f17cf1dd-ad0d-4c1b-8e9f-605319212edc> <http://purl.org/dc/terms/spatial> _:b0__263.
_:b0__263 <http://www.w3.org/ns/locn#geometry> "POLYGON((12.91781 66.84361,23.45926 66.84361,23.45926 56.1724,12.91781 56.1724,12.91781 66.84361))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.
<https://www.geodata.se/resources/f17cf1dd-ad0d-4c1b-8e9f-605319212edc> <http://www.w3.org/ns/dcat#contactPoint> <urn:uuid:054df213-7e73-b0a3-05f5-093b3c141de9>;
    <http://www.w3.org/ns/dcat#distribution> <urn:uuid:65a19dab-4a20-1345-3500-c05e6f37d575>, <urn:uuid:4ff758d8-da69-cab4-def8-3f3659c72561>;
    <http://purl.org/dc/terms/issued> "2021-04-09"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2026-05-06"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "LST Protokoll A, samtliga inventerade sträckor, linjer - Biotopkarteringsdatabasen"@sv;
    a <http://www.w3.org/ns/dcat#Dataset>
}

<feed> <https://w3id.org/tree#member> <#1e92dbd680dee0b681ecaa29ea0c8293>.

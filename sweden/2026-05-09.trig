    <http://purl.org/dc/terms/modified> "2026-05-08T12:01:05.659983"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Nattbefolkning efter SNI 2007, 2022 -  - Statistikunderlag för Malmös områden"@sv, "Nighttime population according to SNI 2007, 2022 - - Statistical data for Malmö's areas"@en, "Natbefolkning ifølge SNI 2007, 2022 - - Statistiske data for Malmøs områder"@da;

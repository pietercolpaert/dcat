<#daddb371d477194351c1c24a47460ab2> {
<https://opendata.umea.se/api/v2/catalog/datasets/nybyggda-bostaeder-upplatelseform> <http://www.w3.org/ns/dcat#keyword> "Umeå kommun", "Statistik"@sv, "Statistik och analys"@sv, "Bostäder"@sv, "Bostadsbyggande"@sv;
    <http://purl.org/dc/terms/identifier> "nybyggda-bostaeder-upplatelseform@http://dataportal.se/organisation/SE2120002627";

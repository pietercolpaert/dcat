<#a05c57873cb26c03eea9bac782e4af8a> {
<https://doi.org/10.5879/gp51-a110> <http://www.w3.org/ns/dcat#keyword> "ATMOSPHERIC TEMPERATURE"@en, "AIR TEMPERATURE"@en, "SURFACE TEMPERATURE"@en;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__42285.
_:b0__42285 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/40fa54d4179ee0be292af6d9d5300dc9>;

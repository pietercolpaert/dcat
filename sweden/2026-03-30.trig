<#f10efc9115ff3eb7c3e0dcbcab684b4d> {
<https://opendata-catalog.smhi.se/md/527b0f30-7d22-11ed-a51b-432755aaeed3> <http://www.w3.org/ns/dcat#keyword> "Is"@sv, "Öppna data"@sv, "Hydrologi"@sv, "Observation"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/IRREG>, <http://publications.europa.eu/resource/authority/frequency/OTHER>;

<http://api.kolada.se/v3/kpi/N15539> <http://purl.org/dc/terms/modified> "2025-10-22"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Elever i åk 6 som uppnått betygskriterierna i alla ämnen (som eleven läser), lägeskommun, andel (%)"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/SOCI>, <http://publications.europa.eu/resource/authority/data-theme/EDUC>;

<#a47a84807e9b3cc58cf6ddd22b510f46> {
<https://doi.org/10.5878/002999> <http://www.w3.org/ns/dcat#keyword> "TAXATION"@en, "BESKATTNING"@sv, "HOUSING"@en, "BOENDE"@sv, "LOCAL GOVERNMENT SERVICES"@en, "KOMMUNAL SERVICE"@sv, "ENVIRONMENT"@en, "MILJÖ"@sv, "CHILD CARE"@en, "BARNOMSORG"@sv, "WORKING CONDITIONS"@en, "ARBETSFÖRHÅLLANDEN"@sv, "WAGES"@en, "LÖNER"@sv, "UNEMPLOYMENT"@en, "ARBETSLÖSHET"@sv, "HOURS OF WORK"@en, "ARBETSTID"@sv, "SAVINGS"@en, "SPARANDE"@sv, "SHARES"@en, "AKTIER"@sv, "HOUSEHOLDS"@en, "HUSHÅLL"@sv, "HEALTH"@en, "HÄLSA"@sv, "FISCAL POLICY"@en, "SKATTEPOLITIK"@sv, "CARS"@en, "BILAR"@sv, "INCOME"@en, "INKOMST"@sv, "HOUSING ECONOMICS"@en, "BOSTADSEKONOMI"@sv, "LABOUR AND EMPLOYMENT"@en, "ARBETE OCH SYSSELSÄTTNING"@sv, "INHERITANCE"@en, "ARV"@sv, "EDUCATION"@en, "UTBILDNING"@sv, "MOONLIGHTING"@en, "SVARTARBETE"@sv, "HOME OWNERSHIP"@en, "BOSTADSÄGANDE"@sv, "HOUSING TENURE"@en, "BOENDEFORMER"@sv, "PROPERTY, OWNERSHIP AND TENURE"@en, "EGENDOM, ÄGANDE OCH BESITTNING"@sv, "HOME SELLING"@en, "BOSTADSFÖRSÄLJNING"@sv, "HOME BUYING"@en, "BOSTADSINKÖP"@sv, "HOUSING FINANCE"@en, "BOSTADSFINANSIERING"@sv, "BOATS"@en, "BÅTAR"@sv, "BUILDING COSTS"@en, "BYGGNADSKOSTNAD"@sv, "EXPENDITURE"@en, "UTGIFT"@sv, "SECOND HOMES"@en, "FRITIDSBOSTÄDER"@sv;

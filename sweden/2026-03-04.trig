<http://api.kolada.se/v3/kpi/U71454> <http://purl.org/dc/terms/modified> "2025-03-14"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Patientupplevd kvalitet avseende respekt och bemötande i primärvården, index"@sv;

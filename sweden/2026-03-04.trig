<#ebaeccbb9d7c37c6803f3d1f638734d7> {
<https://doi.org/10.5878/002396> <http://www.w3.org/ns/dcat#keyword> "CORS"@sv, "CORS"@en, "RELIGIOUS ATTENDANCE"@en, "RELIGIÖST DELTAGANDE"@sv, "INTERNAL POLITICS"@en, "INRIKESPOLITIK"@sv, "PUBLIC SECTOR"@en, "OFFENTLIG SEKTOR"@sv, "TAXATION"@en, "BESKATTNING"@sv, "PUBLIC SERVICES"@en, "OFFENTLIG SERVICE"@sv, "TRUST"@en, "FÖRTROENDE"@sv, "FISCAL POLICY"@en, "SKATTEPOLITIK"@sv, "SOCIAL WELFARE"@en, "SOCIAL VÄLFÄRD"@sv, "PUBLIC EXPENDITURE"@en, "OFFENTLIG UTGIFT"@sv, "SOCIAL SECURITY"@en, "SOCIAL TRYGGHET"@sv, "OPPOSITION PARTIES"@en, "OPPOSITIONSPARTIER"@sv, "RELIGIOUS AFFILIATION"@en, "RELIGIÖS TILLHÖRIGHET"@sv, "POLITICAL EXTREMISM"@en, "POLITISK EXTREMISM"@sv, "GOVERNMENT ROLE"@en, "STATSMAKTENS ROLL"@sv, "CORRUPTION"@en, "KORRUPTION"@sv;

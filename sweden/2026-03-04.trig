    <http://purl.org/dc/terms/modified> "2026-03-02T16:32:41.428146Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "CATSS18 - The Child and Adolescent Twin Study in Sweden (18 years)"@en, "CATSS18 - The Child and Adolescent Twin Study in Sweden (18 år)"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/HEAL>;
    <http://purl.org/dc/terms/temporal> _:b0__2150.
_:b0__2150 <http://www.w3.org/ns/dcat#startDate> "2011"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    a <http://purl.org/dc/terms/PeriodOfTime>
}


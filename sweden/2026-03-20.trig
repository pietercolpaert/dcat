<#229ba64aec2472f6ff520c0c11df9d63> {
<https://opendata-catalog.smhi.se/md/8cbb2fe0-f755-11ea-ac97-ab810184d520> <http://www.w3.org/ns/dcat#keyword> "Öppna data"@sv, "Inspire"@sv, "Observation"@sv, "Oceanografi"@sv, "Geografiska oceanografiska förhållanden"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "_8cbb2fe0-f755-11ea-ac97-ab810184d520", "8cbb2fe0-f755-11ea-ac97-ab810184d520";
    <http://www.w3.org/ns/dcat#byteSize> "28129"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021000696>;
    <http://purl.org/dc/terms/description> "Årets medelvattenstånd används som referensnivå när vattenstånd anges relativt medelvattenståndet. När medelvattenståndet beräknas filtreras mellanårsvariationer och långsamma trender som global havsnivåförändring och landhöjning bort. Årets medelvattenstånd är inte samma sak som årsmedelvärdet. \n\nFör mer info se: \nhttps://www.smhi.se/kunskapsbanken/oceanografi/vattenstand-i-havet/arets-medelvattenstand\n\nLeverans: Data levereras på två olika sätt\n1. Som en PDF som kan hittas på https://www.smhi.se/data/hav-och-havsmiljo/havsvattenstand.\n2. Via en maskin-maskin-lösning (Atomflöde). Datamängden är här Inspireanpassad."@sv;
    <http://purl.org/dc/terms/spatial> <https://www.geonames.org/2661886>, _:b0__264.
_:b0__264 <http://www.w3.org/ns/dcat#centroid> "POINT(17.52 60.60)"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    <http://www.w3.org/ns/dcat#bbox> "POLYGON((11 66,24 66,24 55,11 55,11 66))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    <http://www.w3.org/ns/dcat#endDate> "2026-03-20"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#startDate> "2020-01-01"^^<http://www.w3.org/2001/XMLSchema#date>;

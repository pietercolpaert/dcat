    <http://www.w3.org/ns/dcat#distribution> <https://doi.org/10.48723/110j-sn42#distribution>;
    <http://purl.org/dc/terms/issued> "2024-07-29T12:25:55.797249Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

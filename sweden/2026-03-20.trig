TILLHÖRIGHET"@sv, "DEMOCRACY"@en, "DEMOKRATI"@sv, "RESEARCH"@en, "FORSKNING"@sv, "CLIMATE"@en, "KLIMAT"@sv, "INTERNET USE"@en, "INTERNETANVÄNDNING"@sv, "LIBRARIES"@en, "BIBLIOTEK"@sv, "RENEWABLE ENERGY"@en, "FÖRNYBAR ENERGI"@sv, "RELIGIOUS BELIEFS"@en, "RELIGIÖS TRO"@sv, "IDEOLOGIES"@en, "IDEOLOGI"@sv, "RELIGIOUS BEHAVIOUR"@en, "RELIGIÖST BETEENDE"@sv, "INTERNATIONAL COOPERATION"@en, "INTERNATIONELLT SAMARBETE"@sv, "IMMIGRATION POLICY"@en, "INVANDRINGSPOLITIK"@sv, "ENERGY EFFICIENCY"@en, "ENERGISPARANDE"@sv, "SOCIAL CARE"@en, "OMSORG"@sv;

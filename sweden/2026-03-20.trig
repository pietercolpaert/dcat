    <https://www.w3.org/ns/activitystreams#object> <https://opendata.umea.se/api/v2/catalog/datasets/energiforbrukning-i-geografiska-omradet-123501-mariestrand>;
    <https://www.w3.org/ns/activitystreams#published> "2026-03-20T06:19:15.234Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#af76e39e185d21ef22b518c55d9c3b2b> {
<https://opendata.umea.se/api/v2/catalog/datasets/energiforbrukning-i-geografiska-omradet-123501-mariestrand> <http://www.w3.org/ns/dcat#keyword> "Energi"@sv, "Consumption"@en, "Umeå Energi", "Förbrukning"@sv, "El"@sv, "Fjärrvärme"@sv, "Energy"@en, "Electricity"@en, "District heating"@en;
    <http://purl.org/dc/terms/identifier> "energiforbrukning-i-geografiska-omradet-123501-mariestrand@http://dataportal.se/organisation/SE2120002627";
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://admin.dataportal.se/store/43/resource/fd2584866d01e4eaee64e3ffcfe40e02>;
    <http://purl.org/dc/terms/description> "Anonymiserad förbrukningsdata från Umeå Energi per nyckelkodsområde i Umeå Kommun. Detta data bör inte ses som exakta och kompletta förbrukningsvärden utan mer som en kvalificerad uppskattning av förbrukningen i syfte att se trender och indikationer.Datafilerna kommer endast innehålla värden för fastigheter i Umeå kommun där Umeå Energi är nätägare och informationen inte anses vara olämplig för distribution. Uppdateras normalt en gång varje månad med nytillkomna värden.Frågor kring detta förbrukningsdata hänvisas till matdata.datalager@umeaenergi.se "@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://opendata.umea.se/explore/?refine.dcat.contact_name=Ume%C3%A5+Energi&refine.dcat.contact_email=matdata.datalager%2540umeaenergi.se>;
    <http://www.w3.org/ns/dcat#distribution> <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-123501-mariestrand-API>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-123501-mariestrand-csv>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-123501-mariestrand-json>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-123501-mariestrand-jsonl>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-123501-mariestrand-parquet>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-123501-mariestrand-rdfxml>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-123501-mariestrand-jsonld>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-123501-mariestrand-turtle>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-123501-mariestrand-n3>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-123501-mariestrand-xlsx>;

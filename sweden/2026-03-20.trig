    <http://www.w3.org/ns/dcat#distribution> <https://opendata-download-grid-archive.smhi.se/feed/5>, <https://opendata-view.smhi.se/grid-archive/arome_extent/wms?service=wms&request=getcapabilities>, <https://opendata.smhi.se/gridarchive/index_met>, <https://www.smhi.se/data/temperatur-och-vind/temperatur/historisk-data-i-grib-format/sa-fungerar-grib-format>, <https://www.smhi.se/data/temperatur-och-vind/temperatur/historisk-data-i-grib-format/arome>, <urn:uuid:e0c57e61-41bb-c47b-6748-f5a220b517db>, <urn:uuid:7a82d1d4-0157-9048-cad7-35d3bff0eda3>, <urn:uuid:e9e5e835-6fa8-b305-4987-c86bb0272bdd>, <urn:uuid:636a3f53-f054-543d-0f52-66e56b2d0ae2>, <urn:uuid:67553301-1b76-dbb3-e6a0-5dd5371c77b0>;
    <http://purl.org/dc/terms/issued> "2014-03-20"^^<http://www.w3.org/2001/XMLSchema#date>;

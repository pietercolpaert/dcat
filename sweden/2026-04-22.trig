    <https://www.w3.org/ns/activitystreams#published> "2026-04-22T06:38:33.495Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#9701b1bce31a29199d5acc4e3b5d5d6c> {
<https://doi.org/10.15468/TBB5ZR> <http://www.w3.org/ns/dcat#keyword> "Occurrence"@en, "OCCURRENCE"@en, "Specimen"@en, "Gothenburg Natural History Museum";

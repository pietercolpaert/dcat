<https://doi.org/10.5878/f1qk-px15> <http://www.w3.org/ns/dcat#keyword> "skog"@sv, "barrträd"@sv, "conifers"@en, "forest"@en, "vegetation"@en, "leaf age"@en, "ständigt gröna växter"@sv, "evergreen plants"@en, "barr"@sv, "needles (parts of plants)"@en, "ackumulation"@sv, "accumulation"@en, "kvicksilver"@sv, "mercury"@en, "vegetation"@sv, "mättnad"@sv, "saturation"@en, "Picea abies"@en, "Trochodendron aralioides"@en, "Abies pinsapo var. marocana"@en, "Rhododendron catawbiense"@en;

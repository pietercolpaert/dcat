    <http://purl.org/dc/terms/issued> "2020-12-18T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.15468/597VPH>;

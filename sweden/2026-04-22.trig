    <http://purl.org/dc/terms/issued> "2019-04-15T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.5878/hd4x-7x60>;
    <http://purl.org/dc/terms/modified> "2025-01-20T12:50:13.086633Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

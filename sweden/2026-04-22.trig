<#8096bed9557934ce200f7dd35a03bf19> {
<https://opendata-catalog.smhi.se/md/a52a78e0-89ed-11ea-a966-bfa48b38ccc2> <http://www.w3.org/ns/dcat#keyword> "Öppna data"@sv, "Observation"@sv, "Oceanografi"@sv, "Havsvattenstånd"@sv, "Geografiska oceanografiska förhållanden"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/MONTHLY>;
    <http://purl.org/dc/terms/identifier> "_a52a78e0-89ed-11ea-a966-bfa48b38ccc2", "a52a78e0-89ed-11ea-a966-bfa48b38ccc2";

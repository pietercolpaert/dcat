<#62918ba2fa5dfb700313d8c97833d738> {
<https://doi.org/10.5878/9qg4-9a30> <http://www.w3.org/ns/dcat#keyword> "Primärvård"@sv, "Cardiovascular Diseases"@en, "Nervsystemets sjukdomar"@sv, "Nervous System Diseases"@en, "Rehabilitering"@sv, "Rehabilitation"@en, "Primary Health Care"@en, "Lungsjukdomar"@sv, "Lung Diseases"@en, "prevention"@sv, "prevention"@en, "Aktiviteter i dagliga livet"@sv, "Activities of Daily Living"@en, "Kronisk sm��rta"@sv, "Chronic Pain"@en, "Kardiovaskulära sjukdomar"@sv, "Patients"@en, "Patienter"@sv, "Self-Management"@en, "Självstyrning"@sv, "Healthcare organization"@en, "vårdgivare"@sv, "Healthcare professional"@en, "hälso- och sjukvårdspersonal"@sv, "referral processes"@en, "remissvägar"@sv, "experiences"@en, "erfarenheter"@sv, "sjukvårdsorganisation"@en, "healthcare organization"@sv, "care processes"@en, "vårdprocesser"@sv, "professionals"@en, "professioner"@sv, "CHRONIC ILLNESS"@en, "KRONISK SJUKDOM"@sv;

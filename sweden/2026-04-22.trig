<#512b770a89322fd0457eb53d0b7678c0> {
<https://opendata-catalog.smhi.se/md/2cb9200d-57a3-4068-8157-5706fd0c587b> <http://www.w3.org/ns/dcat#keyword> "Öppna data"@sv, "Meteorologi"@sv, "Observation"@sv, "Solskenstid"@sv, "HVD"@sv, "Geografiska meteorologiska förhållanden"@sv;

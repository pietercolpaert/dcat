    <http://www.w3.org/ns/dcat#distribution> <https://opendata-api.malmo.se/dataset/39273cfc-aa1c-444a-8b72-6f27cd4a8db2/resource/266d4d8d-cef7-415c-bef1-ed3c8581c687>;

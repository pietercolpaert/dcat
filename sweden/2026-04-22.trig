_:b0__8521 <http://purl.org/dc/terms/description> "Källa: Skolverket"@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/N11055> <http://purl.org/dc/terms/modified> "2025-04-24"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Heltidstjänster i förskola med viss pedagogisk utbildning, kommunal regi, andel (%)"@sv;

    <http://purl.org/dc/terms/modified> "2026-03-18T21:27:49.307634"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Elever i årskurs 9 - genomsnitt av meritvärde, lägeskommun (17 ämnen)"@sv, "Students in grade 9 - average of merit value, location municipality (17 subjects)"@en, "Elever i 9. klasse - gennemsnit af meritværdi, placeringskommune (17 fag)"@da;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/EDUC>;

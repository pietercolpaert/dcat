<#8e72d89c7074d4d685975720ed3e6b3b> {
<https://opendata-catalog.smhi.se/md/e1faa8e1-77ad-4716-8266-e3c359e043eb> <http://www.w3.org/ns/dcat#keyword> "Is"@sv, "Öppna data"@sv, "Observation"@sv, "Oceanografi"@sv;

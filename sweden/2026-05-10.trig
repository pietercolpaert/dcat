<http://api.kolada.se/v3/kpi/N79196> <http://www.w3.org/ns/dcat#keyword> "Region"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "N79196";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Relativ 5-årsöverlevnad vid cancersjukdom, samtliga tumörlägen utom bröst-, prostata- och annan hudcancer än malignt melanom. Avser patienter 30-89 år vid tiden för diagnos. Åldersstandardiserade värden. Mätperioden är fem år, där det redovisade årtalet är det sista av dessa. Täljaren: Den observerade överlevnaden i gruppen som fått en cancerform utom bröst-, prostata- och annan hudcancer än malignt melanom. Nämnaren: Den förväntade överlevnaden i en jämförbar grupp från befolkningen med avseende på huvudsakliga faktorer som påverkar överlevnad (här: kön, ålder och tidsperiod). Detta nyckeltal uppdateras vart femte år. Data finns tillgängligt enligt könsuppdelning."@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/N79196_json>;
    <http://purl.org/dc/terms/provenance> _:b0__6836.
_:b0__6836 <http://purl.org/dc/terms/description> "Källa: Socialstyrelsen via Vården i Siffror"@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/N79196> <http://purl.org/dc/terms/modified> "2026-02-20"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Överlevnad vid cancersjukdom – flera cancerformer, andel (%)"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/HEAL>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


<https://opendata-api.malmo.se/dataset/c7d18e08-1373-4fce-a4b0-8f46d66279bd> <http://www.w3.org/ns/dcat#keyword> "Malmö stad", "gis", "karta", "geodata", "Vatten", "VA", "Enskilt Avlopp", "Avlopp", "map";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/DAILY>;
    <http://purl.org/dc/terms/identifier> "c7d18e08-1373-4fce-a4b0-8f46d66279bd";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://malmo.se/>;
    <http://purl.org/dc/terms/description> "Platser i Malmö där avloppsvatten från byggnader renas vid en enskild avloppsanläggning. \n\nVår placering av de enskilda avloppen är inte alltid korrekt, särskilt på koloniområden. Attributet koordinatpunkttyp beskriver vad som använts för att skapa punkten. Mittpunkt av fastighet kan vara långt från det faktiska avloppet. "@sv, "Locations in Malmö where wastewater from buildings is treated at an individual\nsewage plant.\n\nOur location of individual drains is not always accurate, especially in\nresidential areas. The coordinate point type attribute describes what was used\nto create the point. The center point of the property may be far from the\nactual drain.\n\n"@en, "Steder i Malmø, hvor spildevand fra bygninger behandles på et individuelt\nrensningsanlæg.\n\nVores placering af individuelle afløb er ikke altid nøjagtig, især i\nboligområder. Attributten for koordinatpunkttype beskriver, hvad der blev\nbrugt til at oprette punktet. Ejendommens midtpunkt kan være langt fra det\nfaktiske afløb.\n\n"@da;
    <http://purl.org/dc/terms/spatial> <http://www.geonames.org/2692965/malmoe.html>, _:b0__4255.
_:b0__4255 <http://www.w3.org/ns/dcat#bbox> "POLYGON((12.8850967451 55.6421476735,13.1517619812 55.6421476735,13.1517619812 55.5022773196,12.8850967451 55.5022773196,12.8850967451 55.6421476735))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.
<https://opendata-api.malmo.se/dataset/c7d18e08-1373-4fce-a4b0-8f46d66279bd> <http://www.w3.org/ns/dcat#contactPoint> <https://admin.dataportal.se/store/290/resource/00384f6c30a75c7618456af7c6cec6b6>;
    <http://www.w3.org/ns/dcat#distribution> <https://opendata-api.malmo.se/dataset/c7d18e08-1373-4fce-a4b0-8f46d66279bd/resource/e35d66f8-5504-4469-861c-af6cad4adb52>;
    <http://purl.org/dc/terms/issued> "2024-03-24"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2026-05-09T23:06:44.890160"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Enskilda avlopp"@sv, "Individual drains"@en, "Individuelle afløb"@da;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>;
    a <http://www.w3.org/ns/dcat#Dataset>
}


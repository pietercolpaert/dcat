}

<feed> <https://w3id.org/tree#member> <#f470d44d18b1c47a8dc80a278a3fc147>.
<#f470d44d18b1c47a8dc80a278a3fc147> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://doi.org/10.5281/zenodo.19726021>;
    <https://www.w3.org/ns/activitystreams#published> "2026-05-10T06:55:54.900Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#f470d44d18b1c47a8dc80a278a3fc147> {
<https://doi.org/10.5281/zenodo.19726021> <http://www.w3.org/ns/dcat#keyword> "Atrial Fibrillation"@en, "Epicardial Adipose Tissue/diagnostic imaging"@en, "Growth Differentiation Factor 15"@en, "Bone morphogenetic protein 10"@en, "Atrial cardiomyopathy"@en, "Computational fluid dynamics"@en;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__2778.
_:b0__2778 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/81fd15919a880c5ea493ffe9632f409e>;
    a <http://www.w3.org/ns/prov#Attribution>.
<https://doi.org/10.5281/zenodo.19726021> <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021003096>;
    <http://purl.org/dc/terms/description> "The study aimed to investigate whether left atrial wall modification factors (epicardial adipose tissue and inflammation), and coagulation markers correlate to each other, to the level of left atrial blood stasis, and hence, indirectly to the risk of cardioembolic stroke, in atrial fibrillation patients in sinus rhythm. \n\nThe data comprises clinical background and demographical information of the study participants, measurements of different blood inflammation and coagulation markers, and results of imaging processing regarding heart chamber size, function, epicardial fat volume, and left atrial blood flow parameters. \n\nThe data is quantitative and numerical. The folder is created in SPSS Statistics for Windows, version 29.0 (IBM Corp., Armonk, N.Y., USA).\n\nThis research was funded by \n\nRegion Östergötland Grants (grant number 974839, 987498); \n\nSwedish Heart and Lung Foundation Grants ( grant number 20200220, 20230201);\n\nSwedish Research Council Grants (grant number 2018-02779, 2022-03931);\n\nSweden’s Innovation Agency Vinnova Grant (grant number 2019-02261) and\n\nKonung Gustaf V: s och Drottning Victorias Stiftelse. \n\nLiU secure repository is a data repository that hosts research data which cannot be openly available for ethical or legal reasons. LiU secure repository is managed by Linköping University Library as a service to researchers at Linköping University (Sweden). For requests of access or further information, please contact datamanagement@liu.se"@en;
    <http://www.w3.org/ns/dcat#distribution> <https://doi.org/10.5281/zenodo.19726021#distribution>;
    <http://purl.org/dc/terms/issued> "2026-04-24T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.5281/zenodo.19726021>;
    <http://purl.org/dc/terms/modified> "2026-05-08T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "FFAB5 study dataset"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/HEAL>;
    a <http://www.w3.org/ns/dcat#Dataset>
}


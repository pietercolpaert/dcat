<https://datakatalog.karlstad.se/store/7/resource/12> <http://www.w3.org/ns/dcat#temporalResolution> "P1Y"^^<http://www.w3.org/2001/XMLSchema#duration>;
    <http://www.w3.org/ns/dcat#keyword> "Mål"@sv, "Indikatorer"@sv, "Måluppfyllelse"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL_2>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;

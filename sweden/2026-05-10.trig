<#7683440c9c48b8006f85a75d031c1c52> {
<http://api.kolada.se/v3/kpi/N02823> <http://www.w3.org/ns/dcat#keyword> "Kommun"@sv, "Region"@sv, "Rådet för främjande av kommunala analyser - Kolada";

<https://doi.org/10.5878/aaxe-kg23> <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021003054>;
    <http://purl.org/dc/terms/description> "Polymer linings used in sewer rehabilitation technologies are expected to cure fast in order for the renewed line to return to the service quickly and with minimum disruption. This dataset includes the original data obtained from the thermal analyses of a reinforced polyester composite used as pipe lining, including studying gelation, enthalpy and curing process for a better understanding of the material's curing behavior after application in the field. \n\nDatasetet har ursprungligen publicerats i DiVA och flyttades ��ver till SND 2024."@sv, "Polymer linings used in sewer rehabilitation technologies are expected to cure fast in order for the renewed line to return to the service quickly and with minimum disruption. This dataset includes the original data obtained from the thermal analyses of a reinforced polyester composite used as pipe lining, including studying gelation, enthalpy and curing process for a better understanding of the material's curing behavior after application in the field. \n\nThe dataset was originally published in DiVA and moved to SND in 2024."@en;
    <http://www.w3.org/ns/dcat#distribution> <https://doi.org/10.5878/aaxe-kg23#distribution>;
    <http://purl.org/dc/terms/issued> "2019-08-07T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.5878/aaxe-kg23>;
    <http://purl.org/dc/terms/modified> "2024-06-26T11:02:58.15714Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Monitoring the gelation time and curing process of a reinforced polyester lining - original data"@sv, "Monitoring the gelation time and curing process of a reinforced polyester lining - original data"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TECH>;
    a <http://www.w3.org/ns/dcat#Dataset>
}


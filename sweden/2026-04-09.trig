<#619be55c5e0823de64ec529630d7314f> {
<https://metadata.havochvatten.se/store/1/resource/398> <http://www.w3.org/ns/dcat#keyword> "Havsplanering"@sv, "Fysisk planering"@sv, "MSP"@en, "Marine spatial planning"@en, "Havsplan"@sv, "Marine spatial plan"@en;
    <http://data.europa.eu/r5r/hvdCategory> <http://data.europa.eu/bna/c_dd313021>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021006420>;
    <http://purl.org/dc/terms/description> "En havsplan ger vägledning om användning för de områden som omfattas av havsplanen. Sverige har tre havsplaner: Bottniska viken, Östersjön och Västerhavet. Dessa beslutades av regeringen den 10 februari 2022. Plankartan ska tolkas i den ungefärliga skalan mellan 1:700 000 och 1:1 000 000.\nPå ingångssidan finns mer information om havsplanering och en webbkarta som visar plankarta samt planeringsförutsättningar."@sv, "There are three marine spatial plans in Sweden. They were adopted by the government 10 february 2022. The plan map should be interpreted in scales between 1:700 000 and 1:1 000 000.\n\nThis version of marine spatial plans applied to the period between 2024-05-16 and 2025-01-20."@en;
    <http://purl.org/dc/terms/isPartOf> <https://metadata.havochvatten.se/store/34/resource/14>;
    <http://www.w3.org/ns/dcat#contactPoint> <https://metadata.havochvatten.se/store/1/resource/275>;
    <http://www.w3.org/ns/dcat#distribution> <https://metadata.havochvatten.se/store/1/resource/399>, <https://metadata.havochvatten.se/store/1/resource/400>, <https://metadata.havochvatten.se/store/1/resource/407>, <https://metadata.havochvatten.se/store/1/resource/408>, <https://metadata.havochvatten.se/store/1/resource/413>, <https://metadata.havochvatten.se/store/1/resource/416>;
    <http://purl.org/dc/terms/issued> "2022-02-10"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#landingPage> <https://www.havochvatten.se/vagledning-foreskrifter-och-lagar/vagledningar/havsplaner.html>;
    <http://purl.org/dc/terms/subject> <http://www.eionet.europa.eu/gemet/concept/7495>, <http://www.eionet.europa.eu/gemet/concept/6287>, <http://www.eionet.europa.eu/gemet/concept/6225>, <http://www.eionet.europa.eu/gemet/concept/5486>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg_impl/2023/138/oj>;
    <http://purl.org/dc/terms/title> "Havsplaner för Bottniska viken, Östersjön och Västerhavet. 2022"@sv, "Marine spatial plans for the Gulf of Bothnia, Baltic Sea and Skagerrak/Kattegat"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>;
    <http://purl.org/dc/terms/temporal> _:b0__6155.
_:b0__6155 <http://www.w3.org/ns/dcat#endDate> "2025-01-20"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#startDate> "2022-02-10"^^<http://www.w3.org/2001/XMLSchema#date>;
    a <http://purl.org/dc/terms/PeriodOfTime>.
<https://metadata.havochvatten.se/store/1/resource/398> a <http://www.w3.org/ns/dcat#Dataset>
}


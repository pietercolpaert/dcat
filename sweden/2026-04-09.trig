<#4809db8eff01fed424b2c63c831f5367> {
<https://doi.org/10.5878/002901> <http://www.w3.org/ns/dcat#keyword> "RELIGIOUS ATTENDANCE"@en, "RELIGIÖST DELTAGANDE"@sv, "PARTICIPATION"@en, "DELTAGANDE"@sv, "HOUSING"@en, "BOENDE"@sv, "SHOPPING"@en, "SHOPPING"@sv, "CHILD CARE"@en, "BARNOMSORG"@sv, "WORKING CONDITIONS"@en, "ARBETSFÖRHÅLLANDEN"@sv, "DOMESTIC RESPONSIBILITIES"@en, "HUSHÅLLSANSVAR"@sv, "HOUSEHOLDS"@en, "HUSHÅLL"@sv, "SCHOOLS"@en, "SKOLOR"@sv, "TRUST"@en, "FÖRTROENDE"@sv, "CLUBS"@en, "FÖRENINGAR"@sv, "JOB SATISFACTION"@en, "ARBETSTILLFREDSSTÄLLELSE"@sv, "FAMILY LIFE"@en, "FAMILJELIV"@sv, "CHILDREN"@en, "BARN"@sv, "HOUSEWORK"@en, "HUSHÅLLSARBETE"@sv, "CITIZENSHIP SKILLS"@en, "MEDBORGERLIGA FÄRDIGHETER"@sv, "WORKPLACE"@en, "ARBETSPLATS"@sv, "HEALTH SERVICES"@en, "HÄLSOVÅRD"@sv;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__88313.
_:b0__88313 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;

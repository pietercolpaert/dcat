<feed> <https://w3id.org/tree#member> <#ffcf6d2ae680c3d7b4b38b7619931145>.
<#ffcf6d2ae680c3d7b4b38b7619931145> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <https://metadata.havochvatten.se/store/1/resource/818>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-09T06:33:26.027Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#ffcf6d2ae680c3d7b4b38b7619931145> {
<https://metadata.havochvatten.se/store/1/resource/818> <http://www.w3.org/ns/dcat#keyword> "miljö"@sv, "vatten"@sv, "provtagning"@sv, "östersjön"@sv;
    <http://purl.org/dc/terms/identifier> "d865fc7c-defa-4c8f-9002-00cd4e48a4a6";
    <http://data.europa.eu/r5r/hvdCategory> <http://data.europa.eu/bna/c_dd313021>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021006420>;
    <http://purl.org/dc/terms/description> "Havs och vattenmyndigheten arbetar med utveckling av nya biologiska bedömningsgrunder för kusten inom vattenförvaltningen. Biologiska bedömningsgrunder är ett viktigt verktyg för att utvärdera ekologisk status samt för att implementera lämpliga åtgärder som förbättrar vattenkvalitén och bidrar till sammanhängande funktionella ekosystem. Syftet med detta projekt var att utveckla biologiska bedömningsgrunder i Östersjön som även är känsliga för fysisk påverkan med koppling till kvalitetsfaktorn Makroalger och Gömfröiga växter enligt föreskriften HVMFS 2019:25. \nArbetet utmynnade i tre föreslagna och utvärderade parametrar; Artdiversitet, Täckningsgrad och Ytutbredning. Den data som samlades in har mätts med hjälp av kratt- och videoprov och akustiska metoder i tre olika områden i Östersjön - Stockholm, Östergötland och Blekinge. Data består av GIS filer och beskrivning av arter som påträffades vid olika djup längs provtagna transekter. Inom varje lokal samlades data in i ett påverkat område och ett icke-påverkat för att analysera skillnaden. Detaljerad beskrivning om metoder, analys och resultat och går att få vid kontakt med Havs- och vattenmyndigheten."@sv;
    <http://purl.org/dc/terms/isPartOf> <https://metadata.havochvatten.se/store/34/resource/54>;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/2661886>, _:b0__8214.
_:b0__8214 <http://www.w3.org/ns/dcat#bbox> "POLYGON((13.916516418854954 60.070550713937195,19.995029803705144 60.070550713937195,19.995029803705144 55.64834409285052,13.916516418854954 55.64834409285052,13.916516418854954 60.070550713937195))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.
<https://metadata.havochvatten.se/store/1/resource/818> <http://www.w3.org/ns/dcat#contactPoint> <https://metadata.havochvatten.se/store/1/resource/272>;
    <http://www.w3.org/ns/dcat#version> "1", "2025-06-18";
    <http://www.w3.org/ns/dcat#distribution> <https://metadata.havochvatten.se/store/1/resource/903>, <https://metadata.havochvatten.se/store/1/resource/904>, <https://metadata.havochvatten.se/store/1/resource/905>;
    <http://purl.org/dc/terms/provenance> _:b0__4788.
_:b0__4788 <http://purl.org/dc/terms/description> "Insamling av data för utveckling av bedömningsgrund."@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<https://metadata.havochvatten.se/store/1/resource/818> <http://purl.org/dc/terms/subject> <http://inspire.ec.europa.eu/metadata-codelist/TopicCategory/biota>, <http://www.eionet.europa.eu/gemet/concept/10194>;
    <http://purl.org/dc/terms/created> "2026-01-07"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg_impl/2023/138/oj>;
    <http://purl.org/dc/terms/title> "Gömfröiga växter"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>;
    <http://purl.org/dc/terms/conformsTo> <http://www.opengis.net/def/crs/EPSG/0/3006>;
    a <http://www.w3.org/ns/dcat#Dataset>
}


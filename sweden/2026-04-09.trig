<https://metadata.havochvatten.se/store/1/resource/530> <http://www.w3.org/ns/dcat#keyword> "Havslandskap"@sv;
    <http://xmlns.com/foaf/0.1/page> <https://www.havochvatten.se/download/18.5b07be29168ba461a982d5a6/1549460413584/Datadokumentation%20Omv%C3%A4nda%20kartan.docx>;
    <https://dataportal.se/concepts/geose/useLimitation> "Vissa av underlagen sätter begränsningar på hur Omvända kartan får användas och spridas. Se datadokumentation"@sv;
    <http://purl.org/dc/terms/identifier> "25342cb4-fe44-4deb-8894-1b725e5c54a7";

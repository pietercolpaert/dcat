<#df6f1a0ff2595a802e0c60fb4039dff9> {
<https://opendata-catalog.smhi.se/md/25076d38-25e6-4ad6-9cb9-878708728f93> <http://www.w3.org/ns/dcat#keyword> "Strömriktning"@sv, "Öppna data"@sv, "Inspire"@sv, "Observation"@sv, "Oceanografi"@sv, "Geografiska oceanografiska förhållanden"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/MONTHLY>;

<#f254abd3ceacfcd5790e4c6fe1541300> {
<https://doi.org/10.5878/y05x-at50> <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__17013.
_:b0__17013 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/7dbcbe8b6e5923c3bb0723386635a263>;

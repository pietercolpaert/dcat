<http://api.kolada.se/v3/kpi/N15014> <http://purl.org/dc/terms/modified> "2025-08-28"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Kostnad elevhälsa i kommunal grundskola åk 1-9, kr/elev"@sv;

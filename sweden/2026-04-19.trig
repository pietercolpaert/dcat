<#c9c9953844b442334e5ae9359af2b0a6> {
<https://resources.stockholm.se/data/c5a65f72-3b80-4d38-b2f2-851b8a4ea2b0> <http://www.w3.org/ns/dcat#keyword> "Stockholms stad", "Höjddata"@sv, "Verksamhetsdata"@sv, "Extern dataportal"@sv, "1.Publicerad på webb"@sv, "Laser"@sv, "Lidar"@sv, "Punktmoln"@sv, "Laserskanning"@sv, "Lasermoln"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/IRREG>;

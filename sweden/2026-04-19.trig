<#3e37d3d3a0815ae17c1c15b07c79c607> {
<https://doi.org/10.5878/002766> <http://www.w3.org/ns/dcat#keyword> "frekvens"@sv, "frequency"@en, "IMU-Testologen AB", "CONSUMPTION"@en, "KONSUMTION"@sv, "PERIODICALS READERSHIP"@en, "TIDSKRIFTSLÄSARE"@sv, "NEWSPAPER READERSHIP"@en, "TIDNINGS LÄSEKRETS"@sv, "SHOPPING"@en, "SHOPPING"@sv, "RETAIL OUTLETS"@en, "FÖRSÄLJNINGSSTÄLLEN"@sv, "DOMESTIC APPLIANCES"@en, "HUSHÅLLSAPPARAT"@sv, "CONSUMER GOODS"@en, "KONSUMTIONSVAROR"@sv, "INTEREST (COGNITIVE PROCESSES)"@en, "INTRESSE (KOGNITIVA PROCESSER)"@sv;

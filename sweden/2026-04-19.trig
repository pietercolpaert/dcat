    <http://purl.org/dc/terms/issued> "2023-02-24T13:07:38.113979"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2026-03-27T07:19:10.331118"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

<#c554c46a45311ea9e429bc04389ac0e2> {
<https://doi.org/10.5878/eref-hz37> <http://www.w3.org/ns/dcat#keyword> "Markanvändning"@sv, "granbarkborre"@sv, "Norway spruce"@en, "Land use"@en, "markanvändning"@sv, "land use"@en, "skogsbruk"@sv, "forest exploitation"@en, "översikt över skogsskador"@sv, "inventory of forest damage"@en, "skogsskador"@sv, "NRS"@sv, "TFDI"@en, "forest damage"@en, "barrskog"@sv, "coniferous forest"@en, "Ips typographus"@en, "barkborrar"@sv, "Scolytidae"@en, "Inventering av skador på skog"@sv, "Forest damage inventory"@en, "Gran (art)"@sv, "bark beetles"@en, "environmental monitoring and assessment"@en, "miljöanalys"@sv, "Picea abies"@en, "gran"@sv, "ips typographus (linnaeus, c., 1758)"@en, "picea abies (l.) h. karst."@en;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__4115.
_:b0__4115 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;

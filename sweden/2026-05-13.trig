<https://doi.org/10.5878/001842> <http://www.w3.org/ns/dcat#keyword> "förhistorisk tid"@sv, "prehistoric time"@en, "medeltid"@sv, "Middle Ages"@en;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__32456.
_:b0__32456 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/author>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/2469056885632d0db509178609fcbd26>;

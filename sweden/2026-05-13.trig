<#7790c4b7f79182f9175b3d88a06f33fa> {
<https://opendata-catalog.smhi.se/md/eb8cea14-55cf-4c30-8c13-3351870b6f8d> <http://www.w3.org/ns/dcat#keyword> "Öppna data"@sv, "Inspire"@sv, "Meteorologi"@sv, "Observation"@sv, "Relativ luftfuktighet"@sv, "HVD"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/CONT>;

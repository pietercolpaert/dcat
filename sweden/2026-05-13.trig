    <http://www.w3.org/ns/dcat#distribution> <https://opendata-download-metfcst.smhi.se/api/category/fwif1g/version/1/hourly/geotype/point/lon/16/lat/58/data.json>, <https://opendata-download-metfcst.smhi.se/api/category/fwif1g/version/1/hourly/approvedtime.json>, <https://opendata-download-metfcst.smhi.se/api/category/fwif1g/version/1/daily/geotype/point/lon/16/lat/58/data.json>, <https://opendata-download-metfcst.smhi.se/api/category/fwif1g/version/1/daily/approvedtime.json>, <https://opendata.smhi.se/metfcst/fwif>, <https://opendata-download-metfcst.smhi.se/api/category/fwif1g/version/1/daily/geotype/multipoint/validtime/20250515T120000Z/parameter/fwi/leveltype/hl/level/0/data.json?with-geo=false>;
    <http://purl.org/dc/terms/issued> "2021-03-19"^^<http://www.w3.org/2001/XMLSchema#date>;

    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/N70805_json>;
    <http://purl.org/dc/terms/provenance> _:b0__86054.
_:b0__86054 <http://purl.org/dc/terms/description> "K��lla: Socialstyrelsen."@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.

<#9dc762986ce2c16977f3d8d9882f066f> {
<http://api.kolada.se/v3/kpi/U79272> <http://www.w3.org/ns/dcat#keyword> "Region"@sv, "Rådet för främjande av kommunala analyser - Kolada";

<#aa65bcfda02c4f16555b554daae33650> {
<https://opendata.umea.se/api/v2/catalog/datasets/gop_lekparker> <http://www.w3.org/ns/dcat#keyword> "Umeå kommun", "Lekplats"@sv, "Lekpark"@sv;
    <http://purl.org/dc/terms/identifier> "gop_lekparker@http://dataportal.se/organisation/SE2120002627";
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://admin.dataportal.se/store/43/resource/7a00bd3796ed09a600646432cb321722>;
    <http://purl.org/dc/terms/description> "Alla barn ska ha tillgång till stimulerande och utvecklande lekmiljöer\npå parkmark, naturmark och lekplatser.\n\nUmeå kommun har lekplatser i Umeå tätort samt i Sävar, Hörnefors,\nHolmsund och Obbola.Lekplatserna kan vara av olika typer. Betydelsen för varje typ är följande:Närområdeslekplats: En lekplats som kan nyttjas av ett helt bostadsområde (avstånd ca 250 m)Stadsdelslekplats: En lekplats som är samlande för stadsdelen och för lite äldre barn (avstånd ca 500 m)Äventyrslekplats: En stor lekplats med kapacitet för många människor (avstånd 1000-3000 m)"@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://opendata.umea.se/explore/?refine.dcat.contact_name=Gator+och+parker%252C+Ume%C3%A5+kommun&refine.dcat.contact_email=gatorochparker%2540umea.se>;
    <http://www.w3.org/ns/dcat#distribution> <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gop_lekparker-API>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gop_lekparker-csv>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gop_lekparker-json>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gop_lekparker-fgb>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gop_lekparker-geojson>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gop_lekparker-gpx>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gop_lekparker-jsonl>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gop_lekparker-kml>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gop_lekparker-ov2>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gop_lekparker-parquet>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gop_lekparker-rdfxml>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gop_lekparker-jsonld>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gop_lekparker-turtle>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gop_lekparker-n3>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gop_lekparker-shp>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gop_lekparker-xlsx>;
    <http://purl.org/dc/terms/issued> "2026-05-12T02:00:04.677000+00:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

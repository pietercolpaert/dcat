<#01094f2bb387745d7ccc0022114cc6f4> {
<https://doi.org/10.5878/351p-qw44> <http://www.w3.org/ns/dcat#keyword> "microfluidics"@en, "mikrofluidik"@sv, "Acoustofluidics"@en, "Akustofluidik"@sv, "Thermoacoustic effect"@en, "Termoakustisk effekt"@sv, "Acoustic techniques"@en, "Akustiska tekniker"@sv;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__3436.
_:b0__3436 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/be8755a2c34de84bb68eb25a0ed6335a>;
    a <http://www.w3.org/ns/prov#Attribution>.
<https://doi.org/10.5878/351p-qw44> <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__4174.
_:b0__4174 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/6d9540cd021a82506831a53b62fdce9f>;
    a <http://www.w3.org/ns/prov#Attribution>.
<https://doi.org/10.5878/351p-qw44> <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021003211>;
    <http://purl.org/dc/terms/description> "Description: The dataset contains the experimental and numerical data for the publication titled \"A thermally shielded acoustofluidic device for robust particle focusing\" by Corato et al, Ultrasonics 2026. The code necessary to analyse and plot the data is also included. The study investigates temperature regulation of acoustofluidic chips and how this affects the separation performance of small particles."@en, "Beskrivning\n\nDatasetet innehåller experimentella och numeriska data i form av bilder, mätdatafiler och simuleringsfiler för publikationen \"A thermally shielded acoustofluidic device for robust particle focusing\" av Corato et al., Ultrasonics 2026. Koden som krävs för att analysera och plotta data ingår också i datasetet. Studien undersöker temperaturreglering av akustofluidikchip och påverkan på separationen av små partiklar."@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://admin.dataportal.se/store/818/resource/0ab8f92be58b4ce0490d8a48da6b1259>;
    <http://www.w3.org/ns/dcat#distribution> <https://doi.org/10.5878/351p-qw44#distribution>;
    <http://purl.org/dc/terms/issued> "2026-05-11T09:38:06.464761Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.5878/351p-qw44>;
    <http://purl.org/dc/terms/modified> "2026-05-11T09:38:06.464761Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Data for: A thermally shielded acoustofluidic device for robust particle focusing"@en, "Data för: A thermally shielded acoustofluidic device for robust particle focusing"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TECH>;
    a <http://www.w3.org/ns/dcat#Dataset>
}


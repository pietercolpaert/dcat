<#11e8f66ab3dda002e5dd318a26a64dea> {
<http://api.kolada.se/v3/kpi/U07510> <http://www.w3.org/ns/dcat#keyword> "Kommun"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "U07510";

    <http://purl.org/dc/terms/title> "Lund University Biological Museum - Insect collections Inventory"@en;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__5535.
_:b0__5535 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/fe1fd77b2ccead7aecf655ff2e5b5c14>;

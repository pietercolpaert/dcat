    <http://purl.org/dc/terms/modified> "2024-11-12"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/conformsTo> <http://www.opengis.net/def/crs/EPSG/0/3006>, <http://www.sis.se/produkter/foretagsorganisation/kvalitet/allmant/ss-en-iso-191572013/>, <http://www.sis.se/produkter/foretagsorganisation/kvalitet/allmant/sseniso191152005/>, <http://www.sis.se/produkter/informationsteknik-kontorsutrustning/ittillampningar/it-tillampningar-inom-vetenskap/sis-ts-802018/>, <https://www.sis.se/produkter/informationsteknik-kontorsutrustning/ittillampningar/it-tillampningar-inom-vetenskap/ss-en-iso-191312022/>;

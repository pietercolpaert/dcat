<http://api.kolada.se/v3/kpi/N00347> <http://purl.org/dc/terms/modified> "2025-05-05"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Tillgänglighet till tjänster – Regionindex Kvinnor"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>;

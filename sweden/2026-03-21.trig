<#19e40cae69aef1438e0ea6707ba2f6b9> {
<https://opendata.umea.se/api/v2/catalog/datasets/energiforbrukning-i-geografiska-omradet-1746-del-av-savar> <http://www.w3.org/ns/dcat#keyword> "Energi"@sv, "Consumption"@en, "Umeå Energi", "Förbrukning"@sv, "El"@sv, "Fjärrvärme"@sv, "Energy"@en, "Electricity"@en, "District heating"@en;
    <http://purl.org/dc/terms/identifier> "energiforbrukning-i-geografiska-omradet-1746-del-av-savar@http://dataportal.se/organisation/SE2120002627";
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://admin.dataportal.se/store/43/resource/fd2584866d01e4eaee64e3ffcfe40e02>;
    <http://purl.org/dc/terms/description> "Anonymiserad förbrukningsdata från Umeå Energi per nyckelkodsområde i Umeå Kommun. Detta data bör inte ses som exakta och kompletta förbrukningsvärden utan mer som en kvalificerad uppskattning av förbrukningen i syfte att se trender och indikationer.Datafilerna kommer endast innehålla värden för fastigheter i Umeå kommun där Umeå Energi är nätägare och informationen inte anses vara olämplig för distribution. Uppdateras normalt en gång varje månad med nytillkomna värden.Frågor kring detta förbrukningsdata hänvisas till matdata.datalager@umeaenergi.se "@sv, "Här är en engelsk översättning av texten, med en version som är lämplig för en bredare publik och en mer teknisk version för dataintresserade.Allm��n översättning (General Translation)Anonymized consumption data from Umeå Energi for each key-code area in the Municipality of Umeå.This data should not be seen as exact and complete consumption values, but rather as a qualified estimate of consumption for the purpose of identifying trends and indications.The data files will only contain values for properties in the Municipality of Umeå where Umeå Energi is the grid owner and where the information is not considered unsuitable for distribution. The data is normally updated once a month with newly added values.For questions regarding this consumption data, please refer to matdata.datalager@umeaenergi.se."@en;
    <http://www.w3.org/ns/dcat#contactPoint> <https://opendata.umea.se/explore/?refine.dcat.contact_name=Ume%C3%A5+Energi&refine.dcat.contact_email=matdata.datalager%2540umeaenergi.se>;
    <http://www.w3.org/ns/dcat#distribution> <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-1746-del-av-savar-API>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-1746-del-av-savar-csv>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-1746-del-av-savar-json>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-1746-del-av-savar-jsonl>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-1746-del-av-savar-parquet>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-1746-del-av-savar-rdfxml>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-1746-del-av-savar-jsonld>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-1746-del-av-savar-turtle>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-1746-del-av-savar-n3>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-1746-del-av-savar-xlsx>;
    <http://purl.org/dc/terms/issued> "2025-12-17T01:19:03.717000+00:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://opendata.umea.se/explore/dataset/energiforbrukning-i-geografiska-omradet-1746-del-av-savar/>;
    <http://purl.org/dc/terms/modified> "2025-12-17T01:19:03.717000+00:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Energiförbrukning i Geografiska området 1746 (del av Sävar)"@sv, "Energy consumption in the Geographical area 1746 (part of Sävar)"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENER>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


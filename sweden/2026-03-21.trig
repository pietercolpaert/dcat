    <https://www.w3.org/ns/activitystreams#published> "2026-03-21T06:13:23.552Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#d0f9e2fe0816da83589bc8e5a7f50e69> {
<https://doi.org/10.5878/001078> <http://www.w3.org/ns/dcat#keyword> "IMU-Testologen AB";
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__14524.

<#2f8ce57f21a40992b1c9c47342d417ba> {
<https://admin.dataportal.se/store/818/resource/9b20c33155fcc52111a890bd7cc5676e> <http://www.w3.org/ns/dcat#keyword> "Miljö"@sv, "Environment"@en, "Register"@sv, "Livskvalitet"@sv, "Quality of Life"@en, "Livsstil"@sv, "Life Style"@en, "Socioekonomiska faktorer"@sv, "Socioeconomic Factors"@en, "Psykisk hälsa"@sv, "Mental Health"@en, "social interaktion"@sv, "social interaction"@en, "Åldrande"@sv, "Aging"@en, "Longitudinella studier"@sv, "Longitudinal Studies"@en, "Epidemiologiska studier"@sv, "Epidemiologic Studies"@en, "social life"@en, "Aktiviteter i dagliga livet"@sv, "Activities of Daily Living"@en, "Äldre, 80 och över"@sv, "Aged, 80 and over"@en, "Demens"@sv, "Dementia"@en, "Geriatrik"@sv, "Geriatrics"@en, "Minne"@sv, "Memory"@en, "Neuropsykologiska tester"@sv, "Neuropsychological Tests"@en, "Kroppsmasseindex"@sv, "Body Mass Index"@en, "Gener"@sv, "Genes"@en, "Kognition"@sv, "Cognition"@en, "Depression"@sv, "Depression"@en, "Personlighet"@sv, "Personality"@en, "Registries"@en, "Typ 2-diabetes"@sv, "Diabetes Mellitus, Type 2"@en, "Ärftlighet"@sv, "Heredity"@en, "Tvillingstudie [Publikationstyp]"@sv, "Twin Study"@en, "Apolipoproteiner E"@sv, "Apolipoproteins E"@en, "Minnesstörningar"@sv, "Memory Disorders"@en, "Nervdegeneration"@sv, "Nerve Degeneration"@en, "Wechslers skalor"@sv, "Wechsler Scales"@en, "Degenerativ sjukdom i nervsystemet (ospecificerad)"@sv, "Degenerative disease of nervous system unspecified"@en, "Mental status och demenstester"@sv, "Mental Status and Dementia Tests"@en, "Wechsler Memory Scale"@en, "APOE genotyp"@sv, "APOE genotype"@en, "funktionsnivå"@sv, "functional status"@en, "Minnesfunktion"@sv, "Memory function"@en, "near - national e-infrastructure for aging research"@sv, "near - national e-infrastructure for aging research"@en, "funktionell förmåga"@sv, "functional ability"@en, "socialt umgänge"@sv;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__39025.

    <http://www.w3.org/ns/dcat#distribution> <https://catalog.gavle.se/store/1/resource/207>, <https://catalog.gavle.se/store/1/resource/209>;
    <http://purl.org/dc/terms/title> "Sandupptagningsområden"@sv, "Sand removal areas"@en;

    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021003732>;
    <http://purl.org/dc/terms/description> "I Livrustkammaren finns över 30.000 föremål. Flertalet har anknytning till svenska kungar från Gustav Vasa och fram till idag. Det är framförallt praktföremål, dräkter från kröningar, bröllop och dop och paradrustningar och unika vapen som ingått i kungarnas samlingar. Dessutom finns här kröningsvagnar och praktkarosser från hovstallet. "@sv;
    <http://www.w3.org/ns/dcat#distribution> <https://admin.dataportal.se/store/697/resource/5dd5c3d7a5e4c5fcec3044701a852e9c>, <https://admin.dataportal.se/store/697/resource/b61e232a4dbd86f28f5116499a5c5fb7>;
    <http://purl.org/dc/terms/title> "LSH, föremål"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/EDUC>, <http://publications.europa.eu/resource/authority/data-theme/ENVI>;
    a <http://www.w3.org/ns/dcat#Dataset>
}


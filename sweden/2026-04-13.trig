    <http://purl.org/dc/terms/modified> "2026-04-12"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Vägnät"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>;

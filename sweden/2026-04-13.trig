<#176a060b319fab2c3dcf9fb519093cfd> {
<http://pxweb.etjanst.domstol.se/dataset/05_Overklagande_andringsfrekvens_FR_till_KR.px> <http://www.w3.org/ns/dcat#keyword> "Officiell statistik"@sv, "Domstolsverket"@sv, "Migration"@sv, "Förvaltningsrätt"@sv, "Kammarrätt"@sv, "Ändringsfrekvens"@sv, "Ändrad"@sv, "Överklagande"@sv;
    <http://xmlns.com/foaf/0.1/page> <https://www.domstol.se/om-sveriges-domstolar/statistik-styrning-och-utveckling/statistik/officiell-domstolsstatistik/>;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>, <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021002742>;
    <http://purl.org/dc/terms/description> "Överklagandefrekvens i % som är andel m��l som överklagats från förvaltningsrätt till kammarrätt. Överklagandefrekvens beräknas som inkomna mål till kammarrätt dividerat med avgjorda mål på förvaltningsrätt under samma tidsperiod. Tabellen visar även ändringsfrekvens i % som är andel avgjorda mål där utgången i mål vid kammarrätt innebär att en dom eller ett beslut i förvaltningsrätt ändrats."@sv, "Percentage of cases that have been appealed from administrative court to administrative courts of appeal. The table also shows the frequency of amendment in percent, that is, when the administrative court of appeal changed the lower court's decision. The metrics are calculated as the number of incoming cases to the administrative courts of appeal divided by the number of determined cases in the administrative courts during the same time period."@en;
    <http://purl.org/dc/terms/spatial> <http://sws.geonames.org/2661886>;
    <http://www.w3.org/ns/dcat#contactPoint> <https://admin.dataportal.se/store/601/resource/450f76ab581c240995bffa3cac11448a>;
    <http://www.w3.org/ns/dcat#distribution> <http://pxweb.etjanst.domstol.se/distribution/sv/05_Overklagande_andringsfrekvens_FR_till_KR.px>, <http://pxweb.etjanst.domstol.se/distribution/en/05_Overklagande_andringsfrekvens_FR_till_KR.px>;
    <http://purl.org/dc/terms/creator> <http://dataportal.se/organisation/SE2021002742>;
    <http://purl.org/dc/terms/issued> "2025-06-02"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#landingPage> <https://pxweb.etjanst.domstol.se/PxWeb/pxweb/sv/DOMstat/DOMstat__Overklagande/05_Overklagande_andringsfrekvens_FR_till_KR.px>, <https://pxweb.etjanst.domstol.se/PxWeb/pxweb/en/DOMstat/DOMstat__Overklagande/05_Overklagande_andringsfrekvens_FR_till_KR.px>;
    <http://purl.org/dc/terms/modified> "2026-03-31T09:30:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Överklagande- och ändringsfrekvens förvaltningsrätt till kammarrätt"@sv, "Frequency of appeal from administrative courts to administrative courts of appeal"@en;

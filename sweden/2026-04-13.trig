<feed> <https://w3id.org/tree#member> <#ae9d54c889ad904538398524265550e7>.
<#ae9d54c889ad904538398524265550e7> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <https://resources.stockholm.se/data/78beaac9-2001-4b08-9876-b5c6b3b10525>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-13T06:45:01.732Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#ae9d54c889ad904538398524265550e7> {
<https://resources.stockholm.se/data/78beaac9-2001-4b08-9876-b5c6b3b10525> <http://www.w3.org/ns/dcat#keyword> "Stockholms stad", "Verksamhetsdata"@sv, "Extern dataportal"@sv, "4.URI som identifierare"@sv, "infoMapAccessService"@sv, "Trafikplanering"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/IRREG>;
    <http://purl.org/dc/terms/identifier> "78beaac9-2001-4b08-9876-b5c6b3b10525";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/RESTRICTED>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://resources.stockholm.se/metadata#foaf/Stockholms+stad/>;
    <http://purl.org/dc/terms/description> "Skyfall är intensiva regn som kan leda till att marken m��ttas och att dagvattensystemet överbelastas. Detta kan i sin tur orsaka översvämningar och medföra störningar och skador som påverkar både individer och viktiga samhällsfunktioner. Trafikkontoret i Stockholms stad tog under 2024 fram en ny skyfallsmodell som visar hur vatten rinner över ytan samt var vatten kan samlas vid kraftig nederbörd. Modellen har tagits fram för att ge stöd i planeringen av en mer motståndskraftig stad. Resultaten för tre olika nederbördsscenarier presenteras: ett 100-årsregn och ett 500-årsregn, båda anpassade för klimatförändringar genom en klimatfaktor på 1,40 och baserade på regional regnstatistik (”Stockholmsregn”), samt det så kallade Gävleregnet som föll över Gävle 2021 – den mest omfattande nederbörden i närtid i närheten av Stockholm. Tillgängliga metadata redovisar bland annat vilken höjdmodell som använts (inklusive identifierade lågpunkter), vilken karteringsmetod och upplösning som tillämpats. Det gör det möjligt att bedöma underlagets tillförlitlighet och genomföra enklare kvalitetskontroller av resultaten."@sv;
    <http://purl.org/dc/terms/spatial> _:b0__77866.
_:b0__77866 <http://www.w3.org/ns/dcat#bbox> "POLYGON((17.7605 59.4402,18.2011 59.4402,18.2011 59.2272,17.7605 59.2272,17.7605 59.4402))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    <http://www.w3.org/ns/locn#geometry> "POLYGON((17.7605 59.4402,18.2011 59.4402,18.2011 59.2272,17.7605 59.2272,17.7605 59.4402))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.
<https://resources.stockholm.se/data/78beaac9-2001-4b08-9876-b5c6b3b10525> <http://www.w3.org/ns/dcat#contactPoint> <https://resources.stockholm.se/metadata#vcard/Stockholms+stad+-+Trafikkontoret/>;
    <http://www.w3.org/ns/dcat#distribution> <https://resources.stockholm.se/data/78beaac9-2001-4b08-9876-b5c6b3b10525#HTTP:OGC:WMS/3>, <https://resources.stockholm.se/data/78beaac9-2001-4b08-9876-b5c6b3b10525#HTTP:OGC:WMS/4>, <https://resources.stockholm.se/data/78beaac9-2001-4b08-9876-b5c6b3b10525#HTTP:OGC:WMS/5>, <https://resources.stockholm.se/data/78beaac9-2001-4b08-9876-b5c6b3b10525#HTTP:OGC:WMS/6>, <https://resources.stockholm.se/data/78beaac9-2001-4b08-9876-b5c6b3b10525#HTTP:OGC:WMS/7>, <https://resources.stockholm.se/data/78beaac9-2001-4b08-9876-b5c6b3b10525#HTTP:OGC:WMS/8>, <https://resources.stockholm.se/data/78beaac9-2001-4b08-9876-b5c6b3b10525#HTTP:Nedladdning:data/1>, <https://resources.stockholm.se/data/78beaac9-2001-4b08-9876-b5c6b3b10525#HTTP:OGC:WFS/2>;
    <http://purl.org/dc/terms/issued> "2025-06-05"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#landingPage> <https://dataportalen.stockholm.se/dataportalen/GetMetaDataById?id=34fc8b07-1d73-4461-8a32-a5e3236bb6cd>;
    <http://purl.org/dc/terms/type> <http://inspire.ec.europa.eu/metadata-codelist/ResourceType/dataset>;
    <http://purl.org/dc/terms/modified> "2025-06-05"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Stockholms Skyfallsmodell 2024 (TK)"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>;

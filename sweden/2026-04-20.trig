<#61065bef88e2db786817b3f54c03ad86> {
<https://opendata-catalog.smhi.se/md/b451cab6-2a8f-4b14-a125-fe0c49a6c9aa> <http://www.w3.org/ns/dcat#keyword> "Öppna data"@sv, "Meteorologi"@sv, "Observation"@sv, "Väderkod"@sv, "HVD"@sv, "Geografiska meteorologiska förhållanden"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/CONT>;
    <http://purl.org/dc/terms/identifier> "_b451cab6-2a8f-4b14-a125-fe0c49a6c9aa", "b451cab6-2a8f-4b14-a125-fe0c49a6c9aa";
    <http://www.w3.org/ns/dcat#byteSize> "30531"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>;

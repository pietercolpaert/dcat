<https://opendata-catalog.smhi.se/md/0f0138d0-30cd-11ec-8216-93597db8ce1c> <http://www.w3.org/ns/dcat#keyword> "Öppna data"@sv, "Hydrologi"@sv, "Meteorologi"@sv, "Oceanografi"@sv, "Lufttemperatur"@sv, "Lufttryck"@sv, "Molnhöjd"@sv, "Molnmängd"@sv, "Nederbördstyp"@sv, "Relativ luftfuktighet"@sv, "Sikt"@sv, "Vindhastighet"@sv, "Vindriktning"@sv, "Nederbördsintensitet"@sv, "Åska"@sv, "Varningar"@sv, "HVD"@sv;

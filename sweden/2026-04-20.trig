    <http://purl.org/dc/terms/issued> "2023-11-02T09:00:00.000Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "HelsingBotica - MDS standard - Policy - Delivery robot"@en, "HelsingBotica - MDS-standard - Policy - Leveransrobot"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TRAN>, <http://publications.europa.eu/resource/authority/data-theme/ENVI>, <http://publications.europa.eu/resource/authority/data-theme/REGI>;
    a <http://www.w3.org/ns/dcat#Dataset>
}


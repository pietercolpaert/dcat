<https://resources.stockholm.se/data/8d31bae2-c317-48a0-961e-bc7192e150d4> <http://www.w3.org/ns/dcat#keyword> "Stockholms stad", "Verksamhetsdata"@sv, "Extern dataportal"@sv, "4.URI som identifierare"@sv, "infoMapAccessService"@sv, "Trafikplanering"@sv;

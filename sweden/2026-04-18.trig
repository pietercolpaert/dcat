<feed> <https://w3id.org/tree#member> <#76934fa021d3f2e7ab28f214200c0d55>.
<#76934fa021d3f2e7ab28f214200c0d55> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <http://api.kolada.se/v3/kpi/N30025>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-18T06:27:05.896Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#76934fa021d3f2e7ab28f214200c0d55> {
<http://api.kolada.se/v3/kpi/N30025> <http://www.w3.org/ns/dcat#keyword> "Kommun"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "N30025";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Kostnad för kommungemensam verksamhet (Kommunnyckel+SCB-nyckel) fördelat på individ- och familjeomsorg dividerat med kostnad för eget åtagande för individ- och familjeomsorg. Kostnad för eget åtagande är bruttokostnad minus interna intäkter samt försäljning av verksamhet till kommuner och/eller regioner. I individ- och familjeomsorg ingår vård för vuxna med missbruksproblem, barn och ungdomsvård, övriga insatser till vuxna, ekonomiskt bistånd samt familjerätt och familjerådgivning. Avser kostnader för samtliga tjänster, funktioner och varor som redovisas centralt i kommunen och fördelats på Individ- och familjeomsorg i räkenskapssammandraget, t ex ekonomiadministration, HR-funktion och förbrukningsvaror. Gemensamma kostnader fördelas ut för att öka jämförbarheten mellan kommuner som bär sådana kostnader direkt i verksamheten och kommuner som redovisar kostnaderna centralt. Observera att även familjerätt och familjerådgivning ingår. I SCB:s totalkostnad för individ- och familjeomsorg är familjerätt och familjer��dgivning exkluderade och därför är Koladas IFO-totalposter inte direkt jämförbara med SCB:s siffror. "@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/N30025_json>;
    <http://purl.org/dc/terms/provenance> _:b0__54143.
_:b0__54143 <http://purl.org/dc/terms/description> "Källa: SCB Räkenskapssammandraget"@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/N30025> <http://purl.org/dc/terms/modified> "2025-08-28"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Gemensamma kostnader fördelade till individ- och familjeomsorg, andel (%)"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/HEAL>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


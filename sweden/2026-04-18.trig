<https://doi.org/10.5878/vqq9-1k59> <http://www.w3.org/ns/dcat#keyword> "Fysisk kondition"@sv, "Physical Fitness"@en, "Fysisk fostran och  träning"@sv, "Physical Education and Training"@en, "LEISURE TIME ACTIVITIES"@en, "FRITIDSAKTIVITETER"@sv, "SCHOOLS"@en, "SKOLOR"@sv, "PHYSICAL ACTIVITIES"@en, "FYSISK AKTIVITET"@sv, "SPORTS TRAINING"@en, "IDROTTSTRÄNING"@sv, "SCHOOLCHILDREN"@en, "SKOLBARN"@sv;

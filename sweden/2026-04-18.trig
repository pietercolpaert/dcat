<#bfa0b4087c8acf957671982c451d8eb4> {
<https://resources.stockholm.se/data/1aa0bb19-edd0-464b-b941-5c855b820f48> <http://www.w3.org/ns/dcat#keyword> "Stockholms stad", "Verksamhetsdata"@sv, "Extern dataportal"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/IRREG>;

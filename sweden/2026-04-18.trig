<http://api.kolada.se/v3/kpi/N79541> <http://purl.org/dc/terms/modified> "2025-10-30"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Patientupplevd kvalitet avseende kontinuitet och koordinering hos patienter som har besökt en ��ppenvårdsmottagning inom vuxenpsykiatri, index"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/HEAL>;

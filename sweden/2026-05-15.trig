<https://opendata.umea.se/api/v2/catalog/datasets/trad-som-forvaltas-av-gator-och-parker> <http://www.w3.org/ns/dcat#keyword> "Umeå kommun", "Träd"@sv, "Planering"@sv;
    <http://purl.org/dc/terms/identifier> "trad-som-forvaltas-av-gator-och-parker@http://dataportal.se/organisation/SE2120002627";

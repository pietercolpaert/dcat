<feed> <https://w3id.org/tree#member> <#c1846e4ab617d6f398c8314505a8c1b3>.
<#c1846e4ab617d6f398c8314505a8c1b3> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <http://api.kolada.se/v3/kpi/U30341>;
    <https://www.w3.org/ns/activitystreams#published> "2026-05-15T07:07:20.385Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#c1846e4ab617d6f398c8314505a8c1b3> {
<http://api.kolada.se/v3/kpi/U30341> <http://www.w3.org/ns/dcat#keyword> "Kommun"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "U30341";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Svar på frågan \"Inom vilka verksamhetsområden har ni infört en eller flera handläggningsprocesser eller administrativa processer?\". Med automatisering menar socialstyrelsen att processerna sker helt eller delvis med stöd av digital teknik. Automatisering kan göras med stöd av digitala system, ibland med stöd av en RPA (Robotic Process Automation).  När det gäller automatisering av handläggningsprocesser ska dessa inte förväxlas med e-tjänster. En e-tjänst kan vara en ingång till tjänsten, med en automatisering utförs handläggningen helt eller delvis automatiskt utan att en människa utför den.  Exempel på administrativa processer som kan vara föremål för automation är: fakturagranskning och hantering, kontroller, ansökan om sjuklön, behörighetskontroller mm. "@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/U30341_json>;
    <http://purl.org/dc/terms/provenance> _:b0__25313.
_:b0__25313 <http://purl.org/dc/terms/description> "Källa: Socialstyrelsen, enkät om utvecklingen av e-hälsa och välfärdsteknik i kommunerna"@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/U30341> <http://purl.org/dc/terms/modified> "2025-06-03"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Kommunen har infört en eller flera automatiserade handläggnings- eller administrativa processer inom verksamhetsområdet familjerätt, (Ja=1, Nej=0)"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/HEAL>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


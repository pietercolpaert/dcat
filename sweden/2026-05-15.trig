    <https://www.w3.org/ns/activitystreams#published> "2026-05-15T07:07:18.822Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#052e45678f85e2bdad4f88e4689aae5e> {
<https://opendata.umea.se/api/v2/catalog/datasets/energiforbrukning-i-geografiska-omradet-030608-ostermalm> <http://www.w3.org/ns/dcat#keyword> "Energi"@sv, "Umeå Energi", "Förbrukning"@sv, "El"@sv, "Fjärrvärme"@sv;
    <http://purl.org/dc/terms/identifier> "energiforbrukning-i-geografiska-omradet-030608-ostermalm@http://dataportal.se/organisation/SE2120002627";
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://admin.dataportal.se/store/43/resource/fd2584866d01e4eaee64e3ffcfe40e02>;
    <http://purl.org/dc/terms/description> "Anonymiserad förbrukningsdata från Umeå Energi per nyckelkodsområde i Umeå Kommun. Detta data bör inte ses som exakta och kompletta förbrukningsvärden utan mer som en kvalificerad uppskattning av förbrukningen i syfte att se trender och indikationer.Datafilerna kommer endast innehålla värden för fastigheter i Umeå kommun där Umeå Energi är nätägare och informationen inte anses vara olämplig för distribution. Uppdateras normalt en gång varje månad med nytillkomna värden.Frågor kring detta förbrukningsdata hänvisas till matdata.datalager@umeaenergi.se "@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://opendata.umea.se/explore/?refine.dcat.contact_name=Ume%C3%A5+Energi&refine.dcat.contact_email=matdata.datalager%2540umeaenergi.se>;
    <http://www.w3.org/ns/dcat#distribution> <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-030608-ostermalm-API>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-030608-ostermalm-csv>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-030608-ostermalm-json>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-030608-ostermalm-jsonl>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-030608-ostermalm-parquet>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-030608-ostermalm-rdfxml>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-030608-ostermalm-jsonld>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-030608-ostermalm-turtle>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-030608-ostermalm-n3>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-030608-ostermalm-xlsx>;
    <http://purl.org/dc/terms/issued> "2024-01-17T03:35:11.177000+00:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://opendata.umea.se/explore/dataset/energiforbrukning-i-geografiska-omradet-030608-ostermalm/>;
    <http://purl.org/dc/terms/modified> "2024-01-17T03:35:11.177000+00:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

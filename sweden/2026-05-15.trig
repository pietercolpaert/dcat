<https://www.geodata.se/resources/866aee82-09c5-40b4-b5a7-5420924828d5> <http://www.w3.org/ns/dcat#contactPoint> <urn:uuid:054df213-7e73-b0a3-05f5-093b3c141de9>;
    <http://www.w3.org/ns/dcat#distribution> <urn:uuid:f2881d5a-5b85-54dd-c3e9-e56cddc17b99>, <urn:uuid:e8b15883-8a58-3591-9b91-01a8a7842be4>;
    <http://purl.org/dc/terms/issued> "2021-04-15"^^<http://www.w3.org/2001/XMLSchema#date>;

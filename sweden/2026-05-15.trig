    <http://purl.org/dc/terms/issued> "2023-04-24"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2026-05-14T19:06:51.339382"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

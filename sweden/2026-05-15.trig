<#967133c5ee16fb6fac56a74d0dd1bd70> {
<https://opendata-catalog.smhi.se/md/8cbb2fe0-f755-11ea-ac97-ab810184d520> <http://www.w3.org/ns/dcat#keyword> "Öppna data"@sv, "Inspire"@sv, "Observation"@sv, "Oceanografi"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "_8cbb2fe0-f755-11ea-ac97-ab810184d520";

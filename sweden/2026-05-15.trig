    <http://purl.org/dc/terms/issued> "2026-04-17"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2026-05-14T02:41:32.694938"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

<https://metadata.trafikverket.se/store/1/resource/1641> <http://entryscape.org/terms/metadataIdentifier> "8365ca80-1836-45b8-aa60-3f8bc86e007e";
    <http://www.w3.org/ns/dcat#keyword> "område: Vädermätning"@sv, "area: Weather measure"@en;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/CONT>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;

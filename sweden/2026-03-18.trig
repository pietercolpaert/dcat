    <http://purl.org/dc/terms/modified> "2026-03-17"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Cykelflödesmätningar Historisk data (IoT)"@sv, "Bicycle flow measurements Historical data (IoT)"@en;

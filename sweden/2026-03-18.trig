<#e8fc47e995b7fe2d5f99966ba4fa13bd> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <https://catalog.sodertalje.se/store/15/resource/57>;
    <https://www.w3.org/ns/activitystreams#published> "2026-03-18T06:24:33.717Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#e8fc47e995b7fe2d5f99966ba4fa13bd> {
<https://catalog.sodertalje.se/store/15/resource/57> <http://purl.org/dc/terms/license> <http://creativecommons.org/publicdomain/zero/1.0/>;
    <http://purl.org/dc/terms/format> "text/html";
    <http://xmlns.com/foaf/0.1/page> <https://catalog.sodertalje.se/store/15/resource/1113>;
    <http://purl.org/dc/terms/issued> "2022-01-31"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://data.europa.eu/r5r/availability> <http://data.europa.eu/r5r/availability/stable>;
    <http://www.w3.org/ns/adms#status> <http://publications.europa.eu/resource/authority/distribution-status/COMPLETED>;
    <http://purl.org/dc/terms/modified> "2026-01-22"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#accessURL> <https://api.sodertalje.se/dashboard/BC_count>;
    <http://purl.org/dc/terms/title> "Cykelflöden (IoT) i Södertälje - Visualisering"@sv, "Bicycle flows (IoT) in Södertälje - Vizualisation"@en;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/description> "Södertälje Municipality measures the flow of bicycle traffic over the Mälar Bridge and along Nygatan with IoT AI sensors. The sensors are mounted on the east and west sides of the Mälar Bridge and at the passage bridge over Nygatan and use Artificial Intelligence to detect the number of cyclists moving in each direction. \n\nThe sensors report the data continuously, including information about the number of cyclists who have moved in each direction."@en, "Södertälje kommun mäter flödet av cykeltrafik över Mälarbron och längs Nygatan med IoT AI-sensorer. Sensorerna sitter monterade p�� den östra respektive den västra sidan av Mälarbron samt vid passagebron över Nygatan och detekterar med hjälp av Artificiell Intelligens antalet cyklister som rör sig i vardera riktning. \n\nSensorerna rapporterar uppgifterna löpande och då med uppgift om antalet cyklister som rört sig i vardera riktning."@sv;
    a <http://www.w3.org/ns/dcat#Distribution>
}

<feed> <https://w3id.org/tree#member> <#50ea01eee08abd8d444d5f39b2da7290>.
<#50ea01eee08abd8d444d5f39b2da7290> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <https://ckan-malmo.dataplatform.se/dataset/ea2ed4a9-c09f-4f1e-9bf4-3f5ebf4f9924/resource/3584fada-b20f-407e-8a00-eec7e1c53831>;
    <https://www.w3.org/ns/activitystreams#published> "2026-03-18T06:24:33.733Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#50ea01eee08abd8d444d5f39b2da7290> {
<https://ckan-malmo.dataplatform.se/dataset/ea2ed4a9-c09f-4f1e-9bf4-3f5ebf4f9924/resource/3584fada-b20f-407e-8a00-eec7e1c53831> <http://purl.org/dc/terms/license> <http://creativecommons.org/publicdomain/zero/1.0/>;
    <http://purl.org/dc/terms/issued> "2022-08-19T08:18:43.300122"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://data.europa.eu/r5r/availability> <http://data.europa.eu/r5r/availability/available>;
    <http://www.w3.org/ns/adms#status> <http://publications.europa.eu/resource/authority/distribution-status/COMPLETED>;
    <http://purl.org/dc/terms/modified> "2022-08-19T08:18:43.300122"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#accessURL> <https://api.kolada.se/v2/data/municipality/1280/kpi/N13032>;
    <http://purl.org/dc/terms/title> "Nettokostnadsavvikelse fritidshem, inkl. öppen fritidsverksamhet, miljoner kronor (N13032)"@sv;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/description> "Nettokostnadsavvikelse är nettokostnad minus referenskostnad för fritidshem inkl. öppen fritidsverksamhet, här visat i miljoner kronor. Pedagogisk omsorg (tidigare kallat familjedaghem) ingår inte. Nettokostnad är bruttokostnad minus bruttointäkt. Referenskostnaden bygger på nettokostnader och strukturvariabler för det aktuella året. Standardkostnaden för fritidshem beräknas med hjälp av variablerna andel inskrivna i fritidshem samt andel 6-12 åringar. Därutöver tillkommer del av standardkostnaderna från delmodellerna löner, bebyggelsestruktur och befolkningsutveckling. Positiva värden indikerar högre kostnadsläge än förväntat och negativa värden ett lägre kostnadsläge än förväntat. Från och med 2019 beräknas nettokostnadsavvikelse på ett nytt sätt pga förändringar i kostnadsutjämningen.  Detta påverkar jämförbarheten med tidigare år. \nKälla: Kolada"@sv;
    a <http://www.w3.org/ns/dcat#Distribution>
}


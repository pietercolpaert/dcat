<http://api.kolada.se/v3/kpi/U01760> <http://www.w3.org/ns/dcat#keyword> "Kommun"@sv, "Region"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "U01760";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Nationella folkhälsoenkäten är en urvalsundersökning bland befolkningen 16 år och äldre, för 2020 och tidigare omfattas 16-84 år, data avser år T-3 till T. Flerårsmedelvärden redovisas för att få tillräckligt stort dataunderlag. BMI beräknas enligt: vikt (i kg) dividerat med längd (m2) i kvadrat. Andelen räknas genom att ta antal enkätsvarande som beräknats ha ett BMI 25 eller högre enligt ovan dividerat med det totala antalet som besvarat frågan. Extremvärden har exkluderats. Data finns tillgängligt enligt könsuppdelning."@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/U01760_json>;
    <http://purl.org/dc/terms/provenance> _:b0__6510.
_:b0__6510 <http://purl.org/dc/terms/description> "Källa: Folkhälsomyndigheten, Hälsa på lika villkor (HLV)"@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/U01760> <http://purl.org/dc/terms/modified> "2025-12-16"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Invånare med övervikt eller fetma, andel (%)"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/HEAL>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


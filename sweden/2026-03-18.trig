    <http://purl.org/dc/terms/issued> "2024-11-05"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Avaiable plots, vacant land"@en, "Lediga Tomter, ledig tomtmark"@sv;
    <http://www.w3.org/ns/adms#versionNotes> "Initial release"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/REGI>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


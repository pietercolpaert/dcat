<feed> <https://w3id.org/tree#member> <#d6d560517aeb4257d400c3fa12b03e43>.
<#d6d560517aeb4257d400c3fa12b03e43> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <http://api.kolada.se/v3/kpi/U01423>;
    <https://www.w3.org/ns/activitystreams#published> "2026-03-18T06:24:29.893Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#d6d560517aeb4257d400c3fa12b03e43> {
<http://api.kolada.se/v3/kpi/U01423> <http://www.w3.org/ns/dcat#keyword> "Kommun"@sv, "Region"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "U01423";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Två frågor om intag av frukt respektive grönsaker i Nationella folkhälsoenkäten mäter frekvensen av intaget. Svarsalternativen ges olika vikter och de bägge frågorna sammanräknas till ett summaindex. Vikter för respektive svarsalternativ: 3,0 = 3 gånger per dag eller mer, 2,0 = 2 gånger per dag, 1,0 = 1 gång per dag, 0,8 = 5-6 gånger per vecka, 0,5 = 3-4 gånger per vecka, 0,2 = 1-2 gånger per vecka, 0,07 = Några gånger per månad eller aldrig. En summavariabel skapas där bortfall på den ena frågan inte betyder att det blir bortfall för summavariabeln. Summavariabeln kan ha värden mellan 0,07 och 6. Antal för vilka summavariabeln, enligt ovan, är mer än 3 dividerat med antal som besvarat minst en av frågorna. Avser år T-3 till T. Data finns tillgängligt enligt könsuppdelning."@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/U01423_json>;
    <http://purl.org/dc/terms/provenance> _:b0__546.
_:b0__546 <http://purl.org/dc/terms/description> "Källa: Folkhälsomyndigheten, Hälsa på lika villkor (HLV)."@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/U01423> <http://purl.org/dc/terms/modified> "2025-12-16"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Invånare 16-84 år som äter frukt och grönt mer än 3 ggr/dag, andel (%)"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/HEAL>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


    <https://www.w3.org/ns/activitystreams#object> <https://catalog.raa.se/store/1/resource/68>;
    <https://www.w3.org/ns/activitystreams#published> "2026-03-18T06:24:32.183Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#82292ee3a0b7718903cbf2e7eee30582> {
<https://catalog.raa.se/store/1/resource/68> <http://www.w3.org/ns/dcat#keyword> "Kulturmiljö"@sv, "Världsarv"@sv;
    <http://xmlns.com/foaf/0.1/page> <https://catalog.raa.se/store/1/resource/153>;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/DAILY>;
    <http://data.europa.eu/r5r/hvdCategory> <http://data.europa.eu/bna/c_dd313021>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021001090>;
    <http://purl.org/dc/terms/description> "Områden för Sveriges samtliga världsarv. Eventuella buffertzoner ingår inte i datamängden. Världsarven Struves meridianbåge och Höga kusten sträcker sig över flera länder, men enbart de områden som ligger inom Sveriges gränser ingår. Attributdata har utformats utifrån Inspires tekniska riktlinjer för skyddade områden.\n\nEtt världsarv är en kultur- eller naturmiljö som är så värdefull att det är en angelägenhet för hela mänskligheten. Det är en plats, ort, miljö eller objekt som på ett alldeles unikt sätt vittnar om jordens och människans historia."@sv, "A world heritage site is a cultural or naural environment that is so valuable that it is a concern for all of humanity. It is a place, locality, environment or object that in a truly unique way bears witness to the history of the earth and man."@en;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/2661886>, _:b0__44338.
_:b0__44338 <http://www.w3.org/ns/dcat#bbox> "POLYGON((10 69.1,24.2 69.1,24.2 54.9,10 54.9,10 69.1))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.
<https://catalog.raa.se/store/1/resource/68> <http://www.w3.org/ns/dcat#contactPoint> <https://catalog.raa.se/store/1/resource/32>;
    <http://www.w3.org/ns/dcat#distribution> <https://catalog.raa.se/store/1/resource/70>, <https://catalog.raa.se/store/1/resource/183>, <https://catalog.raa.se/store/1/resource/209>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg_impl/2023/138/oj>;
    <http://purl.org/dc/terms/title> "Världsarv i Sverige"@sv, "World Heritage sites in Sweden"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/SOCI>, <http://publications.europa.eu/resource/authority/data-theme/EDUC>, <http://publications.europa.eu/resource/authority/data-theme/ENVI>;
    a <http://www.w3.org/ns/dcat#Dataset>
}


<#6c5a708401a6dc72aaa6ea59f975220c> {
<http://api.kolada.se/v3/kpi/N01705> <http://www.w3.org/ns/dcat#keyword> "Kommun"@sv, "Rådet för främjande av kommunala analyser - Kolada";

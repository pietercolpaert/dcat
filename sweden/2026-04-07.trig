    <http://purl.org/dc/terms/issued> "2024-04-02"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#landingPage> <https://data.arbetsformedlingen.se/dataset/yrkesbarometer/>;
    <http://purl.org/dc/terms/title> "Yrkesbarometer"@en, "Yrkesbarometer"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>;
    <http://purl.org/dc/terms/temporal> _:b0__78193.
_:b0__78193 <http://www.w3.org/ns/dcat#startDate> "2024-04-02"^^<http://www.w3.org/2001/XMLSchema#date>;
    a <http://purl.org/dc/terms/PeriodOfTime>.

    <http://purl.org/dc/terms/title> "HUS93 - Nonresponse study, Spell variables: Household composition - persons moving out"@sv, "HUS93 - Nonresponse study, Spell variables: Household composition - persons moving out"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/SOCI>;

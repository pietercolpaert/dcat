<#30b0eff051c0ddc3dae1ad0d9dd18f7b> {
<https://admin.dataportal.se/store/818/resource/7640faf37ed7ab99d4f0cf2c61ca707c> <http://www.w3.org/ns/dcat#keyword> "Exercise"@en, "Träning"@sv, "Register"@sv, "Äldre"@sv, "Aged"@en, "Socialt stöd"@sv, "Social Support"@en, "Tecken och symtom"@sv, "Signs and Symptoms"@en, "Sjukdom"@sv, "Disease"@en, "Äldrevård"@sv, "Geriatric Nursing"@en, "Omvårdnad"@sv, "Nursing Care"@en, "Trötthet"@sv, "Fatigue"@en, "Aktiviteter i dagliga livet"@sv, "Activities of Daily Living"@en, "Äldre, 80 och över"@sv, "Aged, 80 and over"@en, "Geriatrik"@sv, "Geriatrics"@en, "Kognition"@sv, "Cognition"@en, "Registries"@en, "Sköra äldre"@sv, "Frail Elderly"@en, "Kartläggning och enkäter"@sv, "Surveys and Questionnaires"@en, "Sjukhusvistelse"@sv, "Hospitalization"@en, "Fall-kontrollstudier"@sv, "Case-Control Studies"@en, "Viktminskning"@sv, "Weight Loss"@en, "HEALTH SERVICES"@en, "HÄLSOVÅRD"@sv;

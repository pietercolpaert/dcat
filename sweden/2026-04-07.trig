    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/CONT>;
    <http://purl.org/dc/terms/identifier> "_9e3c0b20-cdb2-11eb-9269-d991226864d8", "9e3c0b20-cdb2-11eb-9269-d991226864d8";

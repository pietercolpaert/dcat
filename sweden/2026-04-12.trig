    <http://purl.org/dc/terms/issued> "2025-01-28T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2026-01-29T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

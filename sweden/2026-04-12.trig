<#6fe0f5163a44ef91f75fdd5be9db3180> {
<https://opendata-catalog.smhi.se/md/9c95eda0-89ec-11ea-a966-bfa48b38ccc2> <http://www.w3.org/ns/dcat#keyword> "Öppna data"@sv, "Observation"@sv, "Oceanografi"@sv, "Havsvattenstånd"@sv, "Geografiska oceanografiska förhållanden"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/MONTHLY>;
    <http://purl.org/dc/terms/identifier> "_9c95eda0-89ec-11ea-a966-bfa48b38ccc2", "9c95eda0-89ec-11ea-a966-bfa48b38ccc2";

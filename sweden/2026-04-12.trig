<#e8287bd71901d676dad8b4cee8fca798> {
<https://admin.dataportal.se/store/818/resource/fd3565f21d49788a805553c1a8863897> <http://www.w3.org/ns/dcat#keyword> "Noise"@en, "Buller"@sv, "Skåne"@sv, "Miljö och folkhälsa"@sv, "Environment and Public Health"@en, "Tecken och symtom"@sv, "Signs and Symptoms"@en, "Luftvägssjukdomar"@sv, "Respiratory Tract Diseases"@en, "Riskfaktorer"@sv, "Risk Factors"@en, "Rök"@sv, "Smoke"@en, "Hörselnedsättning"@sv, "Hearing Loss"@en, "Epidemiologiska studier"@sv, "Epidemiologic Studies"@en, "Läkemedelsförsörjning"@sv, "Drug Utilization"@en, "Astma"@sv, "Asthma"@en, "Överkänslighet"@sv, "Hypersensitivity"@en, "Populationsövervakning"@sv, "Population Surveillance"@en, "Kartläggning och enkäter"@sv, "Surveys and Questionnaires"@en, "Kost"@sv, "Diet"@en, "Eksem"@sv, "Eczema"@en, "Högt blodtryck"@sv, "Hypertension"@en, "Scania"@en, "EpiHealth_Skåne"@sv, "EpiHealth_Skåne"@en, "Luftförorening"@sv, "Air Pollution"@en, "Emfysem"@sv, "Emphysema"@en, "Nästäppa"@sv, "Nasal Obstruction"@en, "HOUSING"@en, "BOENDE"@sv, "MEDICINAL DRUGS"@en, "LÄKEMEDEL"@sv, "HOUSING CONDITIONS"@en, "BOSTADSFÖRHÅLLANDE"@sv, "SMOKING"@en, "RÖKNING"@sv, "MENTAL HEALTH"@en, "PSYKISK HÄLSA"@sv, "PUBLIC HEALTH"@en, "FOLKHÄLSA"@sv, "TRAFFIC NOISE"@en, "TRAFIKBULLER"@sv, "CARDIOVASCULAR DISEASES"@en, "HJÄRT-KÄRLSJUKDOMAR"@sv, "PASSIVE SMOKING"@en, "PASSIV RÖKNING"@sv, "PARKS"@en, "PARKER"@sv, "GREEN BELT AREAS"@en, "GRÖNBÄLTESOMRÅDEN"@sv, "COUGHING"@en, "HOSTA"@sv, "BRONCHITIS"@en, "LUFTRÖRSKATARR"@sv, "SMELL"@en, "LUKT"@sv, "WATER INFRASTRUCTURE"@en, "VATTENINFRASTRUKTUR"@sv, "TINNITUS"@en, "TINNITUS"@sv, "TRANSPORT"@en, "TRANSPORT"@sv, "WALKING ABILITY"@en, "GÅNGFÖRMÅGA"@sv;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__6422.
_:b0__6422 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;

    <http://purl.org/dc/terms/spatial> _:b0__12710.
_:b0__12710 <http://www.w3.org/ns/locn#geometry> "POLYGON((11.108 69.036,24.163 69.036,24.163 55.343,11.108 55.343,11.108 69.036))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;

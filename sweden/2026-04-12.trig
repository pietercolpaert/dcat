<#945613984c3d0b28ddec1fca22f0265c> {
<https://admin.dataportal.se/store/818/resource/bdc91dd235551821aec077ad565c6194> <http://www.w3.org/ns/dcat#keyword> "Viking Age"@en, "Runverket"@en, "Runestone"@en, "Rune stone"@en, "Runsten"@en, "Runinskrift"@en, "Runor"@en, "Runes"@en, "Runic inscription"@en, "1000-tal"@en, "11th century"@en, "Hälsingland"@en, "3D-skanning"@en, "3D-scan"@en, "3D models"@en, "Hs 1"@en, "Hs 2"@en, "Hs 3"@en, "Hs 4"@en, "Hs 6"@en, "Hs 9"@en, "Hs 10"@en, "Hs 11"@en, "Hs 12"@en, "Hs 14"@en, "Hs 15"@en, "Hs 16"@en, "Hs 21"@en;
    <http://purl.org/dc/terms/issued> "2025-06-11T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2025-06-11T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "3D-data Runstenar i Hälsingland\n3D data Runestones in Hälsingland"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/EDUC>;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__4097.
_:b0__4097 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/d3b0084dd7dbe2b1b65172513bd132d0>;
    a <http://www.w3.org/ns/prov#Attribution>.
<https://admin.dataportal.se/store/818/resource/bdc91dd235551821aec077ad565c6194> <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__7502.
_:b0__7502 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/e0926778acd5f41c66a95651951abd92>;
    a <http://www.w3.org/ns/prov#Attribution>.
<https://admin.dataportal.se/store/818/resource/bdc91dd235551821aec077ad565c6194> <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021001090>;
    <http://purl.org/dc/terms/description> "3D-scans of all preserved runestones in Hälsingland. This dataset includes 3D-models of 11th century runestones 3D-scanned for documentation and analysis at Runverket (the runic research group) at the Swedish National Heritage Board.\n\nThe signum Hs + number is an ID-code used in the record of runic inscriptions kept by Runverket at the Swedish National Heritage Board. The signum is used in most publications and web-based resources. It is the key to find further references on a specific runic inscription and the object carrying it.\n\nThe 3D-scanning was made by Henrik Zedig, Länsstyrelsen Västra Götaland, with a handheld laser scanner HandySCAN BLACK ELITE (blue laser) from Creaform with a resolution of 0.40 mm. The data is here provided as STL-files. \n\nNoice has been reduced by using the function Thin in Zeiss INSPECT Optical 3D at a threshold level of 0.02-0.03 mm.\n\nDue to its size, the runestone Hs 10 is divided into six sections.\n\nThe runestone Hs 14 is scanned twice, first in the round and secondly focussing on the runic inscription using a higher resolution."@en;
    a <http://www.w3.org/ns/dcat#Dataset>
}


    <http://purl.org/dc/terms/modified> "2025-06-23T13:39:59.432088Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Internationella förhandlingsbarometern"@sv, "The International Negotiations Survey"@en;

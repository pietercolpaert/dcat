    <http://purl.org/dc/terms/title> "Parallel text typology dataset"@en;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__9149.
_:b0__9149 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;

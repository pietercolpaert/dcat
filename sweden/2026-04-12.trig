<#f9722031b641d13d26beb62e50900ca8> {
<https://admin.dataportal.se/store/818/resource/a8e8630b4e17104363011df97249b97c> <http://www.w3.org/ns/dcat#keyword> "X-ray fluorescence spectroscopy"@en, "Electron microscopy"@en, "Heritage science"@en, "RAÄ-2023-0820"@en, "Paper conservation"@en, "Iron gall ink"@en;
    <http://purl.org/dc/terms/issued> "2024-07-03T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2025-04-24T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Data from project 'Stabilising heritage: Iron gall ink corrosion on paper and the eternal search for an ideal treatment', RAÄ-2023-0820"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/EDUC>;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__3913.
_:b0__3913 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/f1364552083e593c6b86189c0eaf3cf3>;
    a <http://www.w3.org/ns/prov#Attribution>.
<https://admin.dataportal.se/store/818/resource/a8e8630b4e17104363011df97249b97c> <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__9851.
_:b0__9851 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/91a7b785e52a3dda3f28d88d8f27660d>;
    a <http://www.w3.org/ns/prov#Attribution>.
<https://admin.dataportal.se/store/818/resource/a8e8630b4e17104363011df97249b97c> <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021001090>;
    <http://purl.org/dc/terms/description> "Data from the project \"Stabilising heritage: Iron gall ink corrosion on paper and the eternal search for an ideal treatment\" (Diarienummer RAÄ-2023-0820) including files for sample descriptions. Data from the following analytical techniques is included: 1. Scanning electron microscopy with energy dispersive x-ray spectroscopy (SEM-EDS); 2. X-ray fluorescence spectroscopy (XRF). Instrument reports are also included. The intention of the project was to develop a non-aqueous treatment method for documents containing iron gall ink which could provide both mechanical stability and reduce the corrosion rate. SEM-EDS mapping was performed to observe the penetration depth of the ink and treatment materials in the paper samples while XRF lines scans were performed to better understand the phenomenon of a \"halo\" effect around certain ink samples after treatment. All data was collected as part of the master's thesis \"Stabilising heritage: Iron gall ink corrosion on paper and the eternal search for an ideal treatment: \" by Anna Lagerqvist Alidoost, Department for Conservation, University of Gothenburg (https://hdl.handle.net/2077/82110)."@en;
    a <http://www.w3.org/ns/dcat#Dataset>
}


<#3c6c053b61110af842f1d3fe28dd9d9c> {
<https://opendata.umea.se/api/v2/catalog/datasets/laddplatser> <http://www.w3.org/ns/dcat#keyword> "Umeå kommun", "Elbil"@sv, "laddning"@sv, "laddplatser"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/MONTHLY>;
    <http://purl.org/dc/terms/identifier> "laddplatser@http://dataportal.se/organisation/SE2120002627";
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://admin.dataportal.se/store/43/resource/7a00bd3796ed09a600646432cb321722>;
    <http://purl.org/dc/terms/description> "Datat avser laddplatser märkta med kommunkod 2480 (=Umeå).Informationen om laddplatserna kommer fr��n Nobil  [https://info.nobil.no/](https://info.nobil.no/)[](https://info.nobil.no/) Observera att licensvillkor vid återanvändning av datat. Denna information finns hos Nobil.Energimyndigheten har nu tagit över registrering av svenska\nladdstationer, med andra ord ansvaret för Sveriges laddstationsdata i den\nnorska databasen Nobil.\n\n\nDet kan finnas brister i datat, i synnerhet det data som\nregistrerades innan Energimyndigheten tog över ansvaret för registreringen. Ett\nAPI med möjlighet att använda andra data och data över andra geografiska\nområden finns hos Nobil.Datat uppdateras 1 gång per månad."@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://opendata.umea.se/explore/?refine.dcat.contact_name=%C3%96ppna+Data+Ume%C3%A5+kommun&refine.dcat.contact_email=oppnadata%2540umea.se>;
    <http://www.w3.org/ns/dcat#distribution> <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/laddplatser-API>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/laddplatser-csv>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/laddplatser-json>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/laddplatser-fgb>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/laddplatser-geojson>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/laddplatser-gpx>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/laddplatser-jsonl>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/laddplatser-kml>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/laddplatser-ov2>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/laddplatser-parquet>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/laddplatser-rdfxml>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/laddplatser-jsonld>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/laddplatser-turtle>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/laddplatser-n3>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/laddplatser-shp>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/laddplatser-xlsx>;
    <http://purl.org/dc/terms/issued> "2026-05-11T02:00:13.011000+00:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

<feed> <https://w3id.org/tree#member> <#5df6b10afbc49cf2421a967bba2a9f9f>.
<#5df6b10afbc49cf2421a967bba2a9f9f> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <http://api.kolada.se/v3/kpi/U07344>;
    <https://www.w3.org/ns/activitystreams#published> "2026-05-12T06:59:06.970Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#5df6b10afbc49cf2421a967bba2a9f9f> {
<http://api.kolada.se/v3/kpi/U07344> <http://www.w3.org/ns/dcat#keyword> "Kommun"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "U07344";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Svar på frågan: Vilka typer av välfärdsteknik finns tillgängliga i den kommunala hälso- och sjukvården?. Välfärdsteknik är digital teknik som syftar till att bibehålla eller öka trygghet, aktivitet, delaktighet eller självständighet för en person som har eller löper förhöjd risk att få en funktionsnedsättning. Frågan handlar om välf��rdsteknik som kommunen tillhandahåller till den enskilda patienten genom förskrivning enligt Hälso- och sjukvårdslagen, eller att den på annat sätt införts som stöd för personalen eller organisationen, inte sådan teknik som tillhandahålls genom biståndsbeslut enligt socialtjänstlagen eller som den enskilde själv, eller dennes anhöriga köper på öppna marknaden. Med breddinfört menas att kommunen tagit beslut att alla inom målgruppen kan, eller kommer kunna, ta del av tekniken. Pilot eller testverksamhet innebär att det är ett initiativ som är begränsat i tid, i antal personer som kan använda tekniken, eller att det sker under särskilda förutsättningar. "@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/U07344_json>;
    <http://purl.org/dc/terms/provenance> _:b0__77700.
_:b0__77700 <http://purl.org/dc/terms/description> "Källa: Socialstyrelsen, enkät om utvecklingen av e-hälsa och välfärdsteknik i kommunerna"@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/U07344> <http://purl.org/dc/terms/modified> "2025-06-03"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Digital signering av hälso- och sjukvårdsåtgärder finns tillgängligt inom den kommunala hälso- och sjukvården, (Breddinfört=2, testverksamhet=1, Nej=0)"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/HEAL>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


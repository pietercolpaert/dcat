<#640f631a771ddd782c8301da536562df> {
<https://opendata-api.malmo.se/dataset/5249aa0b-6528-43ef-880f-172adac8515b> <http://www.w3.org/ns/dcat#keyword> "Malmö stad", "GIS", "karta", "geodata", "Prövningsplikt", "Miljöfarlig verksamhet", "map";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/DAILY>;
    <http://purl.org/dc/terms/identifier> "5249aa0b-6528-43ef-880f-172adac8515b";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://malmo.se/>;
    <http://purl.org/dc/terms/description> "Miljöfarliga verksamheter med prövningsplikt som finns registrerade hos miljöförvaltningen.\n\nA- och B-verksamheter är tillståndspliktiga verksamheter.\n\nC-verksamheter är anmälningspliktiga verksamheter.\n\nU-verksamheter är inte anmälningspliktiga.\n\nVerksamheterna är i drift och objekt som kan vara skyddsklassade är bortsorterade.\n"@sv, "Environmentally hazardous activities subject to an assessment obligation that\nare registered with the Environmental Administration.\n\nA and B activities are activities that require a permit.\n\nC-activities are activities that require notification.\n\nU-businesses are not subject to notification.\n\nThe operations are in operation and objects that may be classified as\nprotected have been removed.\n\n"@en, "Miljøfarlige aktiviteter, der er underlagt vurderingspligt, og som er\nregistreret hos Miljøforvaltningen.\n\nA- og B-aktiviteter er aktiviteter, der kræver en tilladelse.\n\nC-aktiviteter er aktiviteter, der kræver anmeldelse.\n\nU-virksomheder er ikke underretningspligtige.\n\nDriften er i gang, og objekter, der kan klassificeres som beskyttede, er\nblevet fjernet.\n\n"@da;
    <http://purl.org/dc/terms/spatial> <http://www.geonames.org/2692965/malmoe.html>, _:b0__6488.
_:b0__6488 <http://www.w3.org/ns/dcat#bbox> "POLYGON((12.8850967451 55.6421476735,13.1517619812 55.6421476735,13.1517619812 55.5022773196,12.8850967451 55.5022773196,12.8850967451 55.6421476735))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.
<https://opendata-api.malmo.se/dataset/5249aa0b-6528-43ef-880f-172adac8515b> <http://www.w3.org/ns/dcat#contactPoint> <https://admin.dataportal.se/store/290/resource/00384f6c30a75c7618456af7c6cec6b6>;
    <http://www.w3.org/ns/dcat#distribution> <https://opendata-api.malmo.se/dataset/5249aa0b-6528-43ef-880f-172adac8515b/resource/b8c20e85-9785-4950-b272-05ffedf85e3e>, <https://opendata-api.malmo.se/dataset/5249aa0b-6528-43ef-880f-172adac8515b/resource/8aa6f956-d315-4c42-88c7-2ee33b21169a>;

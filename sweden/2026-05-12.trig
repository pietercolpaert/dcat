<feed> <https://w3id.org/tree#member> <#c9fb919a94100c7dcb90d490f1d4d9a1>.
<#c9fb919a94100c7dcb90d490f1d4d9a1> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <http://api.kolada.se/v3/kpi/U11001>;
    <https://www.w3.org/ns/activitystreams#published> "2026-05-12T06:59:06.005Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#c9fb919a94100c7dcb90d490f1d4d9a1> {
<http://api.kolada.se/v3/kpi/U11001> <http://www.w3.org/ns/dcat#keyword> "Kommun"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "U11001";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Indexet baseras på kostnad per inskrivet barn i kommunal förskola och nettokostnadsavvikelsen för förskola. Nyckeltalen normaliseras så att alla kommunernas värden placeras på en skala från 0 till 100 där 0 är sämst (högst kostnad) och 100 är bäst (lägst kostnad). För att inte extremvärden ska få för stort genomslag sätts värdet till 0 för kommuner med värden under percentil 2,5, och 100 för kommuner med värden över percentil 97,5. För de kommuner som har data på båda nyckeltalen beräknas det ovägda medelvärdet, och därefter normaliseras även medelvärdet till en skala från 0 till 100 på samma sätt. Index utgörs av det normaliserade medelvärdet. RKA:s beräkningar baserade på uppgifter från SCB. "@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/U11001_json>;
    <http://purl.org/dc/terms/provenance> _:b0__53301.
_:b0__53301 <http://purl.org/dc/terms/description> "Källa: RKA:s beräkningar"@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/U11001> <http://purl.org/dc/terms/modified> "2025-09-29"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Resursindex förskola"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/SOCI>, <http://publications.europa.eu/resource/authority/data-theme/REGI>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}

<feed> <https://w3id.org/tree#member> <#d9428bb68ba69c8b7b98d362821ffdbc>.

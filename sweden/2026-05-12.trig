    <http://purl.org/dc/terms/modified> "2016-10-06T09:07:42Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "GIS-material för arkeologiskt projekt: Boplatslämningar vid Västra Stenby"@sv, "GIS-material for the archaeological project: Västra Stenby"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/EDUC>;

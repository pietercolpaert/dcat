    <http://www.w3.org/ns/dcat#landingPage> <https://bolagsverket.se/apierochoppnadata/nedladdningsbarafiler.2517.html>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg_impl/2023/138/oj>;
    <http://purl.org/dc/terms/modified> "2025-02-03"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "High value dataset via file download"@en, "Värdefulla datamängder via filnedladdning"@sv;

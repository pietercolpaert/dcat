    <http://www.w3.org/ns/dcat#distribution> <urn:uuid:52b01117-3a5d-8d41-bd57-94e7399ddc40>, <urn:uuid:e9af6682-77f7-eba3-2e75-65c5f0111e45>, <urn:uuid:ceebf03a-c1e3-c54e-6afb-74d51467f812>;
    <http://purl.org/dc/terms/provenance> _:b0__2338.
_:b0__2338 <http://www.w3.org/2000/01/rdf-schema#value> "Detta fylls inom kort"@sv;

<https://www.geodata.se/resources/eb4d21fa-f874-581a-6560-d048da0a9ab8> <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg_impl/2023/138/oj>;
    <http://purl.org/dc/terms/modified> "2025-11-26"^^<http://www.w3.org/2001/XMLSchema#date>;

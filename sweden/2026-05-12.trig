<feed> <https://w3id.org/tree#member> <#174ea1de58ce0d92ad0f254d1253678a>.
<#174ea1de58ce0d92ad0f254d1253678a> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <https://konsumentverket.entryscape.net/store/1/resource/334>;
    <https://www.w3.org/ns/activitystreams#published> "2026-05-12T06:59:07.747Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#174ea1de58ce0d92ad0f254d1253678a> {
<https://konsumentverket.entryscape.net/store/1/resource/334> <http://www.w3.org/ns/dcat#downloadURL> <https://konsumentverket.entryscape.net/store/1/resource/333>;
    <http://purl.org/dc/terms/format> "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
    <http://www.w3.org/ns/dcat#accessURL> <https://konsumentverket.entryscape.net/store/1/resource/333>;
    <http://purl.org/dc/terms/title> "Beräknade hushållskostnader för 2022, livsmedelskostnader"@sv;
    <http://purl.org/dc/terms/description> "Här redovisas de beräknade månadskostnaderna för livsmedelsinköp. Beräkningarna är uppdelade per måltid: frukost, lunch, middag, mellanmål och guldkant. Guldkant avser exempelvis fika eller godis till helgen och snacks till fredagsmyset. Beräkningarna är uppdelade per ålder och kön. Beräkningarna är baserade på Konsumentverkets matsedel, som är en fyraveckors närings- och klimatberäknad matsedel som täcker dagsbehovet av energi och näring för respektive åldersgrupp."@sv;
    a <http://www.w3.org/ns/dcat#Distribution>
}


<#bc6c77e7f1d69f0bcd8b92e3e1c825a4> {
<https://opendata-catalog.smhi.se/md/5f5b11f0-8a1d-11ea-a966-bfa48b38ccc2> <http://www.w3.org/ns/dcat#keyword> "Öppna data"@sv, "Observation"@sv, "Oceanografi"@sv, "Våghöjd"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/MONTHLY>;
    <http://purl.org/dc/terms/identifier> "_5f5b11f0-8a1d-11ea-a966-bfa48b38ccc2";

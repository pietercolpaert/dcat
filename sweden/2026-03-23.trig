<https://admin.dataportal.se/store/818/resource/bfd7a05ffaa780d972b604cf04854a3d> <http://www.w3.org/ns/dcat#keyword> "Skåne"@sv, "Typ 1-diabetes"@sv, "Diabetes Mellitus, Type 1"@en, "Scania"@en, "EpiHealth"@sv, "EpiHealth"@en, "EpiHealth_Skåne"@sv, "EpiHealth_Skåne"@en, "Insulin"@sv, "Insulin"@en, "omgivningsexponering"@sv, "ambient exposure"@en, "GAD65"@sv, "GAD65"@en, "IA-2"@sv, "IA-2"@en, "ZnT8"@sv, "ZnT8"@en, "virusinfektion"@sv, "viral infections"@en, "CHILDREN"@en, "BARN"@sv;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__4227.
_:b0__4227 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/f44bcde85cfcd70ac81cd7263a134918>;

    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/MONTHLY>;
    <http://purl.org/dc/terms/identifier> "_a35bacb5-4eab-4707-be37-9366e0408cd3", "a35bacb5-4eab-4707-be37-9366e0408cd3";

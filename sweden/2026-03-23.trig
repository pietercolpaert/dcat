<#00cea1d8bc75a16bd5ec3c8cd644dc9e> {
<https://ckan-malmo.dataplatform.se/dataset/6ca294e4-48fe-4c7d-88f5-e66369ee3986> <http://www.w3.org/ns/dcat#keyword> "statistik";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "6ca294e4-48fe-4c7d-88f5-e66369ee3986";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;

<feed> <https://w3id.org/tree#member> <#2f60e111b04e03845dbe029dd26c8414>.
<#2f60e111b04e03845dbe029dd26c8414> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <https://opendata.umea.se/api/v2/catalog/datasets/umea-kommun-transportutslapp-google-data>;
    <https://www.w3.org/ns/activitystreams#published> "2026-03-02T06:19:07.791Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#2f60e111b04e03845dbe029dd26c8414> {
<https://opendata.umea.se/api/v2/catalog/datasets/umea-kommun-transportutslapp-google-data> <http://www.w3.org/ns/dcat#keyword> "Umeå kommun";
    <http://purl.org/dc/terms/identifier> "umea-kommun-transportutslapp-google-data@http://dataportal.se/organisation/SE2120002627";
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://admin.dataportal.se/store/43/resource/7a00bd3796ed09a600646432cb321722>;
    <http://purl.org/dc/terms/description> "Denna datamängd består av en sammanställning av Googles Environmental insights uppskattning av transportutsläpp inom Umeå kommun per år. Förutom skattat utsläpp så finns information om totalt alla resor, per år, som gjorts inom Umeå kommuns gräns samt resor som passerat kommunens gräns.Total ressträcka för alla resor aggregeras och modelleras för hela kommunen med hjälp av aggregerad platsinformation från Google platshistoria och andra källor.Årliga transportutsläpp beräknas baserat på en extrapolering av den totala sträckan för alla gjorda resor, typ av transportsätt och genomsnittlig bränsleförbrukning för varje transportsätt. Regionalt uppskattat genomsnittlig bränsleförbrukning och utsläpp från klimatåtgärden för stadshållbarhetsverktyg (Curb) tillämpas på alla resor för varje läge.För ytterligare information - besök [Google Environmental Insights Explorer - Make Informed Decisions](https://insights.sustainability.google/)Källa: Google Environmental Insights Explorer (2025-05-13)"@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://opendata.umea.se/explore/?refine.dcat.contact_name=Digitalisering+och+verksamhetsutveckling&refine.dcat.contact_email=oppnadata%2540umea.se>;
    <http://www.w3.org/ns/dcat#distribution> <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/umea-kommun-transportutslapp-google-data-API>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/umea-kommun-transportutslapp-google-data-csv>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/umea-kommun-transportutslapp-google-data-json>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/umea-kommun-transportutslapp-google-data-jsonl>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/umea-kommun-transportutslapp-google-data-parquet>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/umea-kommun-transportutslapp-google-data-rdfxml>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/umea-kommun-transportutslapp-google-data-jsonld>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/umea-kommun-transportutslapp-google-data-turtle>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/umea-kommun-transportutslapp-google-data-n3>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/umea-kommun-transportutslapp-google-data-xlsx>;
    <http://purl.org/dc/terms/issued> "2025-05-12T12:02:00.171000+00:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://opendata.umea.se/explore/dataset/umea-kommun-transportutslapp-google-data/>;
    <http://purl.org/dc/terms/modified> "2025-05-12T12:02:00.171000+00:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Umeå kommun, antal resor och transportutsläpp"@sv, "Umeå municipality, number of trips and transport emissions"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TRAN>, <http://publications.europa.eu/resource/authority/data-theme/ENVI>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


<#14690b9895aa0eae1e5c89cea77a7969> {
<https://opendata.umea.se/api/v2/catalog/datasets/trad-som-forvaltas-av-gator-och-parker> <http://www.w3.org/ns/dcat#keyword> "Umeå kommun", "Träd"@sv, "Tree"@en, "Planering"@sv, "Planning"@en;
    <http://purl.org/dc/terms/identifier> "trad-som-forvaltas-av-gator-och-parker@http://dataportal.se/organisation/SE2120002627";
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://admin.dataportal.se/store/43/resource/7a00bd3796ed09a600646432cb321722>;
    <http://purl.org/dc/terms/description> "Gator och parker förvaltar ungefär 30 000 träd som står längs med gator, på torg och i parker. Träden finns registrerade i en databas där information om träden uppdateras dagligen. Året runt arbetar personal med att plantera, vattna, beskära och göra säkerhetsbesiktningar av träden.Datamängden uppdateras kontinuerligt.Utgivare är Gator och Parker, Umeå kommunHar ni frågor så kontakta gatorochparker@umea.se"@sv, "Streets and Parks manage approximately 30,000 trees located along streets, in squares, and parks. The trees are registered in a database where information about them is updated daily. Throughout the year, staff work on planting, watering, pruning, and conducting safety inspections of the trees.The dataset is continuously updated.The publisher is Streets and Parks, Umeå Municipality.If you have any questions, please contact [gatorochparker@umea.se](None)."@en;
    <http://www.w3.org/ns/dcat#contactPoint> <https://opendata.umea.se/explore/?refine.dcat.contact_name=Gator+och+parker%252C+Ume%C3%A5+kommun&refine.dcat.contact_email=gatorochparker%2540umea.se>;
    <http://www.w3.org/ns/dcat#distribution> <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/trad-som-forvaltas-av-gator-och-parker-API>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/trad-som-forvaltas-av-gator-och-parker-csv>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/trad-som-forvaltas-av-gator-och-parker-json>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/trad-som-forvaltas-av-gator-och-parker-fgb>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/trad-som-forvaltas-av-gator-och-parker-geojson>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/trad-som-forvaltas-av-gator-och-parker-gpx>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/trad-som-forvaltas-av-gator-och-parker-jsonl>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/trad-som-forvaltas-av-gator-och-parker-kml>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/trad-som-forvaltas-av-gator-och-parker-ov2>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/trad-som-forvaltas-av-gator-och-parker-parquet>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/trad-som-forvaltas-av-gator-och-parker-rdfxml>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/trad-som-forvaltas-av-gator-och-parker-jsonld>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/trad-som-forvaltas-av-gator-och-parker-turtle>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/trad-som-forvaltas-av-gator-och-parker-n3>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/trad-som-forvaltas-av-gator-och-parker-shp>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/trad-som-forvaltas-av-gator-och-parker-xlsx>;
    <http://purl.org/dc/terms/issued> "2026-01-06T23:55:24.420000+00:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

<#567edd49d0d5977808519d3d7a2045c1> {
<http://api.kolada.se/v3/kpi/N85532> <http://www.w3.org/ns/dcat#keyword> "Kommun"@sv, "Region"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "N85532";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Totala emissioner av växthusgaser ifrån egen uppvärmning av bostäder och lokaler inom det geografiska området, ton CO2e. Egen uppvärmning inkluderar uppvärmning av bostäder, Kommersiella och offentliga lokaler samt Jordbruks- och skogsbrukslokaler. Växthusgaser totalt är det totala utsläppet av växthusgaser (CO2 med fossilt ursprung samt N2O, CH4, HFC, PFC, och SF6) omräknat till koldioxidekvivalenter. Utsläppen ska inte tolkas som konsumtionsbaserade utsläpp. Enskilda industriverksamheter kan leda till höga utsläpp lokalt, liksom vägtrafik på stamvägnätet eller en stor andel jordbruk. Nyckeltalet följer upp miljökvalitetsmålet Begränsad klimatpåverkan, se även sverigesmiljomal.se. Vid uppdatering av emissionsdata revideras tidsserien bakåt. Uppgifter för olika undersektorer kan vara osäkra på kommunnivå, se vidare Metodbeskrivning på den Nationella emissionsdatabasens hemsida. "@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/N85532_json>;
    <http://purl.org/dc/terms/provenance> _:b0__6574.
_:b0__6574 <http://purl.org/dc/terms/description> "Källa: Nationella emissionsdatabasen"@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/N85532> <http://purl.org/dc/terms/modified> "2025-06-09"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Utsläpp till luft av växthusgaser, egen uppvärmning, ton CO2e"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/SOCI>, <http://publications.europa.eu/resource/authority/data-theme/REGI>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


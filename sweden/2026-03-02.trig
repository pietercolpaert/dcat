<feed> <https://w3id.org/tree#member> <#1a0009f231271b9ba1cbf5205b0c5958>.
<#1a0009f231271b9ba1cbf5205b0c5958> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <http://api.kolada.se/v3/kpi/U17401>;
    <https://www.w3.org/ns/activitystreams#published> "2026-03-02T06:19:05.907Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#1a0009f231271b9ba1cbf5205b0c5958> {
<http://api.kolada.se/v3/kpi/U17401> <http://www.w3.org/ns/dcat#keyword> "Kommun"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "U17401";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Indexet baseras på avvikelse från modellberäknat värde för andel elever med examen inom fyra år och ett elevenkätsindex. Nyckeltalen avser kommunal gymnasieskola. Nyckeltalet normaliseras så att alla kommunernas värden placeras på en skala från 0 till 100 där 0 är sämst och 100 är bäst. För att inte extremvärden ska få för stort genomslag sätts värdet till 0 för kommuner med värden under percentil 2,5, och 100 för kommuner med värden över percentil 97,5. För de kommuner som har data på båda nyckeltalen beräknas ett viktat medelvärde där avvikelse från modellberäknat värde ges vikten 75 % och elevenkätsindex vikten 25 %. Därefter normaliseras även medelvärdet till en skala från 0 till 100 på samma sätt. Index utgörs av det normaliserade medelvärdet. "@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/U17401_json>;
    <http://purl.org/dc/terms/provenance> _:b0__1043.
_:b0__1043 <http://purl.org/dc/terms/description> "Källa: RKA:s beräkningar baserade på uppgifter från SKR, SCB och Skolverket."@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/U17401> <http://purl.org/dc/terms/modified> "2025-09-29"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Kvalitetsindex kommunal gymnasieskola"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/SOCI>, <http://publications.europa.eu/resource/authority/data-theme/REGI>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


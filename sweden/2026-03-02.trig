    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "N30014";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Standardkostnaden (kr/inv 1 nov fg år) för individ- och familjeomsorg beräknad enligt det kommunala utjämningssystemet. Standardkostnaden för individ- och familjeomsorg bygger på en regressionsanalys. Variabler som ingår är: andel barn 0 – 19 år som lever under inkomststandard, andelen lågutbildade personer födda i Sverige i åldern 20 – 40 år, roten ur tätortsbefolkningen, andelen av befolkningen boende i flerfamiljshus byggda 1965 – 1975, antal dagar med sjukpenning eller sjukersättning i åldersgruppen 16 – 64 år (ohälsotal) samt andel gränspendlare i åldern 16 – 74. Vidare tillkommer tillägg eller avdrag för skillnader i lönekostnader. Ny kostnadsutjämning från 2020 påverkar standardkostnaderna från 2020. "@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/N30014_json>;
    <http://purl.org/dc/terms/provenance> _:b0__6766.
_:b0__6766 <http://purl.org/dc/terms/description> "Källa: SCB."@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/N30014> <http://purl.org/dc/terms/modified> "2025-04-15"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Standardkostnad individ- och familjeomsorg, kr/inv"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/HEAL>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


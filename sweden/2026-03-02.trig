_:b0__5818 <http://purl.org/dc/terms/description> "Källa: SKR"@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/N15018> <http://purl.org/dc/terms/modified> "2025-09-30"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Referenskostnad grundskola F-9, kr/inv"@sv;

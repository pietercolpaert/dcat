    <http://purl.org/dc/terms/modified> "2025-05-27T08:00:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Varaktigt låg ekonomisk standard (relativ), barn och unga efter kön, region och år. Andel (procent). 2014-2023"@sv;
    a <http://www.w3.org/ns/dcat#Dataset>
}

<feed> <https://w3id.org/tree#member> <#e5d0b651ef4e237e83ddd09b96be12bd>.
<#e5d0b651ef4e237e83ddd09b96be12bd> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <http://api.kolada.se/v3/kpi/N01711>;
    <https://www.w3.org/ns/activitystreams#published> "2026-03-02T06:19:08.370Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.

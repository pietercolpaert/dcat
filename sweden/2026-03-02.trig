    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "N11019";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Standardkostnaden (kr/inv 1 nov fg år) för förskoleverksamhet enligt det kommunala utjämningssystemet. Standardkostnaden för förskola, fritidshem och annan pedagogisk verksamhet beräknas utifrån kommunens åldersstruktur för åldersgrupperna 1-5 år (förskola) respektive 6-12 år (fritidshem) multiplicerat med riksgenomsnitt för kostnad per barn i de aktuella åldersgrupperna. Vidare tillkommer tillägg eller avdrag för skillnader i: behov av förskola, behov av fritidshem, socioekonomi gles bebyggelse, lönekostnad och befolkningsförändringar. Ny kostnadsutjämning från 2020 påverkar standardkostnaderna från 2020. "@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/N11019_json>;
    <http://purl.org/dc/terms/provenance> _:b0__9465.
_:b0__9465 <http://purl.org/dc/terms/description> "Källa: SCB."@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/N11019> <http://purl.org/dc/terms/modified> "2025-04-15"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Standardkostnad förskoleverksamhet, kr/inv"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/SOCI>, <http://publications.europa.eu/resource/authority/data-theme/EDUC>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


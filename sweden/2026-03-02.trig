    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Medborgarnas bedömning av kommunens gymnasieverksamhet, skala 0-100. Om kommunen saknar egen gymnasieskola avser frågan den gymnasieutbildning som kommunens ungdomar erbjuds i annan kommun. Utgår från frågan: \"Vad tror eller tycker du om gymnasieskolan i din kommun?\". Data finns tillgängligt enligt könsuppdelning."@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/U17400_json>;
    <http://purl.org/dc/terms/provenance> _:b0__7434.
_:b0__7434 <http://purl.org/dc/terms/description> "Källa SCB:s medborgarundersökningar."@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/U17400> <http://purl.org/dc/terms/title> "Nöjd Medborgar-Index - Gymnasieskola, index"@sv;

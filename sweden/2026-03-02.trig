    <http://purl.org/dc/terms/title> "Gemensamma kostnader fördelade till vård och omsorg totalt, andel (%)"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>;

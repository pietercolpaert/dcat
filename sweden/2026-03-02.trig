    <http://purl.org/dc/terms/provenance> _:b0__6446.
_:b0__6446 <http://purl.org/dc/terms/description> "Källa: Nationella emissionsdatabasen"@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/N85521> <http://purl.org/dc/terms/modified> "2025-06-09"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Utsläpp till luft av Kväveoxider (NOx), Jordbruk, kg"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


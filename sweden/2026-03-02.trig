    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Standardkostnaden (kr/inv 1 nov fg år) för gymnasieskolan enligt det kommunala utjämningssystemet. Standardkostnaden beräknas utifrån andelen ungdomar i åldrarna 16-18 år multiplicerat med riksgenomsnitt för kostnad per ungdom i de aktuella åldersgrupperna. Vidare tillkommer tillägg eller avdrag för skillnader i: elevernas programval, gleshet, lönekostnader och befolkningsförändringar. Programvalsfaktorn utgörs av ett medelvärde av de två senaste åren. Ny kostnadsutjämning från 2020 påverkar standardkostnaderna från 2020. "@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/N17022_json>;
    <http://purl.org/dc/terms/provenance> _:b0__3905.
_:b0__3905 <http://purl.org/dc/terms/description> "Källa: SCB."@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/N17022> <http://purl.org/dc/terms/modified> "2025-04-15"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Standardkostnad gymnasieskola, kr/inv"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/SOCI>, <http://publications.europa.eu/resource/authority/data-theme/EDUC>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


<feed> <https://w3id.org/tree#member> <#576c8d65f5605be8bda2e8e0320d71fa>.
<#576c8d65f5605be8bda2e8e0320d71fa> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <https://konsumentverket.entryscape.net/store/1/resource/208>;
    <https://www.w3.org/ns/activitystreams#published> "2026-03-02T06:19:12.368Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#576c8d65f5605be8bda2e8e0320d71fa> {
<https://konsumentverket.entryscape.net/store/1/resource/208> <http://www.w3.org/ns/dcat#downloadURL> <https://konsumentverket.entryscape.net/store/1/resource/207>;
    <http://purl.org/dc/terms/format> "text/csv";
    <http://www.w3.org/ns/dcat#accessURL> <https://konsumentverket.entryscape.net/store/1/resource/207>;
    <http://purl.org/dc/terms/title> "Beräknade hushållskostnader för 2023, individuella artiklar"@sv;
    <http://purl.org/dc/terms/description> "Konsumentverket beräknar årligen några av de vanligaste hushållskostnaderna som tillsammans står för omkring en tredjedel av hushållens totala kostnader. Beräkningarna omfattar både individuella och hushållsgemensamma kostnader och utgår från ett grundläggande behov av varor och tjänster som behövs för att klara vardagen, oberoende av hushållets inkomster. Här redovisas vilka artiklar som ingår i beräkningarna för de individuella kostnaderna. Grupper som ingår är kläder och skor, fritid, mobiltelefon, personlig hygien, barn- och ungdomsförsäkring samt barnutrustning. Beräkningarna är uppdelade per ålder och kön. I filerna listas beräknat pris per enhet, behov (antal och användningstid) samt månadskostnad."@sv;
    a <http://www.w3.org/ns/dcat#Distribution>
}


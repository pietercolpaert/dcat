    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Nettokostnad för fritidshem tkr dividerat med antal invånare totalt 31/12. Med nettokostnad avses bruttokostnad minus bruttointäkt. Avser pedagogisk gruppverksamhet för skolbarn till och med tolv års ålder som vänder sig till barn vars föräldrar förvärvsarbetar eller studerar och till barn som har ett eget behov av verksamheten. Barnen är inskrivna. Fritidshemmet kan bedrivas som en helt fristående verksamhet men är oftast i mer eller mindre utsträckning integrerad med förskoleklassen och/eller den obligatoriska skolan. Verksamheten kan för de äldre barnen ibland ha andra benämningar t.ex. fritidsklubb, innehåller även fritidshem för särskolebarn om dessa är inskrivna i fritidshem. Avser samtlig regi. "@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/N13004_json>;
    <http://purl.org/dc/terms/provenance> _:b0__9552.
_:b0__9552 <http://purl.org/dc/terms/description> "Källa: SCB:s Räkenskapssammandrag."@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/N13004> <http://purl.org/dc/terms/modified> "2025-08-28"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Nettokostnad fritidshem, kr/inv"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/SOCI>, <http://publications.europa.eu/resource/authority/data-theme/EDUC>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


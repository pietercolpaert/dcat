    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "N23825";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Avser personer 65+ år som bor i ordinärt boende, med eller utan hemtjänst, och som är inskrivna i kommunal hemsjukvård, utav 1 000 invånare  65+ år i kommunen. För att räknas som inskriven krävs registrering av hemsjukvård både månaden före och efter den aktuella månaden. Personer som under månaden bor i särskilt boende för äldre samt personer med LSS-boende under året ingår inte. Kommuner i Stockholms län, exklusive Norrtälje kommun, omfattas inte av mått eller indikatorer som beskriver hemsjukvården i ordinärt boende. För Stockholms läns kommuner (Norrtälje undantaget) ansvarar Region Stockholm för hemsjukvården i ordinärt boende Data finns tillgängligt enligt könsuppdelning."@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/N23825_json>;
    <http://purl.org/dc/terms/provenance> _:b0__555.
_:b0__555 <http://purl.org/dc/terms/description> "Källa: Socialstyrelsen"@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/N23825> <http://purl.org/dc/terms/modified> "2026-02-24"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Hemsjukvård i ordinärt boende, 65+ år, antal inskrivna/1000 inv"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


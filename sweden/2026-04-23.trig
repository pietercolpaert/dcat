    <http://www.w3.org/ns/dcat#keyword> "Konsumentverket"@sv, "Kostnadsberäkningar"@sv, "Referensvärden"@sv, "Hushållskostnader"@sv, "Referenskostnader"@sv, "Matkostnader"@sv, "Livsmedelskostnader"@sv;
    <http://www.w3.org/ns/dcat#distribution> <https://konsumentverket.entryscape.net/store/1/resource/334>, <https://konsumentverket.entryscape.net/store/1/resource/336>, <https://konsumentverket.entryscape.net/store/1/resource/346>;
    <http://www.w3.org/ns/dcat#inSeries> <https://konsumentverket.entryscape.net/store/1/resource/322>;
    <http://purl.org/dc/terms/title> "Beräknade hushållskostnader, livsmedelskostnader 2022"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/SOCI>, <http://publications.europa.eu/resource/authority/data-theme/ECON>, <http://publications.europa.eu/resource/authority/data-theme/AGRI>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021002064>;
    <http://purl.org/dc/terms/description> "Här redovisas de beräknade månadskostnaderna för livsmedelsinköp. Beräkningarna är uppdelade per måltid: frukost, lunch, middag, mellanmål och guldkant. Guldkant avser exempelvis fika eller godis till helgen och snacks till fredagsmyset. Beräkningarna är uppdelade per ålder och kön. Beräkningarna är baserade på Konsumentverkets matsedel, som är en fyraveckors närings- och klimatberäknad matsedel som täcker dagsbehovet av energi och näring för respektive åldersgrupp."@sv;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


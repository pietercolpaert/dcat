<#a04d2405de5546bf648c1f7e508f8276> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://konsumentverket.entryscape.net/store/1/resource/461>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-23T06:38:57.840Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#a04d2405de5546bf648c1f7e508f8276> {
<https://konsumentverket.entryscape.net/store/1/resource/461> <http://www.w3.org/ns/dcat#contactPoint> <https://konsumentverket.entryscape.net/store/1/resource/6>;
    <http://www.w3.org/ns/dcat#keyword> "Konsumentverket"@sv, "Kostnadsberäkningar"@sv, "Referensvärden"@sv, "Hushållskostnader"@sv, "Skäliga levnadskostnader"@sv, "Referenskostnader"@sv, "Referensbudget"@sv, "Hushållsgemensamma kostnader"@sv, "Koll på pengarna"@sv;
    <http://www.w3.org/ns/dcat#distribution> <https://konsumentverket.entryscape.net/store/1/resource/463>;
    <http://www.w3.org/ns/dcat#inSeries> <https://konsumentverket.entryscape.net/store/1/resource/351>;
    <http://purl.org/dc/terms/title> "Beräknade hushållskostnader, summering 2024"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ECON>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021002064>;
    <http://purl.org/dc/terms/description> "Konsumentverket beräknar årligen några av de vanligaste hushållskostnaderna som tillsammans står för omkring fyrtio procent av hushållens totala kostnader. Beräkningarna omfattar både individuella och hushållsgemensamma kostnader och utgår från ett grundläggande behov av varor och tjänster som behövs för att klara vardagen, oberoende av hushållets inkomster.\n\nHär redovisas en summering av Konsumentverkets alla beräknade hushållskostnader. Denna tabell presenteras även i Koll på pengarna. Beräkningarna är uppdelade i livsmedelskostnader samt individuella- och hushållsgemensamma kostnader. Livsmedelskostnaderna och de individuella kostnaderna är uppdelade per kön och ålder medan de hushållsgemensamma kostnaderna är uppdelade per hushållsstorlek (1–7 personer)."@sv;
    a <http://www.w3.org/ns/dcat#Dataset>
}

<feed> <https://w3id.org/tree#member> <#01c8ff7ec58df8b273eccf95f3abb42b>.
<#01c8ff7ec58df8b273eccf95f3abb42b> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://konsumentverket.entryscape.net/store/1/resource/385>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-23T06:38:57.840Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#01c8ff7ec58df8b273eccf95f3abb42b> {
<https://konsumentverket.entryscape.net/store/1/resource/385> <http://www.w3.org/ns/dcat#contactPoint> <https://konsumentverket.entryscape.net/store/1/resource/6>;
    <http://www.w3.org/ns/dcat#keyword> "Kostnadsberäkningar"@sv, "Referensvärden"@sv, "Hushållskostnader"@sv, "Matkostnad"@sv;
    <http://www.w3.org/ns/dcat#distribution> <https://konsumentverket.entryscape.net/store/1/resource/387>, <https://konsumentverket.entryscape.net/store/1/resource/389>;
    <http://www.w3.org/ns/dcat#inSeries> <https://konsumentverket.entryscape.net/store/1/resource/374>;
    <http://purl.org/dc/terms/title> "Beräknade hushållskostnader, livsmedelsartiklar 2024"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/ECON>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021002064>;
    <http://purl.org/dc/terms/description> "Här redovisas vilka artiklar som ingår i beräkningarna för livsmedelskostnaderna. Artiklarna är uppdelade i undergrupper som exempelvis grönsaker, frukt och bär, fisk, kött och chark med mera. I filerna listas beräknat pris per enhet (kg). Beräkningarna är baserade på Konsumentverkets matsedel, som är en fyraveckors närings- och klimatberäknad matsedel som täcker dagsbehovet av energi och näring."@sv;
    a <http://www.w3.org/ns/dcat#Dataset>
}

<feed> <https://w3id.org/tree#member> <#08bb8d317bc3e5fcd8fb13f7971e93d8>.
<#08bb8d317bc3e5fcd8fb13f7971e93d8> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://konsumentverket.entryscape.net/store/1/resource/438>;

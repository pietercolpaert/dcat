    <https://www.w3.org/ns/activitystreams#object> <https://konsumentverket.entryscape.net/store/1/resource/32>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-23T06:38:57.846Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#b32c54ce4b41f8d9fb3b6867d8c950e7> {
<https://konsumentverket.entryscape.net/store/1/resource/32> <http://www.w3.org/ns/dcat#keyword> "Konsumtion"@sv, "Miljö"@sv, "Environment"@en, "Kvinnor"@sv, "Män"@sv, "Consumption"@en, "Female"@en, "Male"@en, "Gender"@en, "Kön"@sv;
    <http://xmlns.com/foaf/0.1/page> <https://www.konsumentverket.se/aktuella-konsumentproblem/forskning-och-rapporter/konsumenterna-och-miljon/>;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021002064>;
    <http://purl.org/dc/terms/description> "Statistiken från undersökningen Konsumenterna och miljön fördelat efter kvinnor och män. Statistiken beskriver hur konsumtionen på olika marknader påverkar miljön och var konsumenter uppfattar det som enklast och svårast att göra val med miljöhänsyn. \n\nI 2019 års rapport har en fråga om klimatångest inkluderats. Alltså om konsumenter upplever oro eller skuld i samband med köp av produkter inom olika konsumtionsområden.\n\nVår förhoppning är att rapporten kan användas som inspiration till åtgärder som syftar till att begränsa konsumtionens miljöpåverkan, samt för prioritering och uppföljning av sådana åtgärder."@sv;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/2661886>;
    <http://www.w3.org/ns/dcat#contactPoint> <https://konsumentverket.entryscape.net/store/1/resource/6>;
    <http://www.w3.org/ns/dcat#distribution> <https://konsumentverket.entryscape.net/store/1/resource/37>, <https://konsumentverket.entryscape.net/store/1/resource/35>;
    <http://purl.org/dc/terms/issued> "2017"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2020-06-22"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Konsumenterna och miljön - fördelning kvinnor och män"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>;
    <http://purl.org/dc/terms/temporal> _:b0__4311.
_:b0__4311 <http://schema.org/startDate> "2017"^^<http://www.w3.org/2001/XMLSchema#date>;
    a <http://purl.org/dc/terms/PeriodOfTime>.
<https://konsumentverket.entryscape.net/store/1/resource/32> a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}

<feed> <https://w3id.org/tree#member> <#289da11f9a404f57d1e3d3cf20048e5a>.
<#289da11f9a404f57d1e3d3cf20048e5a> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://konsumentverket.entryscape.net/store/1/resource/458>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-23T06:38:57.846Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#289da11f9a404f57d1e3d3cf20048e5a> {
<https://konsumentverket.entryscape.net/store/1/resource/458> <http://www.w3.org/ns/dcat#contactPoint> <https://konsumentverket.entryscape.net/store/1/resource/6>;
    <http://www.w3.org/ns/dcat#keyword> "Konsumentverket"@sv, "Kostnadsberäkningar"@sv, "Referensvärden"@sv, "Hushållskostnader"@sv, "Skäliga levnadskostnader"@sv, "Referenskostnader"@sv, "Referensbudget"@sv, "Hushållsgemensamma kostnader"@sv, "Koll på pengarna"@sv;
    <http://www.w3.org/ns/dcat#distribution> <https://konsumentverket.entryscape.net/store/1/resource/460>;
    <http://www.w3.org/ns/dcat#inSeries> <https://konsumentverket.entryscape.net/store/1/resource/351>;
    <http://purl.org/dc/terms/title> "Beräknade hushållskostnader, summering 2023"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/SOCI>, <http://publications.europa.eu/resource/authority/data-theme/ECON>, <http://publications.europa.eu/resource/authority/data-theme/AGRI>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021002064>;
    <http://purl.org/dc/terms/description> "Konsumentverket beräknar årligen några av de vanligaste hushållskostnaderna som tillsammans står för omkring fyrtio procent av hushållens totala kostnader. Beräkningarna omfattar både individuella och hushållsgemensamma kostnader och utgår från ett grundläggande behov av varor och tjänster som behövs för att klara vardagen, oberoende av hushållets inkomster.\n\nHär redovisas en summering av Konsumentverkets alla beräknade hushållskostnader. Denna tabell presenteras även i Koll på pengarna. Beräkningarna är uppdelade i livsmedelskostnader samt individuella- och hushållsgemensamma kostnader. Livsmedelskostnaderna och de individuella kostnaderna är uppdelade per kön och ålder medan de hushållsgemensamma kostnaderna är uppdelade per hushållsstorlek (1–7 personer)."@sv;
    a <http://www.w3.org/ns/dcat#Dataset>
}


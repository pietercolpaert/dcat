    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.5878/001798>;
    <http://purl.org/dc/terms/modified> "2019-12-10T15:30:29Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Fackföreningsundersökningen 1974"@sv, "Trade union survey 1974"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/SOCI>;
    <http://purl.org/dc/terms/temporal> _:b0__2204.
_:b0__2204 <http://www.w3.org/ns/dcat#endDate> "1977"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#startDate> "1974"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    a <http://purl.org/dc/terms/PeriodOfTime>.

<#2b898c476269719cb0e38f76099d07bc> {
<https://konsumentverket.entryscape.net/store/1/resource/368> <http://www.w3.org/ns/dcat#downloadURL> <https://konsumentverket.entryscape.net/store/1/resource/367>;
    <http://purl.org/dc/terms/format> "text/csv";
    <http://www.w3.org/ns/dcat#accessURL> <https://konsumentverket.entryscape.net/store/1/resource/367>;
    <http://purl.org/dc/terms/title> "Beräknade hushållskostnader, individuella artiklar 2024"@sv;
    <http://purl.org/dc/terms/description> "Här redovisas vilka artiklar som ingår i beräkningarna för de individuella kostnaderna. Grupper som ingår är kläder och skor, fritid, mobiltelefon, personlig hygien, barn- och ungdomsförsäkring samt  barnutrustning. Beräkningarna är uppdelade per ålder och kön. I filerna listas beräknat pris per enhet, behov (antal och användningstid) samt månadskostnad."@sv;
    a <http://www.w3.org/ns/dcat#Distribution>
}


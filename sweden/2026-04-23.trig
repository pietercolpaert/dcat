    <http://purl.org/dc/terms/format> "text/csv";
    <http://www.w3.org/ns/dcat#accessURL> <https://konsumentverket.entryscape.net/store/1/resource/488>;
    <http://purl.org/dc/terms/title> "Beräknade hushållskostnader, livsmedelsartiklar 2026"@sv;
    <http://purl.org/dc/terms/description> "Här redovisas vilka artiklar som ingår i beräkningarna för livsmedelskostnaderna. Artiklarna är uppdelade i undergrupper som exempelvis grönsaker, frukt och bär, fisk, kött och chark med mera. I filerna listas beräknat pris per enhet (kg). Beräkningarna är baserade på Konsumentverkets matsedel, som är en fyraveckors matsedel som täcker dagsbehovet av energi och näring."@sv;
    a <http://www.w3.org/ns/dcat#Distribution>
}


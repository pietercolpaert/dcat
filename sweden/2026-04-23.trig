    <http://purl.org/dc/terms/title> "Beräknade hushållskostnader, individuella artiklar 2022"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/SOCI>, <http://publications.europa.eu/resource/authority/data-theme/ECON>;

    <http://purl.org/dc/terms/issued> "2024-08-22"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2026-03-25T14:51:25.075534"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Dagbefolkning (antal arbetsplatser) efter SNI 2007, 2019 - 2021 - Statistikunderlag för Malmös områden"@sv, "Daytime population (number of workplaces) by SNI 2007, 2019 - 2021 - Statistical data for Malmö's areas"@en, "Dagbefolkning (antal arbejdspladser) efter SNI 2007, 2019-2021 - Statistiske data for Malmøs områder"@da;

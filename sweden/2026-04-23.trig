<feed> <https://w3id.org/tree#member> <#dc999c5bfc56afd1e98fa912aca1f94c>.
<#dc999c5bfc56afd1e98fa912aca1f94c> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://konsumentverket.entryscape.net/store/1/resource/373>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-23T06:39:01.406Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#dc999c5bfc56afd1e98fa912aca1f94c> {
<https://konsumentverket.entryscape.net/store/1/resource/373> <http://www.w3.org/ns/dcat#downloadURL> <https://konsumentverket.entryscape.net/store/1/resource/372>;
    <http://purl.org/dc/terms/format> "text/csv";
    <http://www.w3.org/ns/dcat#accessURL> <https://konsumentverket.entryscape.net/store/1/resource/372>;
    <http://purl.org/dc/terms/title> "Beräknade hushållskostnader, individuella artiklar 2025"@sv;
    <http://purl.org/dc/terms/description> "Här redovisas vilka artiklar som ingår i beräkningarna för de individuella kostnaderna. Grupper som ingår är kläder och skor, fritid, mobiltelefon, personlig hygien, barn- och ungdomsförsäkring samt  barnutrustning. Beräkningarna är uppdelade per ålder och kön. I filerna listas beräknat pris per enhet, behov (antal och användningstid) samt månadskostnad."@sv;
    a <http://www.w3.org/ns/dcat#Distribution>
}


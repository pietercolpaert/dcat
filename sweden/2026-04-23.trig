    <https://www.w3.org/ns/activitystreams#object> <https://konsumentverket.entryscape.net/store/1/resource/336>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-23T06:39:01.403Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#e805a22350ffd8670f203579391a591d> {
<https://konsumentverket.entryscape.net/store/1/resource/336> <http://www.w3.org/ns/dcat#downloadURL> <https://konsumentverket.entryscape.net/store/1/resource/335>;
    <http://purl.org/dc/terms/format> "text/csv";
    <http://www.w3.org/ns/dcat#accessURL> <https://konsumentverket.entryscape.net/store/1/resource/335>;
    <http://purl.org/dc/terms/title> "Beräknade hushållskostnader för 2022, livsmedelskostnader"@sv;
    <http://purl.org/dc/terms/description> "Här redovisas de beräknade månadskostnaderna för livsmedelsinköp. Beräkningarna är uppdelade per måltid: frukost, lunch, middag, mellanmål och guldkant. Guldkant avser exempelvis fika eller godis till helgen och snacks till fredagsmyset. Beräkningarna är uppdelade per ålder och kön. Beräkningarna är baserade på Konsumentverkets matsedel, som är en fyraveckors närings- och klimatberäknad matsedel som täcker dagsbehovet av energi och näring för respektive åldersgrupp."@sv;
    a <http://www.w3.org/ns/dcat#Distribution>
}


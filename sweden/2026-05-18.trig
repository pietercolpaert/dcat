    <http://purl.org/dc/terms/modified> "2026-05-18T01:16:12.451000+00:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Luftkvalitetsmätningar Västra esplanaden fr o m 2025"@sv;

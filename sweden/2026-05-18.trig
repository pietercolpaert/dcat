<https://opendata.umea.se/api/v2/catalog/datasets/arbetsmarknadsstatus-per-manad-bas> <http://www.w3.org/ns/dcat#keyword> "Umeå kommun", "Arbetsmarknad"@sv, "Statistik"@sv, "Sysselsättning"@sv, "Statistik och analys"@sv, "Arbetslöshet"@sv;
    <http://purl.org/dc/terms/identifier> "arbetsmarknadsstatus-per-manad-bas@http://dataportal.se/organisation/SE2120002627";

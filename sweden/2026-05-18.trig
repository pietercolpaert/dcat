<#2f6b664e4592485de470557b84c70a79> {
<https://www.geodata.se/resources/c4451697-5616-43c6-b14d-38ea6ab6e4ff> <http://www.w3.org/ns/dcat#keyword> "HVD"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/IRREG>;

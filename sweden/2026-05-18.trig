<#14c84a0e28c41800f8e3a7fbec6af9f1> {
<https://opendata-catalog.smhi.se/md/582432e4-32c0-492e-8f98-cfab5ae84f8d> <http://www.w3.org/ns/dcat#keyword> "Öppna data"@sv, "Inspire"@sv, "Meteorologi"@sv, "Observation"@sv, "Vindriktning"@sv, "HVD"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/CONT>;

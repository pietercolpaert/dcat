    <https://www.w3.org/ns/activitystreams#published> "2026-05-18T07:23:13.333Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#c227c47cd856852f23441b107daedc8f> {
<https://opendata.umea.se/api/v2/catalog/datasets/energiforbrukning-i-geografiska-omradet-1026-del-av-tegs-forsamling-byar-och-gle> <http://www.w3.org/ns/dcat#keyword> "Energi"@sv, "Umeå Energi", "Förbrukning"@sv, "El"@sv, "Fjärrvärme"@sv;
    <http://purl.org/dc/terms/identifier> "energiforbrukning-i-geografiska-omradet-1026-del-av-tegs-forsamling-byar-och-gle@http://dataportal.se/organisation/SE2120002627";
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://admin.dataportal.se/store/43/resource/fd2584866d01e4eaee64e3ffcfe40e02>;
    <http://purl.org/dc/terms/description> "Anonymiserad förbrukningsdata från Umeå Energi per nyckelkodsområde i Umeå Kommun. Detta data bör inte ses som exakta och kompletta förbrukningsvärden utan mer som en kvalificerad uppskattning av förbrukningen i syfte att se trender och indikationer.Datafilerna kommer endast innehålla värden för fastigheter i Umeå kommun där Umeå Energi är nätägare och informationen inte anses vara olämplig för distribution. Uppdateras normalt en gång varje månad med nytillkomna värden.Frågor kring detta förbrukningsdata hänvisas till matdata.datalager@umeaenergi.se "@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://opendata.umea.se/explore/?refine.dcat.contact_name=Ume%C3%A5+Energi&refine.dcat.contact_email=matdata.datalager%2540umeaenergi.se>;
    <http://www.w3.org/ns/dcat#distribution> <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-1026-del-av-tegs-forsamling-byar-och-gle-API>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-1026-del-av-tegs-forsamling-byar-och-gle-csv>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-1026-del-av-tegs-forsamling-byar-och-gle-json>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-1026-del-av-tegs-forsamling-byar-och-gle-jsonl>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-1026-del-av-tegs-forsamling-byar-och-gle-parquet>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-1026-del-av-tegs-forsamling-byar-och-gle-rdfxml>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-1026-del-av-tegs-forsamling-byar-och-gle-jsonld>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-1026-del-av-tegs-forsamling-byar-och-gle-turtle>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-1026-del-av-tegs-forsamling-byar-och-gle-n3>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-1026-del-av-tegs-forsamling-byar-och-gle-xlsx>;
    <http://purl.org/dc/terms/issued> "2026-05-17T02:13:02.821000+00:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

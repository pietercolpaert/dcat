<https://doi.org/10.5878/k65t-qb32> <http://www.w3.org/ns/dcat#keyword> "Sweden"@en, "Sverige"@sv, "lövträd"@sv, "barrträd"@sv, "conifers"@en, "Pinus sylvestris"@en, "tall"@sv, "20th century"@en, "trädslag"@sv, "tree species"@en, "broad-leaved tree"@en, "trädålder"@sv, "tree age"@en, "1900-talet"@sv, "träd diameter"@sv, "tree size"@en, "Riksskogstaxering"@sv, "NFI"@en, "TREE RINGS"@en, "Picea abies"@en, "gran"@sv, "quercus petraea (matt.) liebl."@en, "Plantae"@en, "egentliga växter"@sv, "Eudicots"@en, "tvåhjärtbladiga blomväxter"@sv, "Pinopsida"@en, "barrväxter"@sv;

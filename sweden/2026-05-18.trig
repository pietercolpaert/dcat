    <http://purl.org/dc/terms/publisher> <https://admin.dataportal.se/store/43/resource/7a00bd3796ed09a600646432cb321722>;
    <http://purl.org/dc/terms/description> "BAS, Befolkningens arbetsmarknadsstatus är en statistikprodukt som med hjälp av administrativa data beskriver utbudet av arbetskraft. Syftet är att beskriva arbetsmarknadsläget samt utvecklingen över tid i Umeå kommun. Statistiken redovisar bland annat antalet sysselsatta, arbetslösa och personer utanför arbetskraften för den folkbokförda befolkningen i åldern 15–74 år."@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://opendata.umea.se/explore/?refine.dcat.contact_name=Statistik+och+analys%252C+%C3%96vergripande+planering%252C+Ume%C3%A5+kommun&refine.dcat.contact_email=analysgruppen%2540umea.se>;
    <http://www.w3.org/ns/dcat#distribution> <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/arbetsmarknadsstatus-per-manad-bas-API>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/arbetsmarknadsstatus-per-manad-bas-csv>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/arbetsmarknadsstatus-per-manad-bas-json>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/arbetsmarknadsstatus-per-manad-bas-jsonl>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/arbetsmarknadsstatus-per-manad-bas-parquet>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/arbetsmarknadsstatus-per-manad-bas-rdfxml>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/arbetsmarknadsstatus-per-manad-bas-jsonld>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/arbetsmarknadsstatus-per-manad-bas-turtle>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/arbetsmarknadsstatus-per-manad-bas-n3>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/arbetsmarknadsstatus-per-manad-bas-xlsx>;
    <http://purl.org/dc/terms/issued> "2026-05-17T22:00:09.992000+00:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://opendata.umea.se/explore/dataset/arbetsmarknadsstatus-per-manad-bas/>;

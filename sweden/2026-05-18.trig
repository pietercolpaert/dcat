    <http://purl.org/dc/terms/issued> "2023-04-24"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2026-05-17T19:07:05.280550"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Vattentemperaturer"@sv, "Water temperatures"@en, "Vandtemperaturer"@da;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/EDUC>;
    a <http://www.w3.org/ns/dcat#Dataset>
}

<feed> <https://w3id.org/tree#member> <#c1649e55b3cf2e0cd0a85ce7c7bded72>.
<#c1649e55b3cf2e0cd0a85ce7c7bded72> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <https://editera.dataportal.se/store/233/resource/5>;

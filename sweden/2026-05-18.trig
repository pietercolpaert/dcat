<feed> <https://w3id.org/tree#member> <#481f34237b899cf5a0b5385c098a9890>.
<#481f34237b899cf5a0b5385c098a9890> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <https://konsumentverket.entryscape.net/store/1/resource/424>;
    <https://www.w3.org/ns/activitystreams#published> "2026-05-18T07:23:16.709Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#481f34237b899cf5a0b5385c098a9890> {
<https://konsumentverket.entryscape.net/store/1/resource/424> <http://www.w3.org/ns/dcat#downloadURL> <https://konsumentverket.entryscape.net/store/1/resource/423>;
    <http://purl.org/dc/terms/format> "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
    <http://www.w3.org/ns/dcat#accessURL> <https://konsumentverket.entryscape.net/store/1/resource/423>;
    <http://purl.org/dc/terms/title> "Beräknade hushållskostnader, hushållsgemensamma kostnader 2023"@sv;
    <http://purl.org/dc/terms/description> "Här redovisas de hushållsgemensamma m��nadskostnaderna för grupperna förbrukningsvaror, media, hemutrustning, hemförsäkring, hushållsel samt vatten och avlopp. För gruppen hemförsäkring har tre beräkningar gjorts beroende på om försäkringen ska gälla i en stor eller medelstor stad respektive liten tätort. Beräkningarna är uppdelade per hushållsstorlek (1–7 personer)."@sv;
    a <http://www.w3.org/ns/dcat#Distribution>
}

<feed> <https://w3id.org/tree#member> <#79ba1011b78209ca6dc26d434d7a9963>.
<#79ba1011b78209ca6dc26d434d7a9963> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <https://transportstyrelsen.entryscape.net/store/7/resource/424>;
    <https://www.w3.org/ns/activitystreams#published> "2026-05-18T07:23:16.798Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#79ba1011b78209ca6dc26d434d7a9963> {
<https://transportstyrelsen.entryscape.net/store/7/resource/424> <http://purl.org/dc/terms/license> <http://creativecommons.org/publicdomain/zero/1.0/>;
    <http://purl.org/dc/terms/format> "text/html";
    <http://data.europa.eu/r5r/availability> <http://data.europa.eu/r5r/availability/available>;
    <http://www.w3.org/ns/dcat#accessURL> <https://www.transportstyrelsen.se/sv/om-oss/statistik-och-analys/statistik-inom-vagtrafik/skyltstatistik/efterlysta-skyltar/>;
    <http://purl.org/dc/terms/title> "Efterlysta registreringsskyltar"@sv;
    <http://purl.org/dc/terms/description> "På dessa sidor hittar du statistik över efterlysta registreringsskyltar. Statistiken bygger på uppgifter om skyltar som registreras i vägtrafikregistret som efterlysta av Polismyndigheten.\n\nEn skylt efterlyses om den rapporteras saknad av en fordonsägare till polisen. Att skylten är efterlyst behöver inte betyda att den har stulits. Vanliga orsaker till att en skylt saknas är att en dåligt fastsatt skylt lossnat vid färd.\n\nAnmälda under aktuell månad = Visar hur många registreringar av efterlysta skyltar som gjorts av landets polismyndigheter under en viss månad.\n\nAvlysta efterlysningar under aktuell m��nad = Visar hur många efterlysningar som avlysts av anmälaren dvs. återkallats på grund av att skylten blivit upphittad.\n\nEn uppgift om efterlyst skylt som inte blir avlyst kvarstår i vägtrafikregistret i två års tid innan den gallras bort."@sv;
    a <http://www.w3.org/ns/dcat#Distribution>
}


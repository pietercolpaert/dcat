<#c1649e55b3cf2e0cd0a85ce7c7bded72> {
<https://editera.dataportal.se/store/233/resource/5> <http://www.w3.org/ns/dcat#keyword> "parkering"@sv, "bad"@sv, "badplats"@sv, "strand"@sv, "toalett"@sv, "brygga"@sv, "Sävsjö"@sv, "hopptorn"@sv, "omklädningsrum"@sv, "dush"@sv;

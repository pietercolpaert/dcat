<#ee08c6d43bbce4a7366b1d774541a451> {
<https://metadata.trafikverket.se/store/1/resource/1034> <http://xmlns.com/foaf/0.1/page> <https://bransch.trafikverket.se/tjanster/data-kartor-och-geodatatjanster/las-om-vara-data/jarnvagsdata/>, <https://www.trafikverket.se/e-tjanster/hamta-data-fran-trafikverket/>, <https://lastkajen.trafikverket.se/aboutdatarailway>;
    <https://dataportal.se/concepts/geose/useLimitation> "Ingen begränsning"@sv;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <https://dataportal.se/concepts/geose/spatialScope> <http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/national>;
    <http://purl.org/dc/terms/description> "Dataprodukten Räl är en visualisering av de fysiska rälerna i järnvägsnätet.\n\nEn räl är den skena av stål som järnvägsfordonet rullar på. Rälen har flera funktioner; framförallt att bära upp tågsättens tyngd och f��rdela den till underbyggnaden samt att styra hjulaxlarna. En annan viktig funktion för räl på elektrifierade spår är att vara bärare av signal för linjeblockering (se mer i Dataproduktspecifikation Linjeblockering). Rälen är även återledningsmedium för tågdriftens återgångsströmmar.\n\nDå den fysiska rälen har så många funktioner är det viktigt att ha högkvalitativ data om objektet.\n\nObjekttypen Räl ger information som krävs för framförallt besiktningar och underhållsarbete. Vid besiktningar kontrolleras t ex att rälen inte är utnött vilket skulle orsaka säkerhetsrisker vid framförande av fordon på spåret.\n\nDataprodukten har sträckutbredning och kopplar till järnvägsnätet med referens mot närmast föregående nod och närmast föregående kilometertavla med avstånd i meter i spårlänkens riktning med uppgift om objektets sidoläge i förhållande till spårlänkens riktning (höger| vänster)."@sv;
    <http://purl.org/dc/terms/spatial> <https://sws.geonames.org/2661886>, _:b0__7443.
_:b0__7443 <http://www.w3.org/ns/dcat#bbox> "POLYGON((11.11 69.06,24.16 69.06,24.16 55.34,11.11 55.34,11.11 69.06))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.
<https://metadata.trafikverket.se/store/1/resource/1034> <http://www.w3.org/ns/dcat#contactPoint> <https://metadata.trafikverket.se/store/4/resource/12>;
    <http://purl.org/dc/terms/subject> <http://inspire.ec.europa.eu/metadata-codelist/TopicCategory/transportation>, <http://www.eionet.europa.eu/gemet/concept/8641>;
    <http://purl.org/dc/terms/modified> "2024-11-12"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/conformsTo> <http://www.opengis.net/def/crs/EPSG/0/3006>, <http://www.sis.se/produkter/foretagsorganisation/kvalitet/allmant/ss-en-iso-191572013/>, <http://www.sis.se/produkter/foretagsorganisation/kvalitet/allmant/sseniso191152005/>, <http://www.sis.se/produkter/informationsteknik-kontorsutrustning/ittillampningar/it-tillampningar-inom-vetenskap/sis-ts-802018/>, <https://www.sis.se/produkter/informationsteknik-kontorsutrustning/ittillampningar/it-tillampningar-inom-vetenskap/ss-en-iso-191312022/>;
    <http://purl.org/dc/terms/temporal> _:b0__8494.
_:b0__8494 <http://www.w3.org/ns/dcat#endDate> "2099-12-31"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#startDate> "2001-01-01"^^<http://www.w3.org/2001/XMLSchema#date>;
    a <http://purl.org/dc/terms/PeriodOfTime>.
<https://metadata.trafikverket.se/store/1/resource/1034> <http://entryscape.org/terms/metadataIdentifier> "d9b2319e-13c8-41ac-8705-ffa8b4edd6ab";
    <http://www.w3.org/ns/dcat#keyword> "område: transport"@sv, "trafikslag: järnväg"@sv;

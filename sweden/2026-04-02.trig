<#fd77e15b7582b437e9025f35f4c1fdc2> {
<https://opendata.upplandsvasby.se/dataset/af169c2f-96e0-44b9-a621-093ad2a44c03> <http://www.w3.org/ns/dcat#keyword> "Upplands Väsby kommun", "grillplatser", "grill", "grillplats", "grills";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "037756b0-61e5-4bc1-96f2-f6926d770fa5";

    <http://www.w3.org/ns/dcat#keyword> "grundskola"@sv, "skolor"@sv, "Skolverket"@sv, "Swedish National Agency for Education"@en, "skolenheter"@sv, "school units"@en, "skolenhetsregistret"@sv, "förskoleklass"@sv, "preschool class"@en, "fritidshem"@sv, "leisure-time centre"@en, "compulsory school"@en, "sameskola"@sv, "specialskola"@sv, "compulsory special needs schools"@en, "sami school"@en, "anpassad grundskola"@sv, "compulsory school for pupils with intellectual disabilities"@en, "gymnasieskola"@sv, "upper secondary school"@en, "anpassad gymnasieskola"@sv, "upper secondary school for pupils with intellectual disabilities"@en, "kommunal vuxenutbildning"@sv, "education for adults"@en, "schools"@en, "skolformer"@sv, "school forms"@en, "adresser"@sv, "addresses"@en, "register of schools"@en;

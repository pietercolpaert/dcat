<https://resources.stockholm.se/data/d5d347f7-952a-4c62-82d1-3d57859f35c6> <http://www.w3.org/ns/dcat#keyword> "Stockholms stad", "Flygbild"@sv, "Verksamhetsdata"@sv, "Extern dataportal"@sv, "1.Publicerad på webb"@sv;

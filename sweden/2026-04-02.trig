    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "N45042";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Kostnad för kommungemensam verksamhet (Kommunnyckel+SCB-nyckel) fördelat på affärsverksamhet dividerat med kostnad för eget åtagande avseende affärsverksamhet. Kostnad för eget åtagande är bruttokostnad minus interna intäkter samt försäljning av verksamhet till kommuner och/eller regioner. Avser kostnader för samtliga tjänster, funktioner och varor som redovisas centralt i kommunen och fördelats på affärsverksamhet i räkenskapssammandraget, t ex ekonomiadministration, HR-funktion och förbrukningsvaror. Gemensamma kostnader fördelas ut för att öka jämförbarheten mellan kommuner som bär sådana kostnader direkt i verksamheten och kommuner som redovisar kostnaderna centralt. "@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/N45042_json>;
    <http://purl.org/dc/terms/provenance> _:b0__7683.
_:b0__7683 <http://purl.org/dc/terms/description> "Källa: SCB Räkenskapssammandraget"@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/N45042> <http://purl.org/dc/terms/modified> "2025-08-28"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Gemensamma kostnader fördelade till affärsverksamhet, andel (%)"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/ECON>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


<feed> <https://w3id.org/tree#member> <#202420501f94d155159d72d1f4d53998>.
<#202420501f94d155159d72d1f4d53998> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <http://api.kolada.se/v3/kpi/U40468>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-02T06:27:03.947Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#202420501f94d155159d72d1f4d53998> {
<http://api.kolada.se/v3/kpi/U40468> <http://www.w3.org/ns/dcat#keyword> "Kommun"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "U40468";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Antal deltagare som svarat alternativen \"Till mycket stor del\" eller \"Helt och hållet\" på frågan \"Finns det en tillräcklig planering för vad som ska hända efter att detta stöd upphör?\" dividerat med samtliga deltagare som svarat på frågan. Samtliga svarsalternativ är \"Inte alls\", \"Till liten del\", \"Delvis\", \"Till stor del\", \"Till mycket stor del\", \"Helt och hållet\".  Frågan ställs till deltagare som fått insatser med finansiering eller stöd av Finansiell samordning (Finsam) vid avslut och svarat \"Ja\" på frågan \"Har ni påbörjat en planering efter att nuvarande stöd har upphört?\" Syftet är att mäta om deltagarna upplever att det finns en tillräcklig planering av tjänster som tar vid efter insats. Finansiell samordning sker genom samordningsförbund där det kan ingå en eller flera kommuner och undersökningen sammanställs på samordningsförbundsnivå. Kommuner som ingår i samma samordningsförbund har därför samma värde. "@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/U40468_json>;
    <http://purl.org/dc/terms/provenance> _:b0__39983.
_:b0__39983 <http://purl.org/dc/terms/description> "Källa: Nationella nätverket för samordningsförbund (NNS)."@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/U40468> <http://purl.org/dc/terms/modified> "2026-02-02"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Deltagarbedömning Finsam - Tillräckling planering  finns för vad som ska hända efter insats, andel (%)"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/SOCI>, <http://publications.europa.eu/resource/authority/data-theme/REGI>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


<#a1d987076c45cdd51fb6d8a233def07f> {
<http://api.kolada.se/v3/kpi/N15569> <http://www.w3.org/ns/dcat#keyword> "Kommun"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;

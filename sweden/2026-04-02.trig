    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/SOCI>;
    <http://purl.org/dc/terms/temporal> _:b0__7712.
_:b0__7712 <http://www.w3.org/ns/dcat#startDate> "2017-01-01"^^<http://www.w3.org/2001/XMLSchema#date>;

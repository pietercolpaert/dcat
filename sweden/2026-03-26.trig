<#cf58ed571b8c206033849e2b7e26c1d7> {
<https://doi.org/10.5878/ekw9-mk51> <http://www.w3.org/ns/dcat#keyword> "Attityd"@sv, "Attitude"@en, "Tanzania"@sv, "Tanzania"@en, "bantuspråk"@sv, "Bantu languages"@en, "hotade språk"@sv, "endangered languages"@en, "kodväxling"@sv, "code-switching"@en, "språkdokumentation"@sv, "language documentation"@en, "ngoni"@sv, "Ngoni"@en, "swahili"@sv, "Swahili"@en, "Intervjuer som ämne"@sv, "Interviews as Topic"@en, "Namn"@sv, "Names"@en, "Tabu"@sv, "Taboo"@en, "Fokusgrupper"@sv, "Focus Groups"@en, "IDENTITY"@en, "IDENTITET"@sv;

    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021002932>;
    <http://purl.org/dc/terms/description> "Data om bakterie��verflöd från anpassningsexperiment. Omfattar tillväxten av 16 prover som återväxte varje vecka under en tidsperiod på 6 veckor. \n\nDatasetet har ursprungligen publicerats i DiVA och flyttades över till SND 2024."@sv, "Bacterial abundance data from adaptation experiment. Includes the growth of 16 samples that were regrown weekly over a time period of 6 weeks.\n\nThe dataset was originally published in DiVA and moved to SND in 2024."@en;
    <http://www.w3.org/ns/dcat#distribution> <https://doi.org/10.57804/t67x-x511#distribution>;
    <http://purl.org/dc/terms/issued> "2018-01-16T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.57804/t67x-x511>;
    <http://purl.org/dc/terms/modified> "2024-09-02T14:28:19.982165Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Data on bacterial abundance from adaptation experiment"@sv, "Data on bacterial abundance from adaptation experiment"@en;
    a <http://www.w3.org/ns/dcat#Dataset>
}


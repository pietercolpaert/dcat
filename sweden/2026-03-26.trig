<#1acdfe0989daadcbb5b19d545da7e345> {
<https://opendata.umea.se/api/v2/catalog/datasets/energiforbrukning-i-geografiska-omradet-081810-tavelsjo-omland-sodra> <http://www.w3.org/ns/dcat#keyword> "Energi"@sv, "Consumption"@en, "Umeå Energi", "Förbrukning"@sv, "El"@sv, "Fjärrvärme"@sv, "Energy"@en, "Electricity"@en, "District heating"@en;

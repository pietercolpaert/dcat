<https://doi.org/10.58141/pfmm-1323> <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>, <http://publications.europa.eu/resource/authority/language/ENG>, <http://publications.europa.eu/resource/authority/language/SWL>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021003062>;
    <http://purl.org/dc/terms/description> "Korpus i svenskt teckenspråk som andraspråk omfattar inspelade videomaterial och dokumentation av teckenspråkstexter, producerade av vuxna hörande andraspråksinlärare.\n\nDataurvalet består av sju videosekvenser (.mp4-format) som tagits fram här i syfte att tjäna som illustrativa exempel till en vetenskaplig artikel om självreparation hos L2-inlärare av svenskt teckenspråk."@sv, "Swedish Sign Language as Second Language Corpus includes video recordings and documentation of sign language texts, produced by adult hearing second language learners of Swedish Sign Language.\n\nThe data selection consists of seven video sequences (.mp4 format) created here with the purpose of serving as illustrative examples for a scientific article on self-repair in L2 learners of Swedish Sign Language."@en;
    <http://purl.org/dc/terms/spatial> <http://sws.geonames.org/2661886>;
    <http://www.w3.org/ns/dcat#contactPoint> <https://admin.dataportal.se/store/818/resource/216aec6c13e24d5e2078026393452708>;
    <http://www.w3.org/ns/dcat#distribution> <https://doi.org/10.58141/pfmm-1323#distribution>;
    <http://purl.org/dc/terms/issued> "2023-05-31T13:24:49.21251Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.58141/pfmm-1323>;
    <http://purl.org/dc/terms/modified> "2025-05-23T09:07:44.515654Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Korpus i svenskt teckenspråk som andraspråk"@sv, "Swedish Sign Language as Second Language Corpus"@en;

<#8620198eb63a279c00dd3dd4a4a8b2f7> {
<https://opendata.upplandsvasby.se/dataset/af169c2f-96e0-44b9-a621-093ad2a44c03> <http://www.w3.org/ns/dcat#keyword> "Upplands Väsby kommun", "grillplatser", "grill", "grillplats", "grills";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "037756b0-61e5-4bc1-96f2-f6926d770fa5";
    <http://data.europa.eu/r5r/hvdCategory> "None";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://upplandsvasby.se>;
    <http://purl.org/dc/terms/description> "Kommunala grillplatser.\n\nKommunen erbjuder grillplatser i flera parker och vid sjöar för att allmänheten ska kunna njuta av naturen, umgås och dela måltider i en avslappnad och naturskön miljö. Platserna är bruka utrustade med fasta grillar, sittbänkar och bord.\n\nTillgänglighet är viktigt, och många platser har gångvägar och vissa har även ramper för rullstolsburna samt närliggande parkeringsplatser. Kommunen underhåller grillplatserna regelbundet för att de ska vara rena och säkra att använda.\n\nBesökare uppmanas att följa reglerna och hålla områdena rena...";
    <http://purl.org/dc/terms/spatial> <https://www.geonames.org/2666237/>, _:b0__718.
_:b0__718 <http://www.w3.org/ns/dcat#centroid> "POINT (17.915 59.52)"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    <http://www.w3.org/ns/dcat#bbox> "POLYGON ((17.68 59.46, 18.15 59.46, 18.15 59.58, 17.68 59.58, 17.68 59.46))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    <http://www.w3.org/ns/locn#geometry> "POLYGON ((17.68 59.46, 18.15 59.46, 18.15 59.58, 17.68 59.58, 17.68 59.46))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.
<https://opendata.upplandsvasby.se/dataset/af169c2f-96e0-44b9-a621-093ad2a44c03> <http://www.w3.org/ns/dcat#contactPoint> <http://upplandsvasby.se/gataparkenheten>;

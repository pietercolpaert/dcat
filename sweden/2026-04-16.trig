    <http://purl.org/dc/terms/modified> "2025-06-02T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Data sources used in bibliometric studies 1978-2022"@en;

<https://doi.org/10.5281/zenodo.18430797> <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021001090>;
    <http://purl.org/dc/terms/description> "Samples from medieval wooden doors in Dalarna, Sweden were sent by the County Administrative Board of Dalarna to the Heritage Laboratory at the Swedish National Heritage Board for analysis. The research question was to determine whether the doors are coated with tar or another substance. Data from the following analytical techniques is included: 1. X-ray fluorescence spectroscopy (XRF); 2. Fourier transform infrared spectroscopy (FTIR); 3. visible and UV light optical microscopy. Instrument reports are also included. Project code RAÄ-2025-1685. The analysis report compiling the data and the final report from the County Administrative Board of Dalarna can be found at: 10.5281/zenodo.18430769."@en;
    <http://www.w3.org/ns/dcat#distribution> <https://doi.org/10.5281/zenodo.18430797#distribution>;
    <http://purl.org/dc/terms/issued> "2026-01-30T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.5281/zenodo.18430797>;
    <http://purl.org/dc/terms/modified> "2026-02-02T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Microscopy, XRF and FTIR data from the project Medieval timber houses in Dalarna, project code RAÄ-2025-1685"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/EDUC>;
    a <http://www.w3.org/ns/dcat#Dataset>
}


    <https://www.w3.org/ns/activitystreams#published> "2026-04-16T06:38:21.953Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#79ae7a1d83642d8f7f521b46c74385ac> {
<https://doi.org/10.5281/zenodo.14770956> <http://www.w3.org/ns/dcat#keyword> "Arabian Sea"@en, "MOM4p1-TOPAZ"@en;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__1743.
_:b0__1743 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/689a1f9a02156c3e2342d21d6359ce88>;
    a <http://www.w3.org/ns/prov#Attribution>.
<https://doi.org/10.5281/zenodo.14770956> <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__6526.
_:b0__6526 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/4aa558c1d7711ebdc9d99d8b2f92386b>;
    a <http://www.w3.org/ns/prov#Attribution>.
<https://doi.org/10.5281/zenodo.14770956> <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021003153>;
    <http://purl.org/dc/terms/description> "MOM4p1-TOPAZ data used in the analysis in the manuscript entitled \"On Mode Water formation and erosion in the Arabian Sea: Forcing mechanisms, regionality, and seasonality\".\n\nThe data file contains potential temperature, salinity, and oxygen data from the model run between 2000-2022, 0.25x0.25 degree resolution, of the upper 250m in the Arabian Sea (0-30 N, 35-80 E). The file also contains conservative temperature, absolute salinity, and potential density derived using the GSW toolbox (McDougall et al., 2011).\n\nRefereneces\n\nMcDougall, T.J. and P.M. Barker, 2011: Getting started with TEOS-10 and the Gibbs Seawater (GSW) Oceanographic Toolbox, 28pp., SCOR/IAPSO WG127, ISBN 978-0-646-55621-5.\n\nAcknowledgements: The MOM4p1-TOPAZ runs were carried out on the Param Pravega supercomputer at SERC, Indian Institute of Science, Bengaluru. Thanks to GFDL for providing the source code of the coupled physical–ecosystem model (MOM4P1-TOPAZ). The authors thank P. Neema for subsetting the MOM4p1-TOPAZ dataset."@en;
    <http://www.w3.org/ns/dcat#distribution> <https://doi.org/10.5281/zenodo.14770956#distribution>;
    <http://purl.org/dc/terms/issued> "2025-01-30T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.5281/zenodo.14770956>;
    <http://purl.org/dc/terms/modified> "2025-01-30T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "MOM4p1-TOPAZ data used in the manuscript entitled \"On Mode Water formation and erosion in the Arabian Sea: Forcing mechanisms, regionality, and seasonality\"."@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>;
    a <http://www.w3.org/ns/dcat#Dataset>
}

<feed> <https://w3id.org/tree#member> <#89d15eb7d6a793d19c65df101ba317f5>.
<#89d15eb7d6a793d19c65df101ba317f5> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://doi.org/10.5281/zenodo.14754940>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-16T06:38:21.953Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#89d15eb7d6a793d19c65df101ba317f5> {
<https://doi.org/10.5281/zenodo.14754940> <http://www.w3.org/ns/dcat#keyword> "XRF"@en, "FTIR"@en, "Microscopy"@en, "Heritage science"@en, "SEM"@en, "RAÄ-2024-1941"@en, "Kristianopels kyrka"@en;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__7889.
_:b0__7889 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/f1364552083e593c6b86189c0eaf3cf3>;
    a <http://www.w3.org/ns/prov#Attribution>.
<https://doi.org/10.5281/zenodo.14754940> <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021001090>;
    <http://purl.org/dc/terms/description> "Data from the project \"Pink coloring on the walls of Kristianopels kyrka\" (Diarienummer RAÄ-2024-1941) including a sampling protocol. Data from the following analytical techniques is included: 1. Scanning electron microscopy with energy dispersive x-ray spectroscopy (SEM-EDS); 2. X-ray fluorescence spectroscopy (XRF); 3. Fourier transform infrared spectroscopy (FTIR); 4. optical microscopy. Instrument reports are also included. The intention of the project was to determine if a pink surface layer found on the walls of Krisitanopel church (https://bebyggelseregistret.raa.se/bbr2/byggnad/visaHistorik.raa?byggnadId=21400000441427&page=historik&visaHistorik=true) is a paint layer or due to a biological growth."@en;
    <http://www.w3.org/ns/dcat#distribution> <https://doi.org/10.5281/zenodo.14754940#distribution>;
    <http://purl.org/dc/terms/issued> "2025-01-28T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.5281/zenodo.14754940>;
    <http://purl.org/dc/terms/modified> "2026-01-29T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Data from the project \"Pink coloring on the walls of Kristianopels kyrka\", RAÄ-2024-1941"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/EDUC>;
    a <http://www.w3.org/ns/dcat#Dataset>
}

<feed> <https://w3id.org/tree#member> <#2cd883c75612295fca2b3ef519ca15f8>.
<#2cd883c75612295fca2b3ef519ca15f8> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://doi.org/10.5281/zenodo.14444660>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-16T06:38:21.953Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#2cd883c75612295fca2b3ef519ca15f8> {
<https://doi.org/10.5281/zenodo.14444660> <http://www.w3.org/ns/dcat#keyword> "runes"@en, "runic inscription"@en, "runinskrift"@en, "Runverket"@en, "runor"@en, "rune"@en, "runbleck"@en, "runben"@en, "bennål"@en, "skaft"@en, "stämnyckel"@en, "kamskena"@en, "syllabarium"@en, "runic object"@en, "U AST1;166"@en, "U Fv1983;229"@en, "U Fv1990;33"@en, "U Fv1990;37"@en, "U Fv1992;161C"@en, "U NOR2000;27A"@en, "U NOR2000;29"@en, "U NOR2001;19"@en, "Sl 3"@en, "Sl 9"@en, "Sl 14"@en, "Sl 17"@en, "Sl 28"@en, "Sl 76"@en, "Sl 82"@en, "Sigtuna lösföremål"@en;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__8199.
_:b0__8199 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/e0926778acd5f41c66a95651951abd92>;
    a <http://www.w3.org/ns/prov#Attribution>.
<https://doi.org/10.5281/zenodo.14444660> <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021001090>;
    <http://purl.org/dc/terms/description> "Detta dataset innehåller 3D-modeller av runinskrifter på föremål från vikingatida och tidigmedeltida Sigtuna. Föremålen ingår i Sigtuna Museums samlingar.\n\nThis dataset includes 3D-scans of runic inscriptions on portable objects from Viking Age and Early Medieval Sigtuna, Uppland. The objects belong to the collections of Sigtuna Museum.\n\nThe signum U + code + number is an ID-code used in the record of runic inscriptions kept by Runverket at the Swedish National Heritage Board. The signum is used in most publications and web-based resources. It is the key to find further references on a specific runic inscription and the object carrying it.\n\nFöremålen 3D-skannades 2010 med ATOS II SO (Small Objects), vid Arkeologiska Forskningslaboratoriet (AFL), Stocholms Universitet, av Laila Kitzler Åhfeldt och Joakim Schultzén.\n\nTill U NOR2001:19 (Sl 97, syllabarium) användes mätvolym MV135 = 135x108x95mm, upplösning 0,1mm i slutresultatet.\n\nTill övriga föremål användes mätvolym MV35= 35x28x14mm, upplösning 0,027mm i slutresultatet."@en;
    <http://www.w3.org/ns/dcat#distribution> <https://doi.org/10.5281/zenodo.14444660#distribution>;
    <http://purl.org/dc/terms/issued> "2024-12-13T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.5281/zenodo.14444660>;
    <http://purl.org/dc/terms/modified> "2025-03-11T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "3D-data Runinskrifter på lösföremål från Sigtuna, Uppland\n3D data Runic inscriptions on portable objects from Sigtuna, Uppland"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/EDUC>;
    a <http://www.w3.org/ns/dcat#Dataset>
}


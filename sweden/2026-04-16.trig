<https://doi.org/10.5878/002220> <http://www.w3.org/ns/dcat#keyword> "CORS"@sv, "CORS"@en, "OCCUPATIONS"@en, "YRKEN"@sv, "MASS MEDIA"@en, "MASSMEDIA"@sv, "WORKING CONDITIONS"@en, "ARBETSFÖRHÅLLANDEN"@sv, "UNEMPLOYMENT"@en, "ARBETSLÖSHET"@sv, "HOURS OF WORK"@en, "ARBETSTID"@sv, "RADIO LISTENING"@en, "RADIOLYSSNANDE"@sv, "JOB SATISFACTION"@en, "ARBETSTILLFREDSSTÄLLELSE"@sv, "TELEVISION VIEWING"@en, "TV-TITTANDE"@sv, "MASS MEDIA USE"@en, "MEDIAANVÄNDNING"@sv, "ECONOMIC ACTIVITY"@en, "EKONOMISK AKTIVITET"@sv, "RETIREMENT"@en, "PENSIONERING"@sv;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__60110.
_:b0__60110 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;

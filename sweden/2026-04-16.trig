<https://opendata-catalog.smhi.se/md/617a59fa-087b-4416-83df-486b85dcb1ed> <http://www.w3.org/ns/dcat#keyword> "Öppna data"@sv, "Meteorologi"@sv, "Observation"@sv, "Vindhastighet"@sv, "HVD"@sv, "Geografiska meteorologiska förhållanden"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/CONT>;
    <http://purl.org/dc/terms/identifier> "_617a59fa-087b-4416-83df-486b85dcb1ed", "617a59fa-087b-4416-83df-486b85dcb1ed";
    <http://www.w3.org/ns/dcat#byteSize> "31163"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>;
    <http://data.europa.eu/r5r/hvdCategory> <http://data.europa.eu/bna/c_164e0bf5>;

    <http://www.w3.org/ns/dcat#distribution> <https://opendata-download-algae.smhi.se/api>, <https://opendata-view.smhi.se/algae/SR.SeaSurfaceArea/wms?service=wms&request=getcapabilities>, <https://opendata-view.smhi.se/algae/SR.SeaSurfaceArea/wfs?service=wfs&request=getcapabilities>, <https://opendata-download-algae.smhi.se/inspire.xml>, <https://opendata.smhi.se/algaemaps/api>, <urn:uuid:07ff1fcd-ab8a-41a1-1ee5-ecd33fc54e59>, <urn:uuid:c596ea6b-22d8-03cc-eb09-acc97c1f4bcd>, <urn:uuid:dba497fb-6128-de50-7cbd-5ee210319d8e>, <urn:uuid:e823cf19-3bd3-255f-195d-844d3130e332>, <urn:uuid:18d30b82-8e66-6dda-71e3-06390da7379b>;
    <http://purl.org/dc/terms/issued> "2017-05-31"^^<http://www.w3.org/2001/XMLSchema#date>;

<#e1931819ec69afe492db5e31d94fed63> {
<https://doi.org/10.5281/zenodo.7506220> <http://www.w3.org/ns/dcat#keyword> "computational typology"@en, "parallel text"@en, "multilingual NLP"@en;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__3790.
_:b0__3790 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;

<https://catalog.sodertalje.se/store/15/resource/287> <http://www.w3.org/ns/dcat#temporalResolution> "PT5M"^^<http://www.w3.org/2001/XMLSchema#duration>;
    <http://www.w3.org/ns/dcat#keyword> "Trafik"@sv, "Fordon"@sv, "buss"@sv, "traffic"@en, "transport"@sv, "iot"@sv, "flow"@en, "Trafikm��tning"@sv, "biltrafik"@sv, "Lastbil"@sv, "iot"@en, "motorcykel"@sv, "motorcycle"@sv, "Nygatan"@sv;
    <http://xmlns.com/foaf/0.1/page> <https://catalog.sodertalje.se/store/15/resource/285>;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/CONT>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2120000159>;
    <http://purl.org/dc/terms/description> "Södertälje kommun mäter flödet av bilar, lastbilar, bussar och motorcyklar längs Nygatan med IoT AI-sensorer. Sensorerna sitter monterade längs Nygatan och detekterar med hjälp av Artificiell Intelligens antalet bilar, lastbilar, bussar och motorcyklar som rör sig i vardera riktning.\n\nSensorerna rapporterar uppgifterna en gång var femte minut.\n\nSensorerna kommunicerar över kommunens IoT-nätverk med tekniken LoRaWAN. Sensorerna kan inte spara eller skicka någon bild eller video.\n\nSe dokumentation för beskrivning av data."@sv, "The municipality of Södertälje measures the flow of cars, trucks, buses and motorcycles along Nygatan with IoT AI sensors. The sensors are mounted along Nygatan and use Artificial Intelligence to detect the number of cars, trucks, buses and motorcycles moving in each direction.\n\nThe sensors report the data once every five minutes.\n\nThe sensors communicate over the municipality's IoT network using LoRaWAN technology. The sensors cannot save or send any image or video.\n\nView documentation for description of data."@en;
    <http://purl.org/dc/terms/spatial> <http://sws.geonames.org/2676176>, _:b0__61854.
_:b0__61854 <http://www.w3.org/ns/dcat#bbox> "POINT(17.62458336082596 59.19647591428375)"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.
<https://catalog.sodertalje.se/store/15/resource/287> <http://www.w3.org/ns/dcat#contactPoint> <https://catalog.sodertalje.se/store/12/resource/196>;
    <http://www.w3.org/ns/dcat#distribution> <https://catalog.sodertalje.se/store/15/resource/288>, <https://catalog.sodertalje.se/store/15/resource/331>;
    <http://purl.org/dc/terms/creator> <https://catalog.sodertalje.se/store/15/resource/271>;
    <http://purl.org/dc/terms/issued> "2024-12-23"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2025-06-17"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Trafikflödesmätningar Nygatan (IoT)"@sv, "Traffic flows Nygatan (IoT)"@en;

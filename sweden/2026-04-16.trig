<feed> <https://w3id.org/tree#member> <#1b45e1d566f5e1cec5f90765bdc812de>.
<#1b45e1d566f5e1cec5f90765bdc812de> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://doi.org/10.5281/zenodo.14141222>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-16T06:38:21.954Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#1b45e1d566f5e1cec5f90765bdc812de> {
<https://doi.org/10.5281/zenodo.14141222> <http://www.w3.org/ns/dcat#keyword> "Viking Age"@en, "Runverket"@en, "Runestone"@en, "Rune stone"@en, "Runsten"@en, "Runinskrift"@en, "Runor"@en, "Runes"@en, "Runic inscription"@en, "1000-tal"@en, "Medelpad"@en, "11th Century"@en, "M 1"@en, "M 2"@en, "M 3"@en, "M 4"@en, "M 5"@en, "M 6"@en, "M 7"@en, "M 8"@en, "M 10"@en, "M 11"@en, "M 13"@en, "M 14"@en, "M 15"@en, "M 16"@en;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__3923.
_:b0__3923 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/e0926778acd5f41c66a95651951abd92>;
    a <http://www.w3.org/ns/prov#Attribution>.
<https://doi.org/10.5281/zenodo.14141222> <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__4288.
_:b0__4288 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/d3b0084dd7dbe2b1b65172513bd132d0>;
    a <http://www.w3.org/ns/prov#Attribution>.
<https://doi.org/10.5281/zenodo.14141222> <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021001090>;
    <http://purl.org/dc/terms/description> "3D-scans of runestones in Medelpad. This dataset includes 3D-models of 11th century runestones 3D-scanned for a study within the research project Evighetsrunor: en forskningsplattform för Sveriges runinskrifter (Everlasting Runes: a research platform for Sweden's runic inscriptions) and as a preparation for a corpus publication about runic inscriptions in Medelpad.\n\nThe signum M + number is an ID-code used in the record of runic inscriptions kept by Runverket at the Swedish National Heritage Board. The signum is used in most publications and web-based resources. It is the key to find further references on a specific runic inscription and the object carrying it.\n\nThe 3D-scanning was made by Henrik Zedig, Länsstyrelsen Västra Götaland, with a handheld laser scanner HandySCAN BLACK ELITE (blue laser) from Creaform with a resolution of 0.40 mm. The data is here provided as STL-files. \n\nNoice has been reduced by using the function Thin in Zeiss INSPECT Optical 3D at a threshold level of 0.02-0.03 mm."@en;
    <http://www.w3.org/ns/dcat#distribution> <https://doi.org/10.5281/zenodo.14141222#distribution>;
    <http://purl.org/dc/terms/issued> "2024-11-13T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.5281/zenodo.14141222>;
    <http://purl.org/dc/terms/modified> "2025-06-11T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "3D-data Runstenar i Medelpad\n3D-data Runestones in Medelpad"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/EDUC>;
    a <http://www.w3.org/ns/dcat#Dataset>
}

<feed> <https://w3id.org/tree#member> <#49f5e5aae13c904d23e2b6fa147dc259>.
<#49f5e5aae13c904d23e2b6fa147dc259> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://doi.org/10.5281/zenodo.14046713>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-16T06:38:21.955Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#49f5e5aae13c904d23e2b6fa147dc259> {
<https://doi.org/10.5281/zenodo.14046713> <http://www.w3.org/ns/dcat#keyword> "runsten"@en, "runinskrift"@en, "Runverket"@en, "Runestone"@en, "Rune stone"@en, "Runor"@en, "Runes"@en, "Runstenar"@en, "Tidigkristna gravmonument"@en, "Early Christian grave monuments"@en, "Västergötland"@en, "1000-tal"@en, "900-tal"@en, "Husaby"@en, "Häggesled"@en, "Kållands Råda"@en, "Järpås"@en, "Kållands-Åsaka"@en, "Rackeby"@en, "Mellby"@en, "Håle"@en, "Särestad"@en, "Täng"@en, "Vg 22"@en, "Vg 23"@en, "Vg 24"@en, "Vg 27"@en, "Vg 27B"@en, "Vg 30"@en, "Vg 32"@en, "Vg 33"@en, "Vg 37"@en, "Vg 40"@en, "Vg 41"@en, "Vg 43"@en, "Vg 50"@en, "Vg 51"@en, "Vg 102"@en, "Vg 103"@en, "Vg 105"@en, "Vg 108"@en, "Vg ATA322-4412-2011"@en, "Vg ATA3940/64"@en, "Vg GVMV;89"@en, "Rune-stone"@en, "3D-scanning"@en, "3D-model"@en;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__8136.
_:b0__8136 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/e0926778acd5f41c66a95651951abd92>;
    a <http://www.w3.org/ns/prov#Attribution>.
<https://doi.org/10.5281/zenodo.14046713> <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021001090>;
    <http://purl.org/dc/terms/description> "3D-scans of runestones and Early Christian grave monuments from Västergötland.\n\nThis dataset includes 3D-models of late 10th-11th century runestones and early Christian grave monuments 3D-scanned for research. The study focussed on analysis of the runic inscriptions and ornament, therefor only the inscription surfaces have been scanned. Results of analysis have been published in the article \"Runstenar och eskilstunakistor i Västergötland: Ett exempel på förändrad mobilitet\" (English summary) in the journal Futhark: International Journal of Runic Studies (Futhark 2012, pp. 145-176; see related publications).\n\nThe signum Vg + number is an ID-code used in the record of runic inscriptions kept by Runverket at the Swedish National Heritage Board. The signum originates in the corpus publication Sveriges runinskrifter and other publications and reports, and is used in most publications and web-based resources. It is the key to find further references on a specific runic inscription and the object carrying it.\n\nAs the runic sigla may cover several stones, eg. various fragments of Early Christian grave monuments, the sigla have been complemented by other identifiers (i.e. catalogue numbers in Ljung 2016, Lundberg 1997).\n\nLjung, Cecilia (2016). Under runristad häll [2]. Katalog över tidigkristna gravmonument. Stockholm.\n\nLundberg, Stig (1997). Gravmonument i sten från sen vikingatid och äldre medeltid i Västergötland. Göteborg.\n\nVg + nr = Runic inscription in Västergötlands runinskrifter. Svärdström, Elisabeth (ed.) (1958). Sveriges runinskrifter Bd 5 Västergötlands runinskrifter, H. 3 Skaraborgs läns runstenar: text. Stockholm.\n\nVg ATA + number = Report in ATA (Antikvarisk-Topografiska Arkivet, Stockholm).\n\nVg GVMV + number = entry in Lundberg 1997.\n\nThe carving surfaces were recorded with optical 3D-scanner ATOS II from GOM, measuring volume 350x280x280mm, measuring point distance 0.27 mm, and are here provided in STL-format."@en;
    <http://www.w3.org/ns/dcat#distribution> <https://doi.org/10.5281/zenodo.14046713#distribution>;
    <http://purl.org/dc/terms/issued> "2024-11-07T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.5281/zenodo.14046713>;
    <http://purl.org/dc/terms/modified> "2024-11-07T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "3D-data Runstenar och tidigkristna gravmonument i Västergötland\n3D-data Runestones and Early Christian grave monuments in Västergötland"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/EDUC>;
    a <http://www.w3.org/ns/dcat#Dataset>
}


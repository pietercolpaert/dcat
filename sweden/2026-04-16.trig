    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021003054>;
    <http://purl.org/dc/terms/description> "This data set contains radar measurements on birds, humans and six different drones with a total of 75868 samples.\n\nThe sensor was a  frequency modulated continuous wave (FMCW) radar operating at 77 GHz with a mechanically scanning antenna.\n\nThe 'ReadMe.txt' file contains a detailed description of the data.\n\nThe data set is used in [1] where only FM-sweeps corresponding to azimuth index 54 to 203 are used (out of the provided 256), or 150 sweeps. \n\nWhen using this data set please refer to:\n\n[1] A. Karlsson, M. Jansson and M. Hämäläinen, \"Model-Aided Drone Classification Using Convolutional Neural Networks,\" 2022 IEEE Radar Conference (RadarConf22), 2022, pp. 1-6, doi: 10.1109/RadarConf2248738.2022.9764194.\n\nThe data in version 1.0 and 2.0 is identical apart from the format, \".mat\" in 1.0 and \".npy\" in 2.0"@en;
    <http://www.w3.org/ns/dcat#distribution> <https://doi.org/10.5281/zenodo.5896641#distribution>;
    <http://purl.org/dc/terms/issued> "2021-09-16T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.5281/zenodo.5896641>;
    <http://purl.org/dc/terms/modified> "2022-05-10T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Radar measurements on drones, birds and humans with a 77GHz FMCW sensor."@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TECH>;
    a <http://www.w3.org/ns/dcat#Dataset>
}


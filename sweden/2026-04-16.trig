<https://opendata-catalog.smhi.se/md/39cfa1a2-e61d-4a6f-9740-53b3afa9cde0> <http://www.w3.org/ns/dcat#keyword> "Öppna data"@sv, "Meteorologi"@sv, "Observation"@sv, "Vindhastighet"@sv, "HVD"@sv, "Geografiska meteorologiska förhållanden"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/CONT>;
    <http://purl.org/dc/terms/identifier> "_39cfa1a2-e61d-4a6f-9740-53b3afa9cde0", "39cfa1a2-e61d-4a6f-9740-53b3afa9cde0";
    <http://www.w3.org/ns/dcat#byteSize> "30207"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>;

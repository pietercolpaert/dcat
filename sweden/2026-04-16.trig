    <http://purl.org/dc/terms/modified> "2023-11-07T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Raw glider data: 9 months of hydrographic observations in the Gulf of Oman."@en;

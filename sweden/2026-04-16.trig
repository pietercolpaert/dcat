<https://doi.org/10.5878/003024> <http://www.w3.org/ns/dcat#keyword> "TAXATION"@en, "BESKATTNING"@sv, "HOUSING"@en, "BOENDE"@sv, "LOCAL GOVERNMENT SERVICES"@en, "KOMMUNAL SERVICE"@sv, "ENVIRONMENT"@en, "MILJÖ"@sv, "CHILD CARE"@en, "BARNOMSORG"@sv, "WORKING CONDITIONS"@en, "ARBETSFÖRHÅLLANDEN"@sv, "WAGES"@en, "LÖNER"@sv, "UNEMPLOYMENT"@en, "ARBETSLÖSHET"@sv, "HOURS OF WORK"@en, "ARBETSTID"@sv, "SAVINGS"@en, "SPARANDE"@sv, "SHARES"@en, "AKTIER"@sv, "HOUSEHOLDS"@en, "HUSHÅLL"@sv, "HEALTH"@en, "HÄLSA"@sv, "FISCAL POLICY"@en, "SKATTEPOLITIK"@sv, "CARS"@en, "BILAR"@sv, "INCOME"@en, "INKOMST"@sv, "HOUSING ECONOMICS"@en, "BOSTADSEKONOMI"@sv, "LABOUR AND EMPLOYMENT"@en, "ARBETE OCH SYSSELSÄTTNING"@sv, "INHERITANCE"@en, "ARV"@sv, "EDUCATION"@en, "UTBILDNING"@sv, "MOONLIGHTING"@en, "SVARTARBETE"@sv, "HOME OWNERSHIP"@en, "BOSTADSÄGANDE"@sv, "HOUSING TENURE"@en, "BOENDEFORMER"@sv, "PROPERTY, OWNERSHIP AND TENURE"@en, "EGENDOM, ÄGANDE OCH BESITTNING"@sv, "HOME SELLING"@en, "BOSTADSFÖRSÄLJNING"@sv, "HOME BUYING"@en, "BOSTADSINKÖP"@sv, "HOUSING FINANCE"@en, "BOSTADSFINANSIERING"@sv, "BOATS"@en, "BÅTAR"@sv, "BUILDING COSTS"@en, "BYGGNADSKOSTNAD"@sv, "EXPENDITURE"@en, "UTGIFT"@sv, "SECOND HOMES"@en, "FRITIDSBOSTÄDER"@sv;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__21727.
_:b0__21727 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;

<https://opendata.upplandsvasby.se/dataset/3f326e95-5a45-4a78-b435-008465ec817a> <http://www.w3.org/ns/dcat#keyword> "Upplands Väsby kommun", "utegym", "ute";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "248e99e2-5faa-4075-8027-99d54f925013";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://upplandsvasby.se>;
    <http://purl.org/dc/terms/description> "I Upplands Väsby kommun finns utegym i parker och längs promenader, där alla kan träna gratis utomhus. De har enkla redskap som pull-up-stänger och bänkar för olika övningar. Människor kommer hit på morgonen eller efter jobbet för att träna och få frisk luft. Utegymmen är inte bara till för träning utan också för att umgås och koppla av i naturen.";
    <http://purl.org/dc/terms/spatial> <https://www.geonames.org/2666237/>, _:b0__5777.
_:b0__5777 <http://www.w3.org/ns/dcat#centroid> "POINT (17.96 59.5)"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    <http://www.w3.org/ns/dcat#bbox> "POLYGON ((17.6 59.38, 18.32 59.38, 18.32 59.62, 17.6 59.62, 17.6 59.38))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    <http://www.w3.org/ns/locn#geometry> "POLYGON ((17.6 59.38, 18.32 59.38, 18.32 59.62, 17.6 59.62, 17.6 59.38))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.

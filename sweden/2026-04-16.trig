<feed> <https://w3id.org/tree#member> <#d6f0c68a5182e28a943661f55abf2d1d>.
<#d6f0c68a5182e28a943661f55abf2d1d> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://doi.org/10.5281/zenodo.17878890>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-16T06:38:21.944Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#d6f0c68a5182e28a943661f55abf2d1d> {
<https://doi.org/10.5281/zenodo.17878890> <http://www.w3.org/ns/dcat#keyword> "Behavioral and Personality Change"@en, "Child Maltreatment"@en, "Glioma. Intimate Partner Violence"@en, "Primary Brain Tumor"@en;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__9136.
_:b0__9136 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/a80b72709f6b5fa93a2da79baa198437>;
    a <http://www.w3.org/ns/prov#Attribution>.
<https://doi.org/10.5281/zenodo.17878890> <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021003096>;
    <http://purl.org/dc/terms/description> "This dataset contains transcripts from individual interviews in Microsoft Word (.docx) format. Individual interviews were conducted with 25 family members (partners/ex-partners and adult children) who have been exposed to violence by patients with primary brain tumors. Various forms of violence were reported, and intense suffering and loneliness were expressed. The homes sometimes shifted from being a safe place to being a place marked by fear and unpredictability. In adapting to violence, what initially seemed unreasonable, gradually became “the new normal”. Different strategies to minimize risks and damage were described. Self-blame and shame were often associated with an inability to love the patient, despite the violent actions by the patient. Sometimes, the death of the perpetrator was viewed as the only means of escape, which caused feelings of guilt and shame.\n\nThis study received a grant from the Swedish Crime Victim Authority (Dnr.11889/2024), financial support from the Medical Research Council of Southeast Sweden (Dnr. FORSS-995241 and FORSS-1012648) and a grant from the Swedish Brain Tumor Association. \n\nLiU secure repository is a data repository that hosts research data which cannot be openly available for ethical or legal reasons. LiU secure repository is managed by Linköping University Library as a service to researchers at Linköping University (Sweden). For requests of access or further information, please contact datamanagement@liu.se\n\nIf you have any questions about the contents of this dataset, please contact the researcher Lisa Kastbom at lisa.kastbom@liu.se"@en;
    <http://www.w3.org/ns/dcat#distribution> <https://doi.org/10.5281/zenodo.17878890#distribution>;
    <http://purl.org/dc/terms/issued> "2025-12-10T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.5281/zenodo.17878890>;
    <http://purl.org/dc/terms/modified> "2025-12-10T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Dataset for: \"My safe haven turned into a terror zone\": a qualitative study of family members' experiences of violence by brain tumor patients"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/HEAL>;
    a <http://www.w3.org/ns/dcat#Dataset>
}


    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/CONT>;
    <http://purl.org/dc/terms/identifier> "_76fd0da7-1e91-4ad3-a88b-8c2f89b0b2e0", "76fd0da7-1e91-4ad3-a88b-8c2f89b0b2e0";

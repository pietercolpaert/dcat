<https://doi.org/10.5281/zenodo.7451326> <http://www.w3.org/ns/dcat#keyword> "machine learning"@en, "precipitation"@en, "global water flux partitioning"@en, "runoff"@en, "evapotranspiration"@en, "shapley values"@en, "area of applicability"@en, "dissimilarity index"@en;

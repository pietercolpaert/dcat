<feed> <https://w3id.org/tree#member> <#9a80bd45702dfc059f7ea6fbec58e083>.
<#9a80bd45702dfc059f7ea6fbec58e083> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <https://resources.stockholm.se/data/b6b144d1-6f22-480a-9247-c16688153183>;
    <https://www.w3.org/ns/activitystreams#published> "2026-03-19T06:21:51.775Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#9a80bd45702dfc059f7ea6fbec58e083> {
<https://resources.stockholm.se/data/b6b144d1-6f22-480a-9247-c16688153183> <http://www.w3.org/ns/dcat#keyword> "Stockholms stad", "Verksamhetsdata"@sv, "Extern dataportal"@sv, "Stadsmiljö"@sv, "Ekologisk infrastruktur"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/IRREG>;
    <http://purl.org/dc/terms/identifier> "b6b144d1-6f22-480a-9247-c16688153183";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/RESTRICTED>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://resources.stockholm.se/metadata#foaf/Stockholms+stad/>;
    <http://purl.org/dc/terms/description> "Miljöförvaltningen har i samverkan med berörda förvaltningar och bolag tagit fram lokal åtgärdsprogram för stadens vattenförekomster. De lokala åtgärdsprogrammen omfattar förslag på åtgärder som behöver genomföras för att förbättra vattenmiljön och nå god vattenstatus enligt gällande miljökvalitetsnormer. Många av åtgärderna för bättre vatten är kopplade till rening av dagvatten, som tar med sig olika föroreningar till våra sjöar och vattendrag. Andra åtgärder syftar till att förbättra miljön för vattenlevande djur, som att skapa fria vandringsvägar och bra uppväxt och lekmiljöer. Målet med åtgärdsarbete är friskare sjöar, som har ett rikt djur- och växtliv under ytan och samtidigt är fria från kemikalier som kan påverka sjöns ekosystem och människors hälsa negativt. Det är ansvariga förvaltningar och bolag som vidare utreder och genomför de föreslagna åtgärderna enligt de lokala åtgärdsprogrammen."@sv;
    <http://purl.org/dc/terms/spatial> _:b0__64388.
_:b0__64388 <http://www.w3.org/ns/dcat#bbox> "POLYGON((17.7605 59.4382,18.2011 59.4382,18.2011 59.2272,17.7605 59.2272,17.7605 59.4382))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    <http://www.w3.org/ns/locn#geometry> "POLYGON((17.7605 59.4382,18.2011 59.4382,18.2011 59.2272,17.7605 59.2272,17.7605 59.4382))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.
<https://resources.stockholm.se/data/b6b144d1-6f22-480a-9247-c16688153183> <http://www.w3.org/ns/dcat#contactPoint> <https://resources.stockholm.se/metadata#vcard/Stockholms+stad+-+Milj%C3%B6f%C3%B6rvaltningen/>;
    <http://www.w3.org/ns/dcat#distribution> <https://resources.stockholm.se/data/b6b144d1-6f22-480a-9247-c16688153183#HTTP:ESRI+Portal-URL/1>, <https://resources.stockholm.se/data/b6b144d1-6f22-480a-9247-c16688153183#HTTP:ESRI+Portal-URL/2>;
    <http://www.w3.org/ns/dcat#landingPage> <https://dataportalen.stockholm.se/dataportalen/GetMetaDataById?id=297d40f0-5cec-43d9-811c-ed1ab556caa7>;
    <http://purl.org/dc/terms/type> <http://inspire.ec.europa.eu/metadata-codelist/ResourceType/dataset>;
    <http://purl.org/dc/terms/created> "2024-02-16"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "LÅP-åtgärder"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TRAN>, <http://publications.europa.eu/resource/authority/data-theme/ENVI>;
    a <http://www.w3.org/ns/dcat#dataset>, <http://www.w3.org/ns/dcat#Dataset>
}

<feed> <https://w3id.org/tree#member> <#81a80a29d9ada6936e2bae6f64d11728>.
<#81a80a29d9ada6936e2bae6f64d11728> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <https://doi.org/10.17197/U22006>;

    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Verksamhetens totala driftkostnad för kommunala bil- och cykelvägar. Summan av driftkostnaderna för vinterväghållning, gatubelysning, akuta beläggningsåtgärder, barmarksrenhållning, gatugrönytor, trafikanordningar, trafiksignaler, konstbyggnader och dagvattenavledning och övriga driftkostnader. Exklusive enskilda vägar, kapitalkostnader och kostnad för all beläggningsunderhåll som inte är akuta åtgärder (tex. potthål/snabelbil). Dividerat med meter kommunal bil- och cykelväg. 2018 och bakåt ingick även gångvägar i de redovisade driftskostnaderna, vilket kan medföra trendbrott 2019. "@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/U07427_json>;
    <http://purl.org/dc/terms/provenance> _:b0__438.
_:b0__438 <http://purl.org/dc/terms/description> "Källa: Gatustatistik och NVDB"@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/U07427> <http://purl.org/dc/terms/title> "Driftkostnad kommunala bil- och cykelvägar, kr/meter"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/ENVI>, <http://publications.europa.eu/resource/authority/data-theme/REGI>, _:b0__6582;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


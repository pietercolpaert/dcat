    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "N78113";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Medelvärde inom dimensionen vård och behandling. För att mäta dimensionen har svarande på enkäten fått ta ställning till frågorna: \"Hur upplevde du den vård du fick vid besöket?\" och \"Vilket förtroende kände du för läkaren?\". Varje svar ges en poäng mellan 0-1 beroende på antal svarsalternativ på frågan, poängen vägs sedan samman till ett medelvärde. Enkäten går ut till ett urval av patienter som träffat en läkare på en hälso- eller vårdcentral under september-oktober. Data finns tillgängligt enligt könsuppdelning."@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/N78113_json>;
    <http://purl.org/dc/terms/provenance> _:b0__4425.
_:b0__4425 <http://purl.org/dc/terms/description> "Källa: Nationell patientenkät, SKR"@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/N78113> <http://purl.org/dc/terms/modified> "2025-03-14"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Patientupplevd kvalitet avseende kontinuitet, hälso- och vårdcentral, medelvärde"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/HEAL>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


    <http://www.w3.org/ns/dcat#endDate> "2026-03-19"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#startDate> "2014-08-01"^^<http://www.w3.org/2001/XMLSchema#date>;

<https://metadata.havochvatten.se/store/1/resource/818> <http://purl.org/dc/terms/subject> <http://inspire.ec.europa.eu/metadata-codelist/TopicCategory/biota>, <http://www.eionet.europa.eu/gemet/concept/10194>;
    <http://purl.org/dc/terms/created> "2026-01-07"^^<http://www.w3.org/2001/XMLSchema#date>;

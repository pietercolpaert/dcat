    <http://www.w3.org/ns/dcat#distribution> <https://opendata.smhi.se/lightning/sensordata>, <urn:uuid:8075c7bf-a49f-672b-ea58-2ba3bce5e3cd>;
    <http://purl.org/dc/terms/issued> "2021-06-15"^^<http://www.w3.org/2001/XMLSchema#date>;

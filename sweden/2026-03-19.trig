<#81a80a29d9ada6936e2bae6f64d11728> {
<https://doi.org/10.17197/U22006> <http://www.w3.org/ns/dcat#keyword> "Demographic data"@en, "TABVERK"@en, "Sjukdomar"@en, "Regionala skillnader"@en;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__50926.
_:b0__50926 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/author>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/566c9d19f685376ce4eb8831c68553e4>;

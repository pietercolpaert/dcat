    <http://purl.org/dc/terms/temporal> _:b0__2567.
_:b0__2567 <http://www.w3.org/ns/dcat#endDate> "2099-12-31"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#startDate> "2001-01-01"^^<http://www.w3.org/2001/XMLSchema#date>;
    a <http://purl.org/dc/terms/PeriodOfTime>.
<https://metadata.trafikverket.se/store/1/resource/1042> <http://entryscape.org/terms/metadataIdentifier> "63544532-45d4-4188-99fe-f47dca49360d";
    <http://www.w3.org/ns/dcat#keyword> "område: transport"@sv, "trafikslag: järnväg"@sv;
    <https://dataportal.se/concepts/geose/areaCoveredQuotient> "449964/449964";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/CONT>;

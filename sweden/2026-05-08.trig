<https://opendata.umea.se/api/v2/catalog/datasets/gop_cyckelvag> <http://www.w3.org/ns/dcat#keyword> "Umeå kommun", "Cykel"@sv, "Cykelväg"@sv, "Cykelstråk"@sv, "Cykla"@sv;
    <http://purl.org/dc/terms/identifier> "gop_cyckelvag@http://dataportal.se/organisation/SE2120002627";
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;

    <https://www.w3.org/ns/activitystreams#published> "2026-05-08T06:37:08.076Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#830499f55cf1059d127d138e5b8b6a18> {
<http://api.kolada.se/v3/kpi/N07655> <http://www.w3.org/ns/dcat#keyword> "Kommun"@sv, "Region"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "N07655";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Detta är ett osäkerhetstal, för mer information se Osäkra data på kolada.se. \"Förtroende för att rättsväsendet behandlar brottsmisstänkta på ett bra sätt, andel (%)\" är en punktskattning från en urvalsundersökning. Det innebär att skattningen inte säkert är representativ för populationen som helhet. Men med punktskattning +- osäkerhetstalet kan man med stor sannolikhet säga att det sanna medelvärdet finns inom intervallet. Brå använder sig av asymmetriska konfidensintervall, i Kolada anges osäkerhetstalet som största avståndet mellan konfidensintervall och punktskattning. Det innebär att punktskattning +- osäkerhetstal kan skilja sig åt ena hållet mot konfidensintervallet från NTU. Exempelvis slås 2019-2020 ihop och publiceras för det senaste året, exempelvis år 2020 i Kolada, resultatet för 2021 och 2022 slås ihop och det gemensamma resultatet publiceras under året 2022 i Kolada. "@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/N07655_json>;
    <http://purl.org/dc/terms/provenance> _:b0__44685.
_:b0__44685 <http://purl.org/dc/terms/description> "Källa: BRÅs nationella trygghetsundersökning"@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/N07655> <http://purl.org/dc/terms/modified> "2024-12-15"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Osäkerhetstal - Förtroende för att rättsväsendet behandlar brottsutsatta på ett bra sätt, andel (%)"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/SOCI>, <http://publications.europa.eu/resource/authority/data-theme/REGI>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


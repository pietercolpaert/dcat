<https://doi.org/10.5878/002794> <http://www.w3.org/ns/dcat#keyword> "frekvens"@sv, "frequency"@en, "IMU-Testologen AB", "PERIODICALS READERSHIP"@en, "TIDSKRIFTSLÄSARE"@sv, "NEWSPAPER READERSHIP"@en, "TIDNINGS LÄSEKRETS"@sv, "DOMESTIC APPLIANCES"@en, "HUSHÅLLSAPPARAT"@sv, "CONSUMER GOODS"@en, "KONSUMTIONSVAROR"@sv, "INTEREST (COGNITIVE PROCESSES)"@en, "INTRESSE (KOGNITIVA PROCESSER)"@sv;

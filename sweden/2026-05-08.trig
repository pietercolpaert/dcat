al History Taking"@en, "Benbrott"@sv, "Fractures, Bone"@en, "Bronkit, kronisk"@sv, "Bronchitis, Chronic"@en, "Crohns sjukdom"@sv, "Crohn Disease"@en, "Eksem"@sv, "Eczema"@en, "Kärlkramp i benen"@sv, "Intermittent Claudication"@en, "Gallstenar"@sv, "Gallstones"@en, "Grå starr"@sv, "Cataract"@en, "Grön starr"@sv, "Glaucoma"@en, "Atopisk dermatit"@sv, "Dermatitis, Atopic"@en, "Högt blodtryck"@sv, "Hypertension"@en, "Kolesterol"@sv, "Cholesterol"@en, "Kosttillskott"@sv, "Dietary Supplements"@en, "Kroppslängd"@sv, "Body Height"@en, "Kärlkramp"@sv, "Angina Pectoris"@en, "Ledvärk"@sv, "Arthralgia"@en, "Lungtumörer"@sv, "Lung Neoplasms"@en, "Magkatarr"@sv, "Gastritis"@en, "Migränsjukdomar"@sv, "Migraine Disorders"@en, "Njurstenar"@sv, "Kidney Calculi"@en, "Njurtumörer"@sv, "Kidney Neoplasms"@en, "Parkinsons sjukdom"@sv, "Parkinson Disease"@en, "Psoriasis"@sv, "Psoriasis"@en, "Årstidsbunden allergisk rinit"@sv, "Rhinitis, Allergic, Seasonal"@en, "Tjocktarmstumörer"@sv, "Colonic Neoplasms"@en, "Kolit, ulcerös"@sv, "Colitis, Ulcerative"@en, "Vitaminer"@sv, "Vitamins"@en, "Urineringsstörningar"@sv, "Urination Disorders"@en, "Prostatatumörer"@sv, "Prostatic Neoplasms"@en, "Swedish Cohort Consortium (SCC)"@sv, "Swedish Cohort Consortium (SCC)"@en, "Cohorts.se"@sv, "Cohorts.se"@en, "Stroke"@sv, "Vertigo"@sv;

<https://opendata.umea.se/api/v2/catalog/datasets/luftkvalitetsmaetningar-vaestra-esplanaden-fr-o-m-2025> <http://www.w3.org/ns/dcat#keyword> "Umeå kommun", "NO2"@sv, "Luftkvalitet"@sv, "Miljö"@sv, "PM10"@sv, "Sensorvärden"@sv;
    <http://purl.org/dc/terms/identifier> "luftkvalitetsmaetningar-vaestra-esplanaden-fr-o-m-2025@http://dataportal.se/organisation/SE2120002627";
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://admin.dataportal.se/store/43/resource/7a00bd3796ed09a600646432cb321722>;
    <http://purl.org/dc/terms/description> "Mätdata från kontinuerliga luftmätningar utförs inom\ncentrala Umeå vid Västra Esplanaden.Den datamängd som visas här redovisar de timmedelvärden för\nde mätvärden som fångas in avseende kvävedioxid (NO2) samt Partiklar\n(PM) på Västra EsplanadenNya data hämtas in varje timme, men kan komma att saknas om\nmätstationen av någon anledning inte fungerar för en period.\nDet som visas är ovaliderad rådata som hämtats direkt ifrån\nmätstationen utan att ha granskats innan publicering.Alla tidpunkter är angivna med svensk normaltid. Ingen justering för sommartid görs.\n\nDetta dataset innehåller data från 2025-01-01Data från tidigare perioder finns på [Luftdata Västra Esplanaden t o m 2024 — OpenDataUmea](https://opendata.umea.se/explore/dataset/luftdata-vastra-esplanaden/table/?sort=timestamp_timestamp)"@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://opendata.umea.se/explore/?refine.dcat.contact_name=Milj%C3%B6-+och+h%C3%A4lsoskydd+Ume%C3%A5+kommun&refine.dcat.contact_email=miljoochhalsoskydd%2540umea.se>;
    <http://www.w3.org/ns/dcat#distribution> <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/luftkvalitetsmaetningar-vaestra-esplanaden-fr-o-m-2025-API>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/luftkvalitetsmaetningar-vaestra-esplanaden-fr-o-m-2025-csv>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/luftkvalitetsmaetningar-vaestra-esplanaden-fr-o-m-2025-json>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/luftkvalitetsmaetningar-vaestra-esplanaden-fr-o-m-2025-jsonl>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/luftkvalitetsmaetningar-vaestra-esplanaden-fr-o-m-2025-parquet>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/luftkvalitetsmaetningar-vaestra-esplanaden-fr-o-m-2025-rdfxml>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/luftkvalitetsmaetningar-vaestra-esplanaden-fr-o-m-2025-jsonld>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/luftkvalitetsmaetningar-vaestra-esplanaden-fr-o-m-2025-turtle>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/luftkvalitetsmaetningar-vaestra-esplanaden-fr-o-m-2025-n3>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/luftkvalitetsmaetningar-vaestra-esplanaden-fr-o-m-2025-xlsx>;
    <http://purl.org/dc/terms/issued> "2025-02-17T00:00:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

    <http://www.w3.org/ns/dcat#startDate> "1050"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    a <http://purl.org/dc/terms/PeriodOfTime>.
<https://doi.org/10.5878/001845> <http://purl.org/dc/terms/temporal> _:b0__41586.
_:b0__41586 <http://www.w3.org/ns/dcat#endDate> "0400"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#startDate> "-0499"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    a <http://purl.org/dc/terms/PeriodOfTime>
}


<https://www.geodata.se/resources/ae3339a7-2df6-43eb-8832-f4b9cccefd84> <http://www.w3.org/ns/dcat#keyword> "Inspire"@sv;
    <http://purl.org/dc/terms/identifier> "ae3339a7-2df6-43eb-8832-f4b9cccefd84";
    <http://www.w3.org/ns/dcat#endpointURL> <https://inspire.msb.se/nedladdning/MSB_TopAtomFeed_APSFR.xml>;

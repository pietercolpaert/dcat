    <http://purl.org/dc/terms/modified> "2026-02-11T10:35:13.969653Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Names and memories in Kiyovu, Kigali"@en, "Namn och minnen i Kiyovu, Kigali"@sv;

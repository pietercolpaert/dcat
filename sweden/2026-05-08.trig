    <http://www.w3.org/ns/dcat#distribution> <https://doi.org/10.5878/4jtv-wd18#distribution>;
    <http://purl.org/dc/terms/issued> "2026-02-11T10:35:13.969653Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

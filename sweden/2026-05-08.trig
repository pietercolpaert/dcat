    <http://purl.org/dc/terms/issued> "2023-04-24"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2026-05-07T19:06:40.033300"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Vattentemperaturer"@sv, "Water temperatures"@en, "Vandtemperaturer"@da;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/EDUC>;
    a <http://www.w3.org/ns/dcat#Dataset>
}

<feed> <https://w3id.org/tree#member> <#6a72aa68f2653b593315c483706a4220>.
<#6a72aa68f2653b593315c483706a4220> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <https://opendata-api.malmo.se/dataset/c7d18e08-1373-4fce-a4b0-8f46d66279bd>;
    <https://www.w3.org/ns/activitystreams#published> "2026-05-08T06:37:05.586Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#6a72aa68f2653b593315c483706a4220> {
<https://opendata-api.malmo.se/dataset/c7d18e08-1373-4fce-a4b0-8f46d66279bd> <http://www.w3.org/ns/dcat#keyword> "Malmö stad", "gis", "karta", "geodata", "Vatten", "VA", "Enskilt Avlopp", "Avlopp", "map";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/DAILY>;
    <http://purl.org/dc/terms/identifier> "c7d18e08-1373-4fce-a4b0-8f46d66279bd";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://malmo.se/>;
    <http://purl.org/dc/terms/description> "Platser i Malmö där avloppsvatten från byggnader renas vid en enskild avloppsanläggning. \n\nVår placering av de enskilda avloppen är inte alltid korrekt, särskilt på koloniområden. Attributet koordinatpunkttyp beskriver vad som använts för att skapa punkten. Mittpunkt av fastighet kan vara långt från det faktiska avloppet. "@sv, "Locations in Malmö where wastewater from buildings is treated at an individual\nsewage plant.\n\nOur location of individual drains is not always accurate, especially in\nresidential areas. The coordinate point type attribute describes what was used\nto create the point. The center point of the property may be far from the\nactual drain.\n\n"@en, "Steder i Malmø, hvor spildevand fra bygninger behandles på et individuelt\nrensningsanlæg.\n\nVores placering af individuelle afløb er ikke altid præcis, især i\nboligområder. Attributten \"koordinatpunkttype\" beskriver, hvad der blev brugt\ntil at oprette punktet. Ejendommens midtpunkt kan være langt fra det faktiske\nafløb.\n\n"@da;
    <http://purl.org/dc/terms/spatial> <http://www.geonames.org/2692965/malmoe.html>, _:b0__5748.
_:b0__5748 <http://www.w3.org/ns/dcat#bbox> "POLYGON((12.8850967451 55.6421476735,13.1517619812 55.6421476735,13.1517619812 55.5022773196,12.8850967451 55.5022773196,12.8850967451 55.6421476735))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;

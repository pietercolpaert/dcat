<#88ab1015f141ad6c29b2f89adc567ed6> {
<https://opendata-catalog.smhi.se/md/67892fd0-b487-11ea-8f8b-197eadf2f6fe> <http://www.w3.org/ns/dcat#keyword> "Öppna data"@sv, "Hydrografi"@sv, "Hydrologi"@sv, "Observation"@sv;

<https://opendata-catalog.smhi.se/md/e1faa8e1-77ad-4716-8266-e3c359e043eb> <http://www.w3.org/ns/dcat#contactPoint> <https://www.smhi.se/data/utforskaren-oppna-data/ice_smhi.se>;
    <http://www.w3.org/ns/dcat#distribution> <https://opendata-download.smhi.se/isdata/>, <urn:uuid:4d2e0c5d-a134-0103-722f-a3f8816e29ca>;
    <http://purl.org/dc/terms/issued> "2015-06-30"^^<http://www.w3.org/2001/XMLSchema#date>;

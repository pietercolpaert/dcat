    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/MONTHLY>;
    <http://purl.org/dc/terms/identifier> "_a52a78e0-89ed-11ea-a966-bfa48b38ccc2", "a52a78e0-89ed-11ea-a966-bfa48b38ccc2";

<#1fa6e7b60dc6ec1a8f1049e2e681fbe3> {
<https://opendata-catalog.smhi.se/md/2205ecf4-647b-4ca0-b7b4-50e3199932b9> <http://www.w3.org/ns/dcat#keyword> "Öppna data"@sv, "Inspire"@sv, "Observation"@sv, "Oceanografi"@sv, "Havsvattenstånd"@sv, "Geografiska oceanografiska förhållanden"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/MONTHLY>;
    <http://purl.org/dc/terms/identifier> "_2205ecf4-647b-4ca0-b7b4-50e3199932b9", "2205ecf4-647b-4ca0-b7b4-50e3199932b9";

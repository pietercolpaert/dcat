    <http://www.w3.org/ns/dcat#distribution> <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-112804-alidhem-vastra-API>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-112804-alidhem-vastra-csv>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-112804-alidhem-vastra-json>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-112804-alidhem-vastra-jsonl>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-112804-alidhem-vastra-parquet>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-112804-alidhem-vastra-rdfxml>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-112804-alidhem-vastra-jsonld>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-112804-alidhem-vastra-turtle>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-112804-alidhem-vastra-n3>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-112804-alidhem-vastra-xlsx>;
    <http://purl.org/dc/terms/issued> "2024-01-16T23:07:06.185000+00:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

<http://api.kolada.se/v3/kpi/U26431> <http://purl.org/dc/terms/modified> "2025-12-08"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Brukarbedömning sysselsättning SoL - Brukaren känner sig trygg med alla i personalen, lägeskommun, andel (%)"@sv;

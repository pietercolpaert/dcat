<https://opendata-catalog.smhi.se/md/aaaff2d2-c58b-4aa5-88af-565eb5f3d6d5> <http://www.w3.org/ns/dcat#keyword> "Öppna data"@sv, "Inspire"@sv, "Observation"@sv, "Oceanografi"@sv, "Vågperiod"@sv, "Geografiska oceanografiska förhållanden"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/MONTHLY>;
    <http://purl.org/dc/terms/identifier> "_aaaff2d2-c58b-4aa5-88af-565eb5f3d6d5", "aaaff2d2-c58b-4aa5-88af-565eb5f3d6d5";

    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021001975>;
    <http://purl.org/dc/terms/description> "Skyddade områden i Östersjön som ingår i nätverket Ospar. Ospar är en regional konvention om att skydda miljön i Nordostatlanten. Där ingår Nordsjön, Skagerrak och delar av Kattegatt."@sv;
    <http://purl.org/dc/terms/spatial> _:b0__39813.
_:b0__39813 <http://www.w3.org/ns/locn#geometry> "POLYGON((10.592077 69.059941,24.177412 69.059941,24.177412 55.137212,10.592077 55.137212,10.592077 69.059941))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.
<http://data.naturvardsverket.se/resources/39948786-a278-4cdb-8b95-2ce99f941f65> <http://www.w3.org/ns/dcat#contactPoint> <urn:uuid:f110432b-5a81-0a56-0779-95c58d61af76>;
    <http://www.w3.org/ns/dcat#distribution> <urn:uuid:5ed20755-ec5b-1230-5039-3a259b5430a9>, <urn:uuid:761f4059-0d73-7970-da14-5c9edba91a99>, <urn:uuid:ab83901b-57b5-1d26-67a1-e03a1f385691>, <urn:uuid:5ab48c7c-e0e9-5ff5-3ad5-d442212fc61d>;
    <http://purl.org/dc/terms/provenance> _:b0__75971.
_:b0__75971 <http://www.w3.org/2000/01/rdf-schema#value> "Havs- och vattenmyndigheten (HaV) bereder, tillsammans med länsstyrelserna, frågor om skyddade områden. HaV tar även fram förslag på vilka områden som ska skyddas, vilket regeringen sedan fattar beslut om. Naturvårdsverket upprätthåller listan över skyddade områden (enligt miljöbalken) och Ospar-områden ing��r bland dessa."@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://data.naturvardsverket.se/resources/39948786-a278-4cdb-8b95-2ce99f941f65> <http://purl.org/dc/terms/issued> "2022-01-12"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg_impl/2023/138/oj>;
    <http://purl.org/dc/terms/modified> "2022-05-04"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Skyddade områden: marina områden i Sverige enligt Ospar"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>;
    a <http://www.w3.org/ns/dcat#Dataset>
}


    <http://www.w3.org/ns/dcat#distribution> <https://opendata-download-hydroobs.smhi.se/api/version/latest/parameter/8.json>, <https://opendata-download-hydroobs.smhi.se/api/version/latest/parameter/9.json>, <https://opendata.smhi.se/hydroobs/api>, <https://www.smhi.se/data/hitta-data-for-en-plats/ladda-ner-observationer-fran-sjoar-och-vattendrag/snowDensity>, <urn:uuid:354b6f34-fc4a-e52c-e78e-efe4792bb1ca>, <urn:uuid:817ec519-4ff3-b14d-9774-9b5b4dddc613>, <urn:uuid:0b62cb4e-a21e-e1d3-8625-beb58f9916ce>, <urn:uuid:ef801fad-f437-6e19-f608-b69b3390d358>;

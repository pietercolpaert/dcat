<#e392899599fcf5cbec629e0fbdbac88e> {
<http://api.kolada.se/v3/kpi/U21464> <http://www.w3.org/ns/dcat#keyword> "Kommun"@sv, "Enhetsnivå"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "U21464";

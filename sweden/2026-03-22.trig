    <http://purl.org/dc/terms/modified> "2025-12-17T12:09:51.753658Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "The Swedish Gallup Institute’s surveys from 1942-1956"@en, "Svenska Gallupundersökningar från 1942 till 1956"@sv;

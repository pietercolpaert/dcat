    <http://purl.org/dc/terms/title> "Ngoni - Språk, kultur och sociolingvistisk situation - Fotoelicitering traditionella föremål"@sv, "Ngoni - Language, Culture and Sociolinguistic Situation - Photo Elicitation Traditional Objects"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/SOCI>, <http://publications.europa.eu/resource/authority/data-theme/EDUC>;
    <http://purl.org/dc/terms/temporal> _:b0__97300.
_:b0__97300 <http://www.w3.org/ns/dcat#endDate> "2013-09"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

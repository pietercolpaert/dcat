<#b26efee479b56347b83d8c324fd4143d> {
<https://opendata-api.malmo.se/dataset/d463475a-5dd9-4130-a97a-dc3e19f1da71> <http://www.w3.org/ns/dcat#keyword> "Malmö stad", "gis", "karta", "geodata", "byggnader", "träd", "Primärkarta", "vägar", "vatten", "transport", "map";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/WEEKLY>;
    <http://purl.org/dc/terms/identifier> "d463475a-5dd9-4130-a97a-dc3e19f1da71";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://malmo.se/>;
    <http://purl.org/dc/terms/description> "Primärkartan beskriver det fysiska i staden, såsom byggnader, träd eller transport. Informationen uppdateras kontinuerligt av Stadsbyggnadskontoret och ny version publiceras dagligen. Informationen är lagrad som punkt-, linje- och ytobjekt. \n\nObservera: Primärkartan och dess lager är inte kompletta i alla delar av staden. Arbete med att höja kvalitén pågår ständigt, för mer information kontakta Stadsbyggnadskontoret eller via formuläret."@sv, "The primary map describes the physical features of the city, such as\nbuildings, trees or transport. The information is continuously updated by the\nCity Planning Office and a new version is published daily. The information is\nstored as point, line and area objects.\n\nPlease note: The primary map and its layers are not complete in all parts of\nthe city. Work to improve the quality is ongoing, for more information contact\nthe City Planning Office or via the form.\n\n"@en, "Det primære kort beskriver byens fysiske træk, såsom bygninger, træer eller\ntransport. Oplysningerne opdateres løbende af Byplankontoret, og en ny version\noffentliggøres dagligt. Oplysningerne gemmes som punkt-, linje- og\narealobjekter.\n\nBemærk: Hovedkortet og dets lag er ikke komplette i alle dele af byen.\nArbejdet med at forbedre kvaliteten er i gang. For yderligere information,\nkontakt Byplankontoret eller brug formularen.\n\n"@da;
    <http://purl.org/dc/terms/spatial> <http://www.geonames.org/2692965/malmoe.html>, _:b0__553.
_:b0__553 <http://www.w3.org/ns/dcat#bbox> "POLYGON((12.8850967451 55.6421476735,13.1517619812 55.6421476735,13.1517619812 55.5022773196,12.8850967451 55.5022773196,12.8850967451 55.6421476735))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.
<https://opendata-api.malmo.se/dataset/d463475a-5dd9-4130-a97a-dc3e19f1da71> <http://www.w3.org/ns/dcat#contactPoint> <https://admin.dataportal.se/store/290/resource/590e717ed624870c5e5af379a019ac72>;
    <http://www.w3.org/ns/dcat#distribution> <https://opendata-api.malmo.se/dataset/d463475a-5dd9-4130-a97a-dc3e19f1da71/resource/79e4db81-62c1-4e02-a4ce-9ff4eaa90d46>, <https://opendata-api.malmo.se/dataset/d463475a-5dd9-4130-a97a-dc3e19f1da71/resource/d190adc8-f0d5-4501-ae5a-eb569915a3d0>, <https://opendata-api.malmo.se/dataset/d463475a-5dd9-4130-a97a-dc3e19f1da71/resource/26134fa0-95f9-41bb-8a4e-55a681ced799>, <https://opendata-api.malmo.se/dataset/d463475a-5dd9-4130-a97a-dc3e19f1da71/resource/a4b8fd55-1b4d-4043-8f40-dbf112f2c206>, <https://opendata-api.malmo.se/dataset/d463475a-5dd9-4130-a97a-dc3e19f1da71/resource/733840dd-affa-4a20-99f3-006c291ed240>, <https://opendata-api.malmo.se/dataset/d463475a-5dd9-4130-a97a-dc3e19f1da71/resource/30489778-8eb4-43f9-bc52-b7e4c05ac9e4>, <https://opendata-api.malmo.se/dataset/d463475a-5dd9-4130-a97a-dc3e19f1da71/resource/e4095d48-4730-464d-8e76-e9995d09fd0f>, <https://opendata-api.malmo.se/dataset/d463475a-5dd9-4130-a97a-dc3e19f1da71/resource/968bc7e7-0f29-4a1e-a3ce-ccd1bd5c8c24>, <https://opendata-api.malmo.se/dataset/d463475a-5dd9-4130-a97a-dc3e19f1da71/resource/88140069-9975-485e-8695-faf1eb52822c>, <https://opendata-api.malmo.se/dataset/d463475a-5dd9-4130-a97a-dc3e19f1da71/resource/a5800991-bc33-4956-9035-fd9de3c282d6>, <https://opendata-api.malmo.se/dataset/d463475a-5dd9-4130-a97a-dc3e19f1da71/resource/8147ab89-e30f-43bc-9206-cafb0abeceac>;
    <http://purl.org/dc/terms/issued> "2022-10-24"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2026-05-10T03:03:05.727457"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

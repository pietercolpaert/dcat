<https://opendata.umea.se/api/v2/catalog/datasets/geografiska-omraden> <http://www.w3.org/ns/dcat#keyword> "Umeå kommun", "Befolkning"@sv, "Statistik"@sv, "NYKO6"@sv, "Area"@sv, "Nyckelkodsområde"@sv;

    <http://www.w3.org/ns/adms#status> <http://publications.europa.eu/resource/authority/distribution-status/COMPLETED>;
    <http://www.w3.org/ns/dcat#accessURL> <https://opendata-api.malmo.se/dataset/c37d0a55-9be7-4984-9ce1-a6227c5b3c31/resource/98a640ba-5eea-42a4-b791-f34a22147f6d/download/markytor.geojson>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/description> "Heltäckande markanvändning för Malmö kommun, framtaget efter lagakraftvunna detaljplaners användningsytor. Markytorna visar därför befintlig och i vissa fall planerad markanvändning. Markanvändningen är uppdelad på kvartersmark, hårdgjord yta och grönyta."@sv, "Omfattende arealanvendelse for Malmø Kommune, udarbejdet i henhold til\nanvendelsesområderne i juridisk bindende detaljeplaner. Arealerne viser derfor\neksisterende og i nogle tilfælde planlagt arealanvendelse. Arealanvendelsen er\nopdelt i blokarealer, befæstet areal og grønne områder.\n\n"@da, "Comprehensive land use for Malmö Municipality, produced according to the use\nareas of legally binding detailed plans. The land areas therefore show\nexisting and in some cases planned land use. The land use is divided into\nblock land, paved area and green space.\n\n"@en;
    <http://spdx.org/rdf/terms#checksum> _:b0__81184.
_:b0__81184 <http://spdx.org/rdf/terms#checksumValue> "dcac9d795690db5fb9a10e5d2eec26e35583c808";
    <http://spdx.org/rdf/terms#algorithm> <http://spdx.org/rdf/terms#checksumAlgorithm_sha1>;
    a <http://spdx.org/rdf/terms#Checksum>.
<https://opendata-api.malmo.se/dataset/c37d0a55-9be7-4984-9ce1-a6227c5b3c31/resource/98a640ba-5eea-42a4-b791-f34a22147f6d> <http://purl.org/dc/terms/format> "application/json";
    <http://purl.org/dc/terms/issued> "2023-06-26T09:28:54.705072"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2026-05-10T02:58:52.867736"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Markytor"@sv, "Land surfaces"@en, "Landoverflader"@da;
    a <http://www.w3.org/ns/dcat#Distribution>
}


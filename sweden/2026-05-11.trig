<#669f682bfa9ba82c252813296daf13e8> {
<https://doi.org/10.23695/KXVZ-TX42> <http://www.w3.org/ns/dcat#keyword> "Language Technology (Computational Linguistics)"@en, "corpus"@en;
    <http://www.w3.org/ns/dcat#distribution> <https://doi.org/10.23695/KXVZ-TX42#distribution>;
    <http://purl.org/dc/terms/issued> "2025-01-01T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.23695/KXVZ-TX42>;
    <http://purl.org/dc/terms/modified> "2025-01-19T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "DaLAJ-GED-SuperLim 2.0"@en, "DaLAJ-GED-Superlim 2.0"@sv;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__52837.
_:b0__52837 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;

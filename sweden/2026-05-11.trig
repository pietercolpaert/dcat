    <http://purl.org/dc/terms/modified> "2026-05-10T02:00:04.475000+00:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Lekplatser som förvaltas av Gator och parker"@sv;

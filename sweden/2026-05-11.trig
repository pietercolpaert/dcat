    <http://purl.org/dc/terms/issued> "2023-02-24T12:48:50.737516"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2026-05-10T03:00:13.919461"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

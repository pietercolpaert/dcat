<feed> <https://w3id.org/tree#member> <#c59bff677c7a2e1838d40ef1dfa9d30b>.
<#c59bff677c7a2e1838d40ef1dfa9d30b> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <https://opendata.umea.se/api/v2/catalog/datasets/gallande-detaljplaner>;
    <https://www.w3.org/ns/activitystreams#published> "2026-05-11T07:12:35.870Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#c59bff677c7a2e1838d40ef1dfa9d30b> {
<https://opendata.umea.se/api/v2/catalog/datasets/gallande-detaljplaner> <http://www.w3.org/ns/dcat#keyword> "Umeå kommun", "Markanvändning"@sv, "Detaljplan"@sv, "Planering"@sv, "Gällande detaljplaner"@sv;
    <http://purl.org/dc/terms/identifier> "gallande-detaljplaner@http://dataportal.se/organisation/SE2120002627";
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://admin.dataportal.se/store/43/resource/7a00bd3796ed09a600646432cb321722>;
    <http://purl.org/dc/terms/description> "Kommunens fysiska planering avgör\nhur mark- och vattenområden ska användas. I detaljplaner regleras bland annat\nbebyggelse, gator, parker och friluftsområden. Detaljplanerna ligger till grund\nför beslut om till exempel bygglov.\nDetta dataset visar var, inom kommunens gränser det finns en gällande\nplan, vilket aktnummer planen har och när planen fick laga kraft.  Med aktnumret kan du sedan kontakta kommunen och få ut\ngällande plan med bestämmelser som visar vad som möjliggörs i just ditt område. Olika typer av planer i datasetet är:\ndetaljplaner, områdesbestämmelser, ändringsplaner,\nbyggnadsplaner, stadsplaner och generalplaner.Vid frågor kontakta detaljplanering@umea.se"@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://opendata.umea.se/explore/?refine.dcat.contact_name=Detaljplanering%252C+Ume%C3%A5+kommun&refine.dcat.contact_email=detaljplanering%2540umea.se>;
    <http://www.w3.org/ns/dcat#distribution> <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gallande-detaljplaner-API>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gallande-detaljplaner-csv>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gallande-detaljplaner-json>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gallande-detaljplaner-fgb>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gallande-detaljplaner-geojson>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gallande-detaljplaner-gpx>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gallande-detaljplaner-jsonl>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gallande-detaljplaner-kml>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gallande-detaljplaner-ov2>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gallande-detaljplaner-parquet>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gallande-detaljplaner-rdfxml>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gallande-detaljplaner-jsonld>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gallande-detaljplaner-turtle>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gallande-detaljplaner-n3>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gallande-detaljplaner-shp>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/gallande-detaljplaner-xlsx>;
    <http://purl.org/dc/terms/issued> "2026-05-10T22:00:09.201000+00:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://opendata.umea.se/explore/dataset/gallande-detaljplaner/>;
    <http://purl.org/dc/terms/modified> "2026-05-10T22:00:09.201000+00:00"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Gällande detaljplaner"@sv;

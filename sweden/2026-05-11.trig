<#1d92ae26768dd920308e6bea65fb6822> {
<http://data.naturvardsverket.se/resources/af2e37d3-45b0-4623-bcf2-0765c8ca7ab5> <http://purl.org/dc/terms/identifier> "af2e37d3-45b0-4623-bcf2-0765c8ca7ab5";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;

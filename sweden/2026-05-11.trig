<#bd629594074a7e32bad3b07a75bb6934> {
<https://opendata-catalog.smhi.se/md/c6ae10b6-6a18-4e15-9444-fbd746f4609d> <http://www.w3.org/ns/dcat#keyword> "Öppna data"@sv, "Inspire"@sv, "Meteorologi"@sv, "Observation"@sv, "Lufttemperatur"@sv, "HVD"@sv;

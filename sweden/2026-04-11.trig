<https://doi.org/10.5878/n1c5-vw84> <http://www.w3.org/ns/dcat#keyword> "översikt över skogsskador"@sv, "inventory of forest damage"@en, "skogsskador"@sv, "forest decline"@en, "törskate"@sv, "resin-top disease"@en, "rostsvampar"@sv, "rust fungi"@en, "NRS"@sv, "TFDI"@en, "törskatesvamp"@sv, "resin top disease"@en, "cronartium flaccidum"@en;

    a <http://purl.org/dc/terms/PeriodOfTime>.
<https://doi.org/10.5878/m5m1-br15> <http://purl.org/dc/terms/temporal> _:b0__3554.
_:b0__3554 <http://www.w3.org/ns/dcat#endDate> "2018-06-30"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#startDate> "2018-05-01"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    a <http://purl.org/dc/terms/PeriodOfTime>
}


a picipes"@en, "Ampedus pomorum"@en, "lövrödrock"@sv, "Ischnoglossa prolixa"@en, "Atheta paracrassicornis"@en, "Rhizophagus dispar"@en, "Bolitochara mulsanti"@en, "Hylurgops glabratus"@en, "brun granbastborre"@sv, "Atheta pilicornis"@en, "Cryptophagus scanicus"@en, "Aspidiphorus orbiculatus"@en, "Scaphisoma agaricinum"@en, "Mycetoporus punctus"@en, "Pediacus fuscus"@en, "Rhizophagus bipustulatus"@en, "Drusilla canaliculata"@en, "Hylurgops palliatus"@en, "blek bastborre"@sv, "Ampedus nigrinus"@en, "vedsvartrock"@sv, "Phloeopora testacea"@en, "Quedius scitus"@en, "Zilora ferruginea"@en, "gropig brunbagge"@sv, "Anisotoma glabra"@en, "Ernobius mollis"@en, "mjuk trägnagare"@sv, "cryphalus abietis ferrari, 1867"@en, "cyphon"@en;

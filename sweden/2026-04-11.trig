    <http://purl.org/dc/terms/title> "INDILACT - Förlängd frivillig väntetid för förstakalvare. Del 1: randomiserad kontrollerad studie"@sv, "INDILACT - Extended voluntary waiting period in primiparous dairy cows. Part 1: randomized controlled trial"@en;
    <http://purl.org/dc/terms/temporal> _:b0__8604.
_:b0__8604 <http://www.w3.org/ns/dcat#endDate> "2021-09"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

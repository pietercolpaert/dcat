<https://doi.org/10.5878/3fcc-7594> <http://www.w3.org/ns/dcat#keyword> "Pinus sylvestris"@en, "forestry"@en, "Populus tremula"@en, "herbivory"@en, "boreal forests"@en, "temperate forests"@en, "wind damage"@en, "ecosystem disturbance"@en, "survey design"@en, "Betula pendula"@en, "Betula pubescens"@en, "Fagus sylvatica"@en, "Quercus rubra"@en, "Alnus glutinosa"@en, "Alnus incase"@en, "Salix sp."@en, "Pinus contorta"@en, "Picea rabies"@en;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__6901.

<#7ecadc4936189a455ec0ed649d30d288> {
<https://admin.dataportal.se/store/818/resource/4e7d72852dfb0bac7753c218cb9a7d18> <http://www.w3.org/ns/dcat#keyword> "health"@en, "cancer"@en, "human"@en;

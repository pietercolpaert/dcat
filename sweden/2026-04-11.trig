_:b0__63367 <http://purl.org/dc/terms/description> "Källa: SKR:s undersökning om brukares uppfattning av kvalitet inom verksamheter för boende för barn och unga."@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/U33754> <http://purl.org/dc/terms/modified> "2025-12-08"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Brukarbedömning familjehem - Det finns någon vuxen brukaren kan prata med vid behov, andel (%)"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/HEAL>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


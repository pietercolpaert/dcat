<https://opendata-catalog.smhi.se/md/2c789229-7fb2-485b-ad6e-505e4081d667> <http://www.w3.org/ns/dcat#keyword> "Öppna data"@sv, "Meteorologi"@sv, "Observation"@sv, "Lufttryck"@sv, "HVD"@sv, "Geografiska meteorologiska förhållanden"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/CONT>;
    <http://purl.org/dc/terms/identifier> "_2c789229-7fb2-485b-ad6e-505e4081d667", "2c789229-7fb2-485b-ad6e-505e4081d667";

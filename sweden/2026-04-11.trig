<feed> <https://w3id.org/tree#member> <#9ee42ab0391233b9c9546e91dfca487b>.
<#9ee42ab0391233b9c9546e91dfca487b> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <http://api.kolada.se/v3/kpi/U74203>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-11T06:23:29.307Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#9ee42ab0391233b9c9546e91dfca487b> {
<http://api.kolada.se/v3/kpi/U74203> <http://www.w3.org/ns/dcat#keyword> "Region"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "U74203";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Styrningsindex för specialiserad psykiatrisk vård enligt resultat från medarbetarenkät. HME står för Hållbart medarbetarengagemang och mäter såväl nivån på medarbetarnas engagemang som chefernas och organisationens förmåga att ta tillvara på och skapa engagemang. HME-index består av nio frågor som tillsammans bildar ett totalindex för Hållbart medarbetarengagemang och tre delindex; Motivation, Ledarskap och Styrning. Delindex Styrning består av de tre frågorna Jag är insatt i min arbetsplats mål, Min arbetsplats mål följs upp och utvärderas på ett bra sätt, Jag vet vad som förväntas av mig i mitt arbete. Frågorna besvaras på en skala 1-5 där 1 är stämmer mycket dåligt och 5 ��r stämmer mycket bra. Resultaten omvandlas sedan till ett index med skala 0-100. Resultatet för Styrningsindex är ett medelvärde av indexvärdet på de tre frågorna. Ett högt värde indikerar en hög nivå på organisationens styrning. Avser egen regi. Data finns tillgängligt enligt könsuppdelning."@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/U74203_json>;
    <http://purl.org/dc/terms/provenance> _:b0__59964.
_:b0__59964 <http://purl.org/dc/terms/description> "Källa: Egen undersökning i regionen"@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/U74203> <http://purl.org/dc/terms/title> "Medarbetarengagemang (HME) specialiserad psykiatrisk vård - Styrningsindex"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/HEAL>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


<#c4dde4d69d65145ffdb9dacd49acb2fb> {
<https://doi.org/10.5878/001003> <http://www.w3.org/ns/dcat#keyword> "Swedish Working Life Fund", "LABOUR AND EMPLOYMENT"@en, "ARBETE OCH SYSSELS��TTNING"@sv, "LABOUR MARKET"@en, "ARBETSMARKNAD"@sv, "EMPLOYMENT POLICY"@en, "SYSSELSÄTTNINGSPOLITIK"@sv;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__23330.

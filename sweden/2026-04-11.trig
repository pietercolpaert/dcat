<https://doi.org/10.58141/tbr4-nm83> <http://www.w3.org/ns/dcat#keyword> "daphnia"@sv, "daphnia"@en, "toxicitetstester"@sv, "toxicity tests"@en, "krom"@sv, "hexavalent chromium"@en, "Daphnia"@en;

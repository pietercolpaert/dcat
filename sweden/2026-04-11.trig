<https://admin.dataportal.se/store/818/resource/c766a1f1ecf659f20abc2425ccff1bee> <http://www.w3.org/ns/dcat#keyword> "genomics"@en, "synthetic data"@en;
    <http://purl.org/dc/terms/issued> "2023-12-11T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

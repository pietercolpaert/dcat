<https://admin.dataportal.se/store/818/resource/0b050a2372183a43b14d0837840c0a5b> <http://www.w3.org/ns/dcat#keyword> "health"@en, "children"@en, "cancer"@en, "genomics"@en, "biobank"@en, "tumour"@en;
    <http://purl.org/dc/terms/issued> "2024-02-22T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

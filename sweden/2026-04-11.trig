<#42e5ea2ce7be31d976e4d1cdac953de6> {
<https://doi.org/10.5878/6qa4-cn46> <http://www.w3.org/ns/dcat#keyword> "Naturtyper och biotoper"@sv, "Habitats and biotopes"@en, "Havsområden"@sv, "Sea regions"@en, "arktiska regionen"@sv, "arctic region"@en, "procaryote"@en, "mikrobekologi"@sv, "microbial ecology"@en, "Procaryotæ (prokaryota organismer)"@sv, "arktisk forskning"@sv, "arctic research"@en, "marinekologi"@sv, "marine ecology"@en, "prokaryotes"@en, "archaea"@en, "bacteria cavalier-smith, 2002"@en;

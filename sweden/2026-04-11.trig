<#e11b484aa18aa37e628739cb319b9981> {
<https://doi.org/10.5878/c1gs-8272> <http://www.w3.org/ns/dcat#keyword> "Arabidopsis thaliana"@en, "interferometri"@sv, "microscopy"@en, "cellbiologi"@sv, "cell biology"@en, "plant development stage"@en, "plant breeding"@en, "förnyelse"@sv, "regeneration"@en, "backtrav"@sv, "afm (microscopy)"@en, "scanning electron microscopy"@en, "arabidopsis"@en;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__3220.
_:b0__3220 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/fff4a214bbb830e23d9e5d5ede10dee7>;
    a <http://www.w3.org/ns/prov#Attribution>.
<https://doi.org/10.5878/c1gs-8272> <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__6109.
_:b0__6109 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/94f1e77a3c28e7463e8f162387863762>;
    a <http://www.w3.org/ns/prov#Attribution>.
<https://doi.org/10.5878/c1gs-8272> <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/ENG>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021002817>;
    <http://purl.org/dc/terms/description> "Confocal microscopy, electron microscopy and atomic force microscopy images of Arabidopsis thaliana roots, both in wild plants and mutant plants or plants under chemical treatment. The images show cell division phenotypes in pericycle cells, mainly stained with the specific cellulose dye calcofluor white.\n\nThese results are part of an investigation that seeks to dissect the molecular bases that regulate the regeneration response in Arabidopsis roots after mechanical damage.\n\nMechanical damage by herbivory or abiotic stress is common in nature in plants. Faced with this, plants have developed a rapid regeneration response that allows replacing damaged cells with new cells. In this study we demonstrate that the composition of the cell wall is important to optimize the regeneration response. Particularly, pectin plays a key role in cell-cell adhesion and cell proliferation after wounding.\n\nThe microscopy images are provided as TIFF files along with metadata tables. The atomic force microscopy data also includes force maps created in JPK NanoWizard."@en;
    <http://www.w3.org/ns/dcat#contactPoint> <https://admin.dataportal.se/store/818/resource/51114b511532c3a2185d2769d45f9a7f>, <https://admin.dataportal.se/store/818/resource/84ba45f15d0ac50e3e24b8f607e38531>;
    <http://www.w3.org/ns/dcat#distribution> <https://doi.org/10.5878/c1gs-8272#distribution>;
    <http://purl.org/dc/terms/issued> "2025-02-13T15:02:19.334517Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.5878/c1gs-8272>;
    <http://purl.org/dc/terms/modified> "2025-07-01T11:38:07.172369Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Data for \"Cellular Damage Triggers Mechano-Chemical Control of Cell Wall Dynamics and Patterned Cell Divisions in Plant Healing\""@en, "Data för \"Cellular Damage Triggers Mechano-Chemical Control of Cell Wall Dynamics and Patterned Cell Divisions in Plant Healing\""@sv;
    <http://purl.org/dc/terms/temporal> _:b0__6791.
_:b0__6791 <http://www.w3.org/ns/dcat#endDate> "2024-03-31"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#startDate> "2021-09-01"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    a <http://purl.org/dc/terms/PeriodOfTime>
}


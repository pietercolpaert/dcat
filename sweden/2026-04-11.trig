<https://doi.org/10.5878/jegq-gh64> <http://www.w3.org/ns/dcat#keyword> "nyheter"@sv, "mass media use"@en, "musiklyssnande"@sv, "listening to music"@en, "tv-tittande"@sv, "television viewing"@en, "radiolyssnande"@sv, "radio listening"@en, "news"@en, "social media"@en, "ljudmedier"@sv, "sound media"@en, "digitala medier"@sv, "digital media"@en, "rörlig bild"@sv, "tv/online videos"@en, "tidskrifter"@sv, "magazines"@en, "medieanvändning"@sv, "media use"@en, "sociala medier"@sv, "dagstidningar"@sv, "newspaper"@en;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__60094.
_:b0__60094 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;

<https://admin.dataportal.se/store/818/resource/94b421c9e551963883ea7fc925e4ec65> <http://www.w3.org/ns/dcat#keyword> "COVID-19"@sv, "COVID-19"@en, "AGRICULTURAL PRODUCTION"@en, "JORDBRUKSPRODUKTION"@sv, "POVERTY"@en, "FATTIGDOM"@sv, "RURAL DEVELOPMENT"@en, "LANDSBYGDSUTVECKLING"@sv, "ECONOMIC AND SOCIAL DEVELOPMENT"@en, "EKONOMISK OCH SOCIAL UTVECKLING"@sv, "FOOD PRODUCTION"@en, "LIVSMEDELSPRODUKTION"@sv;

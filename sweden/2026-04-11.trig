    <http://purl.org/dc/terms/modified> "2026-02-10T14:12:31.180662Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "PrepApp Data 2021: A digital tool for long-term preposition acquisition"@en, "PrepApp Data 2021: Ett digitalt verktyg för långsiktig inlärning av preposition"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/SOCI>, <http://publications.europa.eu/resource/authority/data-theme/EDUC>;
    <http://purl.org/dc/terms/temporal> _:b0__88803.
_:b0__88803 <http://www.w3.org/ns/dcat#endDate> "2020-06-05"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#startDate> "2020-02-17"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    a <http://purl.org/dc/terms/PeriodOfTime>.
<https://doi.org/10.5878/0c2x-1m83> a <http://www.w3.org/ns/dcat#Dataset>
}


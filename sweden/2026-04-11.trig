    <http://purl.org/dc/terms/modified> "2022-11-23T06:48:02.403582Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Populationsdynamik i växthusexperiment av bladlöss och deras rovdjur"@sv, "Population dynamics in greenhouse experiments of aphids and their predators"@en;
    <http://purl.org/dc/terms/temporal> _:b0__9820.

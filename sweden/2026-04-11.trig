    <http://purl.org/dc/terms/issued> "2025-05-28T09:25:17.328183Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.5878/vrak-4t29>;
    <http://purl.org/dc/terms/modified> "2025-05-28T09:25:17.328183Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Catch of currant pests (Lamporna capitella, Euhyponomeutoides albithoracellus and Synanthedon tipuliformis) in pheromone traps in Sweden, Norway and Finland 2021-2023"@en, "Fångst av skadegörande insekter på vinbär (Lamporna capitella, Euhyponomeutoides albithoracellus och Synanthedon tipuliformis) i feromonfällor i Sverige, Norge och Finland 2021-2023"@sv;
    <http://purl.org/dc/terms/temporal> _:b0__7829.

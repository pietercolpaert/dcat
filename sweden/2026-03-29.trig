    <http://www.w3.org/ns/dcat#accessURL> <https://ckan-malmo.dataplatform.se/api/action/datastore_search?resource_id=81d95f48-4bdd-49fa-b4a4-f6ded7378a15>;
    <http://purl.org/dc/terms/title> "Nattbefolkning efter SNI 2007, 2008-2018"@sv, "Nighttime population by SNI 2007, 2008-2018"@en, "Natbefolkning efter SNI 2007, 2008-2018"@da;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/description> "Malmö statistik - Nattbefolkning efter SNI 2007, 2008-2018"@sv, "Malmö statistics - Nighttime population according to SNI 2007, 2008-2018\n\n"@en, "Malmö-statistik - Natbefolkning ifølge SNI 2007, 2008-2018\n\n"@da;

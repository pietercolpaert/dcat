<https://opendata-api.malmo.se/dataset/e5a1983c-eb1d-4132-b59e-fa6b4e00c826/resource/e885996c-b567-4fb8-8323-2460ff6fadbc> <http://purl.org/dc/terms/license> <http://creativecommons.org/publicdomain/zero/1.0>;
    <http://purl.org/dc/terms/issued> "2022-08-15T11:02:55.346249"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

    <https://www.w3.org/ns/activitystreams#object> <https://opendata-api.malmo.se/dataset/35db71ba-7ce4-4366-878d-705cd19aff7d/resource/6e130ca3-0e06-4bc5-8552-c88b2fb09a0a>;
    <https://www.w3.org/ns/activitystreams#published> "2026-03-29T06:25:17.687Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#db02d4bc975e89a9172f174cc88e0aa2> {
<https://opendata-api.malmo.se/dataset/35db71ba-7ce4-4366-878d-705cd19aff7d/resource/6e130ca3-0e06-4bc5-8552-c88b2fb09a0a> <http://purl.org/dc/terms/license> <http://creativecommons.org/publicdomain/zero/1.0>;
    <http://purl.org/dc/terms/issued> "2022-08-12T08:44:42.908624"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

_:b0__51103 <http://purl.org/dc/terms/description> "Källa: SCB."@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/N80036> <http://purl.org/dc/terms/modified> "2025-08-28"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Nettokostnad allmäntandvård vuxna (exkl. läkemedel), kr/vuxna invånare"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/HEAL>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;

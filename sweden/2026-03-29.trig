<#61589441ce5f0387cf8b6926c3444bd2> {
<https://opendata-api.malmo.se/dataset/86b521fe-6371-4dfa-8b1c-f4b4cbdbe943> <http://www.w3.org/ns/dcat#keyword> "Malmö stad", "kolada", "statistik";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "86b521fe-6371-4dfa-8b1c-f4b4cbdbe943";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://malmo.se/>;
    <http://purl.org/dc/terms/description> "Beskriver kommunens betalningsförmåga på kort sikt, vid värdet 100 klarar man precis sina kortfristiga ekonomiska åtaganden. \n\nOmsättningstillgångarna minus förråds-, lager- och exploateringstillgångar dividerade med kortfristiga skulder. \n\nStatistik i procent från 1998.\n\nKälla: SCB."@sv, "Describes the municipality's ability to pay in the short term; at a value of\n100, it can just about meet its short-term financial obligations.\n\nCurrent assets minus inventory, warehouse and operating assets divided by\ncurrent liabilities.\n\nStatistics in percentages from 1998.\n\nSource: Statistics Sweden.\n\n"@en, "Beskriver kommunens betalingsevne på kort sigt; ved en værdi på 100 kan den\nlige akkurat opfylde sine kortsigtede økonomiske forpligtelser.\n\nOmsætningsaktiver minus lager, lager og driftsaktiver divideret med\nkortfristede forpligtelser.\n\nStatistik i procenter fra 1998.\n\nKilde: Statistiska Centralbyrån.\n\n"@da;
    <http://purl.org/dc/terms/spatial> <http://www.geonames.org/2692965/malmoe.html>, _:b0__9631.
_:b0__9631 <http://www.w3.org/ns/dcat#bbox> "POLYGON((12.8850967451 55.6421476735,13.1517619812 55.6421476735,13.1517619812 55.5022773196,12.8850967451 55.5022773196,12.8850967451 55.6421476735))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.
<https://opendata-api.malmo.se/dataset/86b521fe-6371-4dfa-8b1c-f4b4cbdbe943> <http://www.w3.org/ns/dcat#contactPoint> <https://admin.dataportal.se/store/290/resource/0e01ba1a25b24ce4d82683ada08cb166>;
    <http://www.w3.org/ns/dcat#distribution> <https://opendata-api.malmo.se/dataset/86b521fe-6371-4dfa-8b1c-f4b4cbdbe943/resource/218e71d6-881a-48a9-9224-89e86fd04cfc>;
    <http://purl.org/dc/terms/issued> "2020-12-15"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2026-03-18T21:24:56.707866"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

    <http://purl.org/dc/terms/issued> "2020-12-17"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2026-03-25T14:52:51.613815"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Ekonomiskt bistånd - Statistikunderlag för Malmös områden"@sv, "Economic assistance - Statistical data for Malmö's areas"@en, "Økonomisk bistand - Statistiske data for Malmøs områder"@da;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/SOCI>;
    <http://purl.org/dc/terms/temporal> _:b0__6329.
_:b0__6329 <http://www.w3.org/ns/dcat#startDate> "2016-01-01"^^<http://www.w3.org/2001/XMLSchema#date>;
    a <http://purl.org/dc/terms/PeriodOfTime>.
<https://opendata-api.malmo.se/dataset/297f7613-012d-4ff5-afe8-0febb651829c> a <http://www.w3.org/ns/dcat#Dataset>
}

<feed> <https://w3id.org/tree#member> <#83d094c9552af1f8f53f6b03214a364d>.
<#83d094c9552af1f8f53f6b03214a364d> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://opendata-api.malmo.se/dataset/8b8e8175-7a61-45d0-9597-1d71eb755461>;

<#ed621dcce2552323d5a8647cdbb13d5f> {
<http://data.naturvardsverket.se/resources/A8C54FB7-1AEB-441C-B649-3E29FF86EB52> <http://www.w3.org/ns/dcat#keyword> "Inspire"@sv, "Värdefulla datamängder"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/WEEKLY>;
    <http://purl.org/dc/terms/identifier> "A8C54FB7-1AEB-441C-B649-3E29FF86EB52";
    <http://data.europa.eu/r5r/hvdCategory> <http://data.europa.eu/bna/c_dd313021>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021001975>;
    <http://purl.org/dc/terms/description> "Natura naturtypskartan beskriver utbredningen av naturtyper som ingår i EU:s Art- och habitatdirektivet, bilaga 1 (EEG 92/443) samt ett urval av andra naturtyper. Kodlistan och en kort beskrivning finns i dokumentet ”Tillgängliga koder för attributet naturtyp i NNK-IT systemet” (bifogas vid nedladdning av data).   Den geografiska utbredningen för data är beslutade Natura 2000-områden, naturreservat och nationalparker, men det kan finnas områden som ej är karterade."@sv;
    <http://purl.org/dc/terms/spatial> _:b0__79607.
_:b0__79607 <http://www.w3.org/ns/locn#geometry> "POLYGON((10.61 69.06,24.18 69.06,24.18 55.14,10.61 55.14,10.61 69.06))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.
<http://data.naturvardsverket.se/resources/A8C54FB7-1AEB-441C-B649-3E29FF86EB52> <http://www.w3.org/ns/dcat#contactPoint> <urn:uuid:f110432b-5a81-0a56-0779-95c58d61af76>;
    <http://www.w3.org/ns/dcat#distribution> <urn:uuid:c63ecb1b-80a5-f8b6-4b79-6ca56af0ddc5>, <urn:uuid:6958259d-f8ea-e31d-cefd-10030f41dbab>, <urn:uuid:8acd1a9a-2dc1-31ee-848e-6933d2b0a5a7>, <urn:uuid:cbf7b3e6-47eb-ed38-09d8-e38853aac2b8>, <urn:uuid:46e834c2-f2a4-13df-cf61-8cbe4b8a4c42>, <urn:uuid:a477de1d-17d6-63d2-2ff4-9f7f1d1f48e2>;
    <http://purl.org/dc/terms/provenance> _:b0__74084.
_:b0__74084 <http://www.w3.org/2000/01/rdf-schema#value> "Data har karterats i olika omgångar och med olika ambitionsnivå. Den första karteringen var inom ramen för projektet \"Basinventering av Natura 2000 och skyddade områden\" och efter att det projektet avslutades sker en mer kontinuerlig kartering av nytillkomna områden. Kartering sker med olika metoder beroende på områdenas storlek och karaktär. Vanliga metoder är flygbildstolkning eller tolkning i ortofoto som kompletteras med information från andra rikstäckande inventeringar (t ex Ängs- och betesmarksinventeringen, nyckelbiotopsinventeringen, våtmarksinventeringen). Data granskas sedan av länsstyrelsen och i vissa fall sker kompletteringar genom fältbesök. Det är viktigt att veta att en del områden endast är översiktligt karterade medan andra delar kan vara väldigt noggrant bedömda. Data är inte ”sanningen” utan en bedömning som gjorts vid ett visst tillfälle. Genom att granska attributet \"karteringsstatus\" går det att bedöma hur noggrant ett område är karterat och avgöra om det är tillräckligt för aktuellt användningsområde."@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://data.naturvardsverket.se/resources/A8C54FB7-1AEB-441C-B649-3E29FF86EB52> <http://purl.org/dc/terms/issued> "2020-09-23"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg_impl/2023/138/oj>;
    <http://purl.org/dc/terms/modified> "2020-09-23"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Naturtyper och biotoper: Natura naturtypskartan"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>;
    a <http://www.w3.org/ns/dcat#Dataset>
}


<#112974d9aa4e4fe54f20fa6ff4f48b38> {
<https://opendata-api.malmo.se/dataset/b6fe783f-a968-4669-a51c-da88fb80e3e0> <http://www.w3.org/ns/dcat#keyword> "Malmö stad", "kolada", "statistik";

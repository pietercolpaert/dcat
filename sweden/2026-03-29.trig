<https://opendata-catalog.smhi.se/md/bb79c7e0-b14d-11ea-8f8b-197eadf2f6fe> <http://www.w3.org/ns/dcat#keyword> "Is"@sv, "Öppna data"@sv, "Inspire"@sv, "Observation"@sv, "Oceanografi"@sv, "Havsområden"@sv;

    a <http://purl.org/dc/terms/Location>.
<https://opendata-catalog.smhi.se/md/bbaf9e24-aea4-471f-afeb-9ab94d63bf96> <http://www.w3.org/ns/dcat#contactPoint> <https://www.smhi.se/data/utforskaren-oppna-data/kundtjanst_smhi.se>;
    <http://www.w3.org/ns/dcat#distribution> <https://www.smhi.se/data/temperatur-och-vind/temperatur/historisk-data-i-grib-format/sa-fungerar-grib-format>, <https://data-download.smhi.se/data/meteorology/cmepss_mbr000_surface/>, <urn:uuid:e202f176-65a4-ad4a-8749-a352245d1552>, <urn:uuid:a44bb7fc-20cf-5560-1da4-57e6abd68852>;
    <http://purl.org/dc/terms/issued> "2026-01-29"^^<http://www.w3.org/2001/XMLSchema#date>, "2015-11-02"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://data.europa.eu/r5r/applicableLegislation> <http://data.europa.eu/eli/reg_impl/2023/138/oj>;
    <http://purl.org/dc/terms/title> "Meteorologisk modell (CMEPSS, medlem 0) - markparametrar"@sv, "Meteorologisk modell (AROME) - markparametrar"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>;
    <http://www.w3.org/ns/dcat#dataQuality> "Prognosmodellen använder fysikaliska lagar, t ex rörelseekvationer, termodynamiska samband, strålnings- och kontinuitetsekvationer för att beräkna vädrets förändring i ett antal tidssteg framåt i tiden.";
    <http://purl.org/dc/terms/conformsTo> <http://www.w3.org/TR/vocab-dcat/>;
    <http://purl.org/dc/terms/rights> _:b0__2459.
_:b0__2459 <http://schema.theodi.org/odrs#copyrightStatement> <https://www.smhi.se/data/om-smhis-data/villkor-for-anvandning>;
    a <http://schema.theodi.org/odrs#RightsStatement>
}


    <http://purl.org/dc/terms/issued> "2020-12-17"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2026-03-25T16:00:49.791968"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Nattbefolkning efter SNI 2007, 2008-2018 - Statistikunderlag för Malmös områden"@sv, "Nighttime population according to SNI 2007, 2008-2018 - Statistical data for Malmö's areas"@en, "Natbefolkning ifølge SNI 2007, 2008-2018 - Statistiske data for Malmøs områder"@da;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/SOCI>;

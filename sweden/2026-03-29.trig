<#2f84922548e361b088a31042757cb971> {
<https://opendata-api.malmo.se/dataset/31bef806-a038-4148-8408-114c043ab0f4> <http://www.w3.org/ns/dcat#keyword> "Malmö stad", "kolada", "politik";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "31bef806-a038-4148-8408-114c043ab0f4";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://malmo.se/>;
    <http://purl.org/dc/terms/description> "Data över valresultatet från kommunfullmäktigevalet i Malmö från 1994 och framåt. \n\nStatistiken i procent.\n\n__Mer information__: https://malmo.se/Service/Om-Malmo-stad/Politik-beslut-och-paverkan.html\n\n## Kommun- och landstingsdatabasen Kolada\n\nDen här öppna datan hämtas från Kommun- och landstingsdatabasen Kolada som innehåller jämförbara nyckeltal om alla Sveriges kommuner och landsting. Nyckeltalen baseras på data från ett stort antal myndigheter och organisationer som exempelvis SCB, SKL, Valmyndigheten, Bolagsverket, Skolverket, Socialstyrelsen och BRÅ. "@sv, "Data on election results from the municipal council elections in Malmö from\n1994 onwards.\n\nStatistics in percentage.\n\n**More information** :\nhttps://malmo.se/Service/Om%2dMalmo%2dstad/Politik%2dbeslut%2doch%2dpaverkan.html\n\n##  Kolada municipality and county council database\n\nThis open data is taken from the Kolada database of municipalities and county\ncouncils, which contains comparable key figures for all of Sweden's\nmunicipalities and county councils. The key figures are based on data from a\nlarge number of authorities and organizations such as Statistics Sweden, the\nSwedish National Agency for Education, the Swedish Election Authority, the\nSwedish Companies Registration Office, the Swedish National Agency for\nEducation, the Swedish National Board of Health and Welfare, and BRÅ.\n\n"@en, "Data om valgresultater fra kommunalvalgene i Malmø fra 1994 og fremefter.\n\nStatistik i procent.\n\n**Mere information** :\nhttps://malmo.se/Service/Om%2dMalmo%2dstad/Politik%2dbeslut%2doch%2dpaverkan.html\n\n##  Kolada kommune og amtsråds database\n\nDisse åbne data er hentet fra Kolada-databasen over kommuner og amtsråd, som\nindeholder sammenlignelige nøgletal for alle Sveriges kommuner og amtsråd.\nNøgletallene er baseret på data fra en lang række myndigheder og\norganisationer såsom Statistikcentralen, Skolstyrelsen, Valstyrelsen,\nErhvervsstyrelsen, Skolstyrelsen, Socialstyrelsen og BRÅ.\n\n"@da;
    <http://purl.org/dc/terms/spatial> <http://www.geonames.org/2692965/malmoe.html>, _:b0__9192.
_:b0__9192 <http://www.w3.org/ns/dcat#bbox> "POLYGON((12.8850967451 55.6421476735,13.1517619812 55.6421476735,13.1517619812 55.5022773196,12.8850967451 55.5022773196,12.8850967451 55.6421476735))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.
<https://opendata-api.malmo.se/dataset/31bef806-a038-4148-8408-114c043ab0f4> <http://www.w3.org/ns/dcat#contactPoint> <https://admin.dataportal.se/store/290/resource/0e01ba1a25b24ce4d82683ada08cb166>;
    <http://www.w3.org/ns/dcat#distribution> <https://opendata-api.malmo.se/dataset/31bef806-a038-4148-8408-114c043ab0f4/resource/b97f5fb7-34db-4d5d-8769-42b6eb753e9f>, <https://opendata-api.malmo.se/dataset/31bef806-a038-4148-8408-114c043ab0f4/resource/6d6b412d-1996-45e8-8a4c-6fdeb9e4634c>, <https://opendata-api.malmo.se/dataset/31bef806-a038-4148-8408-114c043ab0f4/resource/cb623299-ecdb-41be-b2db-66d1974828c5>, <https://opendata-api.malmo.se/dataset/31bef806-a038-4148-8408-114c043ab0f4/resource/9ef816cd-876a-4bcb-b5af-4ea37e7dbc7c>, <https://opendata-api.malmo.se/dataset/31bef806-a038-4148-8408-114c043ab0f4/resource/ccb56bb4-cc5b-4a0e-8dbc-31c058152389>, <https://opendata-api.malmo.se/dataset/31bef806-a038-4148-8408-114c043ab0f4/resource/7f9fa1f4-8084-4e05-b012-48d541e70f02>, <https://opendata-api.malmo.se/dataset/31bef806-a038-4148-8408-114c043ab0f4/resource/53828d82-3da9-4cb9-8ae7-91ab7dc8abcb>, <https://opendata-api.malmo.se/dataset/31bef806-a038-4148-8408-114c043ab0f4/resource/6730378b-f155-4346-ab5e-5e41bb9cc3bc>, <https://opendata-api.malmo.se/dataset/31bef806-a038-4148-8408-114c043ab0f4/resource/09de2d85-80ca-495c-ac6a-a9d646e87e58>;
    <http://purl.org/dc/terms/issued> "2020-11-24"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2026-03-25T16:43:59.768380"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Valresultat"@sv, "Election results"@en, "Valgresultater"@da;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/SOCI>;
    a <http://www.w3.org/ns/dcat#Dataset>
}


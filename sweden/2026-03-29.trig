    <http://purl.org/dc/terms/issued> "2024-08-22"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2026-03-25T16:37:04.389463"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Sysselsättningsgrad, 2022 - - Statistikunderlag för Malmös områden"@sv, "Employment rate, 2022 - - Statistical data for Malmö's areas"@en, "Beskæftigelsesfrekvens, 2022 - - Statistiske data for Malmøs områder"@da;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/SOCI>;
    a <http://www.w3.org/ns/dcat#Dataset>
}


<#4aac77380ce6d79fa48ae36458757e92> {
<https://opendata-api.malmo.se/dataset/570a13c0-6e53-4fac-9dfa-1a8e960ff3b5> <http://www.w3.org/ns/dcat#keyword> "Malmö stad", "ekonomi", "arbetsmarknad", "arbete";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "570a13c0-6e53-4fac-9dfa-1a8e960ff3b5";

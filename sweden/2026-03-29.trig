    <http://purl.org/dc/terms/issued> "2025-06-27"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2026-03-25T16:01:37.759263"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

    <http://www.w3.org/ns/dcat#distribution> <https://opendata-api.malmo.se/dataset/6ca294e4-48fe-4c7d-88f5-e66369ee3986/resource/094852a3-da4b-44c8-b2a1-379d92c748f9>, <https://opendata-api.malmo.se/dataset/6ca294e4-48fe-4c7d-88f5-e66369ee3986/resource/8f5225f3-602f-44b3-a9e2-2f14dccd6a7f>;
    <http://purl.org/dc/terms/issued> "2024-08-22"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2026-03-25T16:36:08.764087"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Summa förvärvs- och kapitalinkomst 2007-2019 - Statistikunderlag för Malmös områden"@sv, "Total earned and capital income 2007-2019 - Statistical data for Malmö's areas"@en, "Samlet arbejds- og kapitalindkomst 2007-2019 - Statistiske data for Malmøs områder"@da;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/SOCI>;
    a <http://www.w3.org/ns/dcat#Dataset>
}

<feed> <https://w3id.org/tree#member> <#e1e4e63f8ba9641318508c56f64b881d>.
<#e1e4e63f8ba9641318508c56f64b881d> a <https://www.w3.org/ns/activitystreams#Create>;

    <http://www.w3.org/ns/dcat#distribution> <https://opendata-api.malmo.se/dataset/b80a51b8-a154-43b3-8ef3-4ddcf1690e62/resource/cc8738e3-85ef-493b-90d4-9e0bc5f91e75>;
    <http://purl.org/dc/terms/issued> "2020-12-15"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2026-03-25T16:00:31.918720"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Nettokostnadsavvikelse individ- och familjeomsorg, procent"@sv, "Net cost variance for individual and family care, percent"@en, "Nettoomkostningsvarians for individuel og familiepleje, procent"@da;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ECON>;

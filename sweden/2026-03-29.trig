<#3aad19fa2d1d2c54c219ecc00e906580> {
<https://opendata-catalog.smhi.se/md/7ef0a848-a7c0-4078-9604-da90978cfb87> <http://www.w3.org/ns/dcat#keyword> "Öppna data"@sv, "Inspire"@sv, "Observation"@sv, "Oceanografi"@sv, "Havstemperatur"@sv, "Geografiska oceanografiska förhållanden"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/MONTHLY>;
    <http://purl.org/dc/terms/identifier> "_7ef0a848-a7c0-4078-9604-da90978cfb87", "7ef0a848-a7c0-4078-9604-da90978cfb87";
    <http://www.w3.org/ns/dcat#byteSize> "31123"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>;
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021000696>;
    <http://purl.org/dc/terms/description> "Syfte: Observera havets temperatur, förbättra havscirkulationsmodeller och stöd inom istjänsten.\n\nEnhet: °C.\n\nEgenskaper: Vattnets temperatur, insamlat från fartyg (ferrybox-system), havspeglar vid kusten eller bojar. Mätning en gång per timme.\n\nKvalitetskoder: Grön (G) = Kontrollerade och godkända värden. Gul (Y) = Grovt kontrollerade värden, misstänkta eller aggregerade värden. Orange (O) = Okontrollerade värden\n\nGränser: Ungefär mellan -3 och +30 grader C.\n\nFör mer info se: https://www.smhi.se/kunskapsbanken/oceanografi/haven-runt-sverige/temperatur-i-havet"@sv;
    <http://purl.org/dc/terms/spatial> <https://www.geonames.org/2661886>, _:b0__4357.
_:b0__4357 <http://www.w3.org/ns/dcat#centroid> "POINT(18.65 62.06)"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    <http://www.w3.org/ns/dcat#bbox> "POLYGON((11 69,26 69,26 55,11 55,11 69))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    <http://www.w3.org/ns/dcat#endDate> "2026-03-28"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://www.w3.org/ns/dcat#startDate> "1970-01-01"^^<http://www.w3.org/2001/XMLSchema#date>;

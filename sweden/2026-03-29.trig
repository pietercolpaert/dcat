<#ea78990d3efcc60d23c9eb7356d8bf3f> {
<https://opendata-api.malmo.se/dataset/297f7613-012d-4ff5-afe8-0febb651829c> <http://www.w3.org/ns/dcat#keyword> "Malmö stad", "ekonomi", "bidrag";

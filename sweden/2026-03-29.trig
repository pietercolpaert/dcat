    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>;
    <http://purl.org/dc/terms/temporal> _:b0__2445.
_:b0__2445 <http://www.w3.org/ns/dcat#startDate> "2024-02-29"^^<http://www.w3.org/2001/XMLSchema#date>;
    a <http://purl.org/dc/terms/PeriodOfTime>.

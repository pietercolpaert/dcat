<#3e4b09b04d874fb45958135469842ffb> {
<https://doi.org/10.5878/002438> <http://www.w3.org/ns/dcat#keyword> "LOCAL GOVERNMENT SERVICES"@en, "KOMMUNAL SERVICE"@sv, "CHILD CARE"@en, "BARNOMSORG"@sv, "DOMESTIC RESPONSIBILITIES"@en, "HUSHÅLLSANSVAR"@sv, "HOUSEHOLDS"@en, "HUSHÅLL"@sv, "CHILDREN"@en, "BARN"@sv, "SOCIAL WELFARE FINANCE"@en, "FINANSIERING AV SOCIAL VÄLFÄRD"@sv, "WELFARE POLICY"@en, "SOCIAL- OCH VÄLFÄRDSPOLITIK"@sv, "PARENTAL ROLE"@en, "FÖRÄLDRAROLL"@sv, "PARENTAL LEAVE"@en, "F��RÄLDRALEDIGHET"@sv;

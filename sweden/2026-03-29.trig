<https://opendata-api.malmo.se/dataset/e89514ce-529d-4240-b000-7b508aacd1b4/resource/373ce918-aa71-4519-92e1-9648f6c52990> <http://purl.org/dc/terms/license> <http://creativecommons.org/publicdomain/zero/1.0>;
    <http://purl.org/dc/terms/issued> "2024-08-21T12:02:19.240607"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

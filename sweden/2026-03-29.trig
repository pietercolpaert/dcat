<#0846ba8ff364c4922e2604efa7a2635e> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://opendata-api.malmo.se/dataset/140830ba-9850-4f01-a1a3-a7e79821a2b7/resource/caf1cee8-9af2-4a75-8fb7-f1d7cb11daeb>;
    <https://www.w3.org/ns/activitystreams#published> "2026-03-29T06:25:17.666Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#0846ba8ff364c4922e2604efa7a2635e> {
<https://opendata-api.malmo.se/dataset/140830ba-9850-4f01-a1a3-a7e79821a2b7/resource/caf1cee8-9af2-4a75-8fb7-f1d7cb11daeb> <http://purl.org/dc/terms/license> <http://creativecommons.org/publicdomain/zero/1.0>;
    <http://data.europa.eu/r5r/availability> <http://data.europa.eu/r5r/availability/available>;
    <http://www.w3.org/ns/dcat#byteSize> "18360199"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>;
    <http://www.w3.org/ns/adms#status> <http://publications.europa.eu/resource/authority/distribution-status/COMPLETED>;
    <http://www.w3.org/ns/dcat#accessURL> <https://opendata-api.malmo.se/dataset/140830ba-9850-4f01-a1a3-a7e79821a2b7/resource/caf1cee8-9af2-4a75-8fb7-f1d7cb11daeb/download/adresser.json>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/description> "Malmö stads adresser som punktobjekt. Punkterna är placerade vid ingången till reseptive adressatta byggnad. Datamängnden innehåller fullständig information om adressen samt vilken fastighet den är placerad på. Adresserna uppdateras av Geodataenheten på Stadsbyggnadskontoret."@sv, "Malmö city addresses as point objects. The points are placed at the entrance\nto the receptive addressed building. The dataset contains complete information\nabout the address and which property it is located on. The addresses are\nupdated by the Geodata Unit at the City Planning Office.\n\n"@en, "Malmøs adresser som punktobjekter. Punkterne er placeret ved indgangen til den\nmodtagende bygning. Datasættet indeholder fuldstændige oplysninger om adressen\nog hvilken ejendom den er placeret på. Adresserne opdateres af Geodataenheden\npå Byplankontoret.\n\n"@da;
    <http://spdx.org/rdf/terms#checksum> _:b0__27425.
_:b0__27425 <http://spdx.org/rdf/terms#checksumValue> "6186bfdb614b6d1df22fa8250ed5e5122b14ec14";
    <http://spdx.org/rdf/terms#algorithm> <http://spdx.org/rdf/terms#checksumAlgorithm_sha1>;
    a <http://spdx.org/rdf/terms#Checksum>.
<https://opendata-api.malmo.se/dataset/140830ba-9850-4f01-a1a3-a7e79821a2b7/resource/caf1cee8-9af2-4a75-8fb7-f1d7cb11daeb> <http://purl.org/dc/terms/format> "application/json";
    <http://purl.org/dc/terms/issued> "2023-02-24T13:31:26.382979"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/modified> "2026-03-18T20:22:46.828897"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Adresser"@sv, "Addresses"@en, "Adresser"@da;

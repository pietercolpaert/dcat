<https://opendata-api.malmo.se/dataset/140830ba-9850-4f01-a1a3-a7e79821a2b7> <http://www.w3.org/ns/dcat#keyword> "Malmö stad", "gis", "karta", "geodata", "adresser", "postnummer", "map";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/UPDATE_CONT>;
    <http://purl.org/dc/terms/identifier> "140830ba-9850-4f01-a1a3-a7e79821a2b7";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;

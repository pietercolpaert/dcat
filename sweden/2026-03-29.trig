<feed> <https://w3id.org/tree#member> <#f443d269e7da91b2306c6273da28e40e>.
<#f443d269e7da91b2306c6273da28e40e> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://opendata-api.malmo.se/dataset/7f000810-a9bd-4d33-9bc5-cced388e4854>;
    <https://www.w3.org/ns/activitystreams#published> "2026-03-29T06:25:14.120Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#f443d269e7da91b2306c6273da28e40e> {
<https://opendata-api.malmo.se/dataset/7f000810-a9bd-4d33-9bc5-cced388e4854> <http://www.w3.org/ns/dcat#keyword> "Malmö stad", "kolada", "arbetsmarknad", "workforce", "labour market";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "7f000810-a9bd-4d33-9bc5-cced388e4854";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://malmo.se/>;
    <http://purl.org/dc/terms/description> "Antal förvärvsarbetande i åldern 20-64 år dividerat med antal invånare i åldern 20-64 år den 31/12.\n\nStatistik i procent från 1997. \n\nMed förvärvsarbetande avses folkbokförda personer i kommunen med löneinkomst av anställning under november månad och personer med inkomst av aktiv näringsverksamhet. \n\nSedan 2019 använder sig SCB av de månatliga arbetsgivardeklarationerna på individ¬nivå (AGI) som datakälla istället för de årliga kontrolluppgifterna (KU), det gör att jämförelser mot tidigare år bör göras med försiktighet. \n\nKälla: SCB:s registerbaserade arbetsmarknadsstatistik (RAMS)."@sv, "Number of gainfully employed persons aged 20-64 divided by number of residents\naged 20-64 on 31/12.\n\nStatistics in percentages from 1997.\n\nGainfully employed refers to registered persons in the municipality with wage\nincome from employment during the month of November and persons with income\nfrom active business activities.\n\nSince 2019, Statistics Sweden has been using the monthly employer declarations\nat the individual level (AGI) as a data source instead of the annual control\ndata (KU), which means that comparisons with previous years should be made\nwith caution.\n\nSource: Statistics Sweden's register-based labour market statistics (RAMS).\n\n"@en, "Antal beskæftigede i alderen 20-64 år divideret med antal beboere i alderen\n20-64 år pr. 31/12.\n\nStatistik i procenter fra 1997.\n\nBeskæftigede personer omfatter registrerede personer i kommunen med\nlønindkomst fra beskæftigelse i november måned og personer med indkomst fra\naktiv erhvervsvirksomhed.\n\nSiden 2019 har Statistiska Centralbyrån brugt de månedlige\narbejdsgivererklæringer på individniveau (AGI) som datakilde i stedet for de\nårlige kontroldata (KU), hvilket betyder, at sammenligninger med tidligere år\nbør foretages med forsigtighed.\n\nKilde: Statistiska centralbankens registerbaserede arbejdsmarkedsstatistik\n(RAMS).\n\n"@da;
    <http://purl.org/dc/terms/spatial> <http://www.geonames.org/2692965/malmoe.html>, _:b0__3874.
_:b0__3874 <http://www.w3.org/ns/dcat#bbox> "POLYGON((12.8850967451 55.6421476735,13.1517619812 55.6421476735,13.1517619812 55.5022773196,12.8850967451 55.5022773196,12.8850967451 55.6421476735))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.
<https://opendata-api.malmo.se/dataset/7f000810-a9bd-4d33-9bc5-cced388e4854> <http://www.w3.org/ns/dcat#contactPoint> <https://admin.dataportal.se/store/290/resource/0e01ba1a25b24ce4d82683ada08cb166>;
    <http://www.w3.org/ns/dcat#distribution> <https://opendata-api.malmo.se/dataset/7f000810-a9bd-4d33-9bc5-cced388e4854/resource/05d450bf-0fc3-40ef-bf41-658544db1212>;
    <http://purl.org/dc/terms/issued> "2020-12-17"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2026-03-18T21:23:35.822813"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Förvärvsarbetande invånare 20-64 år, andel"@sv, "Employed residents aged 20-64, share"@en, "Beskæftigede beboere i alderen 20-64 år, andel"@da;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/SOCI>;
    a <http://www.w3.org/ns/dcat#Dataset>
}


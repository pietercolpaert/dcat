<https://opendata-api.malmo.se/dataset/c6051c71-4d12-4c93-9966-1ad599430d03> <http://www.w3.org/ns/dcat#keyword> "Malmö stad", "trafik", "gis", "karta", "geodata", "map";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/IRREG>;

    <http://purl.org/dc/terms/modified> "2020-05-14T08:41:05Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Medievalundersökningen 1979 - Nyhetsanalysen"@sv, "Media election survey 1979 - News analysis"@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/SOCI>;
    <http://purl.org/dc/terms/temporal> _:b0__5449.
_:b0__5449 <http://www.w3.org/ns/dcat#endDate> "1979-09-16"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

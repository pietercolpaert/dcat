    <http://purl.org/dc/terms/title> "Kostnad förskola, kr/inskrivet barn"@sv, "Preschool cost, SEK/enrolled child"@en, "Førskolepris, SEK/indskrevet barn"@da;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/description> "Bruttokostnad minus interna intäkter och försäljning till andra kommuner och regioner för förskola, dividerat med genomsnittligt antal inskrivna barn i förskola vid mätning 15/10 föregående och innevarande år. Avser samtlig regi.  \n  \nKälla: Kolada"@sv, "Gross cost minus internal revenue and sales to other municipalities and\nregions for preschool, divided by the average number of children enrolled in\npreschool at the measurement on 15/10 of the previous and current year. Refers\nto all management.\n\nSource: Kolada\n\n"@en, "Bruttoomkostninger minus interne indtægter og salg til andre kommuner og\nregioner for førskole, divideret med det gennemsnitlige antal børn indskrevet\ni førskole ved målingen den 15/10 i det foregående og indeværende år.\nRefererer til al ledelse.\n\nKilde: Kolada\n\n"@da;
    a <http://www.w3.org/ns/dcat#Distribution>
}

<feed> <https://w3id.org/tree#member> <#ba623851e38553d15ffd96d7fea02021>.
<#ba623851e38553d15ffd96d7fea02021> a <https://www.w3.org/ns/activitystreams#Create>;
    <https://www.w3.org/ns/activitystreams#object> <https://opendata-api.malmo.se/dataset/2d6a0ac9-a6f0-4bdf-9753-0362486bc698/resource/c4a0165f-135d-41ca-916a-8919aa8a2091>;

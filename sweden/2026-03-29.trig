<#a6623d0605f1ef11ec1cc4905948d35d> {
<https://opendata-api.malmo.se/dataset/f4db76db-8670-40be-bdf6-78630062c20d> <http://www.w3.org/ns/dcat#keyword> "Malmö stad", "kolada", "statistik";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "f4db76db-8670-40be-bdf6-78630062c20d";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://malmo.se/>;
    <http://purl.org/dc/terms/description> "Antal förtroendevalda (kommunpolitiker) kvinnor dividerat med antal förtroendevalda kommunpolitiker totalt, multiplicerat med 100.  Med förtroendevalda avses ledamöter och ersättare i fullmäktige, nämnder och fullmäktigeberedningar samt revisorer. Statistiken tas bara fram vart fjärde år men i Kolada publiceras den förutom mätåret T även på år T+1, T+2 och T+3.  \n  \nKälla: SCB (via Kolada)"@sv, "Number of elected representatives (municipal politicians) women divided by the\ntotal number of elected municipal politicians, multiplied by 100. Elected\nrepresentatives refer to members and substitutes in the council, committees\nand council committees, and auditors. The statistics are only produced every\nfour years, but in Kolada, in addition to the measurement year T, they are\nalso published in years T+1, T+2 and T+3.\n\nSource: Statistics Sweden (via Kolada)\n\n"@en, "Antal valgte repræsentanter (kommunalpolitikere) kvinder divideret med det\nsamlede antal valgte kommunalpolitikere ganget med 100. Valgte repræsentanter\nrefererer til medlemmer og stedfortrædere i byrådet, udvalg og byrådets udvalg\nsamt revisorer. Statistikkerne produceres kun hvert fjerde år, men i Kolada\noffentliggøres de ud over måleåret T også i årene T+1, T+2 og T+3.\n\nKilde: Sveriges Statistik (via Kolada)\n\n"@da;
    <http://purl.org/dc/terms/spatial> <http://www.geonames.org/2692965/malmoe.html>, _:b0__5878.
_:b0__5878 <http://www.w3.org/ns/dcat#bbox> "POLYGON((12.8850967451 55.6421476735,13.1517619812 55.6421476735,13.1517619812 55.5022773196,12.8850967451 55.5022773196,12.8850967451 55.6421476735))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.
<https://opendata-api.malmo.se/dataset/f4db76db-8670-40be-bdf6-78630062c20d> <http://www.w3.org/ns/dcat#contactPoint> <https://admin.dataportal.se/store/290/resource/0e01ba1a25b24ce4d82683ada08cb166>;
    <http://www.w3.org/ns/dcat#distribution> <https://opendata-api.malmo.se/dataset/f4db76db-8670-40be-bdf6-78630062c20d/resource/ee835204-61b2-4f4b-830f-924f5882d34a>;
    <http://purl.org/dc/terms/issued> "2022-12-05"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2026-03-18T20:33:13.571850"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Kvinnor bland förtroendevalda kommunpolitiker, andel (%)"@sv, "Women among elected municipal politicians, percentage (%)"@en, "Kvinder blandt valgte kommunalpolitikere, procentdel (%)"@da;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>;
    a <http://www.w3.org/ns/dcat#Dataset>
}


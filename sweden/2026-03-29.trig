    <http://purl.org/dc/terms/issued> "2025-01-15"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2026-03-25T16:20:04.343775"^^<http://www.w3.org/2001/XMLSchema#dateTime>;

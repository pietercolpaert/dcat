<feed> <https://w3id.org/tree#member> <#db74ff15a3dd28b63b5052b1ed9b29da>.
<#db74ff15a3dd28b63b5052b1ed9b29da> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <http://api.kolada.se/v3/kpi/N40019>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-08T06:32:54.625Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.

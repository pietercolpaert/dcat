    <http://www.w3.org/ns/dcat#distribution> <https://catalog.gavle.se/store/1/resource/180>, <https://catalog.gavle.se/store/1/resource/174>;
    <http://purl.org/dc/terms/title> "Bicycle parking places"@en, "Cykelparkeringsplatser"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/TRAN>;

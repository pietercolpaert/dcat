    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Antal idrottshallar i kommunen dividerat med invånare 7-20. Åldersintervallet har valts för att stämma överens med gränserna statistiken för deltagartillfällen med LOK-stöd. Avser samtliga storlekar (18x36 m till 22x42 m,  Över 22 x 42 m men under 60 x 100 m samt  60 x 100 m eller större). Anläggningsenkäten genomförs vart 4-5 år, senast den genomfördes var 2024. Nyckeltalet uppdateras med senaste enkäts värde varje år tills ny enkät genomförts. "@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/U09898_json>;
    <http://purl.org/dc/terms/provenance> _:b0__76315.
_:b0__76315 <http://purl.org/dc/terms/description> "Källa: SKR:s anläggningsenkät"@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/U09898> <http://purl.org/dc/terms/modified> "2026-02-24"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Idrottshallar, antal/1000 inv 7-20 ��r"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/EDUC>, _:b0__18327;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


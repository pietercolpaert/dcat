<#5dd31079b31507392fcd1f77449c4b9c> {
<http://api.kolada.se/v3/kpi/N00999> <http://www.w3.org/ns/dcat#keyword> "Kommun"@sv, "Region"@sv, "Rådet f��r främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;

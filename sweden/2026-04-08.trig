    <http://www.w3.org/ns/dcat#distribution> <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-040701-vasterslatt-hyreshus-API>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-040701-vasterslatt-hyreshus-csv>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-040701-vasterslatt-hyreshus-json>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-040701-vasterslatt-hyreshus-jsonl>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-040701-vasterslatt-hyreshus-parquet>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-040701-vasterslatt-hyreshus-rdfxml>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-040701-vasterslatt-hyreshus-jsonld>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-040701-vasterslatt-hyreshus-turtle>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-040701-vasterslatt-hyreshus-n3>, <https://opendata.umea.se/api/explore/v2.1/catalog/datasets/energiforbrukning-i-geografiska-omradet-040701-vasterslatt-hyreshus-xlsx>;

    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/MONTHLY>;
    <http://purl.org/dc/terms/identifier> "_b79cb060-8a1f-11ea-a966-bfa48b38ccc2", "b79cb060-8a1f-11ea-a966-bfa48b38ccc2";

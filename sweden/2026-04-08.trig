    <http://purl.org/dc/terms/title> "Molluscs of the Gothenburg Natural History Museum (GNM)"@en;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__9551.
_:b0__9551 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/cd8c0759dc3fda11ca205a0efd54bc21>;

<feed> <https://w3id.org/tree#member> <#b3edb93a3319b533b5abe19934167e5f>.
<#b3edb93a3319b533b5abe19934167e5f> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <https://doi.org/10.5281/zenodo.19236867>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-03T06:27:00.351Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#b3edb93a3319b533b5abe19934167e5f> {
<https://doi.org/10.5281/zenodo.19236867> <http://www.w3.org/ns/dcat#distribution> <https://doi.org/10.5281/zenodo.19236867#distribution>;
    <http://purl.org/dc/terms/issued> "2026-03-26T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://www.w3.org/ns/dcat#landingPage> <https://doi.org/10.5281/zenodo.19236867>;
    <http://purl.org/dc/terms/modified> "2026-03-26T00:00:00Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Raw data from SeaExplorer SEA070 in the Amundsen Sea, 2022, as part of the TARSAN and ARTEMIS deployments on cruise NBP2202."@en;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/ENVI>;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__5415.
_:b0__5415 <http://www.w3.org/ns/dcat#hadRole> <http://inspire.ec.europa.eu/metadata-codelist/ResponsiblePartyRole/principalInvestigator>;
    <http://www.w3.org/ns/prov#agent> <https://admin.dataportal.se/store/818/resource/781b6ee4f63a0b1daf2d1ddb2cb56701>;
    a <http://www.w3.org/ns/prov#Attribution>.
<https://doi.org/10.5281/zenodo.19236867> <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2021003153>;
    <http://purl.org/dc/terms/description> "This dataset contains raw Level-0 glider observations from SeaExplorer SEA070 (“Scratch”) collected in the Amundsen Sea during the NBP2202 expedition in early 2022. It forms part of the TARSAN and ARTEMIS efforts associated with the International Thwaites Glacier Collaboration. TARSAN focused on how atmosphere–ice���ocean interactions influence the Thwaites and Dotson ice shelves, using gliders, ship surveys, AUVs, moorings, and CTDs to characterize ocean conditions on the continental shelf and beneath ice shelves. ARTEMIS complemented that work by adding biogeochemical observations, especially from autonomous platforms, to investigate how West Antarctic Ice Sheet melt affects ecosystem structure and regional carbon cycling. \n\nSEA070 data is provided in raw csv format as a timeseries-style, spanning about mid-January to mid-February 2022 in the eastern Amundsen Sea near 72.2–72.4°S, 117.9–117.3°W. The dataset includes core hydrography from an RBR Legato CTD (temperature, conductivity, salinity, pressure), dissolved oxygen from an RBR Coda sensor, nitrate from a Sea-Bird Deep SUNA, and optical measurements from a WET Labs ECO Puck FLBBCD (chlorophyll, CDOM, backscatter). All data is uncalibrated.\n\nNote that there was a severe CTD electrical noise issue affecting conductivity, absolute values are OK but the data is incredibly noisy.\n\nProcessed data set is accessed here: https://doi.org/10.5281/zenodo.19219996"@en;
    a <http://www.w3.org/ns/dcat#Dataset>
}

<feed> <https://w3id.org/tree#member> <#afcaf491d6211278193b7174454c34c8>.
<#afcaf491d6211278193b7174454c34c8> a <https://www.w3.org/ns/activitystreams#Update>;
    <https://www.w3.org/ns/activitystreams#object> <https://opendata-api.malmo.se/dataset/39025cb4-2496-41a7-9004-0e97a31b7739>;
    <https://www.w3.org/ns/activitystreams#published> "2026-04-03T06:27:00.378Z"^^<http://www.w3.org/2001/XMLSchema#dateTime>.
<#afcaf491d6211278193b7174454c34c8> {
<https://opendata-api.malmo.se/dataset/39025cb4-2496-41a7-9004-0e97a31b7739> <http://www.w3.org/ns/dcat#keyword> "Malmö stad", "boende", "hus";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "39025cb4-2496-41a7-9004-0e97a31b7739";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <https://malmo.se/>;
    <http://purl.org/dc/terms/description> "Visar antalet lägenheter uppdelat efter flerbostadshus, småhus, specialbostäder och övriga hus. ”Lägenhet” används här som beteckning både på bostäder i flerbostadshus och småhus, en villa betraktas till exempel som en lägenhet i denna statistik. Flerbostadshus definieras som bostadsbyggnader innehållande tre eller flera lägenheter inklusive loftgångshus. Småhus definieras som friliggande en- och tvåbostadshus samt par-, rad- och kedjehus (exklusive fritidshus). Specialbostäder innefattar bland annat studentbostäder och bostäder för äldre/funktionshindrade. Övriga hus definieras som byggnader som inte är avsedda för bostadsändamål, till exempel byggnader avsedda för verksamhet eller samhällsfunktion. Antalet lägenheter kan vara större än antalet bostadshushåll om ingen är folkbokförd på lägenheten på grund av administrativ eftersläpning, avsaknad av uppehållstillstånd bland de som bor i lägenheten, att man inte folkbokfört sig i tid, om ingen helt enkelt bodde i lägenheten den 31/12 året statistiken gäller eller på grund av andra liknande skäl. Alla lägenheter som finns med i lägenhetsregistret är med i statistiken men endast områden med fler än 30 lägenheter totalt redovisas. Data från lägenhetsregistret.\n\n__Variabelbeskrivning__  \nHittar du [här](https://malmo.se/404)!  \n                     \n__API__  \nMed hjälp av API-anropet *https://opendata-api.malmo.se/api/3/action/resource_search?query=description:malm%C3%B6%20statistik* får man i JSON-format fram samtliga datamängder som innehåller statistikunderlag för Malmös områden.  \nI varje instans av result/results i JSON-resultatet finns för varje resurs en egenskap \"id\". Värdet för \"id\" kan användas för att hämta datan för respektive statistikvariabel (enligt värdet för egenskapen \"name\").\nAPI-anrop för att hämta statistikdatan: *https://opendata-api.malmo.se/api/action/datastore_search?resource_id=[id-värdet]*   \n\nAnvänd gärna siffrorna, men ange “Stadskontoret, Malmö stad” som källa."@sv, "Shows the number of apartments divided by apartment buildings, single-family\nhouses, special housing and other houses. \"Apartment\" is used here to refer to\nboth apartments in apartment buildings and single-family houses, for example a\nvilla is considered an apartment in these statistics. Apartment buildings are\ndefined as residential buildings containing three or more apartments including\nloft-type houses. Single-family houses are defined as detached one- and two-\nfamily houses as well as semi-detached, terraced and chain houses (excluding\nholiday homes). Special housing includes, among other things, student housing\nand housing for the elderly/disabled. Other houses are defined as buildings\nthat are not intended for residential purposes, for example buildings intended\nfor business or community functions. The number of apartments may be greater\nthan the number of residential households if no one is registered in the\napartment due to administrative backlog, lack of residence permits among those\nliving in the apartment, failure to register in time, if no one simply lived\nin the apartment on 31/12 of the year the statistics apply, or for other\nsimilar reasons. All apartments included in the apartment register are\nincluded in the statistics, but only areas with more than 30 apartments in\ntotal are reported. Data from the apartment register.\n\n**Variable description**  \nYou find it [here](https://malmo.se/404) !\n\n**APIs**  \nUsing the API call\n_https://opendata%2dapi.malmo.se/api/3/action/resource_search?query=description:malm%C3%B6%20statistics,_\nyou can retrieve all data sets that contain statistical data for Malmö's areas\nin JSON format.  \nIn each instance of result/results in the JSON result, there is an \"id\"\nproperty for each resource. The value of \"id\" can be used to retrieve the data\nfor the respective statistics variable (according to the value of the \"name\"\nproperty). API call to retrieve the statistics data:\n_https://opendata%2dapi.malmo.se/api/action/datastore_search?resource_id=[id\nvalue]_\n\nFeel free to use the numbers, but cite “City Office, Malmö City” as the\nsource.\n\n"@en, "Viser antallet af lejligheder opdelt på lejlighedsbygninger, enfamiliehuse,\nsærlige boliger og andre huse. \"Lejlighed\" bruges her til at henvise til både\nlejligheder i lejlighedsbygninger og enfamiliehuse, for eksempel betragtes en\nvilla som en lejlighed i denne statistik. Lejlighedsbygninger er defineret som\nbeboelsesejendomme med tre eller flere lejligheder, inklusive loftshuse.\nEnfamiliehuse er defineret som fritliggende en- og tofamiliehuse samt\ndobbelthuse, rækkehuse og kædehuse (eksklusive fritidshuse). Særlige boliger\nomfatter blandt andet studieboliger og boliger for ældre/handicappede. Andre\nhuse er defineret som bygninger, der ikke er beregnet til boligformål, for\neksempel bygninger beregnet til erhverv eller fællesfunktioner. Antallet af\nlejligheder kan være større end antallet af beboelseshusstande, hvis ingen er\nregistreret i lejligheden på grund af administrative efterslæb, manglende\nopholdstilladelser blandt de beboere i lejligheden, manglende rettidig\nregistrering, hvis ingen blot boede i lejligheden den 31/12 i det år,\nstatistikken gælder, eller af andre lignende årsager. Alle lejligheder, der er\ninkluderet i lejlighedsregisteret, er inkluderet i statistikken, men kun\nområder med mere end 30 lejligheder i alt er rapporteret. Data fra\nlejlighedsregisteret.\n\n**Variabelbeskrivelse**  \nDu finder det [her](https://malmo.se/404) !\n\n**API'er**  \nVed at bruge API-kaldet\n_https://opendata%2dapi.malmo.se/api/3/action/resource_search?query=description:malm%C3%B6%20statistics_\nkan du hente alle datasæt, der indeholder statistiske data for Malmøs områder,\ni JSON-format.  \nI hver forekomst af result/results i JSON-resultatet er der en \"id\"-egenskab\nfor hver ressource. Værdien af ​​\"id\" kan bruges til at hente dataene for den\nrespektive statistikvariabel (i henhold til værdien af ​​egenskaben \"name\").\nAPI-kald for at hente statistikdataene:\n_https://opendata%2dapi.malmo.se/api/action/datastore_search?resource_id=[id-\nværdi]_\n\nBrug gerne tallene, men angiv \"Bykontoret, Malmö Kommune\" som kilde.\n\n"@da;
    <http://purl.org/dc/terms/spatial> <http://www.geonames.org/2692965/malmoe.html>, _:b0__1512.
_:b0__1512 <http://www.w3.org/ns/dcat#bbox> "POLYGON((12.8850967451 55.6421476735,13.1517619812 55.6421476735,13.1517619812 55.5022773196,12.8850967451 55.5022773196,12.8850967451 55.6421476735))"^^<http://www.opengis.net/ont/geosparql#wktLiteral>;
    a <http://purl.org/dc/terms/Location>.
<https://opendata-api.malmo.se/dataset/39025cb4-2496-41a7-9004-0e97a31b7739> <http://www.w3.org/ns/dcat#contactPoint> <https://admin.dataportal.se/store/290/resource/ce429264a6a97cd4bc8687f7a5b0847d>;
    <http://www.w3.org/ns/dcat#distribution> <https://opendata-api.malmo.se/dataset/39025cb4-2496-41a7-9004-0e97a31b7739/resource/ad70f488-e3c9-4c71-a54e-5cd3a94719d0>, <https://opendata-api.malmo.se/dataset/39025cb4-2496-41a7-9004-0e97a31b7739/resource/2e8d56ae-db47-4819-a1d5-3e2ed7dc4138>;
    <http://purl.org/dc/terms/issued> "2021-02-16"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2026-03-25T14:57:01.517720"^^<http://www.w3.org/2001/XMLSchema#dateTime>;
    <http://purl.org/dc/terms/title> "Hustyp - Statistikunderlag för Malmös områden"@sv, "House type - Statistical data for Malmö's areas"@en, "Hustype - Statistiske data for Malmøs områder"@da;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/SOCI>;
    <http://purl.org/dc/terms/temporal> _:b0__1198.
_:b0__1198 <http://www.w3.org/ns/dcat#startDate> "2017-01-01"^^<http://www.w3.org/2001/XMLSchema#date>;
    a <http://purl.org/dc/terms/PeriodOfTime>.
<https://opendata-api.malmo.se/dataset/39025cb4-2496-41a7-9004-0e97a31b7739> a <http://www.w3.org/ns/dcat#Dataset>
}


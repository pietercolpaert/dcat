    <http://purl.org/dc/terms/provenance> _:b0__46235.
_:b0__46235 <http://www.w3.org/2000/01/rdf-schema#value> "Ytor på land med utökat strandskydd har digitaliserats mot ortofoto."@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<https://www.geodata.se/resources/8537df85-6ea0-40a8-9a8c-04e97fa9a9ee> <http://purl.org/dc/terms/issued> "2014-01-01"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/modified> "2022-01-13"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "LstH Strandskydd, utökat"@sv;
    a <http://www.w3.org/ns/dcat#Dataset>
}


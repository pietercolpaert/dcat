    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/N33855_json>;
    <http://purl.org/dc/terms/provenance> _:b0__51382.
_:b0__51382 <http://purl.org/dc/terms/description> "Källa: SKR:s undersökning om brukares uppfattning av kvalitet inom öppna insatser, ungdomar 13-18 år"@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/N33855> <http://purl.org/dc/terms/modified> "2025-12-08"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Brukarbedömning öppna insatser, ungdomar 13-20 år - prata om viktiga saker, andel (%)"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>, <http://publications.europa.eu/resource/authority/data-theme/HEAL>;

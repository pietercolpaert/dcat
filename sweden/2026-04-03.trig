<#771bc5fdab7ef37749bc8c176ff72801> {
<https://admin.dataportal.se/store/818/resource/03f48b2ebc0288f050fe5c1414bf62cf> <http://www.w3.org/ns/dcat#keyword> "Skåne"@sv, "Prostatatumörer"@sv, "Prostatic Neoplasms"@en, "Scania"@en, "EpiHealth"@sv, "EpiHealth"@en, "EpiHealth_Skåne"@sv, "EpiHealth_Skåne"@en, "Fall-kontrollstudier"@sv, "Case-Control Studies"@en, "södra Sverige"@sv, "southern Sweden"@en, "DRINKING BEHAVIOUR"@en, "ALKOHOLVANOR"@sv, "SMOKING"@en, "RÖKNING"@sv, "CANCER"@en, "CANCER"@sv, "HEIGHT (PHYSIOLOGY)"@en, "LÄNGD"@sv, "WEIGHT (PHYSIOLOGY)"@en, "VIKT"@sv, "BLOOD"@en, "BLOD"@sv;
    <http://www.w3.org/ns/prov#qualifiedAttribution> _:b0__11914.

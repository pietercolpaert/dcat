<#7219a18ac278b0a02cb9cc2de1719bc4> {
<https://catalog.harryda.se/store/2/resource/167> <http://www.w3.org/ns/dcat#keyword> "Vandringsled"@sv, "Vandring"@sv, "Natur"@sv, "Promenad"@sv, "Walking"@sv, "Hiking"@sv, "Hike"@sv;
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/BIENNIAL>;

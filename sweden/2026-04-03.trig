<#f284d8036353f49a59d498f4973fb717> {
<https://opendata-catalog.smhi.se/md/cd9b9800-88b0-11eb-b179-d785eca52194> <http://www.w3.org/ns/dcat#keyword> "Öppna data"@sv, "Meteorologi"@sv, "Modelldata"@sv, "Brandrisk"@sv;

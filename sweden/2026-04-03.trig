<#cbce3e9837bb3269aed7c8594fd99761> {
<http://api.kolada.se/v3/kpi/U28139> <http://www.w3.org/ns/dcat#keyword> "Kommun"@sv, "Enhetsnivå"@sv, "Rådet för främjande av kommunala analyser - Kolada";
    <http://purl.org/dc/terms/accrualPeriodicity> <http://publications.europa.eu/resource/authority/frequency/ANNUAL>;
    <http://purl.org/dc/terms/identifier> "U28139";
    <http://purl.org/dc/terms/accessRights> <http://publications.europa.eu/resource/authority/access-right/PUBLIC>;
    <http://purl.org/dc/terms/language> <http://publications.europa.eu/resource/authority/language/SWE>;
    <http://purl.org/dc/terms/publisher> <http://dataportal.se/organisation/SE2220000315>;
    <http://purl.org/dc/terms/description> "Med handledning avses handledning av för uppgiften utbildad handledare som inte arbetar i den egna verksamheten. Med handledning avses här inte arbetsledning av chef. Syftet med handledning är att ha en stödjande funktion för personalen, bidra till den professionella utvecklingen och fungera som kvalitetssäkring i verksamheten. Handledningen kan ske i grupp eller enskilt och utformning/inriktning behöver väljas efter de behov som finns i verksamheten. Kontinuerlig innebär att här inte avses handledning vid enstaka tillfällen. Handledningen ska vara regelbunden under en längre tidsperiod, d.v.s. erbjudas återkommande med jämna mellanrum. På kommunnivå uppges andel enheter som uppfyllt indikatorn, dvs. Ja. På enhetsnivå är Ja=1, Nej=0. "@sv;
    <http://www.w3.org/ns/dcat#contactPoint> <https://rka.entryscape.net/resource/contactpoint/kolada>;
    <http://www.w3.org/ns/dcat#distribution> <http://api.kolada.se/v3/kpi/U28139_json>;
    <http://purl.org/dc/terms/provenance> _:b0__95041.
_:b0__95041 <http://purl.org/dc/terms/description> "Källa: Socialstyrelsens Enhetsundersökning LSS"@sv;
    a <http://purl.org/dc/terms/ProvenanceStatement>.
<http://api.kolada.se/v3/kpi/U28139> <http://purl.org/dc/terms/modified> "2025-10-15"^^<http://www.w3.org/2001/XMLSchema#date>;
    <http://purl.org/dc/terms/title> "Enhetsundersökning LSS - Kontinuerlig handledning har erbjudits till personalen på enheten, daglig verksamhet, andel (%)"@sv;
    <http://www.w3.org/ns/dcat#theme> <http://publications.europa.eu/resource/authority/data-theme/GOVE>;
    <http://entryscape.com/terms/servedByDataService> <http://api.kolada.se/v3/>;
    a <http://www.w3.org/ns/dcat#Dataset>, <http://entryscape.com/terms/ServedByDataService>
}


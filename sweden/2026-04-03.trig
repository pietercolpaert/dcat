    <http://purl.org/dc/terms/identifier> "_d6daf520-7d21-11ed-a51b-432755aaeed3", "d6daf520-7d21-11ed-a51b-432755aaeed3";
    <http://www.w3.org/ns/dcat#byteSize> "24740"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>;

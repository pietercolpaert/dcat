<#04a5a6f152af4d753cf247b989a6d781> {
<https://admin.dataportal.se/store/818/resource/2b489b2468c5df955c7c3bc2212109c5> <http://www.w3.org/ns/dcat#keyword> "Exercise"@en, "Träning"@sv, "Hälsa"@sv, "Health"@en, "Leverans av hälso- och sjukvård"@sv, "Delivery of Health Care"@en, "Psykologisk stress"@sv, "Stress, Psychological"@en, "Socioekonomiska faktorer"@sv, "Socioeconomic Factors"@en, "Medelålders personer"@sv, "Middle Aged"@en, "Cardiovascular Diseases"@en, "Dödlighet"@sv, "Mortality"@en, "Diabetes"@sv, "Diabetes Mellitus"@en, "Fetma"@sv, "Obesity"@en, "Övervikt"@sv, "Overweight"@en, "Kroppsvikt"@sv, "Body Weight"@en, "Hälsokontroll"@sv, "Physical Examination"@en, "Sömn- och vakenhetsstörningar"@sv, "Sleep Wake Disorders"@en, "Sjukdom"@sv, "Disease"@en, "Läkemedelsterapi"@sv, "Drug Therapy"@en, "Riskfaktorer"@sv, "Risk Factors"@en, "Epidemiologi"@sv, "Epidemiology"@en, "Longitudinella studier"@sv, "Longitudinal Studies"@en, "Rökning"@sv, "Smoking"@en, "Sjuklighet"@sv, "Morbidity"@en, "Hjärtsvikt"@sv, "Heart Failure"@en, "Ärftlighet"@sv, "Heredity"@en, "Elektrokardiografi"@sv, "Electrocardiography"@en, "Populationsövervakning"@sv, "Population Surveillance"@en, "Hjärtinfarkt"@sv, "Myocardial Infarction"@en, "Stroke"@en, "Anamnes"@sv, "Medical History Taking"@en, "Högt blodtryck"@sv, "Hypertension"@en, "Kolesterol"@sv, "Cholesterol"@en, "Kroppslängd"@sv, "Body Height"@en, "Kärlkramp"@sv, "Angina Pectoris"@en, "Swedish Cohort Consortium (SCC)"@sv, "Swedish Cohort Consortium (SCC)"@en, "Cohorts.se"@sv, "Cohorts.se"@en, "Kranskärlssjukdom"@sv, "Coronary Disease"@en, "Kroppssammansättning"@sv, "Body Composition"@en, "Blodsocker"@sv, "Blood Glucose"@en, "Insulin"@sv, "Insulin"@en, "Kaffe"@sv, "Coffee"@en, "Triglycerider"@sv, "Triglycerides"@en, "Kardiovaskulära sjukdomar"@sv, "Stroke"@sv;
